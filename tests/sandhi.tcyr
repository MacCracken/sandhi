fn test_url_decode() {
    var a = http_url_decode("hello%20world");
    assert_streq(a, "hello world", "url_decode: %20 → space");

    var b = http_url_decode("a+b+c");
    assert_streq(b, "a b c", "url_decode: + → space");

    var c = http_url_decode("%2Fusr%2Flocal");
    assert_streq(c, "/usr/local", "url_decode: uppercase hex");

    var d = http_url_decode("%2fusr%2flocal");
    assert_streq(d, "/usr/local", "url_decode: lowercase hex");

    var e = http_url_decode("noescape");
    assert_streq(e, "noescape", "url_decode: passthrough");
    return 0;
}

fn test_path_only() {
    var a = http_path_only("/foo?bar=baz");
    assert_streq(a, "/foo", "path_only: strips query");

    var b = http_path_only("/no/query/here");
    assert_streq(b, "/no/query/here", "path_only: no query passthrough");
    return 0;
}

fn test_path_segment() {
    var a = http_path_segment("/a/b/c", 0);
    assert_streq(a, "a", "path_segment[0]");

    var b = http_path_segment("/a/b/c", 1);
    assert_streq(b, "b", "path_segment[1]");

    var c = http_path_segment("/a/b/c", 2);
    assert_streq(c, "c", "path_segment[2]");

    var d = http_path_segment("/a/b/c", 3);
    assert_eq(d, 0, "path_segment out-of-range → 0");

    # Segment indexing ignores the query string.
    var e = http_path_segment("/users/42?ref=1", 1);
    assert_streq(e, "42", "path_segment: query stripped first");
    return 0;
}

fn test_get_param() {
    var a = http_get_param("/a?foo=1&bar=hello%20world", "bar");
    assert_streq(a, "hello world", "get_param: decoded value");

    var b = http_get_param("/a?foo=1&bar=baz", "foo");
    assert_streq(b, "1", "get_param: first key");

    var c = http_get_param("/a?foo=1", "missing");
    assert_eq(c, 0, "get_param: missing → 0");

    var d = http_get_param("/no-query", "anything");
    assert_eq(d, 0, "get_param: no query → 0");
    return 0;
}

fn test_request_parse() {
    var req = "GET /hello?name=sandhi HTTP/1.1\r\nHost: example.com\r\nContent-Length: 5\r\n\r\nhello";
    var rlen = strlen(req);

    var method = http_get_method(req, rlen);
    assert_streq(method, "GET", "get_method");

    var path = http_get_path(req, rlen);
    assert_streq(path, "/hello?name=sandhi", "get_path");

    var host = http_find_header(req, rlen, "Host");
    assert_streq(host, "example.com", "find_header: Host");

    # Case-insensitive lookup.
    var host_lc = http_find_header(req, rlen, "host");
    assert_streq(host_lc, "example.com", "find_header: case-insensitive");

    var clen = http_content_length(req, rlen);
    assert_eq(clen, 5, "content_length");

    var bo = http_body_offset(req, rlen);
    assert_eq(bo, rlen - 5, "body_offset: points at body");

    var missing = http_find_header(req, rlen, "X-Nope");
    assert_eq(missing, 0, "find_header: absent → 0");
    return 0;
}

fn test_sandhi_identity() {
    assert_streq(sandhi_server_version(), "0.2.0", "server version string (module retains its landing version)");
    assert_eq(SANDHI_OK, 0, "error enum: OK is 0");
    assert_streq(sandhi_err_kind_name(SANDHI_ERR_TLS), "TLS", "error kind name");
    return 0;
}

fn test_headers_basic() {
    var h = sandhi_headers_new();
    assert_eq(sandhi_headers_count(h), 0, "headers: new is empty");

    sandhi_headers_set(h, "Host", "example.com");
    sandhi_headers_set(h, "User-Agent", "sandhi/0.3.0");
    assert_eq(sandhi_headers_count(h), 2, "headers: two entries after set/set");

    assert_streq(sandhi_headers_get(h, "Host"), "example.com", "headers: get Host");
    assert_streq(sandhi_headers_get(h, "host"), "example.com", "headers: get is case-insensitive");
    assert_streq(sandhi_headers_get(h, "HOST"), "example.com", "headers: get upper-case too");

    assert_eq(sandhi_headers_has(h, "Content-Type"), 0, "headers: has absent → 0");
    assert_eq(sandhi_headers_has(h, "host"), 1, "headers: has present → 1");
    return 0;
}

fn test_headers_set_replaces() {
    var h = sandhi_headers_new();
    sandhi_headers_set(h, "X-Test", "first");
    sandhi_headers_set(h, "X-Test", "second");
    assert_eq(sandhi_headers_count(h), 1, "headers: set replaces, not appends");
    assert_streq(sandhi_headers_get(h, "X-Test"), "second", "headers: set leaves last value");
    return 0;
}

fn test_headers_add_preserves_order() {
    var h = sandhi_headers_new();
    sandhi_headers_add(h, "Set-Cookie", "a=1");
    sandhi_headers_add(h, "Set-Cookie", "b=2");
    sandhi_headers_add(h, "Set-Cookie", "c=3");
    assert_eq(sandhi_headers_count(h), 3, "headers: add stacks multi-value");
    assert_streq(sandhi_headers_get(h, "Set-Cookie"), "a=1", "headers: get returns first value");
    assert_streq(sandhi_headers_value_at(h, 0), "a=1", "headers: value_at[0]");
    assert_streq(sandhi_headers_value_at(h, 1), "b=2", "headers: value_at[1]");
    assert_streq(sandhi_headers_value_at(h, 2), "c=3", "headers: value_at[2]");
    return 0;
}

fn test_headers_remove() {
    var h = sandhi_headers_new();
    sandhi_headers_add(h, "A", "1");
    sandhi_headers_add(h, "B", "2");
    sandhi_headers_add(h, "a", "3");  # case-insensitive dup
    sandhi_headers_add(h, "C", "4");
    assert_eq(sandhi_headers_remove(h, "A"), 2, "headers: remove returns count");
    assert_eq(sandhi_headers_count(h), 2, "headers: remaining count");
    assert_streq(sandhi_headers_name_at(h, 0), "B", "headers: B survives");
    assert_streq(sandhi_headers_name_at(h, 1), "C", "headers: C survives");
    return 0;
}

fn test_headers_serialize() {
    var h = sandhi_headers_new();
    sandhi_headers_set(h, "Host", "example.com");
    sandhi_headers_set(h, "Content-Length", "13");
    var sb = str_builder_new();
    sandhi_headers_serialize(h, sb);
    var s = str_data(str_builder_build(sb));
    assert_streq(s, "Host: example.com\r\nContent-Length: 13\r\n", "headers: wire format");
    return 0;
}

fn test_headers_parse() {
    var raw = "Host: example.com\r\nContent-Type: application/json\r\nX-Multi: v1\r\nX-Multi: v2\r\n\r\nbody-data";
    var rlen = strlen(raw);
    var h = sandhi_headers_parse(raw, rlen);
    assert_eq(sandhi_headers_count(h), 4, "parse: 4 entries");
    assert_streq(sandhi_headers_get(h, "host"), "example.com", "parse: Host");
    assert_streq(sandhi_headers_get(h, "Content-Type"), "application/json", "parse: Content-Type");
    assert_streq(sandhi_headers_value_at(h, 2), "v1", "parse: multi-value first");
    assert_streq(sandhi_headers_value_at(h, 3), "v2", "parse: multi-value second");
    return 0;
}

fn test_headers_parse_trimming() {
    var raw = "X-Padded:    spaced-value   \r\nX-Tabs:\thello\r\n\r\n";
    var rlen = strlen(raw);
    var h = sandhi_headers_parse(raw, rlen);
    assert_streq(sandhi_headers_get(h, "X-Padded"), "spaced-value", "parse: trims SP");
    assert_streq(sandhi_headers_get(h, "X-Tabs"), "hello", "parse: trims HTAB");
    return 0;
}

fn test_headers_parse_skips_malformed() {
    var raw = "Good: value\r\nmalformed-no-colon\r\nOther: ok\r\n\r\n";
    var rlen = strlen(raw);
    var h = sandhi_headers_parse(raw, rlen);
    assert_eq(sandhi_headers_count(h), 2, "parse: malformed lines skipped");
    assert_streq(sandhi_headers_get(h, "Good"), "value", "parse: valid survives");
    assert_streq(sandhi_headers_get(h, "Other"), "ok", "parse: post-malformed survives");
    return 0;
}

fn test_url_http_basic() {
    var u = sandhi_url_parse("http://example.com/foo");
    assert_neq(u, 0, "url: parses http");
    assert_eq(sandhi_url_scheme(u), SANDHI_URL_HTTP, "url: scheme HTTP");
    assert_streq(sandhi_url_host(u), "example.com", "url: host");
    assert_eq(sandhi_url_port(u), 80, "url: default port 80");
    assert_streq(sandhi_url_path(u), "/foo", "url: path");
    assert_eq(sandhi_url_query(u), 0, "url: no query");
    return 0;
}

fn test_url_https_default_port() {
    var u = sandhi_url_parse("https://example.com/");
    assert_neq(u, 0, "url: parses https");
    assert_eq(sandhi_url_scheme(u), SANDHI_URL_HTTPS, "url: scheme HTTPS");
    assert_eq(sandhi_url_port(u), 443, "url: default port 443");
    return 0;
}

fn test_url_custom_port() {
    var u = sandhi_url_parse("http://localhost:8080/api");
    assert_neq(u, 0, "url: parses with port");
    assert_streq(sandhi_url_host(u), "localhost", "url: host");
    assert_eq(sandhi_url_port(u), 8080, "url: port 8080");
    assert_streq(sandhi_url_path(u), "/api", "url: path");
    return 0;
}

fn test_url_query() {
    var u = sandhi_url_parse("https://api.example.com/v1/users?active=1&limit=50");
    assert_neq(u, 0, "url: parses with query");
    assert_streq(sandhi_url_path(u), "/v1/users", "url: path without query");
    assert_streq(sandhi_url_query(u), "active=1&limit=50", "url: query string");
    return 0;
}

fn test_url_no_path() {
    var u = sandhi_url_parse("http://example.com");
    assert_neq(u, 0, "url: parses no-path");
    assert_streq(sandhi_url_host(u), "example.com", "url: host");
    assert_streq(sandhi_url_path(u), "/", "url: path defaults to /");
    return 0;
}

fn test_url_only_query() {
    var u = sandhi_url_parse("http://example.com?x=1");
    assert_neq(u, 0, "url: parses host + query no path");
    assert_streq(sandhi_url_path(u), "/", "url: path defaults to /");
    assert_streq(sandhi_url_query(u), "x=1", "url: query preserved");
    return 0;
}

fn test_url_case_insensitive_scheme() {
    var a = sandhi_url_parse("HTTP://example.com/");
    var b = sandhi_url_parse("HtTpS://example.com/");
    assert_neq(a, 0, "url: HTTP (upper) parses");
    assert_neq(b, 0, "url: HtTpS (mixed) parses");
    assert_eq(sandhi_url_scheme(a), SANDHI_URL_HTTP, "url: upper scheme normalized");
    assert_eq(sandhi_url_scheme(b), SANDHI_URL_HTTPS, "url: mixed scheme normalized");
    return 0;
}

fn test_url_rejects_malformed() {
    assert_eq(sandhi_url_parse(""), 0, "url: empty → 0");
    assert_eq(sandhi_url_parse("ftp://example.com/"), 0, "url: unsupported scheme → 0");
    assert_eq(sandhi_url_parse("example.com/"), 0, "url: no scheme → 0");
    assert_eq(sandhi_url_parse("http:///path"), 0, "url: empty host → 0");
    assert_eq(sandhi_url_parse("http://example.com:0/"), 0, "url: port 0 → 0");
    assert_eq(sandhi_url_parse("http://example.com:99999/"), 0, "url: port > 65535 → 0");
    assert_eq(sandhi_url_parse("http://example.com:abc/"), 0, "url: non-numeric port → 0");
    return 0;
}

fn test_url_crlf_injection() {
    # stdlib http.cyr pattern — URLs with control bytes can smuggle
    # extra headers if reflected into a request; sandhi rejects early.
    assert_eq(sandhi_url_parse("http://example.com/\r\nX-Evil: 1"), 0, "url: CR rejected");
    assert_eq(sandhi_url_parse("http://example.com/\nX-Evil: 1"), 0, "url: LF rejected");
    assert_eq(sandhi_url_parse("http://example.com/ with space"), 0, "url: SP rejected");
    assert_eq(sandhi_url_parse("http://example.com/\twith-tab"), 0, "url: TAB rejected");
    return 0;
}

fn test_response_content_length() {
    var raw = "HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nContent-Length: 5\r\n\r\nhello";
    var r = sandhi_http_response_parse(raw, strlen(raw));
    assert_eq(sandhi_http_status(r), 200, "resp: status 200");
    assert_eq(sandhi_http_err_kind(r), SANDHI_OK, "resp: err_kind OK");
    assert_eq(sandhi_http_body_len(r), 5, "resp: Content-Length honored");
    assert_streq(sandhi_http_body(r), "hello", "resp: body bytes");
    assert_streq(sandhi_headers_get(sandhi_http_headers(r), "Content-Type"), "text/plain", "resp: headers accessible");
    return 0;
}

fn test_response_chunked() {
    # 5\r\nhello\r\n6\r\n world\r\n0\r\n\r\n  → "hello world"
    var raw = "HTTP/1.1 200 OK\r\nTransfer-Encoding: chunked\r\n\r\n5\r\nhello\r\n6\r\n world\r\n0\r\n\r\n";
    var r = sandhi_http_response_parse(raw, strlen(raw));
    assert_eq(sandhi_http_status(r), 200, "chunked: status");
    assert_eq(sandhi_http_body_len(r), 11, "chunked: total decoded length");
    assert_streq(sandhi_http_body(r), "hello world", "chunked: decoded body");
    return 0;
}

fn test_response_chunked_hex_large() {
    # One chunk of 0xa = 10 bytes.
    var raw = "HTTP/1.1 200 OK\r\nTransfer-Encoding: chunked\r\n\r\na\r\n0123456789\r\n0\r\n\r\n";
    var r = sandhi_http_response_parse(raw, strlen(raw));
    assert_eq(sandhi_http_body_len(r), 10, "chunked: hex size");
    assert_streq(sandhi_http_body(r), "0123456789", "chunked: hex payload");
    return 0;
}

fn test_response_chunked_with_extension() {
    # Chunk extensions after ';' must be ignored.
    var raw = "HTTP/1.1 200 OK\r\nTransfer-Encoding: chunked\r\n\r\n5;name=foo\r\nhello\r\n0\r\n\r\n";
    var r = sandhi_http_response_parse(raw, strlen(raw));
    assert_eq(sandhi_http_body_len(r), 5, "chunked: size ignores extension");
    assert_streq(sandhi_http_body(r), "hello", "chunked: body after extension");
    return 0;
}

fn test_response_close_delimited() {
    # No Content-Length, no Transfer-Encoding → read-to-close semantics.
    var raw = "HTTP/1.1 200 OK\r\nConnection: close\r\n\r\nhello close-delimited body";
    var r = sandhi_http_response_parse(raw, strlen(raw));
    assert_eq(sandhi_http_status(r), 200, "close: status");
    assert_eq(sandhi_http_body_len(r), 26, "close: body = everything after headers");
    assert_streq(sandhi_http_body(r), "hello close-delimited body", "close: body bytes");
    return 0;
}

fn test_response_status_codes() {
    var r1 = sandhi_http_response_parse("HTTP/1.1 404 Not Found\r\n\r\n", 26);
    assert_eq(sandhi_http_status(r1), 404, "status: 404");

    var r2 = sandhi_http_response_parse("HTTP/1.0 301 Moved\r\n\r\n", 22);
    assert_eq(sandhi_http_status(r2), 301, "status: 301 over HTTP/1.0");

    var r3 = sandhi_http_response_parse("HTTP/1.1 500 Internal Server Error\r\n\r\n", 38);
    assert_eq(sandhi_http_status(r3), 500, "status: 500");
    return 0;
}

fn test_response_malformed() {
    var r1 = sandhi_http_response_parse("GARBAGE", 7);
    assert_eq(sandhi_http_err_kind(r1), SANDHI_ERR_PROTOCOL, "malformed: no HTTP/ prefix");

    var r2 = sandhi_http_response_parse("HTTP/1.1 200 OK\r\nno-end", 23);
    assert_eq(sandhi_http_err_kind(r2), SANDHI_ERR_PROTOCOL, "malformed: no \\r\\n\\r\\n terminator");
    return 0;
}

fn test_response_empty_body() {
    var raw = "HTTP/1.1 204 No Content\r\nContent-Length: 0\r\n\r\n";
    var r = sandhi_http_response_parse(raw, strlen(raw));
    assert_eq(sandhi_http_status(r), 204, "empty: 204");
    assert_eq(sandhi_http_body_len(r), 0, "empty: body_len 0");
    return 0;
}

fn test_client_ipv4_parse() {
    # Expected 0x0100007F on little-endian = INADDR_LOOPBACK shape.
    assert_eq(sandhi_net_parse_ipv4("127.0.0.1"), 0x0100007F, "ipv4: 127.0.0.1");
    assert_eq(sandhi_net_parse_ipv4("0.0.0.0"), 0, "ipv4: 0.0.0.0");
    # 1.2.3.4 → bytes 01 02 03 04 → LE uint32 0x04030201
    assert_eq(sandhi_net_parse_ipv4("1.2.3.4"), 0x04030201, "ipv4: 1.2.3.4");
    # 255.255.255.255 → 0xFFFFFFFF
    assert_eq(sandhi_net_parse_ipv4("255.255.255.255"), 0xFFFFFFFF, "ipv4: 255.255.255.255");
    return 0;
}

fn test_client_ipv4_rejects() {
    assert_eq(sandhi_net_parse_ipv4(""), 0 - 1, "ipv4: empty");
    assert_eq(sandhi_net_parse_ipv4("example.com"), 0 - 1, "ipv4: hostname");
    assert_eq(sandhi_net_parse_ipv4("1.2.3"), 0 - 1, "ipv4: only 3 octets");
    assert_eq(sandhi_net_parse_ipv4("1.2.3.4.5"), 0 - 1, "ipv4: 5 octets");
    assert_eq(sandhi_net_parse_ipv4("256.1.1.1"), 0 - 1, "ipv4: octet > 255");
    assert_eq(sandhi_net_parse_ipv4("1..2.3"), 0 - 1, "ipv4: empty octet");
    assert_eq(sandhi_net_parse_ipv4("1.2.3."), 0 - 1, "ipv4: trailing dot");
    return 0;
}

fn test_client_full_path() {
    var u1 = sandhi_url_parse("http://127.0.0.1/foo");
    assert_streq(_sandhi_client_full_path(u1), "/foo", "full_path: no query");

    var u2 = sandhi_url_parse("http://127.0.0.1/api?x=1&y=2");
    assert_streq(_sandhi_client_full_path(u2), "/api?x=1&y=2", "full_path: with query");

    var u3 = sandhi_url_parse("http://127.0.0.1/");
    assert_streq(_sandhi_client_full_path(u3), "/", "full_path: root");
    return 0;
}

fn test_client_host_header() {
    var u1 = sandhi_url_parse("http://example.com/");
    assert_streq(_sandhi_client_host_header(u1), "example.com", "host: default http port omitted");

    var u2 = sandhi_url_parse("https://example.com/");
    assert_streq(_sandhi_client_host_header(u2), "example.com", "host: default https port omitted");

    var u3 = sandhi_url_parse("http://example.com:8080/");
    assert_streq(_sandhi_client_host_header(u3), "example.com:8080", "host: custom port included");

    var u4 = sandhi_url_parse("https://example.com:8443/");
    assert_streq(_sandhi_client_host_header(u4), "example.com:8443", "host: custom https port");
    return 0;
}

# NOTE: the default `User-Agent: sandhi/<version>` string in the
# expected-wire-bytes tests below embeds sandhi_version() at the time
# this file was last touched. Bump the literal on each version bump
# alongside src/main.cyr's sandhi_version(). Added in 0.7.1.

fn test_client_build_request_get() {
    var req = _sandhi_client_build_request("GET", "/path", "example.com", 0, 0);
    var expected = "GET /path HTTP/1.1\r\nHost: example.com\r\nUser-Agent: sandhi/0.8.1\r\nAccept-Encoding: identity\r\nConnection: close\r\n\r\n";
    assert_streq(str_data(req), expected, "build: GET no body no user headers");
    return 0;
}

fn test_client_build_request_post() {
    var req = _sandhi_client_build_request("POST", "/api", "api.example.com", 0, 42);
    var expected = "POST /api HTTP/1.1\r\nHost: api.example.com\r\nContent-Length: 42\r\nUser-Agent: sandhi/0.8.1\r\nAccept-Encoding: identity\r\nConnection: close\r\n\r\n";
    assert_streq(str_data(req), expected, "build: POST emits Content-Length");
    return 0;
}

fn test_client_build_request_post_empty_body() {
    # POST with body_len 0 should still emit Content-Length: 0.
    var req = _sandhi_client_build_request("POST", "/ping", "example.com", 0, 0);
    var expected = "POST /ping HTTP/1.1\r\nHost: example.com\r\nContent-Length: 0\r\nUser-Agent: sandhi/0.8.1\r\nAccept-Encoding: identity\r\nConnection: close\r\n\r\n";
    assert_streq(str_data(req), expected, "build: POST empty body");
    return 0;
}

fn test_client_build_request_user_headers() {
    var h = sandhi_headers_new();
    sandhi_headers_set(h, "Authorization", "Bearer xyz");
    sandhi_headers_set(h, "Accept", "application/json");
    var req = _sandhi_client_build_request("GET", "/me", "api.example.com", h, 0);
    # User-supplied Accept != Accept-Encoding, so both defaults still inject.
    # User hasn't supplied User-Agent either, so the default lands.
    var expected = "GET /me HTTP/1.1\r\nHost: api.example.com\r\nUser-Agent: sandhi/0.8.1\r\nAccept-Encoding: identity\r\nAuthorization: Bearer xyz\r\nAccept: application/json\r\nConnection: close\r\n\r\n";
    assert_streq(str_data(req), expected, "build: user headers serialized");
    return 0;
}

fn test_client_build_request_override_ua_and_ae() {
    # Caller-supplied User-Agent + Accept-Encoding suppress the defaults.
    var h = sandhi_headers_new();
    sandhi_headers_set(h, "User-Agent", "yantra/1.2.3");
    sandhi_headers_set(h, "Accept-Encoding", "gzip, deflate");
    var req = _sandhi_client_build_request("GET", "/probe", "probe.example", h, 0);
    var expected = "GET /probe HTTP/1.1\r\nHost: probe.example\r\nUser-Agent: yantra/1.2.3\r\nAccept-Encoding: gzip, deflate\r\nConnection: close\r\n\r\n";
    assert_streq(str_data(req), expected, "build: caller UA+AE override defaults");
    return 0;
}

fn test_client_bad_url_returns_parse_err() {
    var r = sandhi_http_get("ftp://example.com/", 0);
    assert_eq(sandhi_http_status(r), 0, "bad url: status 0");
    assert_eq(sandhi_http_err_kind(r), SANDHI_ERR_PARSE, "bad url: err_kind PARSE");
    return 0;
}

fn test_client_unresolvable_hostname() {
    # Bogus hostname — both /etc/hosts and real DNS should fail to
    # resolve it, producing SANDHI_ERR_DISCOVERY regardless of env.
    var r = sandhi_http_get("http://this-does-not-exist.invalid/", 0);
    assert_eq(sandhi_http_err_kind(r), SANDHI_ERR_DISCOVERY, "hostname: unresolvable → DISCOVERY");
    return 0;
}

fn test_redirect_is_redirect() {
    assert_eq(_sandhi_is_redirect(200), 0, "redirect: 200 no");
    assert_eq(_sandhi_is_redirect(301), 1, "redirect: 301 yes");
    assert_eq(_sandhi_is_redirect(302), 1, "redirect: 302 yes");
    assert_eq(_sandhi_is_redirect(303), 1, "redirect: 303 yes");
    assert_eq(_sandhi_is_redirect(304), 0, "redirect: 304 not followed");
    assert_eq(_sandhi_is_redirect(307), 1, "redirect: 307 yes");
    assert_eq(_sandhi_is_redirect(308), 1, "redirect: 308 yes");
    assert_eq(_sandhi_is_redirect(400), 0, "redirect: 400 no");
    return 0;
}

fn test_redirect_absolute_location() {
    var out = _sandhi_resolve_location("http://a.example.com/x", "https://b.example.com/y");
    assert_streq(out, "https://b.example.com/y", "redirect: absolute Location");
    return 0;
}

fn test_redirect_relative_location() {
    var out = _sandhi_resolve_location("http://example.com/old", "/new/path");
    assert_streq(out, "http://example.com/new/path", "redirect: relative → scheme+host+path");

    var out2 = _sandhi_resolve_location("https://example.com:8443/old", "/new");
    assert_streq(out2, "https://example.com:8443/new", "redirect: relative preserves custom port");

    var out3 = _sandhi_resolve_location("https://example.com/old", "/new");
    # Default https port omitted.
    assert_streq(out3, "https://example.com/new", "redirect: relative omits default port");
    return 0;
}

fn test_redirect_bad_location() {
    # Non-slash relative is rejected (protocol-relative "//host" would need
    # real support; skip for v0.3.0).
    assert_eq(_sandhi_resolve_location("http://example.com/old", "new-no-slash"), 0, "redirect: bad relative");
    assert_eq(_sandhi_resolve_location("http://example.com/old", 0), 0, "redirect: null Location");
    return 0;
}

fn test_http_options_defaults() {
    var o = sandhi_http_options_new();
    assert_eq(sandhi_http_options_follow(o), 0, "opts: follow default off");
    assert_eq(sandhi_http_options_hops(o), 5, "opts: max_hops default 5");
    assert_eq(sandhi_http_options_bytes(o), 262144, "opts: max_bytes default 256K");
    assert_eq(sandhi_http_options_get_read_ms(o), 0, "opts: read_ms default 0");
    assert_eq(sandhi_http_options_get_write_ms(o), 0, "opts: write_ms default 0");
    assert_eq(sandhi_http_options_get_connect_ms(o), 0, "opts: connect_ms default 0");
    assert_eq(sandhi_http_options_get_total_ms(o), 0, "opts: total_ms default 0");
    assert_eq(sandhi_http_options_follow(0), 0, "opts: null → follow off");
    assert_eq(sandhi_http_options_hops(0), 5, "opts: null → hops 5");
    assert_eq(sandhi_http_options_bytes(0), 262144, "opts: null → bytes 256K");
    assert_eq(sandhi_http_options_get_read_ms(0), 0, "opts: null → read_ms 0");
    assert_eq(sandhi_http_options_get_write_ms(0), 0, "opts: null → write_ms 0");
    assert_eq(sandhi_http_options_get_connect_ms(0), 0, "opts: null → connect_ms 0");
    assert_eq(sandhi_http_options_get_total_ms(0), 0, "opts: null → total_ms 0");
    return 0;
}

fn test_http_options_mutators() {
    var o = sandhi_http_options_new();
    sandhi_http_options_follow_redirects(o, 1);
    sandhi_http_options_max_hops(o, 10);
    sandhi_http_options_max_response_bytes(o, 65536);
    sandhi_http_options_read_ms(o, 5000);
    sandhi_http_options_write_ms(o, 2500);
    sandhi_http_options_connect_ms(o, 1500);
    sandhi_http_options_total_ms(o, 10000);
    assert_eq(sandhi_http_options_follow(o), 1, "opts: follow=1 sticks");
    assert_eq(sandhi_http_options_hops(o), 10, "opts: max_hops=10 sticks");
    assert_eq(sandhi_http_options_bytes(o), 65536, "opts: max_bytes=64K sticks");
    assert_eq(sandhi_http_options_get_read_ms(o), 5000, "opts: read_ms=5000 sticks");
    assert_eq(sandhi_http_options_get_write_ms(o), 2500, "opts: write_ms=2500 sticks");
    assert_eq(sandhi_http_options_get_connect_ms(o), 1500, "opts: connect_ms=1500 sticks");
    assert_eq(sandhi_http_options_get_total_ms(o), 10000, "opts: total_ms=10000 sticks");
    return 0;
}

fn test_http_clamp_ms_no_deadline() {
    # deadline=0 → return raw_ms unchanged.
    assert_eq(_sandhi_http_clamp_ms(5000, 0), 5000, "clamp: no deadline → raw");
    assert_eq(_sandhi_http_clamp_ms(0, 0), 0, "clamp: zero raw, no deadline → 0");
    return 0;
}

fn test_http_clamp_ms_with_deadline_in_future() {
    var deadline = clock_now_ms() + 60000;
    var clamped = _sandhi_http_clamp_ms(1000, deadline);
    assert_eq(clamped > 0 && clamped <= 1000, 1, "clamp: raw < remaining → raw");
    var clamped2 = _sandhi_http_clamp_ms(0, deadline);
    assert_eq(clamped2 > 50000 && clamped2 <= 60000, 1, "clamp: raw 0 → remaining");
    var clamped3 = _sandhi_http_clamp_ms(100000, deadline);
    assert_eq(clamped3 > 50000 && clamped3 <= 60000, 1, "clamp: raw > remaining → remaining");
    return 0;
}

fn test_http_clamp_ms_deadline_elapsed() {
    var deadline = clock_now_ms() - 1000;
    assert_eq(_sandhi_http_clamp_ms(5000, deadline), 0 - 1, "clamp: elapsed → -1 sentinel");
    return 0;
}

fn test_connect_ms_blackhole_returns_timeout() {
    # 192.0.2.0/24 is TEST-NET-1 (RFC 5737) — guaranteed not routed.
    # connect() with a 200 ms timeout should return TIMEOUT well
    # before the kernel's default ~75 s SYN-retry budget. Budget kept
    # generous (5 s) to avoid flakiness on busy CI hosts.
    var opts = sandhi_http_options_new();
    sandhi_http_options_connect_ms(opts, 200);
    var t0 = clock_now_ms();
    var r = sandhi_http_get_opts("http://192.0.2.1/", 0, opts);
    var elapsed = clock_now_ms() - t0;
    assert_eq(sandhi_http_err_kind(r), SANDHI_ERR_TIMEOUT, "connect_ms blackhole: TIMEOUT raised");
    assert_eq(elapsed < 5000, 1, "connect_ms blackhole: returned within budget");
    return 0;
}

fn test_total_ms_blackhole_returns_timeout() {
    # Same target, no connect_ms, but total_ms=300 → must still TIMEOUT
    # because the connect-phase clamp uses the deadline as ceiling.
    var opts = sandhi_http_options_new();
    sandhi_http_options_total_ms(opts, 300);
    var t0 = clock_now_ms();
    var r = sandhi_http_get_opts("http://192.0.2.1/", 0, opts);
    var elapsed = clock_now_ms() - t0;
    assert_eq(sandhi_http_err_kind(r), SANDHI_ERR_TIMEOUT, "total_ms blackhole: TIMEOUT raised");
    assert_eq(elapsed < 5000, 1, "total_ms blackhole: returned within budget");
    return 0;
}

# ================================================================
# Connection pool tests (Bite 1 of 0.8.0)
# ================================================================
#
# Fake-conn fixture: /dev/null fd so sandhi_conn_close is real but
# harmless. Pool API runs end-to-end with no actual network.

fn _test_pool_fake_conn() {
    var fd = syscall(2, "/dev/null", 0, 0);  # open(O_RDONLY)
    var c = alloc(SANDHI_CONN_STRUCT_SIZE);
    store64(c + SANDHI_CONN_OFF_KIND, SANDHI_CONN_PLAIN);
    store64(c + SANDHI_CONN_OFF_FD, fd);
    store64(c + SANDHI_CONN_OFF_TLS_CTX, 0);
    return c;
}

fn test_pool_new_defaults() {
    var p = sandhi_http_pool_new(0, 0);
    assert_eq(sandhi_http_pool_max_per_host(p), 8, "pool: default max_per_host=8");
    assert_eq(sandhi_http_pool_idle_timeout_ms(p), 90000, "pool: default idle_timeout=90s");
    assert_eq(sandhi_http_pool_idle_count(p), 0, "pool: starts empty");
    return 0;
}

fn test_pool_new_explicit() {
    var p = sandhi_http_pool_new(4, 30000);
    assert_eq(sandhi_http_pool_max_per_host(p), 4, "pool: max_per_host=4 sticks");
    assert_eq(sandhi_http_pool_idle_timeout_ms(p), 30000, "pool: idle_timeout=30s sticks");
    return 0;
}

fn test_pool_take_empty_returns_zero() {
    var p = sandhi_http_pool_new(8, 90000);
    var c = _sandhi_pool_take(p, "example.com", 80, 0);
    assert_eq(c, 0, "pool: take from empty → 0");
    return 0;
}

fn test_pool_put_then_take_returns_same_conn() {
    var p = sandhi_http_pool_new(8, 90000);
    var fc = _test_pool_fake_conn();
    _sandhi_pool_put(p, "example.com", 80, 0, fc);
    assert_eq(sandhi_http_pool_idle_count(p), 1, "pool: count=1 after put");
    var taken = _sandhi_pool_take(p, "example.com", 80, 0);
    assert_eq(taken, fc, "pool: take returns the same conn");
    assert_eq(sandhi_http_pool_idle_count(p), 0, "pool: count=0 after take");
    sandhi_conn_close(fc);  # cleanup
    return 0;
}

fn test_pool_routes_isolated() {
    # Putting on host A doesn't affect host B's queue.
    var p = sandhi_http_pool_new(8, 90000);
    var c1 = _test_pool_fake_conn();
    _sandhi_pool_put(p, "alpha.example", 80, 0, c1);
    var taken_b = _sandhi_pool_take(p, "beta.example", 80, 0);
    assert_eq(taken_b, 0, "pool: route B miss when only A populated");
    var taken_a = _sandhi_pool_take(p, "alpha.example", 80, 0);
    assert_eq(taken_a, c1, "pool: route A hit");
    sandhi_conn_close(c1);
    return 0;
}

fn test_pool_route_distinguishes_tls() {
    # http://host:80 and https://host:80 are different routes.
    var p = sandhi_http_pool_new(8, 90000);
    var c_plain = _test_pool_fake_conn();
    _sandhi_pool_put(p, "example", 80, 0, c_plain);
    var taken_tls = _sandhi_pool_take(p, "example", 80, 1);
    assert_eq(taken_tls, 0, "pool: TLS=1 doesn't pick TLS=0 conn");
    var taken_plain = _sandhi_pool_take(p, "example", 80, 0);
    assert_eq(taken_plain, c_plain, "pool: TLS=0 picks the matching conn");
    sandhi_conn_close(c_plain);
    return 0;
}

fn test_pool_cap_evicts_oldest() {
    # max_per_host=2 → on the third put, the OLDEST is closed and dropped.
    var p = sandhi_http_pool_new(2, 90000);
    var c1 = _test_pool_fake_conn();
    var c2 = _test_pool_fake_conn();
    var c3 = _test_pool_fake_conn();
    _sandhi_pool_put(p, "host", 80, 0, c1);
    _sandhi_pool_put(p, "host", 80, 0, c2);
    assert_eq(sandhi_http_pool_idle_count(p), 2, "pool: at cap=2 after 2 puts");
    _sandhi_pool_put(p, "host", 80, 0, c3);  # evicts c1
    assert_eq(sandhi_http_pool_idle_count(p), 2, "pool: still at cap=2 after evict-and-put");
    # LIFO take → c3 (most-recent put), then c2.
    var t1 = _sandhi_pool_take(p, "host", 80, 0);
    assert_eq(t1, c3, "pool: LIFO take returns c3 (most-recent)");
    var t2 = _sandhi_pool_take(p, "host", 80, 0);
    assert_eq(t2, c2, "pool: next take returns c2");
    var t3 = _sandhi_pool_take(p, "host", 80, 0);
    assert_eq(t3, 0, "pool: empty after both pops");
    sandhi_conn_close(c2);
    sandhi_conn_close(c3);
    return 0;
}

fn test_pool_close_drops_all_idle() {
    var p = sandhi_http_pool_new(8, 90000);
    var c1 = _test_pool_fake_conn();
    var c2 = _test_pool_fake_conn();
    _sandhi_pool_put(p, "host-a", 80, 0, c1);
    _sandhi_pool_put(p, "host-b", 443, 1, c2);
    assert_eq(sandhi_http_pool_idle_count(p), 2, "pool: 2 idle pre-close");
    sandhi_http_pool_close(p);
    assert_eq(sandhi_http_pool_idle_count(p), 0, "pool: 0 idle post-close");
    # Subsequent take from an empty pool still works (map_clear left it usable).
    var taken = _sandhi_pool_take(p, "host-a", 80, 0);
    assert_eq(taken, 0, "pool: take from closed-then-emptied → 0");
    return 0;
}

fn test_pool_options_attach() {
    var p = sandhi_http_pool_new(4, 30000);
    var o = sandhi_http_options_new();
    assert_eq(sandhi_http_options_get_pool(o), 0, "options: pool default 0");
    sandhi_http_options_pool(o, p);
    assert_eq(sandhi_http_options_get_pool(o), p, "options: pool attaches");
    return 0;
}

fn test_pool_chunked_complete_detector() {
    # Buffer with header + complete chunked body: "5\r\nhello\r\n0\r\n\r\n"
    # body_start=0 in the test (we're testing the detector in isolation).
    var raw = "5\r\nhello\r\n0\r\n\r\n";
    assert_eq(_sandhi_pool_chunked_complete(raw, 0, strlen(raw)), 1, "chunked: complete detected");

    # Truncated — missing trailing CRLF after 0-chunk.
    var raw2 = "5\r\nhello\r\n0\r\n";
    assert_eq(_sandhi_pool_chunked_complete(raw2, 0, strlen(raw2)), 0, "chunked: incomplete");

    # Mid-chunk truncation.
    var raw3 = "5\r\nhel";
    assert_eq(_sandhi_pool_chunked_complete(raw3, 0, strlen(raw3)), 0, "chunked: data truncated");

    # Multi-chunk before terminal.
    var raw4 = "3\r\nabc\r\n2\r\nde\r\n0\r\n\r\n";
    assert_eq(_sandhi_pool_chunked_complete(raw4, 0, strlen(raw4)), 1, "chunked: multi-chunk complete");
    return 0;
}

fn test_alpn_encode_default() {
    # "h2,http/1.1" → 02 'h' '2' 08 'h' 't' 't' 'p' '/' '1' '.' '1'
    # = 1 + 2 + 1 + 8 = 12 bytes total.
    var out[32];
    memset(&out, 0, 32);
    var n = sandhi_alpn_encode_protos("h2,http/1.1", &out, 32);
    assert_eq(n, 12, "alpn: 12 bytes");
    assert_eq(load8(&out + 0), 2, "first len = 2");
    assert_eq(load8(&out + 1), 104, "h");
    assert_eq(load8(&out + 2), 50, "2");
    assert_eq(load8(&out + 3), 8, "second len = 8");
    assert_eq(load8(&out + 11), 49, "last byte = '1'");
    return 0;
}

fn test_alpn_selected_stubbed() {
    # Real ALPN runtime is gated on libssl fix — accessor returns 0 today.
    var fake_conn = alloc(SANDHI_CONN_STRUCT_SIZE);
    assert_eq(sandhi_conn_alpn_selected(fake_conn), 0, "stub returns 0");
    assert_eq(sandhi_conn_alpn_is_h2(fake_conn), 0, "h2 check returns 0");
    return 0;
}

fn test_retry_defaults() {
    var r = sandhi_retry_new();
    assert_eq(_sandhi_retry_attempts(r), 3, "retry: default 3 attempts");
    assert_eq(_sandhi_retry_initial(r), 50, "retry: default initial 50ms");
    assert_eq(_sandhi_retry_max(r), 2000, "retry: default max 2000ms");
    assert_eq(_sandhi_retry_attempts(0), 3, "retry: null → 3 attempts");
    assert_eq(_sandhi_retry_initial(0), 50, "retry: null → initial 50");
    assert_eq(_sandhi_retry_max(0), 2000, "retry: null → max 2000");
    return 0;
}

fn test_retry_mutators() {
    var r = sandhi_retry_new();
    sandhi_retry_max_attempts(r, 5);
    sandhi_retry_initial_backoff_ms(r, 100);
    sandhi_retry_max_backoff_ms(r, 30000);
    assert_eq(_sandhi_retry_attempts(r), 5, "retry: attempts sticks");
    assert_eq(_sandhi_retry_initial(r), 100, "retry: initial sticks");
    assert_eq(_sandhi_retry_max(r), 30000, "retry: max sticks");
    return 0;
}

fn test_retry_should_retry_on_transient_err() {
    # Synthesize responses via _sandhi_resp_err so we don't need a
    # live peer. Transient → should retry.
    var r_connect = _sandhi_resp_err(SANDHI_ERR_CONNECT);
    assert_eq(_sandhi_retry_should_retry(r_connect), 1, "retry: CONNECT → retry");

    var r_timeout = _sandhi_resp_err(SANDHI_ERR_TIMEOUT);
    assert_eq(_sandhi_retry_should_retry(r_timeout), 1, "retry: TIMEOUT → retry");

    var r_disc = _sandhi_resp_err(SANDHI_ERR_DISCOVERY);
    assert_eq(_sandhi_retry_should_retry(r_disc), 1, "retry: DISCOVERY → retry");
    return 0;
}

fn test_retry_should_not_retry_on_4xx_or_permanent_err() {
    # A real 4xx response — parseable, non-5xx status.
    var raw = "HTTP/1.1 404 Not Found\r\nContent-Length: 0\r\n\r\n";
    var r_404 = sandhi_http_response_parse(raw, strlen(raw));
    assert_eq(_sandhi_retry_should_retry(r_404), 0, "retry: 404 → no retry");

    # 401 AUTH-ish — caller's credential problem, not transient.
    var raw2 = "HTTP/1.1 401 Unauthorized\r\nContent-Length: 0\r\n\r\n";
    var r_401 = sandhi_http_response_parse(raw2, strlen(raw2));
    assert_eq(_sandhi_retry_should_retry(r_401), 0, "retry: 401 → no retry");

    # PARSE err — sandhi gave us bad input; retry won't help.
    var r_parse = _sandhi_resp_err(SANDHI_ERR_PARSE);
    assert_eq(_sandhi_retry_should_retry(r_parse), 0, "retry: PARSE → no retry");

    # TLS err — cert problem; retrying won't fix it.
    var r_tls = _sandhi_resp_err(SANDHI_ERR_TLS);
    assert_eq(_sandhi_retry_should_retry(r_tls), 0, "retry: TLS → no retry");
    return 0;
}

fn test_server_options_defaults() {
    var o = sandhi_server_options_new();
    assert_eq(sandhi_server_options_get_idle_ms(o), 30000, "server opts: idle_ms default 30s");
    assert_eq(sandhi_server_options_get_max_conns(o), 128, "server opts: max_conns default 128");
    assert_eq(sandhi_server_options_get_idle_ms(0), 30000, "server opts: null → idle_ms 30s");
    assert_eq(sandhi_server_options_get_max_conns(0), 128, "server opts: null → max_conns 128");
    return 0;
}

fn test_server_options_mutators() {
    var o = sandhi_server_options_new();
    sandhi_server_options_idle_ms(o, 5000);
    sandhi_server_options_max_conns(o, 64);
    assert_eq(sandhi_server_options_get_idle_ms(o), 5000, "server opts: idle_ms=5000 sticks");
    assert_eq(sandhi_server_options_get_max_conns(o), 64, "server opts: max_conns=64 sticks");
    return 0;
}

fn test_trace_default_disabled() {
    # Default off — calling begin/end is a no-op (depth stays 0).
    assert_eq(sandhi_trace_enabled(), 0, "trace: default disabled");
    var d0 = sandhi_trace_depth();
    sandhi_trace_begin("sandhi.test");
    assert_eq(sandhi_trace_depth(), d0, "trace: disabled begin is no-op");
    sandhi_trace_end();
    return 0;
}

fn test_trace_enable_affects_depth() {
    # With tracing enabled, begin/end moves depth up and back.
    # Redirect sakshi to the ring buffer so we don't spam stderr
    # during the test run.
    sakshi_set_output(SK_OUT_BUFFER);
    sandhi_trace_enable(1);
    assert_eq(sandhi_trace_enabled(), 1, "trace: enabled sticks");
    var d0 = sandhi_trace_depth();
    sandhi_trace_begin("sandhi.test.outer");
    assert_eq(sandhi_trace_depth(), d0 + 1, "trace: depth +1 after begin");
    sandhi_trace_begin("sandhi.test.inner");
    assert_eq(sandhi_trace_depth(), d0 + 2, "trace: depth +2 after nested begin");
    sandhi_trace_end();
    assert_eq(sandhi_trace_depth(), d0 + 1, "trace: depth back to +1 after inner end");
    sandhi_trace_end();
    assert_eq(sandhi_trace_depth(), d0, "trace: depth back to baseline");
    # Restore default state for subsequent tests.
    sandhi_trace_enable(0);
    sakshi_set_output(SK_OUT_STDERR);
    return 0;
}

fn test_retry_should_retry_on_5xx() {
    var raw500 = "HTTP/1.1 500 Internal Server Error\r\nContent-Length: 0\r\n\r\n";
    var r500 = sandhi_http_response_parse(raw500, strlen(raw500));
    assert_eq(_sandhi_retry_should_retry(r500), 1, "retry: 500 → retry");

    var raw502 = "HTTP/1.1 502 Bad Gateway\r\nContent-Length: 0\r\n\r\n";
    var r502 = sandhi_http_response_parse(raw502, strlen(raw502));
    assert_eq(_sandhi_retry_should_retry(r502), 1, "retry: 502 → retry");

    var raw503 = "HTTP/1.1 503 Service Unavailable\r\nContent-Length: 0\r\n\r\n";
    var r503 = sandhi_http_response_parse(raw503, strlen(raw503));
    assert_eq(_sandhi_retry_should_retry(r503), 1, "retry: 503 → retry");

    var raw200 = "HTTP/1.1 200 OK\r\nContent-Length: 0\r\n\r\n";
    var r200 = sandhi_http_response_parse(raw200, strlen(raw200));
    assert_eq(_sandhi_retry_should_retry(r200), 0, "retry: 200 → no retry");
    return 0;
}

fn test_resolve_label_encode() {
    var buf[64];
    memset(&buf, 0, 64);
    var n = _sandhi_resolve_encode_labels("example.com", &buf);
    # Expected: 07 e x a m p l e 03 c o m 00 → 13 bytes
    assert_eq(n, 13, "dns labels: example.com length");
    assert_eq(load8(&buf + 0), 7, "dns labels: first label len 7");
    assert_eq(load8(&buf + 1), 101, "dns labels: 'e'");
    assert_eq(load8(&buf + 8), 3, "dns labels: second label len 3");
    assert_eq(load8(&buf + 9), 99, "dns labels: 'c'");
    assert_eq(load8(&buf + 12), 0, "dns labels: root terminator");
    return 0;
}

fn test_resolve_label_encode_single() {
    var buf[16];
    memset(&buf, 0, 16);
    var n = _sandhi_resolve_encode_labels("localhost", &buf);
    # Expected: 09 l o c a l h o s t 00 → 11 bytes
    assert_eq(n, 11, "dns labels: localhost length");
    assert_eq(load8(&buf + 0), 9, "dns labels: label len 9");
    assert_eq(load8(&buf + 10), 0, "dns labels: terminator");
    return 0;
}

fn test_resolve_parse_response_synthetic() {
    # Hand-built minimal DNS response: Header + Question + 1 A answer.
    # ID: 0x1234, QR=1 RD=1 RA=1, QDCOUNT=1, ANCOUNT=1, NSCOUNT=0, ARCOUNT=0
    # Question: "a.com" / A / IN  (7 bytes name + 4 bytes type/class = 11)
    # Answer:   name-ptr 0xC00C / type A / class IN / TTL 60 / RDLENGTH 4 / 10.0.0.1
    var pkt[64];
    memset(&pkt, 0, 64);
    # Header (12 bytes)
    store8(&pkt + 0, 0x12); store8(&pkt + 1, 0x34);  # ID
    store8(&pkt + 2, 0x81); store8(&pkt + 3, 0x80);  # Flags: QR=1, RD=1, RA=1, RCODE=0
    store8(&pkt + 5, 1);  # QDCOUNT=1
    store8(&pkt + 7, 1);  # ANCOUNT=1
    # Question: "a.com"
    store8(&pkt + 12, 1); store8(&pkt + 13, 97);     # "a"
    store8(&pkt + 14, 3); store8(&pkt + 15, 99); store8(&pkt + 16, 111); store8(&pkt + 17, 109);  # "com"
    store8(&pkt + 18, 0);  # terminator
    store8(&pkt + 20, 1);  # QTYPE=A
    store8(&pkt + 22, 1);  # QCLASS=IN
    # Answer
    store8(&pkt + 23, 0xC0); store8(&pkt + 24, 0x0C);  # name pointer to offset 12
    store8(&pkt + 26, 1);  # type A
    store8(&pkt + 28, 1);  # class IN
    store8(&pkt + 32, 60);  # TTL low byte
    store8(&pkt + 34, 4);  # RDLENGTH
    store8(&pkt + 35, 10); store8(&pkt + 36, 0); store8(&pkt + 37, 0); store8(&pkt + 38, 1);  # 10.0.0.1
    var ip = _sandhi_resolve_parse_response(&pkt, 39, 0x1234);
    # 10.0.0.1 → bytes 10,0,0,1 → LE uint32 = 0x0100000A
    assert_eq(ip, 0x0100000A, "dns parse: A record extracted");
    return 0;
}

fn test_resolve_parse_nxdomain() {
    # Response with RCODE=3 (NXDOMAIN) should be rejected.
    var pkt[16];
    memset(&pkt, 0, 16);
    store8(&pkt + 0, 0x12); store8(&pkt + 1, 0x34);  # ID
    store8(&pkt + 2, 0x81); store8(&pkt + 3, 0x83);  # RCODE=3
    store8(&pkt + 7, 0);  # ANCOUNT=0
    assert_eq(_sandhi_resolve_parse_response(&pkt, 12, 0x1234), 0 - 1, "dns parse: NXDOMAIN → -1");
    return 0;
}

fn test_resolve_parse_no_answer() {
    # Well-formed header but ANCOUNT=0.
    var pkt[12];
    memset(&pkt, 0, 12);
    store8(&pkt + 0, 0x12); store8(&pkt + 1, 0x34);  # ID
    store8(&pkt + 2, 0x81); store8(&pkt + 3, 0x80);
    assert_eq(_sandhi_resolve_parse_response(&pkt, 12, 0x1234), 0 - 1, "dns parse: no answers → -1");
    return 0;
}

fn test_resolve_parse_txid_mismatch_rejected() {
    # Same minimal packet as the synthetic test but we pass a DIFFERENT
    # expected_id — simulates an off-path poisoning packet arriving
    # with the wrong TXID. Must be rejected.
    var pkt[64];
    memset(&pkt, 0, 64);
    store8(&pkt + 0, 0x12); store8(&pkt + 1, 0x34);  # ID
    store8(&pkt + 2, 0x81); store8(&pkt + 3, 0x80);
    store8(&pkt + 5, 1); store8(&pkt + 7, 1);
    store8(&pkt + 12, 1); store8(&pkt + 13, 97);
    store8(&pkt + 14, 3); store8(&pkt + 15, 99); store8(&pkt + 16, 111); store8(&pkt + 17, 109);
    store8(&pkt + 18, 0);
    store8(&pkt + 20, 1); store8(&pkt + 22, 1);
    store8(&pkt + 23, 0xC0); store8(&pkt + 24, 0x0C);
    store8(&pkt + 26, 1); store8(&pkt + 28, 1);
    store8(&pkt + 32, 60); store8(&pkt + 34, 4);
    store8(&pkt + 35, 10); store8(&pkt + 38, 1);
    # Pass wrong expected_id (0xDEAD) — must reject.
    assert_eq(_sandhi_resolve_parse_response(&pkt, 39, 0xDEAD), 0 - 1, "dns parse: TXID mismatch → rejected");
    # Sanity: correct id → accepted.
    assert_eq(_sandhi_resolve_parse_response(&pkt, 39, 0x1234), 0x0100000A, "dns parse: correct TXID accepted");
    return 0;
}

fn test_resolve_parse_wrong_answer_name_skipped() {
    # Pkt where question is "a.com" but the answer RR's owner name is
    # "b.com" (not a compression pointer to the question). Must NOT
    # return the A value — should scan past it and fail.
    var pkt[64];
    memset(&pkt, 0, 64);
    store8(&pkt + 0, 0x12); store8(&pkt + 1, 0x34);  # ID
    store8(&pkt + 2, 0x81); store8(&pkt + 3, 0x80);
    store8(&pkt + 5, 1);  # QDCOUNT=1
    store8(&pkt + 7, 1);  # ANCOUNT=1
    # Question "a.com"
    store8(&pkt + 12, 1); store8(&pkt + 13, 97);
    store8(&pkt + 14, 3); store8(&pkt + 15, 99); store8(&pkt + 16, 111); store8(&pkt + 17, 109);
    store8(&pkt + 18, 0);
    store8(&pkt + 20, 1); store8(&pkt + 22, 1);
    # Answer owner = "b.com" (inline, not pointer)
    store8(&pkt + 23, 1); store8(&pkt + 24, 98);     # "b"
    store8(&pkt + 25, 3); store8(&pkt + 26, 99); store8(&pkt + 27, 111); store8(&pkt + 28, 109);  # "com"
    store8(&pkt + 29, 0);  # root
    store8(&pkt + 31, 1);  # QTYPE=A
    store8(&pkt + 33, 1);  # QCLASS=IN
    store8(&pkt + 37, 60); # TTL low
    store8(&pkt + 39, 4);  # RDLENGTH
    store8(&pkt + 40, 9); store8(&pkt + 43, 1);  # 9.0.0.1 — not what we asked for
    assert_eq(_sandhi_resolve_parse_response(&pkt, 44, 0x1234), 0 - 1, "dns parse: wrong answer-name rejected");
    return 0;
}

fn test_resolve_name_eq_with_compression() {
    # Verify _sandhi_resolve_name_eq follows compression pointers.
    var pkt[32];
    memset(&pkt, 0, 32);
    # At offset 0: "a.com"
    store8(&pkt + 0, 1); store8(&pkt + 1, 97);
    store8(&pkt + 2, 3); store8(&pkt + 3, 99); store8(&pkt + 4, 111); store8(&pkt + 5, 109);
    store8(&pkt + 6, 0);
    # At offset 7: pointer back to offset 0 (0xC000).
    store8(&pkt + 7, 0xC0); store8(&pkt + 8, 0);
    # Should match itself at offsets 0 and 7.
    assert_eq(_sandhi_resolve_name_eq(&pkt, 32, 0, 7), 1, "name_eq: inline vs pointer to same");
    assert_eq(_sandhi_resolve_name_eq(&pkt, 32, 0, 0), 1, "name_eq: identical offsets");
    return 0;
}

fn test_resolve_name_eq_case_insensitive() {
    var pkt[24];
    memset(&pkt, 0, 24);
    # "A.CoM" at offset 0, "a.com" at offset 7 — must match per RFC.
    store8(&pkt + 0, 1); store8(&pkt + 1, 65);  # "A"
    store8(&pkt + 2, 3); store8(&pkt + 3, 67); store8(&pkt + 4, 111); store8(&pkt + 5, 77);  # "CoM"
    store8(&pkt + 6, 0);
    store8(&pkt + 7, 1); store8(&pkt + 8, 97);  # "a"
    store8(&pkt + 9, 3); store8(&pkt + 10, 99); store8(&pkt + 11, 111); store8(&pkt + 12, 109);  # "com"
    store8(&pkt + 13, 0);
    assert_eq(_sandhi_resolve_name_eq(&pkt, 24, 0, 7), 1, "name_eq: case-insensitive");
    return 0;
}

fn test_resolve_name_eq_different_names() {
    var pkt[24];
    memset(&pkt, 0, 24);
    # "a.com" at offset 0, "b.com" at offset 7 — must differ.
    store8(&pkt + 0, 1); store8(&pkt + 1, 97);
    store8(&pkt + 2, 3); store8(&pkt + 3, 99); store8(&pkt + 4, 111); store8(&pkt + 5, 109);
    store8(&pkt + 6, 0);
    store8(&pkt + 7, 1); store8(&pkt + 8, 98);
    store8(&pkt + 9, 3); store8(&pkt + 10, 99); store8(&pkt + 11, 111); store8(&pkt + 12, 109);
    store8(&pkt + 13, 0);
    assert_eq(_sandhi_resolve_name_eq(&pkt, 24, 0, 7), 0, "name_eq: different names");
    return 0;
}

fn test_resolve_parse_aaaa_synthetic() {
    # Synthetic AAAA response: header + "a.com" question + 1 AAAA answer.
    # Answer IPv6 = 2001:db8::1 (bytes: 20 01 0d b8 00 00 00 00 00 00 00 00 00 00 00 01)
    var pkt[80];
    memset(&pkt, 0, 80);
    store8(&pkt + 0, 0x12); store8(&pkt + 1, 0x34);  # TXID
    store8(&pkt + 2, 0x81); store8(&pkt + 3, 0x80);  # QR=1 RD=1 RA=1
    store8(&pkt + 5, 1);  # QDCOUNT=1
    store8(&pkt + 7, 1);  # ANCOUNT=1
    # Question "a.com"
    store8(&pkt + 12, 1); store8(&pkt + 13, 97);
    store8(&pkt + 14, 3); store8(&pkt + 15, 99); store8(&pkt + 16, 111); store8(&pkt + 17, 109);
    store8(&pkt + 18, 0);
    store8(&pkt + 20, 0x1C);  # QTYPE=AAAA (28) — low byte
    store8(&pkt + 22, 1);     # QCLASS=IN
    # Answer
    store8(&pkt + 23, 0xC0); store8(&pkt + 24, 0x0C);  # name ptr → offset 12
    store8(&pkt + 26, 0x1C);  # TYPE=AAAA
    store8(&pkt + 28, 1);     # CLASS=IN
    store8(&pkt + 32, 60);    # TTL low
    store8(&pkt + 34, 16);    # RDLENGTH=16
    # 2001:db8::1
    store8(&pkt + 35, 0x20); store8(&pkt + 36, 0x01);
    store8(&pkt + 37, 0x0d); store8(&pkt + 38, 0xb8);
    # bytes 39..49 stay zero
    store8(&pkt + 50, 0x01);
    var out = _sandhi_resolve_parse_response_aaaa(&pkt, 51, 0x1234);
    assert_neq(out, 0, "aaaa parse: returned a buffer");
    assert_eq(load8(out + 0), 0x20, "aaaa parse: byte 0");
    assert_eq(load8(out + 1), 0x01, "aaaa parse: byte 1");
    assert_eq(load8(out + 2), 0x0d, "aaaa parse: byte 2");
    assert_eq(load8(out + 3), 0xb8, "aaaa parse: byte 3");
    assert_eq(load8(out + 15), 0x01, "aaaa parse: last byte");
    assert_eq(load8(out + 14), 0x00, "aaaa parse: zero-run preserved");
    return 0;
}

fn test_resolve_parse_aaaa_txid_mismatch() {
    # Same AAAA packet, wrong expected_id → must reject with null.
    var pkt[80];
    memset(&pkt, 0, 80);
    store8(&pkt + 0, 0x12); store8(&pkt + 1, 0x34);
    store8(&pkt + 2, 0x81); store8(&pkt + 3, 0x80);
    store8(&pkt + 5, 1); store8(&pkt + 7, 1);
    store8(&pkt + 12, 1); store8(&pkt + 13, 97);
    store8(&pkt + 14, 3); store8(&pkt + 15, 99); store8(&pkt + 16, 111); store8(&pkt + 17, 109);
    store8(&pkt + 18, 0);
    store8(&pkt + 20, 0x1C); store8(&pkt + 22, 1);
    store8(&pkt + 23, 0xC0); store8(&pkt + 24, 0x0C);
    store8(&pkt + 26, 0x1C); store8(&pkt + 28, 1);
    store8(&pkt + 32, 60); store8(&pkt + 34, 16);
    store8(&pkt + 50, 0x01);
    assert_eq(_sandhi_resolve_parse_response_aaaa(&pkt, 51, 0xBEEF), 0, "aaaa parse: TXID mismatch → null");
    return 0;
}

fn test_resolve_random_u16_is_random() {
    # Pull two samples; probability of collision is 1/65536. Three
    # pulls makes it ~(1/65536)^2 ≈ 2e-10 — call it "effectively
    # zero" for CI purposes. If all three match a previously-seen
    # constant like 0x1234, we'd flag the PRNG path.
    var r1 = _sandhi_resolve_random_u16();
    var r2 = _sandhi_resolve_random_u16();
    var r3 = _sandhi_resolve_random_u16();
    # Bounds check.
    assert_eq(r1 >= 0 && r1 < 65536, 1, "random_u16: in range");
    assert_eq(r2 >= 0 && r2 < 65536, 1, "random_u16: in range");
    assert_eq(r3 >= 0 && r3 < 65536, 1, "random_u16: in range");
    # Anti-constant: not all three the same (or same as the old fixed TXID).
    var all_same = 0;
    if (r1 == r2 && r2 == r3) { all_same = 1; }
    assert_eq(all_same, 0, "random_u16: not constant (3-sample heuristic)");
    return 0;
}

fn test_json_build_flat() {
    var o = sandhi_json_obj_new();
    sandhi_json_add_string(o, "name", "firefox");
    sandhi_json_add_int(o, "w3c", 1);
    assert_streq(sandhi_json_build(o), "{\"name\":\"firefox\",\"w3c\":1}", "json build: flat string + int");
    return 0;
}

fn test_json_build_nested() {
    var caps = sandhi_json_obj_new();
    sandhi_json_add_string(caps, "browserName", "firefox");
    sandhi_json_add_bool(caps, "acceptInsecureCerts", 1);
    var outer = sandhi_json_obj_new();
    sandhi_json_add_object(outer, "capabilities", caps);
    assert_streq(sandhi_json_build(outer), "{\"capabilities\":{\"browserName\":\"firefox\",\"acceptInsecureCerts\":true}}", "json build: nested");
    return 0;
}

fn test_json_build_null() {
    var o = sandhi_json_obj_new();
    sandhi_json_add_null(o, "parent");
    assert_streq(sandhi_json_build(o), "{\"parent\":null}", "json build: null");
    return 0;
}

fn test_json_escape_basic() {
    assert_streq(sandhi_json_escape("hello"), "\"hello\"", "escape: plain");
    assert_streq(sandhi_json_escape("say \"hi\""), "\"say \\\"hi\\\"\"", "escape: quotes");
    assert_streq(sandhi_json_escape("line\nbreak"), "\"line\\nbreak\"", "escape: newline");
    assert_streq(sandhi_json_escape("tab\there"), "\"tab\\there\"", "escape: tab");
    assert_streq(sandhi_json_escape("back\\slash"), "\"back\\\\slash\"", "escape: backslash");
    return 0;
}

fn test_json_extract_flat_string() {
    var body = "{\"sessionId\":\"abc-123\",\"other\":42}";
    assert_streq(sandhi_json_get_string(body, "sessionId"), "abc-123", "extract: flat string");
    assert_eq(sandhi_json_get_int(body, "other"), 42, "extract: flat int");
    return 0;
}

fn test_json_extract_nested_string() {
    var body = "{\"value\":{\"sessionId\":\"sess-42\",\"capabilities\":{\"browserName\":\"firefox\"}}}";
    assert_streq(sandhi_json_get_string(body, "value.sessionId"), "sess-42", "extract: one-level nested");
    assert_streq(sandhi_json_get_string(body, "value.capabilities.browserName"), "firefox", "extract: two-level nested");
    return 0;
}

fn test_json_extract_webdriver_error_shape() {
    # Real-shaped W3C WebDriver error envelope.
    var body = "{\"value\":{\"error\":\"no such element\",\"message\":\"not found\",\"stacktrace\":\"\"}}";
    assert_streq(sandhi_json_get_string(body, "value.error"), "no such element", "extract: WebDriver error code");
    assert_streq(sandhi_json_get_string(body, "value.message"), "not found", "extract: WebDriver error message");
    return 0;
}

fn test_json_extract_jsonrpc_error_shape() {
    var body = "{\"jsonrpc\":\"2.0\",\"error\":{\"code\":-32600,\"message\":\"Invalid Request\"},\"id\":1}";
    assert_eq(sandhi_json_get_int(body, "error.code"), 0 - 32600, "extract: JSON-RPC error code");
    assert_streq(sandhi_json_get_string(body, "error.message"), "Invalid Request", "extract: JSON-RPC error message");
    return 0;
}

fn test_json_extract_missing_path() {
    var body = "{\"a\":{\"b\":\"c\"}}";
    assert_eq(sandhi_json_get_string(body, "a.missing"), 0, "extract: missing nested → 0");
    assert_eq(sandhi_json_get_string(body, "x"), 0, "extract: missing top → 0");
    assert_eq(sandhi_json_has_path(body, "a.b"), 1, "has_path: present");
    assert_eq(sandhi_json_has_path(body, "a.missing"), 0, "has_path: absent");
    return 0;
}

fn test_json_extract_with_spaces() {
    var body = "{ \"key\" : \"value\" , \"num\" : 7 }";
    assert_streq(sandhi_json_get_string(body, "key"), "value", "extract: tolerates whitespace");
    assert_eq(sandhi_json_get_int(body, "num"), 7, "extract: int with whitespace");
    return 0;
}

fn test_dispatch_err_extract_webdriver() {
    var body_ok = "{\"value\":{\"sessionId\":\"abc\"}}";
    assert_eq(_sandhi_rpc_err_extract(body_ok, SANDHI_RPC_DIALECT_WEBDRIVER), 0, "dispatch: WD success → 0");

    var body_err = "{\"value\":{\"error\":\"no such element\",\"message\":\"not found\"}}";
    var msg = _sandhi_rpc_err_extract(body_err, SANDHI_RPC_DIALECT_WEBDRIVER);
    assert_streq(msg, "not found", "dispatch: WD error extracts message");
    return 0;
}

fn test_dispatch_err_extract_jsonrpc() {
    var body_ok = "{\"jsonrpc\":\"2.0\",\"id\":1,\"result\":{\"x\":1}}";
    assert_eq(_sandhi_rpc_err_extract(body_ok, SANDHI_RPC_DIALECT_JSONRPC), 0, "dispatch: JSON-RPC success → 0");

    var body_err = "{\"jsonrpc\":\"2.0\",\"id\":1,\"error\":{\"code\":-32600,\"message\":\"Invalid Request\"}}";
    var msg = _sandhi_rpc_err_extract(body_err, SANDHI_RPC_DIALECT_JSONRPC);
    assert_streq(msg, "Invalid Request", "dispatch: JSON-RPC error extracts message");
    return 0;
}

fn test_dispatch_err_generic_no_envelope() {
    var body = "{\"value\":{\"error\":\"ignored\"}}";
    # Generic dialect shouldn't extract — only WebDriver / JSON-RPC do.
    assert_eq(_sandhi_rpc_err_extract(body, SANDHI_RPC_DIALECT_GENERIC), 0, "dispatch: generic → no envelope");
    return 0;
}

fn test_webdriver_url_join() {
    # Various trailing-slash combinations all produce the same shape.
    assert_streq(_sandhi_wd_join("http://127.0.0.1:4444", "/session"), "http://127.0.0.1:4444/session", "wd: no trailing slash on base");
    assert_streq(_sandhi_wd_join("http://127.0.0.1:4444/", "/session"), "http://127.0.0.1:4444/session", "wd: trailing slash absorbed");
    return 0;
}

fn test_webdriver_session_url() {
    assert_streq(_sandhi_wd_session_url("http://127.0.0.1:4444", "sess-1", "/url"), "http://127.0.0.1:4444/session/sess-1/url", "wd: /session/<id>/url");
    assert_streq(_sandhi_wd_session_url("http://127.0.0.1:4444", "sess-1", ""), "http://127.0.0.1:4444/session/sess-1", "wd: session-root");
    # With trailing slash on base.
    assert_streq(_sandhi_wd_session_url("http://x/", "A", "/title"), "http://x/session/A/title", "wd: trailing-slash base trimmed");
    return 0;
}

fn test_webdriver_extract_session_id() {
    # W3C-shaped response.
    var hr_body = "{\"value\":{\"sessionId\":\"abc-w3c\",\"capabilities\":{\"browserName\":\"firefox\"}}}";
    var resp = _sandhi_rpc_resp_new(200, hr_body, strlen(hr_body), SANDHI_OK, 0);
    assert_streq(sandhi_wd_extract_session_id(resp), "abc-w3c", "wd: W3C session id");

    # Pre-W3C fallback.
    var pre_body = "{\"sessionId\":\"old-pre\"}";
    var resp2 = _sandhi_rpc_resp_new(200, pre_body, strlen(pre_body), SANDHI_OK, 0);
    assert_streq(sandhi_wd_extract_session_id(resp2), "old-pre", "wd: pre-W3C fallback");
    return 0;
}

fn test_webdriver_extract_element_id() {
    var body = "{\"value\":{\"element-6066-11e4-a52e-4f735466cecf\":\"elem-uuid-123\"}}";
    var resp = _sandhi_rpc_resp_new(200, body, strlen(body), SANDHI_OK, 0);
    assert_streq(sandhi_wd_extract_element_id(resp), "elem-uuid-123", "wd: W3C element ID");
    return 0;
}

fn test_mcp_envelope_shape() {
    # The envelope should include jsonrpc: "2.0", id: N, method, params.
    # Request-ID counter increments, so we verify shape but not specific id.
    var body = _sandhi_mcp_build_request("tools/list", 0);
    # Just spot-check the structural bits.
    assert_eq(sandhi_json_has_path(body, "jsonrpc"), 1, "mcp: has jsonrpc");
    assert_streq(sandhi_json_get_string(body, "jsonrpc"), "2.0", "mcp: jsonrpc 2.0");
    assert_streq(sandhi_json_get_string(body, "method"), "tools/list", "mcp: method");
    return 0;
}

fn test_mcp_envelope_with_params() {
    var params = "{\"cursor\":\"abc\"}";
    var body = _sandhi_mcp_build_request("resources/list", params);
    assert_streq(sandhi_json_get_string(body, "method"), "resources/list", "mcp: method with params");
    assert_streq(sandhi_json_get_string(body, "params.cursor"), "abc", "mcp: nested param roundtrip");
    return 0;
}

fn test_mcp_id_is_monotonic() {
    var b1 = _sandhi_mcp_build_request("a", 0);
    var b2 = _sandhi_mcp_build_request("b", 0);
    var b3 = _sandhi_mcp_build_request("c", 0);
    var id1 = sandhi_json_get_int(b1, "id");
    var id2 = sandhi_json_get_int(b2, "id");
    var id3 = sandhi_json_get_int(b3, "id");
    assert_eq(id2, id1 + 1, "mcp: id monotonic +1");
    assert_eq(id3, id1 + 2, "mcp: id monotonic +2");
    return 0;
}

fn test_discovery_service_accessors() {
    var s = sandhi_service_new("yantra-worker", "10.0.0.5", 8080, 0x0500000A);
    assert_streq(sandhi_service_name(s), "yantra-worker", "service: name");
    assert_streq(sandhi_service_host(s), "10.0.0.5", "service: host");
    assert_eq(sandhi_service_port(s), 8080, "service: port");
    assert_eq(sandhi_service_ipv4(s), 0x0500000A, "service: ipv4");
    return 0;
}

# Stub resolvers for chain testing — one always-miss, one always-hit.
fn _test_resolver_miss(ctx, name) {
    return 0;
}

fn _test_resolver_hit(ctx, name) {
    # ctx is the port number we want to return; name passes through as service name.
    return sandhi_service_new(name, "127.0.0.1", ctx, 0x0100007F);
}

fn test_discovery_chain_empty() {
    var c = sandhi_discovery_chain_new();
    assert_eq(sandhi_discovery_chain_count(c), 0, "chain: empty count");
    assert_eq(sandhi_discovery_chain_resolve(c, "anything"), 0, "chain: empty resolves to 0");
    return 0;
}

fn test_discovery_chain_all_miss() {
    var c = sandhi_discovery_chain_new();
    sandhi_discovery_chain_add(c, sandhi_resolver_new(&_test_resolver_miss, 0));
    sandhi_discovery_chain_add(c, sandhi_resolver_new(&_test_resolver_miss, 0));
    assert_eq(sandhi_discovery_chain_count(c), 2, "chain: count after 2 adds");
    assert_eq(sandhi_discovery_chain_resolve(c, "svc"), 0, "chain: all-miss returns 0");
    return 0;
}

fn test_discovery_chain_first_hit() {
    var c = sandhi_discovery_chain_new();
    sandhi_discovery_chain_add(c, sandhi_resolver_new(&_test_resolver_hit, 9001));
    sandhi_discovery_chain_add(c, sandhi_resolver_new(&_test_resolver_miss, 0));
    var svc = sandhi_discovery_chain_resolve(c, "a");
    assert_neq(svc, 0, "chain: first-hit resolves");
    assert_eq(sandhi_service_port(svc), 9001, "chain: uses first resolver's port");
    return 0;
}

fn test_discovery_chain_fallthrough() {
    # daimon unreachable → local miss → third resolver hits.
    var c = sandhi_discovery_chain_new();
    sandhi_discovery_chain_add(c, sandhi_resolver_new(&_test_resolver_miss, 0));
    sandhi_discovery_chain_add(c, sandhi_resolver_new(&_test_resolver_miss, 0));
    sandhi_discovery_chain_add(c, sandhi_resolver_new(&_test_resolver_hit, 7777));
    var svc = sandhi_discovery_chain_resolve(c, "svc");
    assert_neq(svc, 0, "chain: fallthrough past misses");
    assert_streq(sandhi_service_host(svc), "127.0.0.1", "chain: host from hitting resolver");
    assert_eq(sandhi_service_port(svc), 7777, "chain: port from hitting resolver");
    return 0;
}

fn test_discovery_chain_as_resolver_nested() {
    # Nest one chain inside another (composition).
    var inner = sandhi_discovery_chain_new();
    sandhi_discovery_chain_add(inner, sandhi_resolver_new(&_test_resolver_hit, 5555));

    var outer = sandhi_discovery_chain_new();
    sandhi_discovery_chain_add(outer, sandhi_resolver_new(&_test_resolver_miss, 0));
    sandhi_discovery_chain_add(outer, sandhi_discovery_chain_as_resolver(inner));

    var svc = sandhi_discovery_chain_resolve(outer, "nested-svc");
    assert_neq(svc, 0, "chain: nested resolves");
    assert_eq(sandhi_service_port(svc), 5555, "chain: nested port");
    return 0;
}

fn test_discovery_daimon_url_building() {
    # No trailing slash on base.
    assert_streq(_sandhi_daimon_url("http://127.0.0.1:9000", "yantra"),
                 "http://127.0.0.1:9000/services/yantra",
                 "daimon: url no trailing slash");
    # With trailing slash on base.
    assert_streq(_sandhi_daimon_url("http://127.0.0.1:9000/", "yantra"),
                 "http://127.0.0.1:9000/services/yantra",
                 "daimon: url trailing slash absorbed");
    return 0;
}

fn test_discovery_daimon_parse_service_roundtrip() {
    var body = "{\"host\":\"10.0.0.42\",\"port\":9100}";
    var s = _sandhi_daimon_parse_service(body, "worker");
    assert_neq(s, 0, "daimon parse: non-null");
    assert_streq(sandhi_service_host(s), "10.0.0.42", "daimon parse: host");
    assert_eq(sandhi_service_port(s), 9100, "daimon parse: port");
    assert_streq(sandhi_service_name(s), "worker", "daimon parse: name copied");
    return 0;
}

fn test_discovery_daimon_parse_service_with_address() {
    var body = "{\"host\":\"node-7.internal\",\"port\":9100,\"address\":\"10.1.2.3\"}";
    var s = _sandhi_daimon_parse_service(body, "srv");
    # address parsed → ipv4 pre-populated. Bytes [10,1,2,3] packed
    # little-endian (matches net.cyr sock_connect shape).
    assert_eq(sandhi_service_ipv4(s), 0x0302010A, "daimon parse: pre-resolved ipv4");
    return 0;
}

fn test_discovery_daimon_parse_service_rejects_malformed() {
    assert_eq(_sandhi_daimon_parse_service("{}", "x"), 0, "daimon parse: empty obj → 0");
    assert_eq(_sandhi_daimon_parse_service("{\"host\":\"h\"}", "x"), 0, "daimon parse: no port → 0");
    assert_eq(_sandhi_daimon_parse_service("{\"host\":\"h\",\"port\":0}", "x"), 0, "daimon parse: port 0 → 0");
    assert_eq(_sandhi_daimon_parse_service("{\"host\":\"h\",\"port\":99999}", "x"), 0, "daimon parse: port >65535 → 0");
    return 0;
}

fn test_discovery_local_stub_always_misses() {
    var r = sandhi_discovery_local_resolver();
    assert_neq(r, 0, "local: resolver non-null");
    assert_eq(sandhi_resolver_lookup(r, "any.local"), 0, "local: stub misses");
    assert_eq(sandhi_discovery_local_available(), 0, "local: available=0 until impl lands");
    return 0;
}

fn test_discovery_register_rejects_bad_inputs() {
    assert_eq(sandhi_discovery_register(0, "n", "h", 80), SANDHI_ERR_INTERNAL, "register: null base_url");
    assert_eq(sandhi_discovery_register("http://x", 0, "h", 80), SANDHI_ERR_INTERNAL, "register: null name");
    assert_eq(sandhi_discovery_register("http://x", "n", 0, 80), SANDHI_ERR_INTERNAL, "register: null host");
    assert_eq(sandhi_discovery_register("http://x", "n", "h", 0), SANDHI_ERR_INTERNAL, "register: port 0");
    assert_eq(sandhi_discovery_register("http://x", "n", "h", 99999), SANDHI_ERR_INTERNAL, "register: port >65535");
    assert_eq(sandhi_discovery_deregister(0, "n"), SANDHI_ERR_INTERNAL, "deregister: null base_url");
    return 0;
}

fn test_tls_policy_default() {
    var p = sandhi_tls_policy_new_default();
    assert_eq(sandhi_tls_policy_flags(p), SANDHI_TLS_POLICY_DEFAULT, "policy: default flags 0");
    assert_eq(sandhi_tls_policy_pinned_hash(p), 0, "policy: default no pin");
    assert_eq(sandhi_tls_policy_mtls_cert(p), 0, "policy: default no mtls");
    assert_eq(sandhi_tls_policy_trust_store(p), 0, "policy: default no trust override");
    return 0;
}

fn test_tls_policy_pinned() {
    var p = sandhi_tls_policy_new_pinned("abc123");
    assert_eq(sandhi_tls_policy_has_flag(p, SANDHI_TLS_POLICY_PINNED), 1, "policy: pinned flag set");
    assert_eq(sandhi_tls_policy_has_flag(p, SANDHI_TLS_POLICY_MTLS), 0, "policy: mtls not set");
    assert_streq(sandhi_tls_policy_pinned_hash(p), "abc123", "policy: pin stored");
    return 0;
}

fn test_tls_policy_mtls() {
    var p = sandhi_tls_policy_new_mtls("/etc/client.pem", "/etc/client.key");
    assert_eq(sandhi_tls_policy_has_flag(p, SANDHI_TLS_POLICY_MTLS), 1, "policy: mtls flag set");
    assert_streq(sandhi_tls_policy_mtls_cert(p), "/etc/client.pem", "policy: mtls cert path");
    assert_streq(sandhi_tls_policy_mtls_key(p), "/etc/client.key", "policy: mtls key path");
    return 0;
}

fn test_tls_policy_trust_store() {
    var p = sandhi_tls_policy_new_trust_store("/etc/ssl/custom-ca.pem");
    assert_eq(sandhi_tls_policy_has_flag(p, SANDHI_TLS_POLICY_CUSTOM_TRUST), 1, "policy: custom trust flag");
    assert_streq(sandhi_tls_policy_trust_store(p), "/etc/ssl/custom-ca.pem", "policy: trust bundle path");
    return 0;
}

fn test_tls_policy_combine_additive() {
    var a = sandhi_tls_policy_new_pinned("pin");
    var b = sandhi_tls_policy_new_mtls("c", "k");
    var c = sandhi_tls_policy_combine(a, b);
    assert_eq(sandhi_tls_policy_has_flag(c, SANDHI_TLS_POLICY_PINNED), 1, "combine: keeps PINNED");
    assert_eq(sandhi_tls_policy_has_flag(c, SANDHI_TLS_POLICY_MTLS), 1, "combine: adds MTLS");
    assert_streq(sandhi_tls_policy_pinned_hash(c), "pin", "combine: pin preserved from a");
    assert_streq(sandhi_tls_policy_mtls_cert(c), "c", "combine: mtls cert from b");
    return 0;
}

fn test_tls_policy_combine_right_wins() {
    var a = sandhi_tls_policy_new_pinned("old-pin");
    var b = sandhi_tls_policy_new_pinned("new-pin");
    var c = sandhi_tls_policy_combine(a, b);
    assert_streq(sandhi_tls_policy_pinned_hash(c), "new-pin", "combine: right-hand wins on conflict");
    return 0;
}

fn test_tls_policy_combine_null_safe() {
    var a = sandhi_tls_policy_new_pinned("pin");
    assert_neq(sandhi_tls_policy_combine(a, 0), 0, "combine: null-rhs passthrough");
    assert_neq(sandhi_tls_policy_combine(0, a), 0, "combine: null-lhs passthrough");
    return 0;
}

fn test_fp_normalize_basic() {
    assert_streq(sandhi_fp_normalize("abcdef"), "abcdef", "fp: lowercase passthrough");
    assert_streq(sandhi_fp_normalize("ABCDEF"), "abcdef", "fp: uppercase → lower");
    assert_streq(sandhi_fp_normalize("AbCdEf"), "abcdef", "fp: mixed case");
    return 0;
}

fn test_fp_normalize_delimiters() {
    assert_streq(sandhi_fp_normalize("ab:cd:ef"), "abcdef", "fp: colons stripped");
    assert_streq(sandhi_fp_normalize("ab cd ef"), "abcdef", "fp: spaces stripped");
    assert_streq(sandhi_fp_normalize("ab\tcd"), "abcd", "fp: tabs stripped");
    assert_streq(sandhi_fp_normalize("ab:CD ef"), "abcdef", "fp: mixed delimiters + case");
    return 0;
}

fn test_fp_normalize_rejects_invalid() {
    assert_eq(sandhi_fp_normalize("xyz"), 0, "fp: non-hex rejected");
    assert_eq(sandhi_fp_normalize("ab!cd"), 0, "fp: punctuation rejected");
    assert_eq(sandhi_fp_normalize(0), 0, "fp: null passthrough");
    return 0;
}

fn test_fp_eq() {
    assert_eq(sandhi_fp_eq("abcdef", "AB:CD:EF"), 1, "fp_eq: case + delimiter insensitive");
    assert_eq(sandhi_fp_eq("abcdef", "abcdee"), 0, "fp_eq: different");
    assert_eq(sandhi_fp_eq("abcdef", ""), 0, "fp_eq: one empty");
    assert_eq(sandhi_fp_eq(0, "abc"), 0, "fp_eq: null never matches");
    assert_eq(sandhi_fp_eq("abc", 0), 0, "fp_eq: null never matches (rhs)");
    return 0;
}

fn test_fp_byte_length() {
    # 64 hex chars = 32 bytes = SHA-256
    assert_eq(sandhi_fp_byte_length("e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"), 32, "fp: SHA-256 length");
    # With colons.
    assert_eq(sandhi_fp_byte_length("e3:b0:c4:42:98:fc:1c:14:9a:fb:f4:c8:99:6f:b9:24:27:ae:41:e4:64:9b:93:4c:a4:95:99:1b:78:52:b8:55"), 32, "fp: SHA-256 with colons");
    # SHA-1 (legacy — 40 chars = 20 bytes)
    assert_eq(sandhi_fp_byte_length("da39a3ee5e6b4b0d3255bfef95601890afd80709"), 20, "fp: SHA-1 length");
    # Odd — malformed
    assert_eq(sandhi_fp_byte_length("abc"), 0, "fp: odd nibble → 0");
    assert_eq(sandhi_fp_byte_length("xyz"), 0, "fp: invalid → 0");
    return 0;
}

fn test_fp_encode_bytes() {
    var buf[4];
    store8(&buf + 0, 0xDE);
    store8(&buf + 1, 0xAD);
    store8(&buf + 2, 0xBE);
    store8(&buf + 3, 0xEF);
    assert_streq(sandhi_fp_encode_bytes(&buf, 4), "deadbeef", "fp: encode raw bytes");
    return 0;
}

fn test_tls_enforcement_flag() {
    # Surface shipped but enforcement-available flag reflects the stub state.
    assert_eq(sandhi_tls_policy_enforcement_available(), 0, "tls: enforcement stubbed today");
    return 0;
}

fn test_sse_single_event() {
    var raw = "data: hello\n\n";
    var rem = alloc(8);
    var events = sandhi_sse_parse(raw, strlen(raw), rem);
    assert_eq(vec_len(events), 1, "sse: one event");
    var e = vec_get(events, 0);
    assert_streq(sandhi_sse_event_name(e), "message", "sse: default event name");
    assert_streq(sandhi_sse_event_data(e), "hello", "sse: data extracted");
    assert_eq(sandhi_sse_event_id(e), 0, "sse: no id");
    assert_eq(sandhi_sse_event_retry(e), 0 - 1, "sse: retry unset → -1");
    return 0;
}

fn test_sse_named_event() {
    var raw = "event: ping\ndata: {}\n\n";
    var rem = alloc(8);
    var events = sandhi_sse_parse(raw, strlen(raw), rem);
    assert_eq(vec_len(events), 1, "sse: one event");
    var e = vec_get(events, 0);
    assert_streq(sandhi_sse_event_name(e), "ping", "sse: named event");
    assert_streq(sandhi_sse_event_data(e), "{}", "sse: JSON payload");
    return 0;
}

fn test_sse_multi_line_data() {
    # WHATWG spec: multiple data: lines concatenate with \n.
    var raw = "data: line one\ndata: line two\ndata: line three\n\n";
    var rem = alloc(8);
    var events = sandhi_sse_parse(raw, strlen(raw), rem);
    assert_eq(vec_len(events), 1, "sse: one event from 3 data lines");
    var e = vec_get(events, 0);
    assert_streq(sandhi_sse_event_data(e), "line one\nline two\nline three", "sse: data concatenated with LF");
    return 0;
}

fn test_sse_id_and_retry() {
    var raw = "id: 42\nretry: 3000\ndata: hi\n\n";
    var rem = alloc(8);
    var events = sandhi_sse_parse(raw, strlen(raw), rem);
    var e = vec_get(events, 0);
    assert_streq(sandhi_sse_event_id(e), "42", "sse: id captured");
    assert_eq(sandhi_sse_event_retry(e), 3000, "sse: retry ms parsed");
    return 0;
}

fn test_sse_comments_ignored() {
    var raw = ": keepalive heartbeat\ndata: hello\n: another comment\n\n";
    var rem = alloc(8);
    var events = sandhi_sse_parse(raw, strlen(raw), rem);
    assert_eq(vec_len(events), 1, "sse: comments don't block event");
    assert_streq(sandhi_sse_event_data(vec_get(events, 0)), "hello", "sse: data still extracted");
    return 0;
}

fn test_sse_multiple_events() {
    var raw = "data: one\n\ndata: two\n\ndata: three\n\n";
    var rem = alloc(8);
    var events = sandhi_sse_parse(raw, strlen(raw), rem);
    assert_eq(vec_len(events), 3, "sse: three events");
    assert_streq(sandhi_sse_event_data(vec_get(events, 0)), "one", "sse: e0");
    assert_streq(sandhi_sse_event_data(vec_get(events, 1)), "two", "sse: e1");
    assert_streq(sandhi_sse_event_data(vec_get(events, 2)), "three", "sse: e2");
    return 0;
}

fn test_sse_crlf_line_endings() {
    var raw = "data: hello\r\n\r\n";
    var rem = alloc(8);
    var events = sandhi_sse_parse(raw, strlen(raw), rem);
    assert_eq(vec_len(events), 1, "sse: CRLF accepted");
    assert_streq(sandhi_sse_event_data(vec_get(events, 0)), "hello", "sse: data clean of CR");
    return 0;
}

fn test_sse_partial_trailing_event() {
    # Last event has no terminating blank line — should stay in remaining.
    var raw = "data: first\n\ndata: partial";
    var rem = alloc(8);
    var events = sandhi_sse_parse(raw, strlen(raw), rem);
    assert_eq(vec_len(events), 1, "sse: only complete event emitted");
    assert_streq(sandhi_sse_event_data(vec_get(events, 0)), "first", "sse: complete one");
    # remaining offset should be just past the first blank-line terminator.
    var r = load64(rem);
    assert_eq(r, 13, "sse: remaining points past 'data: first\\n\\n'");
    return 0;
}

fn test_sse_field_without_space_after_colon() {
    # Spec: optional leading SP after colon is stripped; tight form also valid.
    var raw = "data:tight\n\n";
    var rem = alloc(8);
    var events = sandhi_sse_parse(raw, strlen(raw), rem);
    assert_streq(sandhi_sse_event_data(vec_get(events, 0)), "tight", "sse: no-space variant");
    return 0;
}

fn test_sse_empty_data_field() {
    var raw = "event: ping\ndata:\n\n";
    var rem = alloc(8);
    var events = sandhi_sse_parse(raw, strlen(raw), rem);
    assert_eq(vec_len(events), 1, "sse: event dispatched despite empty data");
    assert_streq(sandhi_sse_event_data(vec_get(events, 0)), "", "sse: empty data value");
    return 0;
}

fn test_sse_blank_line_resets_fields() {
    # After the first event dispatches, event_name should reset to "message".
    var raw = "event: ping\ndata: one\n\ndata: two\n\n";
    var rem = alloc(8);
    var events = sandhi_sse_parse(raw, strlen(raw), rem);
    assert_eq(vec_len(events), 2, "sse: two events");
    assert_streq(sandhi_sse_event_name(vec_get(events, 0)), "ping", "sse: first is named");
    assert_streq(sandhi_sse_event_name(vec_get(events, 1)), "message", "sse: second resets to default");
    return 0;
}

fn test_stream_result_accessors() {
    var r = _sandhi_stream_result(200, 5, SANDHI_OK, 1);
    assert_eq(sandhi_stream_status(r), 200, "stream: status");
    assert_eq(sandhi_stream_events(r), 5, "stream: event count");
    assert_eq(sandhi_stream_err(r), SANDHI_OK, "stream: err_kind");
    assert_eq(sandhi_stream_stopped(r), 1, "stream: stopped-by-cb flag");
    return 0;
}

fn test_stream_chunk_parse_size() {
    var sb = _sandhi_sb_new(256);
    var s = "a\r\n0123456789";
    _sandhi_sb_append(sb, s, strlen(s));
    var sz = _sandhi_chunk_parse_size(sb);
    assert_neq(sz, 0 - 1, "chunk: parse returns valid");
    assert_eq(sz & 0xFFFFFFFF, 10, "chunk: hex a → 10");
    assert_eq((sz >> 32) & 0xFFFFFFFF, 3, "chunk: consumed 'a\\r\\n' (3 bytes)");
    return 0;
}

fn test_stream_chunk_parse_size_incomplete() {
    var sb = _sandhi_sb_new(256);
    var s = "ff";  # no CRLF yet
    _sandhi_sb_append(sb, s, strlen(s));
    assert_eq(_sandhi_chunk_parse_size(sb), 0 - 1, "chunk: incomplete line → -1");
    return 0;
}

fn test_stream_chunk_parse_size_zero() {
    var sb = _sandhi_sb_new(256);
    var s = "0\r\n";
    _sandhi_sb_append(sb, s, strlen(s));
    var sz = _sandhi_chunk_parse_size(sb);
    assert_eq(sz & 0xFFFFFFFF, 0, "chunk: zero-size terminal");
    assert_eq((sz >> 32) & 0xFFFFFFFF, 3, "chunk: consumed terminal line");
    return 0;
}

fn test_stream_chunked_decode_roundtrip() {
    # Two chunks "hello" (5) + " world" (6) + terminal 0.
    var in_sb = _sandhi_sb_new(256);
    var frame = "5\r\nhello\r\n6\r\n world\r\n0\r\n\r\n";
    _sandhi_sb_append(in_sb, frame, strlen(frame));
    var out_sb = _sandhi_sb_new(256);
    var state = _sandhi_chunk_state_new();
    _sandhi_stream_decode_chunked_into(in_sb, state, out_sb);
    assert_eq(_sandhi_chunk_done(state), 1, "chunk: terminal seen");
    assert_eq(_sandhi_sb_len(out_sb), 11, "chunk: 11 bytes decoded");
    # Compare contents.
    var p = _sandhi_sb_ptr(out_sb);
    store8(p + 11, 0);
    assert_streq(p, "hello world", "chunk: decoded bytes");
    return 0;
}

