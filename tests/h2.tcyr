# sandhi h2 test suite — split from sandhi.tcyr at 0.8.0 Bite 2.5
# because the per-program fixup-table cap (32768) made it impossible
# to keep all tests in one file once HPACK + h2 frames + h2 lifecycle
# tests piled up. See docs/proposals/2026-04-24-cyrius-fixup-table-cap.md
# for the upstream-investigation note.

# h2 tests only need the modules they exercise — h2/hpack today,
# h2/frame and h2/conn as later bites land. Trim aggressively to
# stay under the per-program fixup-table cap (32768).
include "src/error.cyr"
include "src/http/h2/huffman.cyr"
include "src/http/h2/hpack.cyr"
include "src/http/h2/frame.cyr"

# ================================================================
# HPACK tests (Bite 2 of 0.8.0) — RFC 7541 Appendix C
# ================================================================

fn test_hpack_static_table_spotcheck() {
    # RFC 7541 Appendix A — verify a handful of indices.
    assert_streq(sandhi_hpack_static_name(1), ":authority", "static[1] name");
    assert_streq(sandhi_hpack_static_name(2), ":method",    "static[2] name");
    assert_streq(sandhi_hpack_static_value(2), "GET",       "static[2] value");
    assert_streq(sandhi_hpack_static_value(3), "POST",      "static[3] value");
    assert_streq(sandhi_hpack_static_name(7), ":scheme",    "static[7] name");
    assert_streq(sandhi_hpack_static_value(7), "https",     "static[7] value");
    assert_streq(sandhi_hpack_static_name(8), ":status",    "static[8] name");
    assert_streq(sandhi_hpack_static_value(8), "200",       "static[8] value");
    assert_streq(sandhi_hpack_static_name(16), "accept-encoding",  "static[16] name");
    assert_streq(sandhi_hpack_static_value(16), "gzip, deflate",   "static[16] value");
    assert_streq(sandhi_hpack_static_name(32), "cookie",   "static[32] name");
    assert_streq(sandhi_hpack_static_name(58), "user-agent", "static[58] name");
    assert_streq(sandhi_hpack_static_name(61), "www-authenticate", "static[61] name");
    assert_eq(sandhi_hpack_static_size(), 61, "static table has 61 entries");
    return 0;
}

# RFC 7541 C.1.1: integer 10, 5-bit prefix → 0x0A
fn test_hpack_int_encode_c11() {
    var buf[4];
    memset(&buf, 0, 4);
    var p = _hpack_int_encode(&buf, 0, 0, 5, 10);
    assert_eq(p, 1, "C.1.1: 1 byte");
    assert_eq(load8(&buf), 10, "C.1.1: 0x0A");
    return 0;
}

# RFC 7541 C.1.2: integer 1337, 5-bit prefix → 0x1F 0x9A 0x0A
fn test_hpack_int_encode_c12() {
    var buf[4];
    memset(&buf, 0, 4);
    var p = _hpack_int_encode(&buf, 0, 0, 5, 1337);
    assert_eq(p, 3, "C.1.2: 3 bytes");
    assert_eq(load8(&buf + 0), 0x1F, "C.1.2: 0x1F");
    assert_eq(load8(&buf + 1), 0x9A, "C.1.2: 0x9A");
    assert_eq(load8(&buf + 2), 0x0A, "C.1.2: 0x0A");
    return 0;
}

# RFC 7541 C.1.3: integer 42, 8-bit prefix → 0x2A
fn test_hpack_int_encode_c13() {
    var buf[4];
    memset(&buf, 0, 4);
    var p = _hpack_int_encode(&buf, 0, 0, 8, 42);
    assert_eq(p, 1, "C.1.3: 1 byte");
    assert_eq(load8(&buf), 42, "C.1.3: 0x2A");
    return 0;
}

fn test_hpack_int_decode_c12() {
    # Reverse C.1.2 — 0x1F 0x9A 0x0A → 1337 with 5-bit prefix.
    var buf[3];
    store8(&buf + 0, 0x1F);
    store8(&buf + 1, 0x9A);
    store8(&buf + 2, 0x0A);
    var off = alloc(8);
    store64(off, 0);
    var v = alloc(8);
    var r = _hpack_int_decode(&buf, 3, off, 5, v);
    assert_eq(r, 0, "decode ok");
    assert_eq(load64(v), 1337, "decode 1337");
    assert_eq(load64(off), 3, "off=3");
    return 0;
}

fn test_hpack_dynamic_table_add_and_lookup() {
    var t = sandhi_hpack_table_new(0);
    assert_eq(sandhi_hpack_table_count(t), 0, "empty");
    sandhi_hpack_table_add(t, "x-custom", "abc");
    assert_eq(sandhi_hpack_table_count(t), 1, "count=1");
    assert_eq(sandhi_hpack_table_size(t), 8 + 3 + 32, "size = name+val+32");
    var no = alloc(8);
    var vo = alloc(8);
    var r = sandhi_hpack_lookup(t, 62, no, vo);
    assert_eq(r, 0, "lookup ok");
    assert_streq(load64(no), "x-custom", "name");
    assert_streq(load64(vo), "abc",      "value");
    return 0;
}

fn test_hpack_dynamic_table_evicts_at_cap() {
    # Each "k0"+"v0" entry = 2+2+32 = 36. Cap 80 fits 2.
    var t = sandhi_hpack_table_new(80);
    sandhi_hpack_table_add(t, "k0", "v0");
    sandhi_hpack_table_add(t, "k1", "v1");
    assert_eq(sandhi_hpack_table_count(t), 2, "fits 2");
    sandhi_hpack_table_add(t, "k2", "v2");
    assert_eq(sandhi_hpack_table_count(t), 2, "still 2");
    var no = alloc(8); var vo = alloc(8);
    sandhi_hpack_lookup(t, 62, no, vo);
    assert_streq(load64(no), "k2", "62=k2");
    sandhi_hpack_lookup(t, 63, no, vo);
    assert_streq(load64(no), "k1", "63=k1");
    var r = sandhi_hpack_lookup(t, 64, no, vo);
    assert_eq(r, _SANDHI_HPACK_ERR_BAD_INDEX, "64 evicted");
    return 0;
}

fn test_hpack_dynamic_table_oversized_drops_all() {
    var t = sandhi_hpack_table_new(50);
    sandhi_hpack_table_add(t, "k", "v");
    assert_eq(sandhi_hpack_table_count(t), 1, "pre-overflow");
    var big_name = alloc(101);
    var big_val  = alloc(101);
    var i = 0;
    while (i < 100) { store8(big_name + i, 65); store8(big_val + i, 66); i = i + 1; }
    store8(big_name + 100, 0);
    store8(big_val + 100, 0);
    sandhi_hpack_table_add(t, big_name, big_val);
    assert_eq(sandhi_hpack_table_count(t), 0, "oversized empties");
    return 0;
}

fn test_hpack_encode_decode_literal_inline() {
    var buf[64];
    memset(&buf, 0, 64);
    var t = sandhi_hpack_table_new(0);
    var p = sandhi_hpack_encode_literal_indexed(t, &buf, 0, "x-foo", "bar");
    assert_eq(p, 11, "literal: 11 bytes");
    assert_eq(load8(&buf + 0), 0x40, "byte 0");
    assert_eq(load8(&buf + 1), 0x05, "byte 1");

    var t2 = sandhi_hpack_table_new(0);
    var off = alloc(8); store64(off, 0);
    var no = alloc(8); var vo = alloc(8);
    var r = sandhi_hpack_decode_field(t2, &buf, 11, off, no, vo);
    assert_eq(r, 0, "decode ok");
    assert_streq(load64(no), "x-foo", "name");
    assert_streq(load64(vo), "bar",   "value");
    assert_eq(sandhi_hpack_table_count(t2), 1, "added to dyn");
    return 0;
}

fn test_hpack_encode_decode_indexed() {
    var buf[2];
    memset(&buf, 0, 2);
    var p = sandhi_hpack_encode_indexed(&buf, 0, 2);
    assert_eq(p, 1, "indexed: 1 byte");
    assert_eq(load8(&buf), 0x82, "indexed: 0x82");

    var off = alloc(8); store64(off, 0);
    var no = alloc(8); var vo = alloc(8);
    var t = sandhi_hpack_table_new(0);
    var r = sandhi_hpack_decode_field(t, &buf, 1, off, no, vo);
    assert_eq(r, 0, "decode ok");
    assert_streq(load64(no), ":method", "name");
    assert_streq(load64(vo), "GET",     "value");
    return 0;
}

fn test_hpack_encode_decode_no_index() {
    var buf[32];
    memset(&buf, 0, 32);
    var p = sandhi_hpack_encode_literal_no_index(&buf, 0, "x-no", "ok");
    assert_eq(p, 1 + 1 + 4 + 1 + 2, "no-index: bytes");
    assert_eq(load8(&buf), 0x00, "no-index marker");

    var off = alloc(8); store64(off, 0);
    var no = alloc(8); var vo = alloc(8);
    var t = sandhi_hpack_table_new(0);
    var r = sandhi_hpack_decode_field(t, &buf, p, off, no, vo);
    assert_eq(r, 0, "decode ok");
    assert_streq(load64(no), "x-no", "name");
    assert_streq(load64(vo), "ok",   "value");
    assert_eq(sandhi_hpack_table_count(t), 0, "no add");
    return 0;
}

fn test_hpack_encode_decode_never_indexed() {
    var buf[32];
    memset(&buf, 0, 32);
    var p = sandhi_hpack_encode_literal_never(&buf, 0, "secret", "tok");
    assert_eq(load8(&buf), 0x10, "never-index marker");

    var off = alloc(8); store64(off, 0);
    var no = alloc(8); var vo = alloc(8);
    var t = sandhi_hpack_table_new(0);
    var r = sandhi_hpack_decode_field(t, &buf, p, off, no, vo);
    assert_eq(r, 0, "decode ok");
    assert_streq(load64(no), "secret", "name");
    assert_eq(sandhi_hpack_table_count(t), 0, "no add");
    return 0;
}

fn test_hpack_dynamic_size_update_decode() {
    var buf[8];
    memset(&buf, 0, 8);
    var p = sandhi_hpack_encode_table_size_update(&buf, 0, 256);
    assert_eq(load8(&buf) & 0xE0, 0x20, "size-update marker");

    var t = sandhi_hpack_table_new(4096);
    var off = alloc(8); store64(off, 0);
    var no = alloc(8); var vo = alloc(8);
    var r = sandhi_hpack_decode_field(t, &buf, p, off, no, vo);
    assert_eq(r, _SANDHI_HPACK_TBL_UPDATE, "size-update sentinel");
    assert_eq(sandhi_hpack_table_max_size(t), 256, "applied");
    return 0;
}

fn test_hpack_huffman_decode_www_example() {
    # RFC 7541 C.4.1 — "www.example.com" Huffman-encoded as 12 bytes:
    #   f1 e3 c2 e5 f2 3a 6b a0 ab 90 f4 ff
    var buf[16];
    memset(&buf, 0, 16);
    store8(&buf + 0, 0xf1);
    store8(&buf + 1, 0xe3);
    store8(&buf + 2, 0xc2);
    store8(&buf + 3, 0xe5);
    store8(&buf + 4, 0xf2);
    store8(&buf + 5, 0x3a);
    store8(&buf + 6, 0x6b);
    store8(&buf + 7, 0xa0);
    store8(&buf + 8, 0xab);
    store8(&buf + 9, 0x90);
    store8(&buf + 10, 0xf4);
    store8(&buf + 11, 0xff);
    var s = sandhi_hpack_huffman_decode(&buf, 0, 12);
    assert_neq(s, 0, "huffman: decoded non-null");
    assert_streq(s, "www.example.com", "huffman: www.example.com");
    return 0;
}

fn test_hpack_huffman_decode_malformed() {
    # Padding that's not all-1s — must reject. 0x00 = 8 zero bits.
    # First 5 bits = '0' (sym 48), then 3 trailing zeros = bad padding.
    var buf[2];
    store8(&buf + 0, 0x00);
    var s = sandhi_hpack_huffman_decode(&buf, 0, 1);
    assert_eq(s, 0, "huffman: bad padding rejected");
    return 0;
}

fn test_hpack_huffman_via_string_decode() {
    # End-to-end: feed a Huffman-encoded string through HPACK's
    # _hpack_string_decode (no longer returns HUFFMAN error).
    # 0x8c = string with H=1, length 12, then the 12 huffman bytes.
    var buf[16];
    memset(&buf, 0, 16);
    store8(&buf + 0, 0x8c);
    store8(&buf + 1, 0xf1);
    store8(&buf + 2, 0xe3);
    store8(&buf + 3, 0xc2);
    store8(&buf + 4, 0xe5);
    store8(&buf + 5, 0xf2);
    store8(&buf + 6, 0x3a);
    store8(&buf + 7, 0x6b);
    store8(&buf + 8, 0xa0);
    store8(&buf + 9, 0xab);
    store8(&buf + 10, 0x90);
    store8(&buf + 11, 0xf4);
    store8(&buf + 12, 0xff);
    var off = alloc(8); store64(off, 0);
    var out_cell = alloc(8);
    var r = _hpack_string_decode(&buf, 13, off, out_cell);
    assert_eq(r, 0, "string decode huffman ok");
    assert_streq(load64(out_cell), "www.example.com", "string decode value");
    return 0;
}

# RFC 7541 C.3.1 — first request in the sequence:
#   :method: GET, :scheme: http, :path: /, :authority: www.example.com
# Wire (no Huffman):
#   82 86 84 41 0F 77 77 77 2E 65 78 61 6D 70 6C 65 2E 63 6F 6D
fn test_hpack_rfc_c31_request_decode() {
    var buf[32];
    memset(&buf, 0, 32);
    store8(&buf + 0, 0x82);
    store8(&buf + 1, 0x86);
    store8(&buf + 2, 0x84);
    store8(&buf + 3, 0x41);
    store8(&buf + 4, 0x0F);
    var host = "www.example.com";
    var i = 0;
    while (i < 15) { store8(&buf + 5 + i, load8(host + i)); i = i + 1; }

    var t = sandhi_hpack_table_new(0);
    var off = alloc(8); store64(off, 0);
    var no = alloc(8); var vo = alloc(8);

    var r1 = sandhi_hpack_decode_field(t, &buf, 20, off, no, vo);
    assert_eq(r1, 0, "C.3.1 #1");
    assert_streq(load64(no), ":method", "C.3.1 #1 name");
    assert_streq(load64(vo), "GET",     "C.3.1 #1 value");

    var r2 = sandhi_hpack_decode_field(t, &buf, 20, off, no, vo);
    assert_eq(r2, 0, "C.3.1 #2");
    assert_streq(load64(vo), "http",    "C.3.1 #2 value");

    var r3 = sandhi_hpack_decode_field(t, &buf, 20, off, no, vo);
    assert_eq(r3, 0, "C.3.1 #3");
    assert_streq(load64(vo), "/",       "C.3.1 #3 value");

    var r4 = sandhi_hpack_decode_field(t, &buf, 20, off, no, vo);
    assert_eq(r4, 0, "C.3.1 #4");
    assert_streq(load64(no), ":authority",       "C.3.1 #4 name");
    assert_streq(load64(vo), "www.example.com",  "C.3.1 #4 value");

    assert_eq(sandhi_hpack_table_count(t), 1, "C.3.1: 1 dyn entry");
    return 0;
}

# ================================================================
# h2/frame tests (Bite 3 of 0.8.0) — RFC 7540 §4.1, §6
# ================================================================

fn test_h2_hdr_roundtrip() {
    # length=42, type=DATA, flags=END_STREAM, stream_id=7
    var out[16];
    memset(&out, 0, 16);
    var n = sandhi_h2_hdr_encode(&out, 0, 42, 0x0, 0x1, 7);
    assert_eq(n, 9, "hdr enc: 9 bytes");
    # length 24 BE: 00 00 2A
    assert_eq(load8(&out + 0), 0x00, "byte 0");
    assert_eq(load8(&out + 1), 0x00, "byte 1");
    assert_eq(load8(&out + 2), 0x2A, "byte 2 = 42");
    assert_eq(load8(&out + 3), 0x00, "type DATA");
    assert_eq(load8(&out + 4), 0x01, "flags END_STREAM");
    # stream_id 31 BE: 00 00 00 07
    assert_eq(load8(&out + 8), 0x07, "sid byte 3 = 7");

    var h = sandhi_h2_hdr_decode(&out, 9, 0);
    assert_eq(sandhi_h2_hdr_length(h),    42, "dec length");
    assert_eq(sandhi_h2_hdr_type(h),      0x0, "dec type");
    assert_eq(sandhi_h2_hdr_flags(h),     0x1, "dec flags");
    assert_eq(sandhi_h2_hdr_stream_id(h), 7,   "dec sid");
    return 0;
}

fn test_h2_hdr_strips_reserved_bit() {
    # Stream ID with high bit set MUST be ignored on read (§4.1).
    var buf[9];
    memset(&buf, 0, 9);
    # length=0, type=PING, flags=0
    store8(&buf + 5, 0xFF);  # high bit + 0x7F in next-most byte
    store8(&buf + 6, 0xFF);
    store8(&buf + 7, 0xFF);
    store8(&buf + 8, 0xFF);
    var h = sandhi_h2_hdr_decode(&buf, 9, 0);
    # 0xFFFFFFFF & 0x7FFFFFFF = 0x7FFFFFFF
    assert_eq(sandhi_h2_hdr_stream_id(h), 0x7FFFFFFF, "reserved bit stripped");
    return 0;
}

fn test_h2_hdr_rejects_oversize_length() {
    var out[16];
    memset(&out, 0, 16);
    var r = sandhi_h2_hdr_encode(&out, 0, 0x1000000, 0, 0, 0);
    assert_eq(r, _SANDHI_H2_ERR_BAD_LENGTH, "length > 2^24-1 rejected");
    return 0;
}

fn test_h2_hdr_rejects_high_bit_stream() {
    var out[16];
    memset(&out, 0, 16);
    var r = sandhi_h2_hdr_encode(&out, 0, 0, 0, 0, 0x80000000);
    assert_eq(r, _SANDHI_H2_ERR_BAD_STREAM, "stream_id high bit rejected");
    return 0;
}

fn test_h2_settings_pair_roundtrip() {
    var out[16];
    memset(&out, 0, 16);
    # SETTINGS_MAX_CONCURRENT_STREAMS = 100
    var n = sandhi_h2_settings_pair_encode(&out, 0, 0x3, 100);
    assert_eq(n, 6, "settings pair: 6 bytes");
    # id 16 BE: 00 03
    assert_eq(load8(&out + 0), 0x00, "id high");
    assert_eq(load8(&out + 1), 0x03, "id low");
    # value 32 BE: 00 00 00 64
    assert_eq(load8(&out + 5), 0x64, "value low byte = 100");

    var id_cell = alloc(8); var v_cell = alloc(8);
    var off = sandhi_h2_settings_pair_decode(&out, 6, 0, id_cell, v_cell);
    assert_eq(off, 6, "decode advanced 6");
    assert_eq(load64(id_cell), 0x3, "decoded id");
    assert_eq(load64(v_cell), 100, "decoded value");
    return 0;
}

fn test_h2_window_update_roundtrip() {
    var out[8];
    memset(&out, 0, 8);
    var n = sandhi_h2_window_update_encode(&out, 0, 65535);
    assert_eq(n, 4, "window: 4 bytes");
    var v = sandhi_h2_window_update_decode(&out, 4, 0);
    assert_eq(v, 65535, "decoded increment");
    return 0;
}

fn test_h2_window_update_rejects_zero() {
    var out[8];
    memset(&out, 0, 8);
    var r = sandhi_h2_window_update_encode(&out, 0, 0);
    assert_eq(r, _SANDHI_H2_ERR_MALFORMED, "increment 0 rejected");
    return 0;
}

fn test_h2_rst_stream_roundtrip() {
    var out[8];
    memset(&out, 0, 8);
    sandhi_h2_rst_stream_encode(&out, 0, 0x8);  # CANCEL
    var ec = sandhi_h2_rst_stream_decode(&out, 4, 0);
    assert_eq(ec, 0x8, "rst CANCEL");
    return 0;
}

fn test_h2_goaway_roundtrip() {
    var out[16];
    memset(&out, 0, 16);
    # last_stream_id=42, error=PROTOCOL_ERROR, no debug
    var n = sandhi_h2_goaway_encode(&out, 0, 42, 0x1, 0, 0);
    assert_eq(n, 8, "goaway: 8 bytes (no debug)");
    var sid_cell = alloc(8); var err_cell = alloc(8);
    var r = sandhi_h2_goaway_decode(&out, 8, 0, sid_cell, err_cell);
    assert_eq(r, 0, "goaway decode ok");
    assert_eq(load64(sid_cell), 42,  "last_stream");
    assert_eq(load64(err_cell), 0x1, "error PROTOCOL");
    return 0;
}

fn test_h2_ping_roundtrip() {
    var payload = "abcdefgh";  # 8 bytes
    var out[16];
    memset(&out, 0, 16);
    var n = sandhi_h2_ping_encode(&out, 0, payload);
    assert_eq(n, 8, "ping: 8 bytes");
    assert_eq(load8(&out + 0), 97, "ping byte 0 = 'a'");
    assert_eq(load8(&out + 7), 104, "ping byte 7 = 'h'");
    return 0;
}

fn main() {
    alloc_init();

    test_group("h2/hpack/static_table");
    test_hpack_static_table_spotcheck();

    test_group("h2/hpack/int_c11");
    test_hpack_int_encode_c11();

    test_group("h2/hpack/int_c12");
    test_hpack_int_encode_c12();

    test_group("h2/hpack/int_c13");
    test_hpack_int_encode_c13();

    test_group("h2/hpack/int_decode_c12");
    test_hpack_int_decode_c12();

    test_group("h2/hpack/dyn_add");
    test_hpack_dynamic_table_add_and_lookup();

    test_group("h2/hpack/dyn_evict");
    test_hpack_dynamic_table_evicts_at_cap();

    test_group("h2/hpack/dyn_oversized");
    test_hpack_dynamic_table_oversized_drops_all();

    test_group("h2/hpack/literal_inline");
    test_hpack_encode_decode_literal_inline();

    test_group("h2/hpack/indexed");
    test_hpack_encode_decode_indexed();

    test_group("h2/hpack/no_index");
    test_hpack_encode_decode_no_index();

    test_group("h2/hpack/never_indexed");
    test_hpack_encode_decode_never_indexed();

    test_group("h2/hpack/size_update");
    test_hpack_dynamic_size_update_decode();

    test_group("h2/hpack/huffman_www");
    test_hpack_huffman_decode_www_example();

    test_group("h2/hpack/huffman_malformed");
    test_hpack_huffman_decode_malformed();

    test_group("h2/hpack/huffman_via_string");
    test_hpack_huffman_via_string_decode();

    test_group("h2/hpack/rfc_c31");
    test_hpack_rfc_c31_request_decode();

    test_group("h2/frame/hdr_roundtrip");
    test_h2_hdr_roundtrip();

    test_group("h2/frame/hdr_strips_reserved");
    test_h2_hdr_strips_reserved_bit();

    test_group("h2/frame/hdr_oversize");
    test_h2_hdr_rejects_oversize_length();

    test_group("h2/frame/hdr_high_bit_stream");
    test_h2_hdr_rejects_high_bit_stream();

    test_group("h2/frame/settings_pair");
    test_h2_settings_pair_roundtrip();

    test_group("h2/frame/window_update");
    test_h2_window_update_roundtrip();

    test_group("h2/frame/window_update_zero");
    test_h2_window_update_rejects_zero();

    test_group("h2/frame/rst_stream");
    test_h2_rst_stream_roundtrip();

    test_group("h2/frame/goaway");
    test_h2_goaway_roundtrip();

    test_group("h2/frame/ping");
    test_h2_ping_roundtrip();

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
