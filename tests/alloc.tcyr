# sandhi alloc test suite — covers the v1.1.0 Allocator-as-first-arg
# migration. Lives in its own .tcyr so it doesn't push tests/sandhi.tcyr
# over the per-program fixup-table cap (architecture/001).
#
# Each batch of the migration adds a `test_alloc_batchN_*` group below
# that drives the per-request-arena pattern + OOM coverage for at least
# one `_a` variant in that batch (proposal acceptance gates 4 + 5).

include "src/version_str.cyr"
include "src/error.cyr"
include "src/obs/trace.cyr"
include "src/http/headers.cyr"
include "src/http/url.cyr"
include "src/http/conn.cyr"
include "src/http/response.cyr"
include "src/net/resolve.cyr"
include "src/http/client.cyr"
include "src/http/pool.cyr"
include "src/http/h2/huffman.cyr"
include "src/http/h2/hpack.cyr"
include "src/http/h2/frame.cyr"
include "src/http/h2/conn.cyr"
include "src/http/sse.cyr"
include "src/http/stream.cyr"
include "src/http/retry.cyr"
include "src/server/mod.cyr"
include "src/tls_policy/policy.cyr"
include "src/tls_policy/fingerprint.cyr"
include "src/rpc/json.cyr"
include "src/rpc/dispatch.cyr"
include "src/rpc/webdriver.cyr"
include "src/discovery/service.cyr"
include "src/discovery/chain.cyr"
include "src/discovery/daimon.cyr"
include "src/discovery/local.cyr"
include "src/main.cyr"  # sandhi_version() — referenced by http/client.cyr's UA builder

# ================================================================
# Batch 1 — leaves
# ================================================================

# url.cyr — per-request-arena round-trip. Parse two URLs into the
# same arena across a reset; verify reset reclaims the first parse.
fn test_alloc_batch1_url_arena_reset() {
    var a = arena_allocator(4096);
    assert_eq(a != 0, 1, "arena_allocator(4096) constructed");

    var u1 = sandhi_url_parse_a(a, "http://example.com:8080/foo?bar=baz");
    assert_eq(u1 != 0, 1, "url parse #1 into arena succeeded");
    assert_eq(sandhi_url_scheme(u1), SANDHI_URL_HTTP, "scheme #1");
    assert_eq(sandhi_url_port(u1), 8080, "port #1");
    assert_streq(sandhi_url_host(u1), "example.com", "host #1");
    assert_streq(sandhi_url_path(u1), "/foo", "path #1");
    assert_streq(sandhi_url_query(u1), "bar=baz", "query #1");

    var used_after_first = arena_used(allocator_state(a));
    assert_eq(used_after_first > 0, 1, "arena bytes consumed by parse #1");

    reset_via(a);

    var used_after_reset = arena_used(allocator_state(a));
    assert_eq(used_after_reset, 0, "reset_via clears arena");

    var u2 = sandhi_url_parse_a(a, "https://[::1]:443/");
    assert_eq(u2 != 0, 1, "url parse #2 into reset arena succeeded");
    assert_eq(sandhi_url_scheme(u2), SANDHI_URL_HTTPS, "scheme #2");
    assert_eq(sandhi_url_port(u2), 443, "port #2");
    assert_streq(sandhi_url_host(u2), "::1", "v6 host stripped of brackets");
    return 0;
}

# url.cyr — OOM via fail_after_n_allocs. The host parse path takes
# 2 allocs (host cstr + struct) for the simplest input
# "http://example.com/"; failing after 1 should yield 0 cleanly.
fn test_alloc_batch1_url_oom() {
    var a = fail_after_n_allocs(1);
    assert_eq(a != 0, 1, "fail_after_n_allocs(1) constructed");
    var u = sandhi_url_parse_a(a, "http://example.com/");
    assert_eq(u, 0, "OOM at second alloc → parse returns 0, no abort");
    return 0;
}

# headers.cyr — arena reset reclaims a parsed header block.
fn test_alloc_batch1_headers_arena_reset() {
    var a = arena_allocator(4096);
    var raw = "X-One: alpha\r\nX-Two: beta\r\n\r\n";
    var rlen = strlen(raw);

    var h1 = sandhi_headers_parse_a(a, raw, rlen);
    assert_eq(h1 != 0, 1, "headers parse #1 into arena");
    assert_eq(sandhi_headers_count(h1), 2, "two entries parsed");
    assert_streq(sandhi_headers_get(h1, "x-one"), "alpha", "case-insensitive get");

    var used_after_first = arena_used(allocator_state(a));
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "arena cleared");
    assert_eq(used_after_first > 0, 1, "first parse did consume bytes");

    var h2 = sandhi_headers_parse_a(a, raw, rlen);
    assert_eq(h2 != 0, 1, "headers parse #2 into reset arena");
    assert_eq(sandhi_headers_count(h2), 2, "two entries parsed (round 2)");
    return 0;
}

# headers.cyr — OOM. add_a returns -2 on alloc failure (not -1
# which is byte-rejection). Drive a 0-budget allocator to confirm.
fn test_alloc_batch1_headers_add_oom() {
    var a = arena_allocator(4096);
    var h = sandhi_headers_new_a(a);
    assert_eq(h != 0, 1, "block allocated");

    # Switch to a failing alloc for the actual add. fail_after(0)
    # makes EVERY alloc fail.
    var failer = fail_after_n_allocs(0);
    var rc = sandhi_headers_add_a(failer, h, "X-Test", "value");
    assert_eq(rc, 0 - 2, "add_a returns -2 on OOM");
    return 0;
}

# service.cyr — service_new_a OOM yields 0 cleanly.
fn test_alloc_batch1_service_oom() {
    var failer = fail_after_n_allocs(0);
    var s = sandhi_service_new_a(failer, "x", "host", 80, 0);
    assert_eq(s, 0, "service_new_a returns 0 on OOM");
    return 0;
}

# pool.cyr — pool_new_a stores the allocator on the struct.
fn test_alloc_batch1_pool_alloc_slot() {
    var a = arena_allocator(8192);
    var p = sandhi_http_pool_new_a(a, 4, 60000);
    assert_eq(p != 0, 1, "pool_new_a succeeded");
    assert_eq(sandhi_http_pool_max_per_host(p), 4, "max_per_host stored");
    # Confirm the allocator slot round-trips: _sandhi_pool_alloc(p)
    # must be the same pointer we handed in.
    assert_eq(_sandhi_pool_alloc(p) == a, 1, "pool stores allocator handle");
    return 0;
}

# h2/frame.cyr — hdr_new_a + hdr_decode_a + OOM round-trip.
fn test_alloc_batch1_h2_hdr_arena() {
    var a = arena_allocator(1024);
    var h = sandhi_h2_hdr_new_a(a, 16, SANDHI_H2_FRAME_DATA, 0, 1);
    assert_eq(h != 0, 1, "h2 hdr alloced into arena");
    assert_eq(sandhi_h2_hdr_length(h), 16, "length round-trip");
    assert_eq(sandhi_h2_hdr_type(h), SANDHI_H2_FRAME_DATA, "type round-trip");
    assert_eq(sandhi_h2_hdr_stream_id(h), 1, "stream_id round-trip");

    var failer = fail_after_n_allocs(0);
    var h_oom = sandhi_h2_hdr_new_a(failer, 0, 0, 0, 0);
    assert_eq(h_oom, 0, "hdr_new_a returns 0 on OOM");
    return 0;
}

# ================================================================
# Batch 2 — TLS + h2 leaves
# ================================================================

# fingerprint.cyr — normalize/encode/eq into an arena, then OOM.
fn test_alloc_batch2_fingerprint_arena() {
    var a = arena_allocator(1024);

    var raw = "E3:B0:C4:42:98:FC:1C:14";
    var n = sandhi_fp_normalize_a(a, raw);
    assert_eq(n != 0, 1, "fp_normalize_a into arena");
    assert_streq(n, "e3b0c44298fc1c14", "lowercased + delimiters stripped");

    var bytes[3];
    store8(&bytes + 0, 0xab);
    store8(&bytes + 1, 0xcd);
    store8(&bytes + 2, 0xef);
    var hex = sandhi_fp_encode_bytes_a(a, &bytes, 3);
    assert_streq(hex, "abcdef", "encode_bytes_a into arena");

    assert_eq(sandhi_fp_eq_a(a, "AB:CD:EF", "abcdef"), 1, "fp_eq_a delimiter+case insensitive");
    assert_eq(sandhi_fp_eq_a(a, "abcdef", "abcd00"), 0, "fp_eq_a different fingerprint");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_fp_normalize_a(failer, "abcd"), 0, "normalize_a OOM → 0");
    assert_eq(sandhi_fp_encode_bytes_a(failer, &bytes, 3), 0, "encode_bytes_a OOM → 0");
    return 0;
}

# policy.cyr — combined policy built into an arena and reset.
fn test_alloc_batch2_policy_arena_combine() {
    var a = arena_allocator(2048);

    var pinned = sandhi_tls_policy_new_pinned_a(a, "deadbeef");
    var mtls   = sandhi_tls_policy_new_mtls_a(a, "/cert.pem", "/key.pem");
    assert_eq(pinned != 0, 1, "pinned policy in arena");
    assert_eq(mtls   != 0, 1, "mtls policy in arena");

    var combined = sandhi_tls_policy_combine_a(a, pinned, mtls);
    assert_eq(combined != 0, 1, "combine_a into arena");
    var flags = sandhi_tls_policy_flags(combined);
    assert_eq(flags & SANDHI_TLS_POLICY_PINNED, SANDHI_TLS_POLICY_PINNED, "flags carry pinned");
    assert_eq(flags & SANDHI_TLS_POLICY_MTLS,   SANDHI_TLS_POLICY_MTLS,   "flags carry mtls");
    assert_streq(sandhi_tls_policy_pinned_hash(combined), "deadbeef", "pin survives combine");
    assert_streq(sandhi_tls_policy_mtls_cert(combined),   "/cert.pem", "cert survives combine");

    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "policy arena reset");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_tls_policy_new_default_a(failer), 0, "default_a OOM → 0");
    return 0;
}

# huffman.cyr — decode_a into an arena. The static decode tree is
# pinned to default_alloc, so resetting the per-call arena does NOT
# break subsequent decodes.
fn test_alloc_batch2_huffman_decode_arena() {
    # RFC 7541 C.4.1 — Huffman("www.example.com") =
    # f1e3 c2e5 f23a 6ba0 ab90 f4ff (12 bytes).
    var enc[12];
    store8(&enc + 0,  0xf1); store8(&enc + 1,  0xe3);
    store8(&enc + 2,  0xc2); store8(&enc + 3,  0xe5);
    store8(&enc + 4,  0xf2); store8(&enc + 5,  0x3a);
    store8(&enc + 6,  0x6b); store8(&enc + 7,  0xa0);
    store8(&enc + 8,  0xab); store8(&enc + 9,  0x90);
    store8(&enc + 10, 0xf4); store8(&enc + 11, 0xff);

    var a = arena_allocator(4096);
    var s = sandhi_hpack_huffman_decode_a(a, &enc, 0, 12);
    assert_streq(s, "www.example.com", "huffman decode_a into arena");

    reset_via(a);
    var s2 = sandhi_hpack_huffman_decode_a(a, &enc, 0, 12);
    assert_streq(s2, "www.example.com", "decode after arena reset (static tree intact)");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_hpack_huffman_decode_a(failer, &enc, 0, 12), 0, "decode_a OOM → 0");
    return 0;
}

# hpack.cyr — table_new_a + decode_field_a into an arena.
fn test_alloc_batch2_hpack_table_arena() {
    var a = arena_allocator(8192);
    var t = sandhi_hpack_table_new_a(a, 4096);
    assert_eq(t != 0, 1, "hpack table_new_a in arena");
    assert_eq(sandhi_hpack_table_count(t), 0, "table starts empty");
    assert_eq(sandhi_hpack_table_max_size(t), 4096, "max_size honored");

    sandhi_hpack_table_add_a(a, t, "x-custom", "value");
    assert_eq(sandhi_hpack_table_count(t), 1, "add_a inserted entry");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_hpack_table_new_a(failer, 4096), 0, "table_new_a OOM → 0");
    return 0;
}

# ================================================================
# Batch 3 — discovery + rpc
# ================================================================

# rpc/json.cyr — build a nested JSON object into an arena, parse a
# response body via dotted-path extraction also routed through the
# arena, then reset to reclaim everything.
fn test_alloc_batch3_json_arena() {
    var a = arena_allocator(8192);
    var inner = sandhi_json_obj_new_a(a);
    sandhi_json_add_string_a(a, inner, "browser", "firefox");
    sandhi_json_add_int_a(a, inner, "w3c", 1);

    var outer = sandhi_json_obj_new_a(a);
    sandhi_json_add_object_a(a, outer, "capabilities", inner);
    sandhi_json_add_bool_a(a, outer, "strict", 1);

    var wire = sandhi_json_build_a(a, outer);
    assert_eq(wire != 0, 1, "json_build_a into arena");
    # Extract from the rendered wire — proves both build + extract
    # round-trip into `a`.
    var got = sandhi_json_get_string_a(a, wire, "capabilities.browser");
    assert_streq(got, "firefox", "nested object string extraction");
    assert_eq(sandhi_json_get_int_a(a, wire, "capabilities.w3c"), 1, "int extraction");
    assert_eq(sandhi_json_has_path_a(a, wire, "missing"), 0, "absent path → 0");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena consumed bytes");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "json arena cleared");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_json_get_string_a(failer, "{\"x\":\"y\"}", "x"), 0, "get_string_a OOM → 0");
    return 0;
}

# rpc/dispatch.cyr — wrap a synthetic HTTP response into an rpc-resp
# struct using `_a`. Uses a faked HTTP response built directly via
# _sandhi_resp_new since we don't want a live transport call here.
fn test_alloc_batch3_dispatch_wrap_arena() {
    var a = arena_allocator(4096);

    # Build a JSON-RPC error envelope body.
    var body = "{\"jsonrpc\":\"2.0\",\"error\":{\"code\":42,\"message\":\"boom\"},\"id\":1}";
    var blen = strlen(body);
    var hr = _sandhi_resp_new(200, body, blen, sandhi_headers_new(), SANDHI_OK);
    var rpc = _sandhi_rpc_wrap_a(a, hr, SANDHI_RPC_DIALECT_JSONRPC);
    assert_eq(rpc != 0, 1, "rpc resp built in arena");
    assert_eq(sandhi_rpc_err_kind(rpc), SANDHI_ERR_REMOTE, "json-rpc error envelope detected");
    assert_streq(sandhi_rpc_err_message(rpc), "boom", "error message extracted");
    assert_eq(sandhi_rpc_http_status(rpc), 200, "http status preserved");

    var failer = fail_after_n_allocs(0);
    var rpc_oom = _sandhi_rpc_resp_new_a(failer, 0, 0, 0, 0, 0);
    assert_eq(rpc_oom, 0, "_sandhi_rpc_resp_new_a OOM → 0");
    return 0;
}

# rpc/webdriver.cyr — URL builders into an arena.
fn test_alloc_batch3_webdriver_url_arena() {
    var a = arena_allocator(4096);
    var u1 = _sandhi_wd_join_a(a, "http://drv:4444", "/status");
    assert_streq(u1, "http://drv:4444/status", "_wd_join_a no-trailing");
    var u2 = _sandhi_wd_join_a(a, "http://drv:4444/", "/status");
    assert_streq(u2, "http://drv:4444/status", "_wd_join_a trailing-slash trimmed");

    var u3 = _sandhi_wd_session_url_a(a, "http://drv:4444", "abc123", "/element");
    assert_streq(u3, "http://drv:4444/session/abc123/element", "_wd_session_url_a built");

    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_wd_join_a(failer, "http://drv", "/x"), 0, "_wd_join_a OOM → 0");
    return 0;
}

# ================================================================
# Batch 4 — HTTP response/request foundation
# ================================================================

# response.cyr — central response constructor lands the entire
# response (headers, body, struct) in a single arena. Reset reclaims
# everything in one shot — the headline per-request-arena win.
fn test_alloc_batch4_response_parse_arena() {
    var a = arena_allocator(8192);

    var raw = "HTTP/1.1 200 OK\r\nContent-Length: 5\r\nContent-Type: text/plain\r\n\r\nhello";
    var rlen = strlen(raw);

    var resp = sandhi_http_response_parse_a(a, raw, rlen);
    assert_eq(resp != 0, 1, "response parsed into arena");
    assert_eq(sandhi_http_status(resp), 200, "status decoded");
    assert_eq(sandhi_http_body_len(resp), 5, "body len decoded");
    assert_streq(sandhi_http_body(resp), "hello", "body bytes decoded");
    assert_eq(sandhi_http_err_kind(resp), SANDHI_OK, "no err");
    assert_streq(sandhi_headers_get(sandhi_http_headers(resp), "Content-Type"),
    "text/plain", "header surfaced");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena consumed bytes for headers + body + struct");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "arena cleared in one shot");

    # Round 2 — same arena, fresh response.
    var resp2 = sandhi_http_response_parse_a(a, raw, rlen);
    assert_eq(sandhi_http_status(resp2), 200, "second parse into reset arena");
    return 0;
}

# response.cyr — chunked decode through the per-request arena.
fn test_alloc_batch4_chunked_arena() {
    var a = arena_allocator(8192);
    var raw = "HTTP/1.1 200 OK\r\nTransfer-Encoding: chunked\r\n\r\n5\r\nhello\r\n6\r\n world\r\n0\r\n\r\n";
    var rlen = strlen(raw);

    var resp = sandhi_http_response_parse_a(a, raw, rlen);
    assert_eq(sandhi_http_status(resp), 200, "chunked status");
    assert_eq(sandhi_http_body_len(resp), 11, "chunked body len");
    assert_streq(sandhi_http_body(resp), "hello world", "chunked body content");
    return 0;
}

# response.cyr — error responses also flow through `a` (no global-bump
# leak even on parse failure).
fn test_alloc_batch4_resp_err_arena() {
    var a = arena_allocator(2048);
    var resp = sandhi_http_response_parse_a(a, "not http", 8);
    assert_eq(sandhi_http_err_kind(resp), SANDHI_ERR_PROTOCOL, "malformed → PROTOCOL err");
    assert_eq(sandhi_http_status(resp), 0, "status 0 on err");
    assert_eq(sandhi_http_headers(resp) != 0, 1, "headers block always non-null");
    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "err response was allocated from arena");
    return 0;
}

# response.cyr — OOM. fail_after(0) means even the first alloc fails;
# _resp_new_a returns 0 cleanly. Then the err shortcut also returns 0
# (since headers_new_a fails → _resp_err_a's headers param is 0, but
# _resp_err_a still tries to alloc the resp struct itself — which
# also fails → returns 0).
fn test_alloc_batch4_resp_oom() {
    var failer = fail_after_n_allocs(0);
    var r = _sandhi_resp_new_a(failer, 200, 0, 0, 0, SANDHI_OK);
    assert_eq(r, 0, "_sandhi_resp_new_a returns 0 on OOM");
    var r2 = _sandhi_resp_err_a(failer, SANDHI_ERR_PROTOCOL);
    assert_eq(r2, 0, "_sandhi_resp_err_a returns 0 on OOM");
    return 0;
}

# ================================================================
# Batch 5 — connection layer
# ================================================================

# conn.cyr — _set_timeout_ms_a allocates a 16-byte timeval into `a`.
# We can't easily exercise the open path (needs a real network),
# but the timeval helper is deterministic.
fn test_alloc_batch5_conn_timeout_arena() {
    var a = arena_allocator(2048);
    # ms <= 0 short-circuits without touching `a`.
    assert_eq(_sandhi_conn_set_timeout_ms_a(a, 0, 0, _SANDHI_SO_RCVTIMEO), 0,
    "ms<=0 returns 0 without alloc");
    var used_after_noop = arena_used(allocator_state(a));
    assert_eq(used_after_noop, 0, "no-op didn't touch arena");

    # ms>0 with fd=-1 — alloc happens, syscall fails. We only assert
    # the alloc landed in `a` (used > 0).
    _sandhi_conn_set_timeout_ms_a(a, 0 - 1, 1000, _SANDHI_SO_RCVTIMEO);
    var used_after_set = arena_used(allocator_state(a));
    assert_eq(used_after_set > 0, 1, "timeval allocated into arena");

    # OOM. fail_after(0) → alloc fails → returns -1.
    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_conn_set_timeout_ms_a(failer, 0 - 1, 1000, _SANDHI_SO_RCVTIMEO),
    0 - 1, "set_timeout_ms_a OOM → -1");
    return 0;
}

# h2/conn.cyr — h2 conn struct + enc/dec hpack tables all land in `a`.
fn test_alloc_batch5_h2_conn_arena() {
    var a = arena_allocator(8192);
    # Underlying sandhi_conn ptr can be 0 — h2_conn_new just stores
    # the value, doesn't dereference.
    var c = sandhi_h2_conn_new_a(a, 0);
    assert_eq(c != 0, 1, "h2_conn_new_a built struct in arena");
    assert_eq(sandhi_h2_conn_underlying(c), 0, "underlying ptr stored");
    assert_eq(sandhi_h2_conn_enc_table(c) != 0, 1, "enc table allocated");
    assert_eq(sandhi_h2_conn_dec_table(c) != 0, 1, "dec table allocated");
    assert_eq(sandhi_h2_conn_peer_max_frame(c), _SANDHI_H2_DEFAULT_PEER_FRAME,
    "default peer max-frame initialized");
    # next_stream_id starts at 1 and bumps by 2.
    assert_eq(sandhi_h2_conn_next_stream_id(c), 1, "first stream id = 1");
    assert_eq(sandhi_h2_conn_next_stream_id(c), 3, "second stream id = 3");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_h2_conn_new_a(failer, 0), 0, "h2_conn_new_a OOM → 0");
    return 0;
}

# resolve.cyr — _name_eq_a's 8 transient cells round-trip into `a`.
# Build two compressed-name buffers and compare.
fn test_alloc_batch5_resolve_name_eq_arena() {
    var a = arena_allocator(4096);

    # Build a tiny DNS-like buf with two names to compare. Layout:
    # offset 0: "example.com" labels = 07 e x a m p l e 03 c o m 00
    # offset 13: same again
    # offset 26: "EXAMPLE.com" — case-different
    var buf[39];
    var labels = "\x07example\x03com\x00\x07example\x03com\x00\x07EXAMPLE\x03com\x00";
    var i = 0;
    while (i < 39) { store8(&buf + i, load8(labels + i)); i = i + 1; }

    assert_eq(_sandhi_resolve_name_eq_a(a, &buf, 39, 0, 13), 1,
    "identical names compare equal");
    assert_eq(_sandhi_resolve_name_eq_a(a, &buf, 39, 0, 26), 1,
    "case-insensitive equal");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "name_eq scratch landed in arena");

    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "arena reset reclaimed scratch");

    # Round 2 — same arena.
    assert_eq(_sandhi_resolve_name_eq_a(a, &buf, 39, 0, 13), 1, "round 2 still works");
    return 0;
}

# ================================================================
# Batch 6 — client + streaming + server
# ================================================================

# client.cyr / retry.cyr — options + retry struct in arena.
fn test_alloc_batch6_options_arena() {
    var a = arena_allocator(2048);
    var opts = sandhi_http_options_new_a(a);
    assert_eq(opts != 0, 1, "options_new_a");
    assert_eq(sandhi_http_options_bytes(opts), SANDHI_HTTP_DEFAULT_MAX_BYTES, "default max bytes");
    sandhi_http_options_max_hops(opts, 7);
    assert_eq(sandhi_http_options_hops(opts), 7, "max_hops setter survives");

    var retry = sandhi_retry_new_a(a);
    assert_eq(retry != 0, 1, "retry_new_a");
    assert_eq(_sandhi_retry_attempts(retry), SANDHI_RETRY_DEFAULT_ATTEMPTS, "default attempts");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_http_options_new_a(failer), 0, "options_new_a OOM → 0");
    assert_eq(sandhi_retry_new_a(failer), 0, "retry_new_a OOM → 0");
    return 0;
}

# server/mod.cyr — request parsing helpers all flow through `a`.
fn test_alloc_batch6_server_parse_arena() {
    var a = arena_allocator(4096);
    var req = "GET /api/users?id=42 HTTP/1.1\r\nHost: example.com\r\nUser-Agent: probe\r\n\r\n";
    var rlen = strlen(req);

    var method = sandhi_server_get_method_a(a, req, rlen);
    assert_streq(method, "GET", "method extracted");
    var path = sandhi_server_get_path_a(a, req, rlen);
    assert_streq(path, "/api/users?id=42", "path extracted");
    var ua = sandhi_server_find_header_a(a, req, rlen, "User-Agent");
    assert_streq(ua, "probe", "header extracted");
    var bare = sandhi_server_path_only_a(a, path);
    assert_streq(bare, "/api/users", "path_only stripped query");
    var id = sandhi_server_get_param_a(a, path, "id");
    assert_streq(id, "42", "query param extracted");
    var seg = sandhi_server_path_segment_a(a, path, 1);
    assert_streq(seg, "users", "path segment extracted");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "all helpers landed in arena");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "arena cleared in one shot");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_server_get_method_a(failer, req, rlen), 0, "get_method_a OOM → 0");
    return 0;
}

# sse.cyr — full SSE parse round-trip into arena.
fn test_alloc_batch6_sse_parse_arena() {
    var a = arena_allocator(4096);
    var stream = "event: tick\ndata: hello\ndata: world\nid: 7\n\n";
    var slen = strlen(stream);

    var rem_cell = alloc_via(a, 8);
    var events = sandhi_sse_parse_a(a, stream, slen, rem_cell);
    assert_eq(events != 0, 1, "events vec allocated");
    assert_eq(vec_len(events), 1, "one event parsed");
    var ev = vec_get(events, 0);
    assert_streq(sandhi_sse_event_name(ev), "tick", "event name");
    assert_streq(sandhi_sse_event_data(ev), "hello\nworld", "data lines joined");
    assert_streq(sandhi_sse_event_id(ev), "7", "id captured");

    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "sse parse arena cleared");

    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_sse_dup_a(failer, "x"), 0, "_sse_dup_a OOM → 0");
    return 0;
}

# stream.cyr — _stream_result_a / _sb_new_a / _chunk_state_new_a OOM.
fn test_alloc_batch6_stream_result_oom() {
    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_stream_result_a(failer, 0, 0, 0, 0), 0, "stream_result_a OOM → 0");
    assert_eq(_sandhi_sb_new_a(failer, 1024), 0, "sb_new_a OOM → 0");
    assert_eq(_sandhi_chunk_state_new_a(failer), 0, "chunk_state_new_a OOM → 0");
    return 0;
}

# resolve.cyr — OOM on resolv.conf read returns -1 cleanly.
fn test_alloc_batch5_resolve_oom() {
    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_resolve_read_resolv_conf_a(failer), 0 - 1,
    "resolv.conf read OOM → -1");
    # name_eq with failing alloc → returns 0 (not equal) without
    # crashing.
    var buf[2];
    store8(&buf, 0); store8(&buf + 1, 0);
    assert_eq(_sandhi_resolve_name_eq_a(failer, &buf, 2, 0, 1), 0,
    "name_eq_a OOM → 0");
    return 0;
}

# discovery/local.cyr — ctx-bound allocator + qname round-trip.
fn test_alloc_batch3_local_arena() {
    var a = arena_allocator(2048);

    var qn = _sandhi_local_qname_a(a, "printer");
    assert_streq(qn, "printer.local", "qname appends .local");
    var qn2 = _sandhi_local_qname_a(a, "host.local");
    assert_streq(qn2, "host.local", "qname passthrough on .local suffix");

    # Resolver wrapper carries the allocator handle on its ctx.
    var r = sandhi_discovery_local_resolver_a(a);
    assert_eq(r != 0, 1, "local_resolver_a built");
    assert_eq(sandhi_resolver_fn(r) == &_sandhi_local_lookup, 1, "fn ptr wired");
    var ctx = sandhi_resolver_ctx(r);
    assert_eq(ctx != 0, 1, "resolver ctx allocated");
    assert_eq(load64(ctx) == a, 1, "ctx +0 carries allocator handle");

    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_local_qname_a(failer, "printer"), 0, "qname_a OOM → 0");
    return 0;
}

