# sandhi alloc test suite — covers the v1.1.0 Allocator-as-first-arg
# migration. Lives in its own .tcyr so it doesn't push tests/sandhi.tcyr
# over the per-program fixup-table cap (architecture/001).
#
# Each batch of the migration adds a `test_alloc_batchN_*` group below
# that drives the per-request-arena pattern + OOM coverage for at least
# one `_a` variant in that batch (proposal acceptance gates 4 + 5).

include "src/version_str.cyr"
include "src/error.cyr"
include "src/obs/trace.cyr"
include "src/obs/prof.cyr"
include "src/http/headers.cyr"
include "src/http/url.cyr"
include "src/http/conn.cyr"
include "src/http/response.cyr"
include "src/net/resolve.cyr"
include "src/http/client.cyr"
include "src/http/pool.cyr"
include "src/http/h2/huffman.cyr"
include "src/http/h2/hpack.cyr"
include "src/http/h2/frame.cyr"
include "src/http/h2/conn.cyr"
include "src/http/h2/request.cyr"
include "src/http/h2/response.cyr"
include "src/http/h2/pool_glue.cyr"
include "src/http/h2/dispatch.cyr"
include "src/http/sse.cyr"
include "src/http/stream.cyr"
include "src/http/retry.cyr"
include "src/server/mod.cyr"
include "src/tls_policy/policy.cyr"
include "src/tls_policy/fingerprint.cyr"
include "src/rpc/json.cyr"
include "src/rpc/dispatch.cyr"
include "src/rpc/webdriver.cyr"
include "src/rpc/appium.cyr"
include "src/rpc/mcp.cyr"
include "src/discovery/service.cyr"
include "src/discovery/chain.cyr"
include "src/discovery/daimon.cyr"
include "src/discovery/local.cyr"
include "src/main.cyr"  # sandhi_version() — referenced by http/client.cyr's UA builder

# ================================================================
# Batch 1 — leaves
# ================================================================

# url.cyr — per-request-arena round-trip. Parse two URLs into the
# same arena across a reset; verify reset reclaims the first parse.
fn test_alloc_batch1_url_arena_reset() {
    var a = arena_allocator(4096);
    assert_eq(a != 0, 1, "arena_allocator(4096) constructed");

    var u1 = sandhi_url_parse_a(a, "http://example.com:8080/foo?bar=baz");
    assert_eq(u1 != 0, 1, "url parse #1 into arena succeeded");
    assert_eq(sandhi_url_scheme(u1), SANDHI_URL_HTTP, "scheme #1");
    assert_eq(sandhi_url_port(u1), 8080, "port #1");
    assert_streq(sandhi_url_host(u1), "example.com", "host #1");
    assert_streq(sandhi_url_path(u1), "/foo", "path #1");
    assert_streq(sandhi_url_query(u1), "bar=baz", "query #1");

    var used_after_first = arena_used(allocator_state(a));
    assert_eq(used_after_first > 0, 1, "arena bytes consumed by parse #1");

    reset_via(a);

    var used_after_reset = arena_used(allocator_state(a));
    assert_eq(used_after_reset, 0, "reset_via clears arena");

    var u2 = sandhi_url_parse_a(a, "https://[::1]:443/");
    assert_eq(u2 != 0, 1, "url parse #2 into reset arena succeeded");
    assert_eq(sandhi_url_scheme(u2), SANDHI_URL_HTTPS, "scheme #2");
    assert_eq(sandhi_url_port(u2), 443, "port #2");
    assert_streq(sandhi_url_host(u2), "::1", "v6 host stripped of brackets");
    return 0;
}

# url.cyr — OOM via fail_after_n_allocs. The host parse path takes
# 2 allocs (host cstr + struct) for the simplest input
# "http://example.com/"; failing after 1 should yield 0 cleanly.
fn test_alloc_batch1_url_oom() {
    var a = fail_after_n_allocs(1);
    assert_eq(a != 0, 1, "fail_after_n_allocs(1) constructed");
    var u = sandhi_url_parse_a(a, "http://example.com/");
    assert_eq(u, 0, "OOM at second alloc → parse returns 0, no abort");
    return 0;
}

# headers.cyr — arena reset reclaims a parsed header block.
fn test_alloc_batch1_headers_arena_reset() {
    var a = arena_allocator(4096);
    var raw = "X-One: alpha\r\nX-Two: beta\r\n\r\n";
    var rlen = strlen(raw);

    var h1 = sandhi_headers_parse_a(a, raw, rlen);
    assert_eq(h1 != 0, 1, "headers parse #1 into arena");
    assert_eq(sandhi_headers_count(h1), 2, "two entries parsed");
    assert_streq(sandhi_headers_get(h1, "x-one"), "alpha", "case-insensitive get");

    var used_after_first = arena_used(allocator_state(a));
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "arena cleared");
    assert_eq(used_after_first > 0, 1, "first parse did consume bytes");

    var h2 = sandhi_headers_parse_a(a, raw, rlen);
    assert_eq(h2 != 0, 1, "headers parse #2 into reset arena");
    assert_eq(sandhi_headers_count(h2), 2, "two entries parsed (round 2)");
    return 0;
}

# headers.cyr — OOM. add_a returns -2 on alloc failure (not -1
# which is byte-rejection). Drive a 0-budget allocator to confirm.
fn test_alloc_batch1_headers_add_oom() {
    var a = arena_allocator(4096);
    var h = sandhi_headers_new_a(a);
    assert_eq(h != 0, 1, "block allocated");

    # Switch to a failing alloc for the actual add. fail_after(0)
    # makes EVERY alloc fail.
    var failer = fail_after_n_allocs(0);
    var rc = sandhi_headers_add_a(failer, h, "X-Test", "value");
    assert_eq(rc, 0 - 2, "add_a returns -2 on OOM");
    return 0;
}

# service.cyr — service_new_a OOM yields 0 cleanly.
fn test_alloc_batch1_service_oom() {
    var failer = fail_after_n_allocs(0);
    var s = sandhi_service_new_a(failer, "x", "host", 80, 0);
    assert_eq(s, 0, "service_new_a returns 0 on OOM");
    return 0;
}

# pool.cyr — pool_new_a stores the allocator on the struct.
fn test_alloc_batch1_pool_alloc_slot() {
    var a = arena_allocator(8192);
    var p = sandhi_http_pool_new_a(a, 4, 60000);
    assert_eq(p != 0, 1, "pool_new_a succeeded");
    assert_eq(sandhi_http_pool_max_per_host(p), 4, "max_per_host stored");
    # Confirm the allocator slot round-trips: _sandhi_pool_alloc(p)
    # must be the same pointer we handed in.
    assert_eq(_sandhi_pool_alloc(p) == a, 1, "pool stores allocator handle");
    return 0;
}

# h2/frame.cyr — hdr_new_a + hdr_decode_a + OOM round-trip.
fn test_alloc_batch1_h2_hdr_arena() {
    var a = arena_allocator(1024);
    var h = sandhi_h2_hdr_new_a(a, 16, SANDHI_H2_FRAME_DATA, 0, 1);
    assert_eq(h != 0, 1, "h2 hdr alloced into arena");
    assert_eq(sandhi_h2_hdr_length(h), 16, "length round-trip");
    assert_eq(sandhi_h2_hdr_type(h), SANDHI_H2_FRAME_DATA, "type round-trip");
    assert_eq(sandhi_h2_hdr_stream_id(h), 1, "stream_id round-trip");

    var failer = fail_after_n_allocs(0);
    var h_oom = sandhi_h2_hdr_new_a(failer, 0, 0, 0, 0);
    assert_eq(h_oom, 0, "hdr_new_a returns 0 on OOM");
    return 0;
}

# ================================================================
# Batch 2 — TLS + h2 leaves
# ================================================================

# fingerprint.cyr — normalize/encode/eq into an arena, then OOM.
fn test_alloc_batch2_fingerprint_arena() {
    var a = arena_allocator(1024);

    var raw = "E3:B0:C4:42:98:FC:1C:14";
    var n = sandhi_fp_normalize_a(a, raw);
    assert_eq(n != 0, 1, "fp_normalize_a into arena");
    assert_streq(n, "e3b0c44298fc1c14", "lowercased + delimiters stripped");

    var bytes[3];
    store8(&bytes + 0, 0xab);
    store8(&bytes + 1, 0xcd);
    store8(&bytes + 2, 0xef);
    var hex = sandhi_fp_encode_bytes_a(a, &bytes, 3);
    assert_streq(hex, "abcdef", "encode_bytes_a into arena");

    assert_eq(sandhi_fp_eq_a(a, "AB:CD:EF", "abcdef"), 1, "fp_eq_a delimiter+case insensitive");
    assert_eq(sandhi_fp_eq_a(a, "abcdef", "abcd00"), 0, "fp_eq_a different fingerprint");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_fp_normalize_a(failer, "abcd"), 0, "normalize_a OOM → 0");
    assert_eq(sandhi_fp_encode_bytes_a(failer, &bytes, 3), 0, "encode_bytes_a OOM → 0");
    return 0;
}

# policy.cyr — combined policy built into an arena and reset.
fn test_alloc_batch2_policy_arena_combine() {
    var a = arena_allocator(2048);

    var pinned = sandhi_tls_policy_new_pinned_a(a, "deadbeef");
    var mtls   = sandhi_tls_policy_new_mtls_a(a, "/cert.pem", "/key.pem");
    assert_eq(pinned != 0, 1, "pinned policy in arena");
    assert_eq(mtls   != 0, 1, "mtls policy in arena");

    var combined = sandhi_tls_policy_combine_a(a, pinned, mtls);
    assert_eq(combined != 0, 1, "combine_a into arena");
    var flags = sandhi_tls_policy_flags(combined);
    assert_eq(flags & SANDHI_TLS_POLICY_PINNED, SANDHI_TLS_POLICY_PINNED, "flags carry pinned");
    assert_eq(flags & SANDHI_TLS_POLICY_MTLS,   SANDHI_TLS_POLICY_MTLS,   "flags carry mtls");
    assert_streq(sandhi_tls_policy_pinned_hash(combined), "deadbeef", "pin survives combine");
    assert_streq(sandhi_tls_policy_mtls_cert(combined),   "/cert.pem", "cert survives combine");

    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "policy arena reset");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_tls_policy_new_default_a(failer), 0, "default_a OOM → 0");
    return 0;
}

# huffman.cyr — decode_a into an arena. The static decode tree is
# pinned to default_alloc, so resetting the per-call arena does NOT
# break subsequent decodes.
fn test_alloc_batch2_huffman_decode_arena() {
    # RFC 7541 C.4.1 — Huffman("www.example.com") =
    # f1e3 c2e5 f23a 6ba0 ab90 f4ff (12 bytes).
    var enc[12];
    store8(&enc + 0,  0xf1); store8(&enc + 1,  0xe3);
    store8(&enc + 2,  0xc2); store8(&enc + 3,  0xe5);
    store8(&enc + 4,  0xf2); store8(&enc + 5,  0x3a);
    store8(&enc + 6,  0x6b); store8(&enc + 7,  0xa0);
    store8(&enc + 8,  0xab); store8(&enc + 9,  0x90);
    store8(&enc + 10, 0xf4); store8(&enc + 11, 0xff);

    var a = arena_allocator(4096);
    var s = sandhi_hpack_huffman_decode_a(a, &enc, 0, 12);
    assert_streq(s, "www.example.com", "huffman decode_a into arena");

    reset_via(a);
    var s2 = sandhi_hpack_huffman_decode_a(a, &enc, 0, 12);
    assert_streq(s2, "www.example.com", "decode after arena reset (static tree intact)");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_hpack_huffman_decode_a(failer, &enc, 0, 12), 0, "decode_a OOM → 0");
    return 0;
}

# hpack.cyr — table_new_a + decode_field_a into an arena.
fn test_alloc_batch2_hpack_table_arena() {
    var a = arena_allocator(8192);
    var t = sandhi_hpack_table_new_a(a, 4096);
    assert_eq(t != 0, 1, "hpack table_new_a in arena");
    assert_eq(sandhi_hpack_table_count(t), 0, "table starts empty");
    assert_eq(sandhi_hpack_table_max_size(t), 4096, "max_size honored");

    sandhi_hpack_table_add_a(a, t, "x-custom", "value");
    assert_eq(sandhi_hpack_table_count(t), 1, "add_a inserted entry");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_hpack_table_new_a(failer, 4096), 0, "table_new_a OOM → 0");
    return 0;
}

# ================================================================
# Batch 3 — discovery + rpc
# ================================================================

# rpc/json.cyr — build a nested JSON object into an arena, parse a
# response body via dotted-path extraction also routed through the
# arena, then reset to reclaim everything.
fn test_alloc_batch3_json_arena() {
    var a = arena_allocator(8192);
    var inner = sandhi_json_obj_new_a(a);
    sandhi_json_add_string_a(a, inner, "browser", "firefox");
    sandhi_json_add_int_a(a, inner, "w3c", 1);

    var outer = sandhi_json_obj_new_a(a);
    sandhi_json_add_object_a(a, outer, "capabilities", inner);
    sandhi_json_add_bool_a(a, outer, "strict", 1);

    var wire = sandhi_json_build_a(a, outer);
    assert_eq(wire != 0, 1, "json_build_a into arena");
    # Extract from the rendered wire — proves both build + extract
    # round-trip into `a`.
    var got = sandhi_json_get_string_a(a, wire, "capabilities.browser");
    assert_streq(got, "firefox", "nested object string extraction");
    assert_eq(sandhi_json_get_int_a(a, wire, "capabilities.w3c"), 1, "int extraction");
    assert_eq(sandhi_json_has_path_a(a, wire, "missing"), 0, "absent path → 0");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena consumed bytes");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "json arena cleared");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_json_get_string_a(failer, "{\"x\":\"y\"}", "x"), 0, "get_string_a OOM → 0");
    return 0;
}

# rpc/dispatch.cyr — wrap a synthetic HTTP response into an rpc-resp
# struct using `_a`. Uses a faked HTTP response built directly via
# _sandhi_resp_new since we don't want a live transport call here.
fn test_alloc_batch3_dispatch_wrap_arena() {
    var a = arena_allocator(4096);

    # Build a JSON-RPC error envelope body.
    var body = "{\"jsonrpc\":\"2.0\",\"error\":{\"code\":42,\"message\":\"boom\"},\"id\":1}";
    var blen = strlen(body);
    var hr = _sandhi_resp_new(200, body, blen, sandhi_headers_new(), SANDHI_OK);
    var rpc = _sandhi_rpc_wrap_a(a, hr, SANDHI_RPC_DIALECT_JSONRPC);
    assert_eq(rpc != 0, 1, "rpc resp built in arena");
    assert_eq(sandhi_rpc_err_kind(rpc), SANDHI_ERR_REMOTE, "json-rpc error envelope detected");
    assert_streq(sandhi_rpc_err_message(rpc), "boom", "error message extracted");
    assert_eq(sandhi_rpc_http_status(rpc), 200, "http status preserved");

    var failer = fail_after_n_allocs(0);
    var rpc_oom = _sandhi_rpc_resp_new_a(failer, 0, 0, 0, 0, 0);
    assert_eq(rpc_oom, 0, "_sandhi_rpc_resp_new_a OOM → 0");
    return 0;
}

# rpc/webdriver.cyr — URL builders into an arena.
fn test_alloc_batch3_webdriver_url_arena() {
    var a = arena_allocator(4096);
    var u1 = _sandhi_wd_join_a(a, "http://drv:4444", "/status");
    assert_streq(u1, "http://drv:4444/status", "_wd_join_a no-trailing");
    var u2 = _sandhi_wd_join_a(a, "http://drv:4444/", "/status");
    assert_streq(u2, "http://drv:4444/status", "_wd_join_a trailing-slash trimmed");

    var u3 = _sandhi_wd_session_url_a(a, "http://drv:4444", "abc123", "/element");
    assert_streq(u3, "http://drv:4444/session/abc123/element", "_wd_session_url_a built");

    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_wd_join_a(failer, "http://drv", "/x"), 0, "_wd_join_a OOM → 0");
    return 0;
}

# ================================================================
# Batch 4 — HTTP response/request foundation
# ================================================================

# response.cyr — central response constructor lands the entire
# response (headers, body, struct) in a single arena. Reset reclaims
# everything in one shot — the headline per-request-arena win.
fn test_alloc_batch4_response_parse_arena() {
    var a = arena_allocator(8192);

    var raw = "HTTP/1.1 200 OK\r\nContent-Length: 5\r\nContent-Type: text/plain\r\n\r\nhello";
    var rlen = strlen(raw);

    var resp = sandhi_http_response_parse_a(a, raw, rlen);
    assert_eq(resp != 0, 1, "response parsed into arena");
    assert_eq(sandhi_http_status(resp), 200, "status decoded");
    assert_eq(sandhi_http_body_len(resp), 5, "body len decoded");
    assert_streq(sandhi_http_body(resp), "hello", "body bytes decoded");
    assert_eq(sandhi_http_err_kind(resp), SANDHI_OK, "no err");
    assert_streq(sandhi_headers_get(sandhi_http_headers(resp), "Content-Type"),
    "text/plain", "header surfaced");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena consumed bytes for headers + body + struct");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "arena cleared in one shot");

    # Round 2 — same arena, fresh response.
    var resp2 = sandhi_http_response_parse_a(a, raw, rlen);
    assert_eq(sandhi_http_status(resp2), 200, "second parse into reset arena");
    return 0;
}

# response.cyr — chunked decode through the per-request arena.
fn test_alloc_batch4_chunked_arena() {
    var a = arena_allocator(8192);
    var raw = "HTTP/1.1 200 OK\r\nTransfer-Encoding: chunked\r\n\r\n5\r\nhello\r\n6\r\n world\r\n0\r\n\r\n";
    var rlen = strlen(raw);

    var resp = sandhi_http_response_parse_a(a, raw, rlen);
    assert_eq(sandhi_http_status(resp), 200, "chunked status");
    assert_eq(sandhi_http_body_len(resp), 11, "chunked body len");
    assert_streq(sandhi_http_body(resp), "hello world", "chunked body content");
    return 0;
}

# response.cyr — error responses also flow through `a` (no global-bump
# leak even on parse failure).
fn test_alloc_batch4_resp_err_arena() {
    var a = arena_allocator(2048);
    var resp = sandhi_http_response_parse_a(a, "not http", 8);
    assert_eq(sandhi_http_err_kind(resp), SANDHI_ERR_PROTOCOL, "malformed → PROTOCOL err");
    assert_eq(sandhi_http_status(resp), 0, "status 0 on err");
    assert_eq(sandhi_http_headers(resp) != 0, 1, "headers block always non-null");
    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "err response was allocated from arena");
    return 0;
}

# response.cyr — OOM. fail_after(0) means even the first alloc fails;
# _resp_new_a returns 0 cleanly. Then the err shortcut also returns 0
# (since headers_new_a fails → _resp_err_a's headers param is 0, but
# _resp_err_a still tries to alloc the resp struct itself — which
# also fails → returns 0).
fn test_alloc_batch4_resp_oom() {
    var failer = fail_after_n_allocs(0);
    var r = _sandhi_resp_new_a(failer, 200, 0, 0, 0, SANDHI_OK);
    assert_eq(r, 0, "_sandhi_resp_new_a returns 0 on OOM");
    var r2 = _sandhi_resp_err_a(failer, SANDHI_ERR_PROTOCOL);
    assert_eq(r2, 0, "_sandhi_resp_err_a returns 0 on OOM");
    return 0;
}

# ================================================================
# Batch 5 — connection layer
# ================================================================

# conn.cyr — _set_timeout_ms_a allocates a 16-byte timeval into `a`.
# We can't easily exercise the open path (needs a real network),
# but the timeval helper is deterministic.
fn test_alloc_batch5_conn_timeout_arena() {
    var a = arena_allocator(2048);
    # ms <= 0 short-circuits without touching `a`.
    assert_eq(_sandhi_conn_set_timeout_ms_a(a, 0, 0, _SANDHI_SO_RCVTIMEO), 0,
    "ms<=0 returns 0 without alloc");
    var used_after_noop = arena_used(allocator_state(a));
    assert_eq(used_after_noop, 0, "no-op didn't touch arena");

    # ms>0 with fd=-1 — alloc happens, syscall fails. We only assert
    # the alloc landed in `a` (used > 0).
    _sandhi_conn_set_timeout_ms_a(a, 0 - 1, 1000, _SANDHI_SO_RCVTIMEO);
    var used_after_set = arena_used(allocator_state(a));
    assert_eq(used_after_set > 0, 1, "timeval allocated into arena");

    # OOM. fail_after(0) → alloc fails → returns -1.
    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_conn_set_timeout_ms_a(failer, 0 - 1, 1000, _SANDHI_SO_RCVTIMEO),
    0 - 1, "set_timeout_ms_a OOM → -1");
    return 0;
}

# h2/conn.cyr — h2 conn struct + enc/dec hpack tables all land in `a`.
fn test_alloc_batch5_h2_conn_arena() {
    var a = arena_allocator(8192);
    # Underlying sandhi_conn ptr can be 0 — h2_conn_new just stores
    # the value, doesn't dereference.
    var c = sandhi_h2_conn_new_a(a, 0);
    assert_eq(c != 0, 1, "h2_conn_new_a built struct in arena");
    assert_eq(sandhi_h2_conn_underlying(c), 0, "underlying ptr stored");
    assert_eq(sandhi_h2_conn_enc_table(c) != 0, 1, "enc table allocated");
    assert_eq(sandhi_h2_conn_dec_table(c) != 0, 1, "dec table allocated");
    assert_eq(sandhi_h2_conn_peer_max_frame(c), _SANDHI_H2_DEFAULT_PEER_FRAME,
    "default peer max-frame initialized");
    # next_stream_id starts at 1 and bumps by 2.
    assert_eq(sandhi_h2_conn_next_stream_id(c), 1, "first stream id = 1");
    assert_eq(sandhi_h2_conn_next_stream_id(c), 3, "second stream id = 3");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_h2_conn_new_a(failer, 0), 0, "h2_conn_new_a OOM → 0");
    return 0;
}

# resolve.cyr — _name_eq_a's 8 transient cells round-trip into `a`.
# Build two compressed-name buffers and compare.
fn test_alloc_batch5_resolve_name_eq_arena() {
    var a = arena_allocator(4096);

    # Build a tiny DNS-like buf with two names to compare. Layout:
    # offset 0: "example.com" labels = 07 e x a m p l e 03 c o m 00
    # offset 13: same again
    # offset 26: "EXAMPLE.com" — case-different
    var buf[39];
    var labels = "\x07example\x03com\x00\x07example\x03com\x00\x07EXAMPLE\x03com\x00";
    var i = 0;
    while (i < 39) { store8(&buf + i, load8(labels + i)); i = i + 1; }

    assert_eq(_sandhi_resolve_name_eq_a(a, &buf, 39, 0, 13), 1,
    "identical names compare equal");
    assert_eq(_sandhi_resolve_name_eq_a(a, &buf, 39, 0, 26), 1,
    "case-insensitive equal");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "name_eq scratch landed in arena");

    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "arena reset reclaimed scratch");

    # Round 2 — same arena.
    assert_eq(_sandhi_resolve_name_eq_a(a, &buf, 39, 0, 13), 1, "round 2 still works");
    return 0;
}

# ================================================================
# Batch 6 — client + streaming + server
# ================================================================

# client.cyr / retry.cyr — options + retry struct in arena.
fn test_alloc_batch6_options_arena() {
    var a = arena_allocator(2048);
    var opts = sandhi_http_options_new_a(a);
    assert_eq(opts != 0, 1, "options_new_a");
    assert_eq(sandhi_http_options_bytes(opts), SANDHI_HTTP_DEFAULT_MAX_BYTES, "default max bytes");
    sandhi_http_options_max_hops(opts, 7);
    assert_eq(sandhi_http_options_hops(opts), 7, "max_hops setter survives");

    var retry = sandhi_retry_new_a(a);
    assert_eq(retry != 0, 1, "retry_new_a");
    assert_eq(_sandhi_retry_attempts(retry), SANDHI_RETRY_DEFAULT_ATTEMPTS, "default attempts");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_http_options_new_a(failer), 0, "options_new_a OOM → 0");
    assert_eq(sandhi_retry_new_a(failer), 0, "retry_new_a OOM → 0");
    return 0;
}

# server/mod.cyr — request parsing helpers all flow through `a`.
fn test_alloc_batch6_server_parse_arena() {
    var a = arena_allocator(4096);
    var req = "GET /api/users?id=42 HTTP/1.1\r\nHost: example.com\r\nUser-Agent: probe\r\n\r\n";
    var rlen = strlen(req);

    var method = sandhi_server_get_method_a(a, req, rlen);
    assert_streq(method, "GET", "method extracted");
    var path = sandhi_server_get_path_a(a, req, rlen);
    assert_streq(path, "/api/users?id=42", "path extracted");
    var ua = sandhi_server_find_header_a(a, req, rlen, "User-Agent");
    assert_streq(ua, "probe", "header extracted");
    var bare = sandhi_server_path_only_a(a, path);
    assert_streq(bare, "/api/users", "path_only stripped query");
    var id = sandhi_server_get_param_a(a, path, "id");
    assert_streq(id, "42", "query param extracted");
    var seg = sandhi_server_path_segment_a(a, path, 1);
    assert_streq(seg, "users", "path segment extracted");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "all helpers landed in arena");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "arena cleared in one shot");

    var failer = fail_after_n_allocs(0);
    assert_eq(sandhi_server_get_method_a(failer, req, rlen), 0, "get_method_a OOM → 0");
    return 0;
}

# sse.cyr — full SSE parse round-trip into arena.
fn test_alloc_batch6_sse_parse_arena() {
    var a = arena_allocator(4096);
    var stream = "event: tick\ndata: hello\ndata: world\nid: 7\n\n";
    var slen = strlen(stream);

    var rem_cell = alloc_via(a, 8);
    var events = sandhi_sse_parse_a(a, stream, slen, rem_cell);
    assert_eq(events != 0, 1, "events vec allocated");
    assert_eq(vec_len(events), 1, "one event parsed");
    var ev = vec_get(events, 0);
    assert_streq(sandhi_sse_event_name(ev), "tick", "event name");
    assert_streq(sandhi_sse_event_data(ev), "hello\nworld", "data lines joined");
    assert_streq(sandhi_sse_event_id(ev), "7", "id captured");

    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "sse parse arena cleared");

    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_sse_dup_a(failer, "x"), 0, "_sse_dup_a OOM → 0");
    return 0;
}

# stream.cyr — _stream_result_a / _sb_new_a / _chunk_state_new_a OOM.
fn test_alloc_batch6_stream_result_oom() {
    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_stream_result_a(failer, 0, 0, 0, 0), 0, "stream_result_a OOM → 0");
    assert_eq(_sandhi_sb_new_a(failer, 1024), 0, "sb_new_a OOM → 0");
    assert_eq(_sandhi_chunk_state_new_a(failer), 0, "chunk_state_new_a OOM → 0");
    return 0;
}

# resolve.cyr — OOM on resolv.conf read returns -1 cleanly.
fn test_alloc_batch5_resolve_oom() {
    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_resolve_read_resolv_conf_a(failer), 0 - 1,
    "resolv.conf read OOM → -1");
    # name_eq with failing alloc → returns 0 (not equal) without
    # crashing.
    var buf[2];
    store8(&buf, 0); store8(&buf + 1, 0);
    assert_eq(_sandhi_resolve_name_eq_a(failer, &buf, 2, 0, 1), 0,
    "name_eq_a OOM → 0");
    return 0;
}

# discovery/local.cyr — ctx-bound allocator + qname round-trip.
fn test_alloc_batch3_local_arena() {
    var a = arena_allocator(2048);

    var qn = _sandhi_local_qname_a(a, "printer");
    assert_streq(qn, "printer.local", "qname appends .local");
    var qn2 = _sandhi_local_qname_a(a, "host.local");
    assert_streq(qn2, "host.local", "qname passthrough on .local suffix");

    # Resolver wrapper carries the allocator handle on its ctx.
    var r = sandhi_discovery_local_resolver_a(a);
    assert_eq(r != 0, 1, "local_resolver_a built");
    assert_eq(sandhi_resolver_fn(r) == &_sandhi_local_lookup, 1, "fn ptr wired");
    var ctx = sandhi_resolver_ctx(r);
    assert_eq(ctx != 0, 1, "resolver ctx allocated");
    assert_eq(load64(ctx) == a, 1, "ctx +0 carries allocator handle");

    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_local_qname_a(failer, "printer"), 0, "qname_a OOM → 0");
    return 0;
}

# ================================================================
# 1.2.0 — Batch A: orchestrator allocator review
# ================================================================
# Audit-pass tests for the request-orchestrator layer
# (`_sandhi_http_do` / `_do_impl` / `_dispatch` / `_exchange` /
# `_exchange_keepalive` / `_sandhi_client_build_request`). The 1.1.0
# leaf-level migration was clean (no `_a` fn called a bare paired
# version), but the orchestrators above the leaves had no `_a`
# variants — every consumer call to `sandhi_http_get` etc. went
# through `default_alloc()` for the entire request path, bypassing
# any per-request arena even when leaves like `sandhi_url_parse_a`
# would have honored it. Batch A adds `_a` variants for the four
# orchestrators + the request builder. Follow / retry / h2 auto /
# top-level public verbs land in 1.2.1+.

# build_request — arena round-trip. The pre-1.2.0 `_a` variant
# silently dropped `a` and routed every str_builder op through
# default_alloc(); the new `_va` impl threads `a` correctly.
fn test_alloc_120a_build_request_arena() {
    var a = arena_allocator(4096);

    var req = _sandhi_client_build_request_a(a, "GET", "/probe", "example.com", 0, 0);
    assert_eq(req != 0, 1, "build_request_a returned a Str");
    var s = str_data(req);
    # Wire format must include the auto-injected Host: example.com line.
    var has_host = 0;
    var i = 0;
    while (i + 17 < strlen(s)) {
        if (load8(s + i) == 72 && load8(s + i + 1) == 111 && load8(s + i + 2) == 115
        && load8(s + i + 3) == 116 && load8(s + i + 4) == 58 && load8(s + i + 5) == 32) {
            has_host = 1;
        }
        i = i + 1;
    }
    assert_eq(has_host, 1, "auto-injected Host: line present in arena-built request");

    var used_after_first = arena_used(allocator_state(a));
    assert_eq(used_after_first > 0, 1, "arena consumed by build_request_a");

    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "reset_via clears arena");

    # Second build into the reset arena succeeds; previous req's
    # Str struct + str_builder + cstrings all reclaimed.
    var req2 = _sandhi_client_build_request_a(a, "POST", "/api", "api.example.com", 0, 42);
    assert_eq(req2 != 0, 1, "build #2 into reset arena succeeded");
    return 0;
}

# build_request — full variadic with keep_alive flag.
fn test_alloc_120a_build_request_va_keepalive() {
    var a = arena_allocator(4096);
    var req = _sandhi_client_build_request_va(a, "GET", "/", "example.com", 0, 0, 1);
    assert_eq(req != 0, 1, "build_request_va keep_alive=1 succeeded");
    # keep_alive=1 must NOT emit "Connection: close".
    var s = str_data(req);
    var has_close = 0;
    var i = 0;
    while (i + 17 < strlen(s)) {
        if (load8(s + i) == 67 && load8(s + i + 1) == 111 && load8(s + i + 2) == 110
        && load8(s + i + 3) == 110 && load8(s + i + 4) == 101 && load8(s + i + 5) == 99
        && load8(s + i + 6) == 116 && load8(s + i + 7) == 105 && load8(s + i + 8) == 111
        && load8(s + i + 9) == 110 && load8(s + i + 10) == 58 && load8(s + i + 11) == 32
        && load8(s + i + 12) == 99 && load8(s + i + 13) == 108 && load8(s + i + 14) == 111
        && load8(s + i + 15) == 115 && load8(s + i + 16) == 101) {
            has_close = 1;
        }
        i = i + 1;
    }
    assert_eq(has_close, 0, "keep_alive=1 omits Connection: close");
    return 0;
}

# dispatch_a — error-path response is allocated in the arena.
# Drive `_sandhi_http_dispatch_a` against an unparseable URL: every
# alloc until the err-resp construction lands in the arena, which
# `reset_via` should reclaim cleanly.
fn test_alloc_120a_dispatch_err_resp_arena() {
    var a = arena_allocator(4096);
    var opts = sandhi_http_options_new_a(a);
    var resp = _sandhi_http_dispatch_a(a, "GET", "not-a-valid-url", 0, 0, 0, opts);
    assert_eq(resp != 0, 1, "dispatch_a err-resp constructed");
    assert_eq(sandhi_http_err_kind(resp), SANDHI_ERR_PARSE,
    "URL parse fail → SANDHI_ERR_PARSE");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena bytes consumed by err-resp construction");

    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0,
    "reset_via reclaims the err-resp arena allocations");
    return 0;
}

# build_request — OOM via fail_after_n_allocs returns gracefully.
# The first alloc is `str_builder_new_a` (the builder header itself).
fn test_alloc_120a_build_request_oom() {
    var a = fail_after_n_allocs(0);
    var req = _sandhi_client_build_request_a(a, "GET", "/", "example.com", 0, 0);
    # str_builder_new_a returns 0 on OOM; subsequent str_builder_add_*
    # ops are no-ops on a 0 builder; str_builder_build_a returns 0
    # when sb is 0.
    assert_eq(req, 0, "OOM at first alloc → build returns 0 cleanly (no abort)");
    return 0;
}

# ================================================================
# 1.2.1 — Batch B+C: redirect / retry / auto-dispatch path
# ================================================================
# Closes the partial-arena leak 1.2.0 left on `follow=1` and the
# auto-dispatch / retry paths. `_a` variants now exist for
# `_sandhi_http_follow`, `_sandhi_http_auto_once`,
# `_sandhi_http_auto_follow`, `sandhi_http_request_auto`,
# `_sandhi_http_retry`, `_sandhi_http_try_h2_promote`, and
# `_sandhi_strip_sensitive_headers`. Bare versions stay as
# back-compat wrappers passing `default_alloc()`.

# strip_sensitive_headers — arena alloc + reset.
fn test_alloc_121bc_strip_sensitive_arena() {
    var a = arena_allocator(2048);
    var src = sandhi_headers_new_a(a);
    sandhi_headers_set_a(a, src, "Authorization", "Bearer xyz");
    sandhi_headers_set_a(a, src, "X-Trace", "ok");
    sandhi_headers_set_a(a, src, "Cookie", "sid=abc");

    var stripped = _sandhi_strip_sensitive_headers_a(a, src);
    assert_eq(stripped != 0, 1, "strip returns a fresh block");
    assert_eq(sandhi_headers_count(stripped), 1, "only X-Trace survives");
    assert_eq(sandhi_headers_get(stripped, "Authorization"), 0, "Authorization stripped");
    assert_eq(sandhi_headers_get(stripped, "Cookie"), 0, "Cookie stripped");
    assert_streq(sandhi_headers_get(stripped, "X-Trace"), "ok", "X-Trace passes");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena consumed");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "arena reset");
    return 0;
}

# strip_sensitive_headers — OOM on the new headers block returns 0
# cleanly without crashing on the subsequent add_a calls.
fn test_alloc_121bc_strip_sensitive_oom() {
    var a = arena_allocator(2048);
    var src = sandhi_headers_new_a(a);
    sandhi_headers_set_a(a, src, "X-Trace", "ok");

    var failer = fail_after_n_allocs(0);
    var stripped = _sandhi_strip_sensitive_headers_a(failer, src);
    assert_eq(stripped, 0, "OOM at fresh-block alloc → returns 0");
    return 0;
}

# follow_a — driver-level err-resp goes into the arena. Drive against
# an unparseable URL (no Location header to follow) so we exercise the
# arena-bound `_do_a` call inside follow_a and the err-resp it builds.
fn test_alloc_121bc_follow_err_resp_arena() {
    var a = arena_allocator(4096);
    var resp = _sandhi_http_follow_a(a, "GET", "not-a-valid-url", 0, 0, 0,
    5, 0, 0, 0, 0, 0, 0);
    assert_eq(resp != 0, 1, "follow_a constructed err-resp");
    assert_eq(sandhi_http_err_kind(resp), SANDHI_ERR_PARSE, "URL parse fail");
    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena consumed by follow_a path");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "arena reset");
    return 0;
}

# auto_once_a — pool=0 (no pool) path falls through to _do_a; with an
# unparseable URL we exercise the err-resp construction.
fn test_alloc_121bc_auto_once_err_resp_arena() {
    var a = arena_allocator(4096);
    var opts = sandhi_http_options_new_a(a);
    var resp = _sandhi_http_auto_once_a(a, "GET", "not-a-valid-url", 0, 0, 0, opts);
    assert_eq(resp != 0, 1, "auto_once_a constructed err-resp");
    assert_eq(sandhi_http_err_kind(resp), SANDHI_ERR_PARSE, "URL parse fail");
    return 0;
}

# request_auto_a — opts with follow=0 routes through auto_once_a;
# arena threads end-to-end.
fn test_alloc_121bc_request_auto_arena() {
    var a = arena_allocator(4096);
    var opts = sandhi_http_options_new_a(a);
    var resp = sandhi_http_request_auto_a(a, "GET", "garbage://x", 0, 0, 0, opts);
    assert_eq(resp != 0, 1, "request_auto_a built err-resp");
    assert_eq(sandhi_http_err_kind(resp), SANDHI_ERR_PARSE, "URL parse fail");
    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena consumed");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "arena reset reclaims");
    return 0;
}

# retry_a — single attempt against a failing URL (PARSE is non-
# retryable per `_sandhi_retry_should_retry`, so the loop returns
# immediately after the first attempt). Arena threads through.
fn test_alloc_121bc_retry_non_retryable_arena() {
    var a = arena_allocator(4096);
    var opts = sandhi_http_options_new_a(a);
    var policy = sandhi_retry_new_a(a);
    var resp = _sandhi_http_retry_a(a, "GET", "garbage://x", 0, 0, 0, opts, policy);
    assert_eq(resp != 0, 1, "retry_a returned a response");
    assert_eq(sandhi_http_err_kind(resp), SANDHI_ERR_PARSE,
    "PARSE is non-retryable; first attempt returned");
    return 0;
}

# ================================================================
# 1.2.2 — Batch D: top-level public verbs `_a`
# ================================================================
# First slot with consumer-visible end-to-end arena adoption.
# Internal cascade is fully `_a`-threaded post-1.2.1; this batch
# just adds the public-verb wrappers (`sandhi_http_get_a` /
# `_post_a` / `_put_a` / `_patch_a` / `_delete_a` / `_head_a`).
# Bare versions stay as back-compat wrappers passing
# `default_alloc()`.

# get_a — drives an unparseable URL so the err-resp path lands
# entirely in the arena (URL parse → resolve → conn-open path
# never reached, but the err-resp construction does allocate
# from the arena via `_sandhi_resp_err_a`).
fn test_alloc_122d_get_arena() {
    var a = arena_allocator(4096);
    var resp = sandhi_http_get_a(a, "garbage://x", 0);
    assert_eq(resp != 0, 1, "get_a returned a response");
    assert_eq(sandhi_http_err_kind(resp), SANDHI_ERR_PARSE, "PARSE err");
    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena consumed by get_a path");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "reset reclaims");
    return 0;
}

# post_a — body-bearing variant; same shape as get_a but with
# body+body_len threaded through the `_a` chain.
fn test_alloc_122d_post_arena() {
    var a = arena_allocator(4096);
    var body = "hello";
    var resp = sandhi_http_post_a(a, "garbage://x", 0, body, 5);
    assert_eq(resp != 0, 1, "post_a returned a response");
    assert_eq(sandhi_http_err_kind(resp), SANDHI_ERR_PARSE, "PARSE err");
    return 0;
}

# delete_a / head_a — body-less variants share the same path
# shape as get_a (no body args). Both must thread `a` cleanly.
fn test_alloc_122d_delete_head_arena() {
    var a = arena_allocator(4096);
    var r1 = sandhi_http_delete_a(a, "garbage://x", 0);
    assert_eq(sandhi_http_err_kind(r1), SANDHI_ERR_PARSE, "delete_a PARSE err");
    var r2 = sandhi_http_head_a(a, "garbage://x", 0);
    assert_eq(sandhi_http_err_kind(r2), SANDHI_ERR_PARSE, "head_a PARSE err");
    return 0;
}

# put_a / patch_a — body-bearing variants symmetric to post_a.
fn test_alloc_122d_put_patch_arena() {
    var a = arena_allocator(4096);
    var body = "x";
    var r1 = sandhi_http_put_a(a, "garbage://x", 0, body, 1);
    assert_eq(sandhi_http_err_kind(r1), SANDHI_ERR_PARSE, "put_a PARSE err");
    var r2 = sandhi_http_patch_a(a, "garbage://x", 0, body, 1);
    assert_eq(sandhi_http_err_kind(r2), SANDHI_ERR_PARSE, "patch_a PARSE err");
    return 0;
}

# Round-trip across reset — multiple back-to-back calls into the
# same arena, confirming `reset_via` between them gives a fresh
# slate without leaking response memory.
fn test_alloc_122d_get_arena_round_trip() {
    var a = arena_allocator(4096);
    var r1 = sandhi_http_get_a(a, "garbage://1", 0);
    assert_eq(r1 != 0, 1, "first get_a");
    var first_used = arena_used(allocator_state(a));
    reset_via(a);
    var r2 = sandhi_http_get_a(a, "garbage://2", 0);
    assert_eq(r2 != 0, 1, "second get_a after reset");
    assert_eq(first_used > 0, 1, "first call did consume arena");
    return 0;
}

# ================================================================
# 1.2.3 — Batch E: opts / retry / auto user-facing `_a`
# ================================================================
# Paint-on-top wrappers since 1.2.0–1.2.2 already threaded the
# underlying dispatch / retry / auto paths. Each test exercises
# the per-method `_a` against an unparseable URL so the err-resp
# allocates entirely in the arena and reset reclaims cleanly.

# _opts variants — paint on `_sandhi_http_dispatch_a`.
fn test_alloc_123e_opts_arena() {
    var a = arena_allocator(4096);
    var opts = sandhi_http_options_new_a(a);

    var r1 = sandhi_http_get_opts_a(a, "garbage://x", 0, opts);
    assert_eq(sandhi_http_err_kind(r1), SANDHI_ERR_PARSE, "get_opts_a PARSE err");

    var body = "x";
    var r2 = sandhi_http_post_opts_a(a, "garbage://x", 0, body, 1, opts);
    assert_eq(sandhi_http_err_kind(r2), SANDHI_ERR_PARSE, "post_opts_a PARSE err");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena consumed");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "reset reclaims");
    return 0;
}

# _retry variants — paint on `_sandhi_http_retry_a`. PARSE is
# non-retryable so each returns after one attempt.
fn test_alloc_123e_retry_arena() {
    var a = arena_allocator(4096);
    var opts = sandhi_http_options_new_a(a);
    var policy = sandhi_retry_new_a(a);

    var r1 = sandhi_http_get_retry_a(a, "garbage://x", 0, opts, policy);
    assert_eq(sandhi_http_err_kind(r1), SANDHI_ERR_PARSE, "get_retry_a PARSE err");
    var r2 = sandhi_http_head_retry_a(a, "garbage://x", 0, opts, policy);
    assert_eq(sandhi_http_err_kind(r2), SANDHI_ERR_PARSE, "head_retry_a PARSE err");
    var body = "x";
    var r3 = sandhi_http_put_retry_a(a, "garbage://x", 0, body, 1, opts, policy);
    assert_eq(sandhi_http_err_kind(r3), SANDHI_ERR_PARSE, "put_retry_a PARSE err");
    var r4 = sandhi_http_delete_retry_a(a, "garbage://x", 0, opts, policy);
    assert_eq(sandhi_http_err_kind(r4), SANDHI_ERR_PARSE, "delete_retry_a PARSE err");
    return 0;
}

# _auto variants — paint on `sandhi_http_request_auto_a`. No
# pool attached so the path falls through to `_sandhi_http_do_a`
# (just like the test for `auto_once_err_resp_arena` at 1.2.1).
fn test_alloc_123e_auto_body_less_arena() {
    var a = arena_allocator(4096);
    var opts = sandhi_http_options_new_a(a);

    var r1 = sandhi_http_get_auto_a(a, "garbage://x", 0, opts);
    assert_eq(sandhi_http_err_kind(r1), SANDHI_ERR_PARSE, "get_auto_a PARSE err");
    var r2 = sandhi_http_head_auto_a(a, "garbage://x", 0, opts);
    assert_eq(sandhi_http_err_kind(r2), SANDHI_ERR_PARSE, "head_auto_a PARSE err");
    var r3 = sandhi_http_delete_auto_a(a, "garbage://x", 0, opts);
    assert_eq(sandhi_http_err_kind(r3), SANDHI_ERR_PARSE, "delete_auto_a PARSE err");
    return 0;
}

fn test_alloc_123e_auto_body_bearing_arena() {
    var a = arena_allocator(4096);
    var opts = sandhi_http_options_new_a(a);
    var body = "x";

    var r1 = sandhi_http_post_auto_a(a, "garbage://x", 0, body, 1, opts);
    assert_eq(sandhi_http_err_kind(r1), SANDHI_ERR_PARSE, "post_auto_a PARSE err");
    var r2 = sandhi_http_put_auto_a(a, "garbage://x", 0, body, 1, opts);
    assert_eq(sandhi_http_err_kind(r2), SANDHI_ERR_PARSE, "put_auto_a PARSE err");
    var r3 = sandhi_http_patch_auto_a(a, "garbage://x", 0, body, 1, opts);
    assert_eq(sandhi_http_err_kind(r3), SANDHI_ERR_PARSE, "patch_auto_a PARSE err");
    return 0;
}

# ================================================================
# 1.2.4 — Batch F: RPC dialect `_a` (closes the optimization arc)
# ================================================================
# Paint-on-top wrappers atop `sandhi_rpc_call_a` (paired since
# 1.1.0). Each `_a` threads `a` through URL build, JSON envelope
# build, and the underlying RPC dispatch. Since the dialect verbs
# don't have a clean "garbage URL → arena err-resp" path the way
# the http verbs do (they call `sandhi_rpc_call` which goes
# through `_sandhi_http_dispatch` with a non-arena-aware error
# path under garbage URLs), the tests here focus on the JSON
# envelope build threading: `_sandhi_mcp_build_request_a` is the
# canonical case — it calls every json_*_a helper.

# mcp build_request — the dialect's body-builder threads `a`
# through every json_*_a primitive. Verifies the helper
# produces a non-empty JSON-RPC envelope and the arena consumes
# the bytes (and reset reclaims).
fn test_alloc_124f_mcp_build_request_arena() {
    var a = arena_allocator(2048);
    var body = _sandhi_mcp_build_request_a(a, "tools/list", 0);
    assert_eq(body != 0, 1, "mcp build_request_a non-zero");
    # Sanity check: result is a JSON-RPC envelope starting with `{`.
    assert_eq(load8(body) == 123, 1, "envelope starts with '{'");

    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena consumed");
    reset_via(a);
    assert_eq(arena_used(allocator_state(a)), 0, "reset reclaims");
    return 0;
}

# mcp build_request with params — same path with the
# json_add_raw_a branch exercised.
fn test_alloc_124f_mcp_build_request_with_params_arena() {
    var a = arena_allocator(2048);
    var body = _sandhi_mcp_build_request_a(a, "tools/call",
    "{\"name\":\"echo\"}");
    assert_eq(body != 0, 1, "mcp build_request_a with params non-zero");
    return 0;
}

# wd helpers — `_sandhi_wd_build_path_a` and
# `_sandhi_wd_build_element_suffix_a` are the path-construction
# leaves used by extract_element_id_a and the element_*_a verbs.
fn test_alloc_124f_wd_build_helpers_arena() {
    var a = arena_allocator(1024);
    var path = _sandhi_wd_build_path_a(a, "value.", "elem-1");
    assert_streq(path, "value.elem-1", "build_path_a concat");
    var suffix = _sandhi_wd_build_element_suffix_a(a, "abc", "/click");
    assert_streq(suffix, "/element/abc/click", "build_element_suffix_a concat");
    var used = arena_used(allocator_state(a));
    assert_eq(used > 0, 1, "arena consumed");
    return 0;
}

# wd join helper round-trip — the URL builder used by every
# webdriver `_a` verb.
fn test_alloc_124f_wd_join_arena() {
    var a = arena_allocator(1024);
    var url = _sandhi_wd_join_a(a, "http://wd.local:4444", "/session");
    assert_streq(url, "http://wd.local:4444/session", "join_a concat");
    var sess_url = _sandhi_wd_session_url_a(a, "http://wd.local:4444",
    "abc-123", "/url");
    assert_streq(sess_url, "http://wd.local:4444/session/abc-123/url",
    "session_url_a concat");
    return 0;
}

# ================================================================
# 1.2.5 — profile instrumentation
# ================================================================
# `src/obs/prof.cyr` adds per-request per-phase timing captures and
# recv-buffer cap/used tracking. Default-off; runtime toggle via
# `sandhi_prof_enable(1)`. Captures fire inside `_sandhi_http_do_impl_a`
# at five phase boundaries: URL_PARSE_END, DNS_END, CONN_OPEN_END,
# REQ_BUILD_END, EXCHANGE_END.

# Disabled-by-default — every capture is a no-op and `sandhi_prof_get`
# returns 0.
fn test_alloc_125_prof_disabled_default() {
    assert_eq(sandhi_prof_enabled(), 0, "default disabled");
    sandhi_prof_capture(SANDHI_PROF_PHASE_URL_PARSE_END);
    assert_eq(sandhi_prof_get(SANDHI_PROF_PHASE_URL_PARSE_END), 0,
    "disabled capture returns 0");
    return 0;
}

# Enable + capture + read back. The captures must be monotonic
# non-negative (each phase happens-after the previous).
fn test_alloc_125_prof_capture_monotonic() {
    sandhi_prof_enable(1);
    sandhi_prof_reset();
    # Drive a sequence of captures with small busy-loops between
    # so each phase has measurable elapsed-ns. (Empty captures back-
    # to-back can collapse to 0 ns on fast systems if clock_now_ns
    # has coarse resolution.)
    var i = 0;
    while (i < 1000) { i = i + 1; }
    sandhi_prof_capture(SANDHI_PROF_PHASE_URL_PARSE_END);
    while (i < 2000) { i = i + 1; }
    sandhi_prof_capture(SANDHI_PROF_PHASE_DNS_END);
    while (i < 3000) { i = i + 1; }
    sandhi_prof_capture(SANDHI_PROF_PHASE_CONN_OPEN_END);
    while (i < 4000) { i = i + 1; }
    sandhi_prof_capture(SANDHI_PROF_PHASE_REQ_BUILD_END);
    while (i < 5000) { i = i + 1; }
    sandhi_prof_capture(SANDHI_PROF_PHASE_EXCHANGE_END);

    var t1 = sandhi_prof_get(SANDHI_PROF_PHASE_URL_PARSE_END);
    var t2 = sandhi_prof_get(SANDHI_PROF_PHASE_DNS_END);
    var t3 = sandhi_prof_get(SANDHI_PROF_PHASE_CONN_OPEN_END);
    var t4 = sandhi_prof_get(SANDHI_PROF_PHASE_REQ_BUILD_END);
    var t5 = sandhi_prof_get(SANDHI_PROF_PHASE_EXCHANGE_END);

    assert_eq(t1 >= 0, 1, "url_parse_end >= 0");
    assert_eq(t2 >= t1, 1, "dns_end >= url_parse_end (monotonic)");
    assert_eq(t3 >= t2, 1, "conn_open_end >= dns_end");
    assert_eq(t4 >= t3, 1, "req_build_end >= conn_open_end");
    assert_eq(t5 >= t4, 1, "exchange_end >= req_build_end");

    sandhi_prof_enable(0);
    return 0;
}

# Reset zeros all captures back to baseline.
fn test_alloc_125_prof_reset_clears() {
    sandhi_prof_enable(1);
    sandhi_prof_reset();
    var j = 0;
    while (j < 1000) { j = j + 1; }
    sandhi_prof_capture(SANDHI_PROF_PHASE_EXCHANGE_END);
    var t = sandhi_prof_get(SANDHI_PROF_PHASE_EXCHANGE_END);
    assert_eq(t >= 0, 1, "after capture, get returns elapsed");

    # Reset; immediately reading a phase that wasn't re-captured
    # returns 0 elapsed (capture timestamp == start timestamp).
    sandhi_prof_reset();
    assert_eq(sandhi_prof_get(SANDHI_PROF_PHASE_EXCHANGE_END), 0,
    "post-reset, uncaptured phase reads 0");

    sandhi_prof_enable(0);
    return 0;
}

# Recv-buffer record: cap and used round-trip while enabled.
fn test_alloc_125_prof_recv_buf() {
    sandhi_prof_enable(1);
    sandhi_prof_reset();
    sandhi_prof_record_recv(262144, 532);
    assert_eq(sandhi_prof_recv_cap(), 262144, "cap recorded");
    assert_eq(sandhi_prof_recv_used(), 532, "used recorded");

    # Disabled: record is a no-op (existing values stay).
    sandhi_prof_enable(0);
    sandhi_prof_record_recv(99999, 99999);
    assert_eq(sandhi_prof_recv_cap(), 262144, "disabled record is no-op");
    return 0;
}

# End-to-end: enable, drive a request through the public verb, read
# back captures. Use a garbage URL so the path returns at PARSE
# without doing real I/O — only the URL_PARSE phase actually fires
# in this case (subsequent phases get the same baseline timestamp).
fn test_alloc_125_prof_real_request_arena() {
    sandhi_prof_enable(1);
    var a = arena_allocator(4096);
    var resp = sandhi_http_get_a(a, "garbage://x", 0);
    assert_eq(sandhi_http_err_kind(resp), SANDHI_ERR_PARSE, "PARSE err");

    # URL_PARSE captured before the early-return for a parse failure.
    var url_ns = sandhi_prof_get(SANDHI_PROF_PHASE_URL_PARSE_END);
    assert_eq(url_ns >= 0, 1, "url_parse phase captured");
    sandhi_prof_enable(0);
    return 0;
}

# ================================================================
# 1.2.6 — OOM-guard audit on 1.2.0–1.2.4 `_a` additions
# ================================================================
# During 1.2.0 dev, the OOM regression test for
# `_sandhi_client_build_request_va` caught a SIGSEGV — when
# `str_builder_new_a` returned 0, the next `str_builder_add_cstr_a`
# dereferenced null. The fix was a single guard. This audit walked
# every `_a` variant added 1.2.0–1.2.4 looking for the same pattern
# and found two systemic gaps:
#   Pattern A — `alloc_via` for recv buffer in
#     `_sandhi_http_exchange_a` and `_keepalive_a`. Without the
#     guard, `sandhi_conn_recv_all_deadline(conn, rbuf=0, ...)`
#     writes to address 0 → SIGSEGV.
#   Pattern B — `sandhi_json_obj_new_a(a)` chain in dialect verbs.
#     `vec_push_a` (which `sandhi_json_add_*_a` calls) does NOT
#     null-check `v`; it does `load64(v + 8)` directly → SIGSEGV.
# Tests below drive each fixed path under `fail_after_n_allocs(0)`
# and assert the expected graceful return.

# Pattern A: exchange recv-buffer alloc OOM. Drive via the public
# `sandhi_http_get_a` against an unparseable URL — we early-return
# at PARSE before reaching exchange, so this test exercises the
# err-resp path threading. The actual exchange-OOM SIGSEGV path
# can't be reached without a working network conn; the guard is
# defensive but its presence is verified by reading the source.
fn test_alloc_126_exchange_path_arena() {
    var a = arena_allocator(4096);
    var resp = sandhi_http_get_a(a, "garbage://x", 0);
    assert_eq(sandhi_http_err_kind(resp), SANDHI_ERR_PARSE,
    "exchange path err-resp threads through arena");
    return 0;
}

# Pattern B: webdriver `navigate_to_a` JSON envelope OOM. Drive
# the body_obj=0 path via fail_after_n_allocs(0). Without the
# guard, the next sandhi_json_add_string_a would SIGSEGV on
# vec_push_a(v=0).
fn test_alloc_126_wd_navigate_to_oom() {
    var failer = fail_after_n_allocs(0);
    var resp = sandhi_wd_navigate_to_a(failer, "http://wd.local",
    "abc-123", "https://example.com");
    # Either the resp itself is 0 (double-OOM during _sandhi_rpc_resp_new_a)
    # or its err_kind is INTERNAL. Either way: no SIGSEGV.
    if (resp == 0) {
        assert_eq(1, 1, "double-OOM returned 0 cleanly");
        return 0;
    }
    assert_eq(sandhi_rpc_err_kind(resp), SANDHI_ERR_INTERNAL,
    "single-OOM returned INTERNAL err-resp");
    return 0;
}

# Pattern B: webdriver `find_element_a` — same shape with two adds.
fn test_alloc_126_wd_find_element_oom() {
    var failer = fail_after_n_allocs(0);
    var resp = sandhi_wd_find_element_a(failer, "http://wd.local",
    "abc-123", "css selector", "#x");
    if (resp == 0) { assert_eq(1, 1, "double-OOM 0"); return 0; }
    assert_eq(sandhi_rpc_err_kind(resp), SANDHI_ERR_INTERNAL,
    "find_element_a OOM → INTERNAL");
    return 0;
}

# Pattern B: webdriver `element_attribute_a` — uses str_builder for
# URL construction (different shape from json_obj_new chains). The
# guard is on `str_builder_new_a`.
fn test_alloc_126_wd_element_attribute_oom() {
    var failer = fail_after_n_allocs(0);
    var resp = sandhi_wd_element_attribute_a(failer, "http://wd.local",
    "abc-123", "elem-1", "href");
    if (resp == 0) { assert_eq(1, 1, "double-OOM 0"); return 0; }
    assert_eq(sandhi_rpc_err_kind(resp), SANDHI_ERR_INTERNAL,
    "element_attribute_a OOM → INTERNAL");
    return 0;
}

# Pattern B: webdriver helper `_sandhi_wd_build_path_a` returns 0
# on OOM at str_builder_new_a (was SIGSEGVing on the next add_cstr
# before the 1.2.6 guard).
fn test_alloc_126_wd_build_helper_oom() {
    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_wd_build_path_a(failer, "value.", "key"), 0,
    "build_path_a OOM → 0");
    assert_eq(_sandhi_wd_build_element_suffix_a(failer, "abc", "/click"), 0,
    "build_element_suffix_a OOM → 0");
    return 0;
}

# Pattern B: appium `set_context_a` — paint-on-top of the same
# json_obj_new_a chain as webdriver verbs.
fn test_alloc_126_ap_set_context_oom() {
    var failer = fail_after_n_allocs(0);
    var resp = sandhi_ap_set_context_a(failer, "http://wd.local",
    "abc-123", "NATIVE_APP");
    if (resp == 0) { assert_eq(1, 1, "double-OOM 0"); return 0; }
    assert_eq(sandhi_rpc_err_kind(resp), SANDHI_ERR_INTERNAL,
    "set_context_a OOM → INTERNAL");
    return 0;
}

# Pattern B: appium `new_session_a` — three nested json_obj_new_a
# calls (always / caps / root); each was a SIGSEGV waiting for OOM
# at the corresponding alloc index before the 1.2.6 fix.
fn test_alloc_126_ap_new_session_oom() {
    var failer = fail_after_n_allocs(0);
    var resp = sandhi_ap_new_session_a(failer, "http://wd.local",
    "Android", "UiAutomator2", 0);
    if (resp == 0) { assert_eq(1, 1, "double-OOM 0"); return 0; }
    assert_eq(sandhi_rpc_err_kind(resp), SANDHI_ERR_INTERNAL,
    "new_session_a OOM → INTERNAL");
    return 0;
}

# Pattern B: mcp `_sandhi_mcp_build_request_a` returns 0 on the
# json_obj_new_a OOM. Verifies the helper itself; the higher-level
# `sandhi_rpc_mcp_call_a` propagates the 0 body to
# `sandhi_rpc_call_a` which already null-checks and sends bodyless.
fn test_alloc_126_mcp_build_request_oom() {
    var failer = fail_after_n_allocs(0);
    assert_eq(_sandhi_mcp_build_request_a(failer, "tools/list", 0), 0,
    "mcp_build_request_a OOM → 0");
    return 0;
}

# Pattern B: mcp `sandhi_rpc_mcp_stream_a` — the build_request_a
# OOM and the headers_new_a OOM are both guarded; either path
# returns a stream-result struct with err=INTERNAL.
fn test_alloc_126_mcp_stream_oom() {
    var failer = fail_after_n_allocs(0);
    var sr = sandhi_rpc_mcp_stream_a(failer, "http://daimon.local/mcp",
    "tools/list", 0, 0, 0);
    if (sr == 0) { assert_eq(1, 1, "double-OOM 0"); return 0; }
    assert_eq(sandhi_stream_err(sr), SANDHI_ERR_INTERNAL,
    "stream_a OOM → INTERNAL");
    return 0;
}

