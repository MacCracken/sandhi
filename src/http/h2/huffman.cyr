# sandhi/http/h2/huffman — HPACK Huffman code (RFC 7541 Appendix B).
#
# HPACK strings on the wire are length-prefixed with an H bit
# indicating Huffman encoding. Real h2 servers always Huffman-encode
# response headers, so HPACK without a Huffman decoder cannot decode
# real-world traffic. This module supplies that decoder.
#
# Implementation:
#   - The 257-entry code table from RFC 7541 Appendix B is embedded
#     as a single 2570-character hex blob (one string literal = one
#     fixup). Each entry occupies 10 hex chars: 8 for the code value
#     (left-padded with zeros) + 2 for the bit length.
#   - At first use, the blob is parsed and a binary decode tree is
#     built. Each tree node is 24 bytes: { left_ptr, right_ptr,
    #     symbol_or_minus_1 }. Internal nodes have symbol = -1; leaves
#     hold the symbol value 0..256.
#   - Decode walks the tree bit-by-bit. On reaching a leaf, the
#     symbol is emitted (or rejected if it's the EOS, symbol 256 —
#     EOS in payload is a decoding error per §5.2).
#   - Padding handling per §5.2: after consuming all bits, if not
#     at root, the partial path MUST be ≤ 7 bits AND consist of
#     all-1 bits (the most-significant bits of the EOS code, which
#     is 0x3FFFFFFF). Anything else is malformed.
#
# Encode landed at 0.9.8 — `sandhi_hpack_huffman_encoded_len` probes
# the encoded byte count, `sandhi_hpack_huffman_encode` packs bits
# MSB-first into a caller-supplied buffer, EOS-prefix-padding the
# final byte per §5.2. The encoder is wired into hpack.cyr's string
# emit path (`_hpack_string_encode`) which now picks Huffman when
# strictly shorter than raw and sets the H bit accordingly.
#
# Decode landed as Bite 2b of 0.8.0; encode followed at 0.9.8.

# ================================================================
# Tree node layout (24 bytes)
# ================================================================
#
#   +0   left   (ptr to child node, or 0)
#   +8   right  (ptr to child node, or 0)
#   +16  symbol (i64: 0..256 on leaf, -1 on internal node)

var _SANDHI_HPACK_HUFFMAN_INTERNAL = 0 - 1;

fn _hpack_huffman_node_new() {
    var n = alloc(24);
    store64(n + 0, 0);
    store64(n + 8, 0);
    store64(n + 16, _SANDHI_HPACK_HUFFMAN_INTERNAL);
    return n;
}

# ================================================================
# Table blob — RFC 7541 Appendix B, all 257 entries, 10 hex chars each
# ================================================================
#
# Format per entry: 8 hex chars for code (left-zero-padded to fit
# the 30-bit max) + 2 hex chars for the bit length. Symbols are
# implicit by index (0..256). Total: 257 × 10 = 2570 chars.
#
# Single literal so the per-program fixup count stays low. Each line
# below covers 16 symbols × 10 chars = 160 chars; concatenated by
# the lexer into one blob.

var _hpack_huffman_blob = "";

# ================================================================
# Init — build the tree from the blob (and the symbol→code table
# for encode, 0.9.8)
# ================================================================
#
# Encode-side table: array of 257 × 16-byte entries indexed by
# symbol (0..256). Each entry holds:
#   +0  code  (i64) — the variable-bit code, right-aligned in u64
#   +8  bits  (i64) — code length in bits (5..30)
# Allocated lazily inside `_hpack_huffman_init` from the same blob
# that builds the decode tree.

var _hpack_huffman_inited = 0;
var _hpack_huffman_root = 0;
var _hpack_huffman_codes = 0;

fn _hpack_hex_digit(c) {
    if (c >= 48 && c <= 57)  { return c - 48; }   # 0-9
    if (c >= 97 && c <= 102) { return c - 87; }   # a-f
    if (c >= 65 && c <= 70)  { return c - 55; }   # A-F
    return 0 - 1;
}

fn _hpack_parse_hex(blob, off, n) {
    var v = 0;
    var i = 0;
    while (i < n) {
        v = v * 16 + _hpack_hex_digit(load8(blob + off + i));
        i = i + 1;
    }
    return v;
}

# Insert (code, length, sym) into the tree. Walks from root, taking
# left/right by each bit of `code` from MSB to LSB; creates internal
# nodes as needed; sets the leaf symbol at depth=length.
fn _hpack_huffman_add(code, length, sym) {
    var node = _hpack_huffman_root;
    var bit = length - 1;
    while (bit >= 0) {
        var b = (code >> bit) & 1;
        var next = 0;
        if (b == 0) { next = load64(node + 0); }
        else        { next = load64(node + 8); }
        if (next == 0) {
            next = _hpack_huffman_node_new();
            if (b == 0) { store64(node + 0, next); }
            else        { store64(node + 8, next); }
        }
        node = next;
        bit = bit - 1;
    }
    store64(node + 16, sym);
    return 0;
}

fn _hpack_huffman_init() {
    if (_hpack_huffman_inited == 1) { return 0; }
    _hpack_huffman_root = _hpack_huffman_node_new();
    _hpack_huffman_codes = alloc(257 * 16);
    var i = 0;
    while (i < 257) {
        var off = i * 10;
        var code   = _hpack_parse_hex(_hpack_huffman_blob, off, 8);
        var length = _hpack_parse_hex(_hpack_huffman_blob, off + 8, 2);
        _hpack_huffman_add(code, length, i);
        store64(_hpack_huffman_codes + i * 16,     code);
        store64(_hpack_huffman_codes + i * 16 + 8, length);
        i = i + 1;
    }
    _hpack_huffman_inited = 1;
    return 0;
}

fn _hpack_huffman_code_of(symbol) {
    return load64(_hpack_huffman_codes + symbol * 16);
}

fn _hpack_huffman_bits_of(symbol) {
    return load64(_hpack_huffman_codes + symbol * 16 + 8);
}

# ================================================================
# Decode
# ================================================================
#
# Walk the tree bit-by-bit through `nbytes` of input starting at
# `buf+start`. Returns a freshly-allocated NUL-terminated cstr, or 0
# on malformed input (EOS in payload, padding > 7 bits, padding not
# all-1s, no edge for taken bit).

fn sandhi_hpack_huffman_decode(buf, start, nbytes) {
    _hpack_huffman_init();
    if (nbytes < 0) { return 0; }
    var out_cap = nbytes * 8 + 1;     # max ratio: shortest code is 5 bits
    if (out_cap < 1) { out_cap = 1; }
    var out = alloc(out_cap);
    var out_len = 0;
    var node = _hpack_huffman_root;
    var partial_bits = 0;
    var partial_all_ones = 1;
    var byte_idx = 0;
    var bit_idx = 0;
    var bits_left = nbytes * 8;
    while (bits_left > 0) {
        var byte = load8(buf + start + byte_idx);
        var b = (byte >> (7 - bit_idx)) & 1;
        var next = 0;
        if (b == 0) { next = load64(node + 0); partial_all_ones = 0; }
        else        { next = load64(node + 8); }
        if (next == 0) { return 0; }    # bit had no edge — malformed
        node = next;
        partial_bits = partial_bits + 1;
        var sym = load64(node + 16);
        if (sym != _SANDHI_HPACK_HUFFMAN_INTERNAL) {
            if (sym == 256) { return 0; }   # EOS in payload — error
            store8(out + out_len, sym);
            out_len = out_len + 1;
            node = _hpack_huffman_root;
            partial_bits = 0;
            partial_all_ones = 1;
        }
        bit_idx = bit_idx + 1;
        if (bit_idx == 8) {
            bit_idx = 0;
            byte_idx = byte_idx + 1;
        }
        bits_left = bits_left - 1;
    }
    # Padding check: if not at root, partial path must be ≤ 7 bits
    # AND all bits must be 1 (MSBs of EOS code 0x3FFFFFFF). Otherwise
    # malformed per RFC 7541 §5.2.
    if (node != _hpack_huffman_root) {
        if (partial_bits > 7) { return 0; }
        if (partial_all_ones != 1) { return 0; }
    }
    store8(out + out_len, 0);
    return out;
}

# ================================================================
# Encode (RFC 7541 §5.2 + Appendix B) — landed 0.9.8
# ================================================================
#
# Encoded byte count for `s`: walk each byte, sum bit-lengths, divide
# by 8 rounding up. Used by `_hpack_string_encode` in hpack.cyr to
# compare against raw size and pick the shorter representation —
# Huffman only wins on text-shaped strings (cookie blobs, JSON
# payloads, ASCII URLs); short binary tokens often round-trip larger
# under Huffman, in which case we keep the raw form.

fn sandhi_hpack_huffman_encoded_len(s) {
    _hpack_huffman_init();
    if (s == 0) { return 0; }
    var n = strlen(s);
    var bits = 0;
    var i = 0;
    while (i < n) {
        var ch = load8(s + i) & 0xFF;
        bits = bits + _hpack_huffman_bits_of(ch);
        i = i + 1;
    }
    return (bits + 7) >> 3;
}

# Encode `s` into `out` starting at offset `off`. Caller has already
# emitted the H=1 length prefix and sized `out` with room for at
# least `sandhi_hpack_huffman_encoded_len(s)` bytes after `off`.
# Returns the new write offset.
#
# Bit packing is MSB-first per §5.2. The accumulator holds up to
# ~37 bits at once (max code length 30 + up to 7 leftover bits) —
# fits in i64 with room to spare. After the input is exhausted, the
# final partial byte is padded with the most-significant bits of the
# EOS code (all 1s up to 7 bits), which is the canonical pad pattern
# the decoder accepts.
fn sandhi_hpack_huffman_encode(out, off, s) {
    _hpack_huffman_init();
    if (s == 0) { return off; }
    var n = strlen(s);
    var p = off;
    var acc = 0;
    var nbits = 0;
    var i = 0;
    while (i < n) {
        var ch = load8(s + i) & 0xFF;
        var code = _hpack_huffman_code_of(ch);
        var clen = _hpack_huffman_bits_of(ch);
        acc = (acc << clen) | code;
        nbits = nbits + clen;
        while (nbits >= 8) {
            nbits = nbits - 8;
            store8(out + p, (acc >> nbits) & 0xFF);
            p = p + 1;
        }
        i = i + 1;
    }
    if (nbits > 0) {
        var pad_bits = 8 - nbits;
        var pad_mask = (1 << pad_bits) - 1;
        store8(out + p, ((acc << pad_bits) | pad_mask) & 0xFF);
        p = p + 1;
    }
    return p;
}

