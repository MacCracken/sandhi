# sandhi/server — HTTP server surface.
#
# Lift-and-shift landing site for lib/http_server.cyr per M1 of the
# sandhi roadmap. Content below is the verbatim stdlib file as of the
# 5.6.22 toolchain pin; no behavior change, structural move only.
# Routing, middleware, and auth primitives layer on top in later
# milestones — ADR 0001 is strict about staying lift-first-then-enhance.
#
# During the migration window, stdlib lib/http_server.cyr is expected
# to alias these symbols so existing consumers keep building; the alias
# retires at fold-into-stdlib (M6).
#
# Requires: alloc.cyr, string.cyr, fmt.cyr, str.cyr, net.cyr,
# tagged.cyr, syscalls.cyr (all pulled in via stdlib deps).

# ================================================================
# Status codes
# ================================================================
var HTTP_OK                  = 200;
var HTTP_NO_CONTENT          = 204;
var HTTP_MOVED_PERMANENTLY   = 301;
var HTTP_FOUND               = 302;
var HTTP_NOT_MODIFIED        = 304;
var HTTP_BAD_REQUEST         = 400;
var HTTP_UNAUTHORIZED        = 401;
var HTTP_FORBIDDEN           = 403;
var HTTP_NOT_FOUND           = 404;
var HTTP_METHOD_NOT_ALLOWED  = 405;
var HTTP_REQUEST_TIMEOUT     = 408;
var HTTP_PAYLOAD_TOO_LARGE   = 413;
var HTTP_INTERNAL            = 500;
var HTTP_NOT_IMPLEMENTED     = 501;  #skip-lint: HTTP 501 status-code constant
var HTTP_SERVICE_UNAVAILABLE = 503;

# ================================================================
# Internal byte-search + ASCII helpers
# ================================================================

# Find the first occurrence of `needle[0..nlen]` in `haystack[0..hlen]`.
# Returns the offset, or 0 - 1 if not found.
fn _hsv_find(haystack, hlen, needle, nlen): i64 {
    if (nlen == 0) { return 0; }
    if (nlen > hlen) { return 0 - 1; }
    var i = 0;
    while (i <= hlen - nlen) {
        if (memeq(haystack + i, needle, nlen) == 1) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

fn _hsv_to_lower(c): i64 {
    if (c >= 65) { if (c <= 90) { return c + 32; } }
    return c;
}

fn _hsv_iceq(a, b, n): i64 {
    var i = 0;
    while (i < n) {
        if (_hsv_to_lower(load8(a + i)) != _hsv_to_lower(load8(b + i))) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn _hsv_next_nl(buf, start, end): i64 {
    var i = start;
    while (i < end) {
        if (load8(buf + i) == 10) { return i; }
        i = i + 1;
    }
    return end;
}

# ================================================================
# Request parsing — read-only on the buffer, only allocates returned cstrs
# ================================================================

# Method from the request line — "GET", "POST", etc. Returns "" on malformed.
# Extract the request method into `a`. Returns "" on malformed; 0 on
# OOM (caller can distinguish by null-checking; "" is non-zero).
fn sandhi_server_get_method_a(a, buf, blen): i64 {
    var sp = _hsv_find(buf, blen, " ", 1);
    if (sp < 0) { return ""; }
    var out = alloc_via(a, sp + 1);
    if (out == 0) { return 0; }
    memcpy(out, buf, sp);
    store8(out + sp, 0);
    return out;
}

fn sandhi_server_get_method(buf, blen): i64 {
    return sandhi_server_get_method_a(default_alloc(), buf, blen);
}

fn sandhi_server_get_path_a(a, buf, blen): i64 {
    var sp1 = _hsv_find(buf, blen, " ", 1);
    if (sp1 < 0) { return ""; }
    var sp2 = _hsv_find(buf + sp1 + 1, blen - sp1 - 1, " ", 1);
    if (sp2 < 0) { return ""; }
    var out = alloc_via(a, sp2 + 1);
    if (out == 0) { return 0; }
    memcpy(out, buf + sp1 + 1, sp2);
    store8(out + sp2, 0);
    return out;
}

fn sandhi_server_get_path(buf, blen): i64 {
    return sandhi_server_get_path_a(default_alloc(), buf, blen);
}

# Offset of the body start (after \r\n\r\n) — 0 - 1 if no headers terminator.
fn sandhi_server_body_offset(buf, blen): i64 {
    var off = _hsv_find(buf, blen, "\r\n\r\n", 4);
    if (off < 0) { return 0 - 1; }
    return off + 4;
}

# Case-insensitive header lookup. Returns the value cstr (trimmed of leading
# SP and trailing CR), or 0 if the header is absent.
fn sandhi_server_find_header_a(a, buf, blen, name): i64 {
    var nlen = strlen(name);
    var headers_end = _hsv_find(buf, blen, "\r\n\r\n", 4);
    if (headers_end < 0) { headers_end = blen; }
    var line_start = _hsv_next_nl(buf, 0, headers_end);
    if (line_start >= headers_end) { return 0; }
    line_start = line_start + 1;
    while (line_start < headers_end) {
        var line_end = _hsv_next_nl(buf, line_start, headers_end);
        if (line_start + nlen + 1 <= line_end
        && _hsv_iceq(buf + line_start, name, nlen) == 1
        && load8(buf + line_start + nlen) == 58) {
            var vs = line_start + nlen + 1;
            while (vs < line_end && load8(buf + vs) == 32) { vs = vs + 1; }
            var ve = line_end;
            if (ve > vs && load8(buf + ve - 1) == 13) { ve = ve - 1; }
            var vlen = ve - vs;
            var out = alloc_via(a, vlen + 1);
            if (out == 0) { return 0; }
            memcpy(out, buf + vs, vlen);
            store8(out + vlen, 0);
            return out;
        }
        line_start = line_end + 1;
    }
    return 0;
}

fn sandhi_server_find_header(buf, blen, name): i64 {
    return sandhi_server_find_header_a(default_alloc(), buf, blen, name);
}

# Content-Length value — 0 if header absent or malformed.
#
# 0.9.1 P1 — strict per RFC 7230 §3.3.2: pure decimal digits (with
# optional leading/trailing whitespace) only. Previously skipped
# non-digits silently, so "10, 20" parsed as 1020 — CL.CL smuggling.
# Returns 0 on any malformed value (including non-digit characters
# embedded in the number); the existing accept loop reads body up
# to the parsed length so 0 means "no body" which is a safe fail
# closed for malformed input.
fn sandhi_server_content_length(buf, blen): i64 {
    var v = sandhi_server_find_header(buf, blen, "Content-Length");
    if (v == 0) { return 0; }
    var i = 0;
    while (load8(v + i) == 32 || load8(v + i) == 9) { i = i + 1; }
    if (load8(v + i) == 0) { return 0; }
    var n = 0;
    var seen_digit = 0;
    while (load8(v + i) >= 48 && load8(v + i) <= 57) {
        n = n * 10 + (load8(v + i) - 48);
        seen_digit = 1;
        i = i + 1;
    }
    if (seen_digit == 0) { return 0; }
    while (load8(v + i) == 32 || load8(v + i) == 9) { i = i + 1; }
    if (load8(v + i) != 0) { return 0; }
    return n;
}

# 0.9.1 P1 — count occurrences of a given header name in the
# request. Used to detect Host.Host / CL.CL / TE.TE duplicate
# conditions that are malformed per RFC 7230. Case-insensitive
# match. We don't have to be perfect about line boundaries here
# because sandhi_server_find_header / `_hsv_find` already understand the
# request format — we just iterate all body offsets and use them.
fn _sandhi_server_count_header_occurrences(buf, blen, name): i64 {
    var count = 0;
    var pos = 0;
    var name_len = strlen(name);
    var line_start = 0;
    while (line_start < blen) {
        # Find end of line.
        var line_end = line_start;
        while (line_end < blen && load8(buf + line_end) != 10) { line_end = line_end + 1; }
        if (line_end == line_start) { return count; }  # blank line ends headers
        if (line_end == line_start + 1 && load8(buf + line_start) == 13) {
            return count;
        }
        # Compare line prefix against `name:` (case-insensitive).
        if (line_end > line_start + name_len) {
            if (_hsv_iceq(buf + line_start, name, name_len) == 1) {
                if (load8(buf + line_start + name_len) == 58) {
                    count = count + 1;
                }
            }
        }
        line_start = line_end + 1;
    }
    return count;
}

# 0.9.1 P1 — 1 if the request has multiple Host / Content-Length /
# Transfer-Encoding headers (CL.CL / Host.Host / TE.TE smuggling
# vector per RFC 7230 §3.3.2 + §5.4). Server replies 400 on truthy
# rather than dispatching to the handler.
fn sandhi_server_request_has_dup_smuggling_header(buf, blen): i64 {
    if (_sandhi_server_count_header_occurrences(buf, blen, "Host") > 1)              { return 1; }
    if (_sandhi_server_count_header_occurrences(buf, blen, "Content-Length") > 1)    { return 1; }
    if (_sandhi_server_count_header_occurrences(buf, blen, "Transfer-Encoding") > 1) { return 1; }
    return 0;
}

# 0.9.0 P0 #2 — 1 if the request carries both `Content-Length` AND
# `Transfer-Encoding: chunked`, which is malformed per RFC 7230
# §3.3.3 and the canonical CL.TE smuggling vector. The accept-loop
# in `sandhi_server_run_opts` checks this and replies 400 before
# handing the request to the user's handler.
fn sandhi_server_request_has_cl_te_conflict(buf, blen): i64 {
    if (sandhi_server_find_header(buf, blen, "Content-Length") == 0) { return 0; }
    var te = sandhi_server_find_header(buf, blen, "Transfer-Encoding");
    if (te == 0) { return 0; }
    # Tolerant case-insensitive substring match for "chunked".
    var i = 0;
    while (load8(te + i) != 0) {
        var c0 = load8(te + i);
        if (c0 >= 65 && c0 <= 90) { c0 = c0 + 32; }
        if (c0 == 99) {
            var j = 1;
            var matched = 1;
            var want = "hunked";
            while (matched == 1 && j < 7) {
                var ch = load8(te + i + j);
                if (ch >= 65 && ch <= 90) { ch = ch + 32; }
                if (ch != load8(want + j - 1)) { matched = 0; }
                j = j + 1;
            }
            if (matched == 1) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Path + query helpers
# ================================================================

# "/foo?bar=baz" → "/foo". Returns the input unchanged if there's no '?'.
fn sandhi_server_path_only_a(a, path): i64 {
    if (path == 0) { return path; }
    var i = 0;
    while (load8(path + i) != 0) {
        if (load8(path + i) == 63) {
            var out = alloc_via(a, i + 1);
            if (out == 0) { return 0; }
            memcpy(out, path, i);
            store8(out + i, 0);
            return out;
        }
        i = i + 1;
    }
    return path;
}

fn sandhi_server_path_only(path): i64 {
    return sandhi_server_path_only_a(default_alloc(), path);
}

fn sandhi_server_url_decode_a(a, s): i64 {
    if (s == 0) { return ""; }
    var slen = strlen(s);
    var out = alloc_via(a, slen + 1);
    if (out == 0) { return 0; }
    var si = 0;
    var oi = 0;
    while (si < slen) {
        var c = load8(s + si);
        if (c == 37 && si + 2 < slen) {
            var h1 = load8(s + si + 1);
            var h2 = load8(s + si + 2);
            var v1 = 0;
            var v2 = 0;
            if (h1 >= 48 && h1 <= 57) { v1 = h1 - 48; }
            elif (h1 >= 65 && h1 <= 70) { v1 = h1 - 55; }
            elif (h1 >= 97 && h1 <= 102) { v1 = h1 - 87; }
            if (h2 >= 48 && h2 <= 57) { v2 = h2 - 48; }
            elif (h2 >= 65 && h2 <= 70) { v2 = h2 - 55; }
            elif (h2 >= 97 && h2 <= 102) { v2 = h2 - 87; }
            store8(out + oi, v1 * 16 + v2);
            si = si + 3;
        } elif (c == 43) {
            store8(out + oi, 32);
            si = si + 1;
        } else {
            store8(out + oi, c);
            si = si + 1;
        }
        oi = oi + 1;
    }
    store8(out + oi, 0);
    return out;
}

fn sandhi_server_url_decode(s): i64 {
    return sandhi_server_url_decode_a(default_alloc(), s);
}

# Query parameter value, percent-decoded. 0 if not found.
# Example: sandhi_server_get_param("/a?foo=1&bar=hello%20world", "bar") → "hello world"
fn sandhi_server_get_param_a(a, path, name): i64 {
    if (path == 0) { return 0; }
    var plen = strlen(path);
    var qmark = 0 - 1;
    var pi = 0;
    while (pi < plen) {
        if (load8(path + pi) == 63) { qmark = pi + 1; pi = plen; }
        pi = pi + 1;
    }
    if (qmark < 0) { return 0; }
    var nlen = strlen(name);
    pi = qmark;
    while (pi < plen) {
        if (pi + nlen + 1 <= plen
        && memeq(path + pi, name, nlen) == 1
        && load8(path + pi + nlen) == 61) {
            var vs = pi + nlen + 1;
            var ve = vs;
            while (ve < plen && load8(path + ve) != 38) { ve = ve + 1; }
            var raw = alloc_via(a, ve - vs + 1);
            if (raw == 0) { return 0; }
            memcpy(raw, path + vs, ve - vs);
            store8(raw + ve - vs, 0);
            return sandhi_server_url_decode_a(a, raw);
        }
        while (pi < plen && load8(path + pi) != 38) { pi = pi + 1; }
        pi = pi + 1;
    }
    return 0;
}

fn sandhi_server_get_param(path, name): i64 {
    return sandhi_server_get_param_a(default_alloc(), path, name);
}

fn sandhi_server_path_segment_a(a, path, n): i64 {
    if (path == 0) { return 0; }
    var path_only = sandhi_server_path_only_a(a, path);
    var plen = strlen(path_only);
    var seg = 0;
    var ss = 0;
    var pi = 0;
    if (pi < plen && load8(path_only + pi) == 47) { pi = pi + 1; ss = pi; }
    while (pi <= plen) {
        var c = 0;
        if (pi < plen) { c = load8(path_only + pi); }
        if (c == 47 || c == 0) {
            if (seg == n) {
                var slen = pi - ss;
                var out = alloc_via(a, slen + 1);
                if (out == 0) { return 0; }
                memcpy(out, path_only + ss, slen);
                store8(out + slen, 0);
                return out;
            }
            seg = seg + 1;
            ss = pi + 1;
        }
        pi = pi + 1;
    }
    return 0;
}

fn sandhi_server_path_segment(path, n): i64 {
    return sandhi_server_path_segment_a(default_alloc(), path, n);
}

# ================================================================
# Response builders
# ================================================================

# Minimal status response with Content-Length: 0.
# e.g. sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
# 1.2.7 Batch G: each `_send_*` gains an `_a` variant that threads
# `a` through `str_builder_*_a`. Bare versions stay as back-compat
# wrappers passing `default_alloc()`. Return shape: `_a` returns 0
# on success, `-1` on OOM (str_builder_new_a returned 0). Bare
# versions return whatever `_a` returns — under default_alloc that's
# always 0 in practice. Closes the SIGSEGV-on-OOM gap that mirrored
# the 1.2.6 RPC dialect findings.
fn sandhi_server_send_status_a(a, cfd, code, msg): i64 {
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0 - 1; }
    str_builder_add_cstr_a(a, sb, "HTTP/1.1 ");
    str_builder_add_int_a(a, sb, code);
    str_builder_add_cstr_a(a, sb, " ");
    str_builder_add_cstr_a(a, sb, msg);
    str_builder_add_cstr_a(a, sb, "\r\nContent-Length: 0\r\nConnection: close\r\n\r\n");
    var s = str_data(str_builder_build_a(a, sb));
    sock_send(cfd, s, strlen(s));
    return 0;
}

fn sandhi_server_send_status(cfd, code, msg): i64 {
    return sandhi_server_send_status_a(default_alloc(), cfd, code, msg);
}

# Full response. extra_headers is a cstr (each line CRLF-terminated) or 0.
# e.g. sandhi_server_send_response(cfd, 200, "OK", "application/json", body, len, 0);
fn sandhi_server_send_response_a(a, cfd, code, msg, content_type, body, body_len, extra_headers): i64 {
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0 - 1; }
    str_builder_add_cstr_a(a, sb, "HTTP/1.1 ");
    str_builder_add_int_a(a, sb, code);
    str_builder_add_cstr_a(a, sb, " ");
    str_builder_add_cstr_a(a, sb, msg);
    str_builder_add_cstr_a(a, sb, "\r\nContent-Type: ");
    str_builder_add_cstr_a(a, sb, content_type);
    str_builder_add_cstr_a(a, sb, "\r\nContent-Length: ");
    str_builder_add_int_a(a, sb, body_len);
    str_builder_add_cstr_a(a, sb, "\r\n");
    if (extra_headers != 0) { str_builder_add_cstr_a(a, sb, extra_headers); }
    str_builder_add_cstr_a(a, sb, "Connection: close\r\n\r\n");
    var head = str_data(str_builder_build_a(a, sb));
    sock_send(cfd, head, strlen(head));
    if (body_len > 0) { sock_send(cfd, body, body_len); }
    return 0;
}

fn sandhi_server_send_response(cfd, code, msg, content_type, body, body_len, extra_headers): i64 {
    return sandhi_server_send_response_a(default_alloc(), cfd, code, msg,
    content_type, body, body_len, extra_headers);
}

# 204 No Content with optional extra headers (CRLF-terminated cstr or 0).
fn sandhi_server_send_204_a(a, cfd, extra_headers): i64 {
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0 - 1; }
    str_builder_add_cstr_a(a, sb, "HTTP/1.1 204 No Content\r\n");
    if (extra_headers != 0) { str_builder_add_cstr_a(a, sb, extra_headers); }
    str_builder_add_cstr_a(a, sb, "Content-Length: 0\r\nConnection: close\r\n\r\n");
    var s = str_data(str_builder_build_a(a, sb));
    sock_send(cfd, s, strlen(s));
    return 0;
}

fn sandhi_server_send_204(cfd, extra_headers): i64 {
    return sandhi_server_send_204_a(default_alloc(), cfd, extra_headers);
}

# ================================================================
# Chunked / streaming responses (Transfer-Encoding: chunked)
# ================================================================
# Use this for SSE, large bodies, or any long-running response.
# Sequence:
#   sandhi_server_send_chunked_start(cfd, 200, "text/event-stream", 0);
#   sandhi_server_send_chunk(cfd, "data: hello\n\n", 13);
#   sandhi_server_send_chunk(cfd, "data: world\n\n", 13);
#   sandhi_server_send_chunked_end(cfd);

# Begin a chunked / SSE response. Sends the HTTP/1.1 status line plus
# Transfer-Encoding: chunked. Follow with repeated sandhi_server_send_chunk calls
# and finish with sandhi_server_send_chunked_end. extra_headers is a cstr of
# CRLF-terminated header lines or 0.
fn sandhi_server_send_chunked_start_a(a, cfd, code, content_type, extra_headers): i64 {
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0 - 1; }
    str_builder_add_cstr_a(a, sb, "HTTP/1.1 ");
    str_builder_add_int_a(a, sb, code);
    str_builder_add_cstr_a(a, sb, " OK\r\nContent-Type: ");
    str_builder_add_cstr_a(a, sb, content_type);
    str_builder_add_cstr_a(a, sb, "\r\nTransfer-Encoding: chunked\r\n");
    if (extra_headers != 0) { str_builder_add_cstr_a(a, sb, extra_headers); }
    str_builder_add_cstr_a(a, sb, "Connection: close\r\n\r\n");
    var head = str_data(str_builder_build_a(a, sb));
    sock_send(cfd, head, strlen(head));
    return 0;
}

fn sandhi_server_send_chunked_start(cfd, code, content_type, extra_headers): i64 {
    return sandhi_server_send_chunked_start_a(default_alloc(), cfd, code, content_type, extra_headers);
}

# Send one chunk of a chunked-transfer response. Emits the chunk-length
# as lowercase hex followed by CRLF, then `len` bytes of `data`, then
# another CRLF. Use between sandhi_server_send_chunked_start and sandhi_server_send_chunked_end.
fn sandhi_server_send_chunk(cfd, data, len): i64 {
    var hexbuf[32];
    var hi = 0;
    var n = len;
    if (n == 0) { store8(&hexbuf, 48); hi = 1; }
    else {
        var tmp[32];
        var ti = 0;
        while (n > 0) {
            var d = n & 15;
            if (d < 10) { store8(&tmp + ti, 48 + d); }
            else { store8(&tmp + ti, 87 + d); }
            n = n >> 4;
            ti = ti + 1;
        }
        var ri = ti;
        while (ri > 0) {
            ri = ri - 1;
            store8(&hexbuf + hi, load8(&tmp + ri));
            hi = hi + 1;
        }
    }
    store8(&hexbuf + hi, 13);
    store8(&hexbuf + hi + 1, 10);
    sock_send(cfd, &hexbuf, hi + 2);
    if (len > 0) { sock_send(cfd, data, len); }
    sock_send(cfd, "\r\n", 2);
    return 0;
}

# Terminate a chunked-transfer response. Sends the zero-length chunk
# that tells the client the body is complete ("0\r\n\r\n").
fn sandhi_server_send_chunked_end(cfd): i64 {
    sock_send(cfd, "0\r\n\r\n", 5);
    return 0;
}

# ================================================================
# Request reading — Content-Length aware
# ================================================================

# Read a complete HTTP request from cfd into buf (up to max bytes). Reads
# until either:
#   - the request body is fully received (per Content-Length), OR
#   - cfd is closed by the peer, OR
#   - max bytes have been read.
# Returns the total bytes read (or 0 - 1 on socket error). Always
# null-terminates buf at the returned length.
fn sandhi_server_recv_request(cfd, buf, max): i64 {
    var have = 0;
    var need_body = 0 - 1;

    while (have < max) {
        var r = sock_recv(cfd, buf + have, max - have);
        if (is_err_result(r) == 1) { return 0 - 1; }
        var n = payload(r);
        if (n <= 0) {
            store8(buf + have, 0);
            return have;
        }
        have = have + n;

        if (need_body == 0 - 1) {
            store8(buf + have, 0);
            var bo = sandhi_server_body_offset(buf, have);
            if (bo >= 0) {
                var clen = sandhi_server_content_length(buf, have);
                need_body = bo + clen;
            }
        }
        if (need_body != 0 - 1 && have >= need_body) {
            store8(buf + have, 0);
            return have;
        }
    }
    store8(buf + have, 0);
    return have;
}

# ================================================================
# Server lifecycle — bind, listen, accept-loop
# ================================================================

# Per-process request buffer (lazily allocated, reused across connections).
var _hsv_req_buf = 0;
var HSV_REQ_BUF_SIZE = 65536;

# ================================================================
# Server options (added 0.7.2)
# ================================================================
#
# Struct layout (16 bytes):
#   +0   idle_ms    (int: per-connection recv timeout; 0 = blocking.
#                    Default 30000 = 30 s; matches Go `net/http.Server.
#                    IdleTimeout`. Slowloris guard — a peer that sends
#                    a partial request then stalls gets dropped.)
#   +8   max_conns  (int: reserved for 0.8.0+. Server today is single-
#                    threaded accept/serve; honoring this requires a
#                    thread-pool or epoll-based accept model, which is
#                    bigger than 0.7.2 budget. Getter/setter exist
#                    so the option survey-surface stays stable across
#                    0.7.2 → 0.8.0.)

#
# 1.6.8 extends the struct (16 → 64 bytes) for server-side TLS creds + a
# decoupled accept backlog. New fields are zeroed by options_new, so a
# plaintext caller that never touches them is byte-identical to pre-1.6.8
# (tls_on == 0 → the serve loops take the plaintext path).
#   +16  tls_cert      (ptr: cert chain bytes — leaf-first PEM or DER; 0 = none)
#   +24  tls_cert_len  (int: cert byte length)
#   +32  tls_key       (ptr: private key bytes — PEM or DER; Ed25519 / ECDSA
#                       P-256 / P-384 only, RSA unsupported by the native stack)
#   +40  tls_key_len   (int: key byte length)
#   +48  tls_on        (int: 1 once sandhi_server_options_tls() set creds)
#   +56  backlog       (int: kernel listen backlog AND pooled handoff-channel
#                       depth — DECOUPLED from max_conns/worker count, 1.6.8.
#                       Default 128. A burst beyond the worker count now queues
#                       up to `backlog` accepted conns instead of being sized to
#                       the worker pool — the yeo-cy-test 🔵 handoff-depth fix.)

enum SandhiServerOptOff {
    SANDHI_SERVER_OPT_OFF_IDLE_MS      = 0;
    SANDHI_SERVER_OPT_OFF_MAX_CONNS    = 8;
    SANDHI_SERVER_OPT_OFF_TLS_CERT     = 16;
    SANDHI_SERVER_OPT_OFF_TLS_CERT_LEN = 24;
    SANDHI_SERVER_OPT_OFF_TLS_KEY      = 32;
    SANDHI_SERVER_OPT_OFF_TLS_KEY_LEN  = 40;
    SANDHI_SERVER_OPT_OFF_TLS_ON       = 48;
    SANDHI_SERVER_OPT_OFF_BACKLOG      = 56;
}

var SANDHI_SERVER_OPT_STRUCT_SIZE = 64;
var SANDHI_SERVER_DEFAULT_IDLE_MS = 30000;
var SANDHI_SERVER_DEFAULT_MAX_CONNS = 128;
var SANDHI_SERVER_DEFAULT_BACKLOG = 128;

fn sandhi_server_options_new_a(a): i64 {
    var o = alloc_via(a, SANDHI_SERVER_OPT_STRUCT_SIZE);
    if (o == 0) { return 0; }
    store64(o + SANDHI_SERVER_OPT_OFF_IDLE_MS, SANDHI_SERVER_DEFAULT_IDLE_MS);
    store64(o + SANDHI_SERVER_OPT_OFF_MAX_CONNS, SANDHI_SERVER_DEFAULT_MAX_CONNS);
    store64(o + SANDHI_SERVER_OPT_OFF_TLS_CERT, 0);
    store64(o + SANDHI_SERVER_OPT_OFF_TLS_CERT_LEN, 0);
    store64(o + SANDHI_SERVER_OPT_OFF_TLS_KEY, 0);
    store64(o + SANDHI_SERVER_OPT_OFF_TLS_KEY_LEN, 0);
    store64(o + SANDHI_SERVER_OPT_OFF_TLS_ON, 0);
    store64(o + SANDHI_SERVER_OPT_OFF_BACKLOG, SANDHI_SERVER_DEFAULT_BACKLOG);
    return o;
}

fn sandhi_server_options_new(): i64 {
    return sandhi_server_options_new_a(default_alloc());
}

fn sandhi_server_options_idle_ms(opts, ms): i64 {
    store64(opts + SANDHI_SERVER_OPT_OFF_IDLE_MS, ms);
    return 0;
}

fn sandhi_server_options_max_conns(opts, n): i64 {
    store64(opts + SANDHI_SERVER_OPT_OFF_MAX_CONNS, n);
    return 0;
}

fn sandhi_server_options_get_idle_ms(opts): i64 {
    if (opts == 0) { return SANDHI_SERVER_DEFAULT_IDLE_MS; }
    return load64(opts + SANDHI_SERVER_OPT_OFF_IDLE_MS);
}

fn sandhi_server_options_get_max_conns(opts): i64 {
    if (opts == 0) { return SANDHI_SERVER_DEFAULT_MAX_CONNS; }
    return load64(opts + SANDHI_SERVER_OPT_OFF_MAX_CONNS);
}

# Enable server-side TLS on these options. `cert` is the server cert chain
# (leaf-first), `key` the matching private key — both as raw bytes (PEM or
# DER; the native stack auto-detects). Keys: Ed25519 / ECDSA P-256 / P-384
# (RSA is not supported by the native server stack). The buffers are
# BORROWED by pointer (not copied) — they must outlive the server, so pass
# process-lifetime buffers (e.g. read once at startup). Sets tls_on so the
# `_tls` serve loops take the TLS path; the plaintext loops ignore it.
fn sandhi_server_options_tls(opts, cert, cert_len, key, key_len): i64 {
    if (opts == 0) { return 0; }
    store64(opts + SANDHI_SERVER_OPT_OFF_TLS_CERT, cert);
    store64(opts + SANDHI_SERVER_OPT_OFF_TLS_CERT_LEN, cert_len);
    store64(opts + SANDHI_SERVER_OPT_OFF_TLS_KEY, key);
    store64(opts + SANDHI_SERVER_OPT_OFF_TLS_KEY_LEN, key_len);
    store64(opts + SANDHI_SERVER_OPT_OFF_TLS_ON, 1);
    return 0;
}

fn sandhi_server_options_get_tls(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_SERVER_OPT_OFF_TLS_ON);
}

# Accept backlog: the kernel `listen()` backlog AND, for the pooled servers,
# the depth of the accepted-connection handoff channel. DECOUPLED from
# `max_conns` (the worker count) as of 1.6.8 so a spiky burst beyond the
# worker count queues up to `backlog` connections instead of being sized to
# the pool. Default 128.
fn sandhi_server_options_backlog(opts, n): i64 {
    if (opts == 0) { return 0; }
    store64(opts + SANDHI_SERVER_OPT_OFF_BACKLOG, n);
    return 0;
}

fn sandhi_server_options_get_backlog(opts): i64 {
    if (opts == 0) { return SANDHI_SERVER_DEFAULT_BACKLOG; }
    var b = load64(opts + SANDHI_SERVER_OPT_OFF_BACKLOG);
    if (b < 1) { b = SANDHI_SERVER_DEFAULT_BACKLOG; }
    return b;
}

# ================================================================
# SIGPIPE guard (1.6.6) — security fix (yeo-cy-test probe finding)
# ================================================================
# `net.cyr`'s `sock_send` is a bare `sys_write` with NO `MSG_NOSIGNAL`,
# so a peer that closes the connection mid-response makes the kernel
# raise SIGPIPE — whose DEFAULT disposition terminates the process. That
# is a trivial unauthenticated remote DoS against any sandhi server: a
# client that sends a request line then disconnects (or drops during the
# response write) kills the whole server (verified by the yeo-cy-test
# probe — signal 13). The server owns the process lifecycle, so it
# installs `SIG_IGN` for SIGPIPE once at startup; a send to a dead peer
# then fails with EPIPE on the `sock_send` (whose return both serve loops
# already ignore) instead of terminating the process.
#
# Why a raw syscall here (the one place the server path reaches past a
# stdlib helper): `sock_send` can't pass MSG_NOSIGNAL (the primitive has
# no flags arg, and forking it is forbidden — CLAUDE.md) and stdlib
# exposes no signal-disposition helper (no `signal_ignore`, and SIGPIPE
# isn't even in the `Signal` enum). The proper long-term home is a stdlib
# `signal_ignore(signum)` / `sock_send` MSG_NOSIGNAL — filed as a roadmap
# deferral; when it lands this migrates onto it, exactly as 1.6.1/1.6.2
# migrated conn.cyr's raw socket syscalls onto `net.cyr` helpers.
#
# Portability: `rt_sigaction(SIGPIPE, SIG_IGN)`. SIGPIPE = 13 and
# SIG_IGN = 1 on every Linux arch; the kernel `struct sigaction` is
# {sa_handler, sa_flags, [sa_restorer], sa_mask}. A 32-byte buffer zeroed
# except sa_handler = SIG_IGN is correct for BOTH x86_64 (sa_restorer at
# +16, sa_mask at +24) and aarch64 (sa_mask at +16, no restorer): every
# field past sa_handler is 0, so flags = 0 / mask = 0 whichever ABI reads
# where, and no SA_RESTORER is needed because an ignored signal is never
# delivered. Only the syscall number differs (x86_64 = 13, aarch64 = 134).
# macOS/Windows: no raw rt_sigaction (the macOS ESYSXLAT whitelist
# doesn't cover sigaction, so a raw call would mis-dispatch) — left a
# no-op pending the stdlib helper (roadmap: macOS SIGPIPE guard). AGNOS:
# no signals + no inbound TCP server (`sock_listen` Errs before the loop),
# so moot. Idempotent + cheap; called once per server start (the loops
# never return), so re-installing on every entry is fine.
var _SANDHI_SIGPIPE = 13;
var _SANDHI_SIG_IGN = 1;

fn _sandhi_server_ignore_sigpipe(): i64 {
    #ifdef CYRIUS_TARGET_LINUX
    # alloc (8-byte aligned, unlike a stack buffer on aarch64) — leaked
    # once at startup, negligible; the server loop never returns.
    var sa = alloc_via(default_alloc(), 32);
    if (sa == 0) { return 0; }      # OOM at startup — skip guard, don't crash
    store64(sa, _SANDHI_SIG_IGN);   # sa_handler = SIG_IGN
    store64(sa + 8, 0);             # sa_flags = 0 (no SA_RESTORER needed for IGN)
    store64(sa + 16, 0);            # x86_64 sa_restorer / aarch64 sa_mask
    store64(sa + 24, 0);            # x86_64 sa_mask
    #ifdef CYRIUS_ARCH_X86
    return syscall(13, _SANDHI_SIGPIPE, sa, 0, 8);    # SYS_rt_sigaction = 13
    #endif
    #ifdef CYRIUS_ARCH_AARCH64
    return syscall(134, _SANDHI_SIGPIPE, sa, 0, 8);   # SYS_rt_sigaction = 134
    #endif
    #endif
    return 0;
}

# Bind addr:port, listen, accept-loop. For each connection:
#   read full request → call handler_fp(ctx, cfd, buf, bytes) → close cfd.
#
# `addr` is a network-order IPv4 (use INADDR_ANY() for 0.0.0.0,
# INADDR_LOOPBACK() for 127.0.0.1). `handler_fp` must have the signature:
#   fn handler(ctx, cfd, req_buf, req_len) → 0
#
# Returns 1 on bind/listen failure; never returns on success (loops forever).
fn sandhi_server_run(addr, port, handler_fp, ctx): i64 {
    return sandhi_server_run_opts(addr, port, handler_fp, ctx, 0);
}

# Opts-aware variant. Applies SO_RCVTIMEO on each accepted connection
# to bound slow/idle peers (slowloris guard). max_conns is accepted
# but not honored today — server stays single-threaded until 0.8.0.
fn sandhi_server_run_opts(addr, port, handler_fp, ctx, opts): i64 {
    # 1.6.6 security fix: ignore SIGPIPE so a peer that disconnects
    # mid-response can't kill the process (sock_send is MSG_NOSIGNAL-less).
    _sandhi_server_ignore_sigpipe();

    # _hsv_req_buf is a process-wide singleton shared across every
    # accepted connection — it must outlive any per-request arena, so
    # always allocate from the global bump.
    if (_hsv_req_buf == 0) { _hsv_req_buf = alloc_via(default_alloc(), HSV_REQ_BUF_SIZE); }

    var idle_ms = sandhi_server_options_get_idle_ms(opts);

    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) { return 1; }
    var sfd = payload(sfd_r);
    sock_reuse(sfd);

    var br = sock_bind(sfd, addr, port);
    if (is_err_result(br) == 1) { return 1; }

    var lr = sock_listen(sfd, 16);
    if (is_err_result(lr) == 1) { return 1; }

    while (1 == 1) {
        var cr = sock_accept(sfd);
        if (is_err_result(cr) == 0) {
            var cfd = payload(cr);
            # Apply per-connection idle timeout (slowloris guard).
            # _sandhi_conn_set_timeout_ms is sandhi/http/conn.cyr's
            # setsockopt helper — works on any socket fd, not just
            # client-side ones.
            if (idle_ms > 0) {
                _sandhi_conn_set_timeout_ms(cfd, idle_ms, _SANDHI_SO_RCVTIMEO);
            }
            var n = sandhi_server_recv_request(cfd, _hsv_req_buf, HSV_REQ_BUF_SIZE - 1);
            if (n > 0) {
                # 0.9.0 P0 #2 — reject CL+TE coexistence with 400
                # (smuggling vector, RFC 7230 §3.3.3).
                # 0.9.1 P1 — also reject Host.Host / CL.CL / TE.TE
                # duplicates (smuggling vector, RFC 7230 §3.3.2 + §5.4).
                if (sandhi_server_request_has_cl_te_conflict(_hsv_req_buf, n) == 1) {
                    sandhi_server_send_status(cfd, 400, "Bad Request");
                } elif (sandhi_server_request_has_dup_smuggling_header(_hsv_req_buf, n) == 1) {
                    sandhi_server_send_status(cfd, 400, "Bad Request");
                } else {
                    fncall4(handler_fp, ctx, cfd, _hsv_req_buf, n);
                }
            }
            sock_close(cfd);
        }
    }
    return 0;
}

# ================================================================
# Epoll-cooperative server (1.4.9) — sandhi_server_run_async
# ================================================================
# Honors `sandhi_server_options_max_conns` as the per-drain concurrency
# cap, composing the stdlib cooperative runtime `lib/async.cyr`. The
# decided worker shape (roadmap 1.4.9): epoll-cooperative, not a thread
# pool — the handler stays single-threaded/cooperative (no thread-safety
# requirement) and must not block indefinitely. Absorbs daimon's
# `serve_async` pattern so daimon can collapse its hand-rolled accept
# loop + per-call buffer + smuggling-check duplication onto this one call
# (docs/issues/2026-05-10-daimon-server-max-conns.md).
#
# The sync single-flight `sandhi_server_run` / `sandhi_server_run_opts`
# are unchanged — this is an opt-in concurrent variant.

# Per-connection async handler argument (32 bytes), allocated from the
# per-batch arena: { cfd, handler_fp, ctx, req_buf }.
enum SandhiAsyncArgOff {
    SANDHI_ASYNC_ARG_CFD = 0;
    SANDHI_ASYNC_ARG_FP  = 8;
    SANDHI_ASYNC_ARG_CTX = 16;
    SANDHI_ASYNC_ARG_BUF = 24;
}

# One handler task per accepted connection: recv (SO_RCVTIMEO-bounded),
# smuggling-reject (the same fns the sync loop uses), dispatch to the
# user handler, close. The recv buffer is PER-HANDLER (passed in `arg`) —
# the no-interleave invariant sandhi owns under a concurrent server. The
# sync path's process-global `_hsv_req_buf` is unsafe here because two
# handlers could interleave their recv loops if the runtime ever gains
# true preemption; per-handler buffers are correct regardless.
#
# NOTE: we do NOT `async_await_readable(cfd)` first — `lib/async.cyr`'s
# await is an `epoll_wait(..., -1)` with an INFINITE timeout, so a client
# that connects and never sends would block the whole cooperative loop
# forever (a trivial DoS). The runtime is run-to-completion (no
# preemption), so the await buys no concurrency anyway; the SO_RCVTIMEO'd
# recv (idle_ms, floored > 0 by the caller) is the bounded wait.
fn _sandhi_server_async_handler(arg): i64 {
    var cfd = load64(arg + SANDHI_ASYNC_ARG_CFD);
    var fp  = load64(arg + SANDHI_ASYNC_ARG_FP);
    var ctx = load64(arg + SANDHI_ASYNC_ARG_CTX);
    var buf = load64(arg + SANDHI_ASYNC_ARG_BUF);

    var n = sandhi_server_recv_request(cfd, buf, HSV_REQ_BUF_SIZE - 1);
    if (n > 0) {
        if (sandhi_server_request_has_cl_te_conflict(buf, n) == 1) {
            sandhi_server_send_status(cfd, 400, "Bad Request");
        } elif (sandhi_server_request_has_dup_smuggling_header(buf, n) == 1) {
            sandhi_server_send_status(cfd, 400, "Bad Request");
        } else {
            fncall4(fp, ctx, cfd, buf, n);
        }
    }
    sock_close(cfd);
    return 0;
}

# Epoll-cooperative accept loop. `max_conns` (server options, default 128)
# is the per-drain concurrency cap: drain the accept queue non-blocking up
# to `max_conns` connections, spawn a handler task for each, run the batch
# to completion via `async_run`, reset the arena, repeat; block on the
# listen fd via `async_await_readable` when the queue is empty. Per-
# connection `idle_ms` / SO_RCVTIMEO bounds slow peers, as on the sync
# path. `handler_fp` signature matches the sync path:
#   fn handler(ctx, cfd, req_buf, req_len) -> 0
# Returns 1 on bind/listen/arena failure; never returns on success.
#
# Memory: per-connection recv buffers + arg structs come from a single
# `max_conns`-sized arena, reset each batch — no growth. As of 1.5.3
# (cyrius v6.1.22 `async_new_in`) `lib/async.cyr`'s OWN runtime + every
# `async_spawn` task struct are drawn from that SAME arena too, so the
# per-batch `reset_via` reclaims them — ZERO residual leak (was ~32 B/conn
# + ~40 B/batch on the no-free global bump before the fix). RSS stays flat
# over a sustained connection stream. See the inline 1.5.3 note on the
# arena sizing below.
fn sandhi_server_run_async(addr, port, handler_fp, ctx, opts): i64 {
    # 1.6.6 security fix: ignore SIGPIPE (see sandhi_server_run_opts) — a
    # disconnecting peer must not be able to terminate the process.
    _sandhi_server_ignore_sigpipe();

    var idle_ms   = sandhi_server_options_get_idle_ms(opts);
    var max_conns = sandhi_server_options_get_max_conns(opts);
    if (max_conns < 1) { max_conns = 1; }
    # The cooperative loop runs handlers to completion with no preemption,
    # so EVERY per-connection recv MUST be time-bounded — a single client
    # that connects and sends nothing would otherwise hang the whole loop
    # (and every other connection in the batch). Unlike the single-flight
    # sync path, idle_ms == 0 (blocking) is unsafe here, so floor it to the
    # default. SO_RCVTIMEO (set per accept below) is the bound; there is no
    # unbounded epoll wait on a client fd.
    if (idle_ms <= 0) { idle_ms = SANDHI_SERVER_DEFAULT_IDLE_MS; }

    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) { return 1; }
    var sfd = payload(sfd_r);
    sock_reuse(sfd);
    if (is_err_result(sock_bind(sfd, addr, port)) == 1) { return 1; }
    if (is_err_result(sock_listen(sfd, 16)) == 1) { return 1; }

    # Listen fd non-blocking so the accept queue drains cooperatively
    # (EAGAIN ends the drain). 1.6.2: composes stdlib `sock_set_nonblocking`
    # (cyrius 6.2.10) instead of the Linux-hardcoded `O_NONBLOCK` fcntl — the
    # stdlib helper carries the per-target flag value (Darwin O_NONBLOCK=0x0004 vs
    # Linux 0x800) and is itself an agnos no-op (SYS_FCNTL is undefined there +
    # inbound TCP is agnos Phase B — `sock_listen` already returns Err above, so
    # this fn bails before the cooperative accept loop regardless).
    sock_set_nonblocking(sfd);

    # Per-batch arena: max_conns × (recv buffer + arg struct + task struct)
    # + slack for the runtime struct. Backing memory is allocated once and
    # reused across batches via reset_via — so nothing accumulates.
    # 1.5.3 (Batch A2): the per-conn `+64` covers the 32-byte arg AND the
    # 32-byte async task struct, and the `+4096` slack covers the 40-byte
    # runtime — because the runtime is now created with `async_new_in(arena)`
    # (cyrius v6.1.22), so the rt + every `async_spawn` task come from this
    # arena instead of the no-free global bump. reset_via(arena) per batch
    # therefore reclaims them too → zero residual leak (was ~32 B/conn +
    # 40 B/batch on the global bump). RSS stays flat over a sustained stream.
    var per_conn  = HSV_REQ_BUF_SIZE + 64;
    var arena = arena_allocator(max_conns * per_conn + 4096);
    if (arena == 0) { sock_close(sfd); return 1; }

    var rt = async_new_in(arena);
    if (rt == 0) { sock_close(sfd); return 1; }
    var batch = 0;
    while (1 == 1) {
        var accepting = 1;
        while (accepting == 1) {
            var cr = sock_accept(sfd);
            if (is_err_result(cr) == 1) {
                accepting = 0;                 # EAGAIN — queue drained
            } else {
                var cfd = payload(cr);
                # idle_ms is floored > 0 above — always bound the recv.
                _sandhi_conn_set_timeout_ms(cfd, idle_ms, _SANDHI_SO_RCVTIMEO);
                var arg = alloc_via(arena, 32);
                var buf = alloc_via(arena, HSV_REQ_BUF_SIZE);
                if (arg == 0 || buf == 0) {
                    sock_close(cfd);           # arena exhausted — shed load
                    accepting = 0;
                } else {
                    store64(arg + SANDHI_ASYNC_ARG_CFD, cfd);
                    store64(arg + SANDHI_ASYNC_ARG_FP,  handler_fp);
                    store64(arg + SANDHI_ASYNC_ARG_CTX, ctx);
                    store64(arg + SANDHI_ASYNC_ARG_BUF, buf);
                    # async_spawn now draws the task struct from `arena` too
                    # (1.5.3). Guard its alloc like arg/buf: on exhaustion the
                    # task is unlinked + the handler that closes cfd never runs,
                    # so close cfd here and shed. The per-conn budget (arg 32 +
                    # buf + task 32 = HSV_REQ_BUF_SIZE + 64) leaves no slack, so
                    # this completes the load-shed path for the arena-backed task.
                    var task = async_spawn(rt, &_sandhi_server_async_handler, arg);
                    if (task == 0) {
                        sock_close(cfd);
                        accepting = 0;
                    } else {
                        batch = batch + 1;
                    }
                }
            }
            if (batch >= max_conns) { accepting = 0; }
        }

        if (batch > 0) {
            async_run(rt);          # drains the batch; closes rt's epfd
            reset_via(arena);       # reclaim this batch's buffers + args + rt + tasks
            batch = 0;
            rt = async_new_in(arena);   # fresh arena-backed runtime for the next batch
            if (rt == 0) { sock_close(sfd); return 1; }
        } else {
            async_await_readable(sfd);   # empty queue — block until a conn
        }
    }
    return 0;
}

# ================================================================
# Routing (1.6.7) — method+path route table with :name params
# ================================================================
# First (and driving) consumer: yeo-cy-test (SecureYeoman → Cyrius port).
# `sandhi_server_run*` dispatches every request to a single handler; this is
# the "routing … layers on top in later milestones" item from this module's
# header. The shape is lifted verbatim from the probe's reference
# (secureyeoman/yeo-cy-test/src/httpd.cyr `route_match` / `router_*`), recast
# into sandhi's stateless-accessor idiom.
#
# Param buffer: a caller-owned scratch buffer holding the captured `:name`
# segments as {ptr,len} pairs pointing INTO the request path. Layout:
#   [+0 count][slot i at +8+i*16 → +0 ptr, +8 len]
# Use a STACK buffer (`var p[SANDHI_ROUTE_PARAMS_SIZE]`) per request — it is
# per-invocation, so it is thread-safe under the pooled server with zero
# allocation and zero leak; `sandhi_server_router_handler` does exactly that.
var SANDHI_ROUTE_MAX_PARAMS  = 16;
var SANDHI_ROUTE_PARAMS_SIZE = 264;   # 8 (count) + 16 slots * 16 B

# Reset a param buffer (count → 0). Call before reuse; route_match also
# resets, so this is only needed to zero a fresh stack buffer defensively.
fn sandhi_route_params_init(params): i64 {
    if (params == 0) { return 0; }
    store64(params, 0);
    return 0;
}

# Number of `:name` segments captured by the last successful route_match.
fn sandhi_route_param_count(params): i64 {
    if (params == 0) { return 0; }
    return load64(params);
}

# Match `path` (a path-only cstr — e.g. `sandhi_server_path_only(get_path(...))`)
# against a route `pattern` cstr, capturing `:name` segments into `params` (may
# be 0 to match without capturing). Both must be absolute. Segment-by-segment
# split on '/': a literal segment must match exactly; a `:name` segment matches
# any one non-empty segment and is captured (ptr+len into `path`). Segment
# counts must be EQUAL, so "/api/notes" does NOT match "/api/notes/:id" (nor the
# reverse). Returns 1 on match (params filled), 0 otherwise. Resets params first.
fn sandhi_server_route_match(path, pattern, params): i64 {
    if (params != 0) { store64(params, 0); }
    if (path == 0 || pattern == 0) { return 0; }
    var pp = pattern;
    var b  = path;
    if (load8(pp) != 47) { return 0; }      # pattern must begin with '/'
    if (load8(b) != 47)  { return 0; }       # path must begin with '/'
    pp = pp + 1;
    b = b + 1;
    while (1 == 1) {
        var ps = pp;                         # pattern segment [ps, pp)
        while (load8(pp) != 0 && load8(pp) != 47) { pp = pp + 1; }
        var pseg = pp - ps;
        var bs = b;                          # path segment [bs, b)
        while (load8(b) != 0 && load8(b) != 47) { b = b + 1; }
        var bseg = b - bs;

        if (pseg > 0 && load8(ps) == 58) {   # ':' → capture, matches any non-empty
            if (bseg == 0) { return 0; }
            if (params != 0) {
                var np = load64(params);
                if (np < SANDHI_ROUTE_MAX_PARAMS) {
                    var slot = params + 8 + np * 16;
                    store64(slot, bs);
                    store64(slot + 8, bseg);
                    store64(params, np + 1);
                }
            }
        } else {                             # literal segment: exact match
            if (pseg != bseg) { return 0; }
            if (pseg > 0 && memeq(ps, bs, pseg) == 0) { return 0; }
        }

        var pmore = 0;
        if (load8(pp) == 47) { pmore = 1; }
        var bmore = 0;
        if (load8(b) == 47) { bmore = 1; }
        if (pmore != bmore) { return 0; }    # differing segment counts
        if (pmore == 0) { return 1; }        # both exhausted → full match
        pp = pp + 1;
        b = b + 1;
    }
    return 0;
}

# Captured param `idx` parsed as a non-negative decimal i64, or `-1` if the
# index is out of range / the segment is empty / non-numeric. (For `:id`-style
# integer keys — a non-numeric value yields `-1` so the handler returns a clean
# 400 rather than mis-parsing.) Parses in place; no allocation.
fn sandhi_route_param_int(params, idx): i64 {
    if (params == 0) { return 0 - 1; }
    if (idx < 0 || idx >= load64(params)) { return 0 - 1; }
    var slot = params + 8 + idx * 16;
    var p   = load64(slot);
    var len = load64(slot + 8);
    if (len <= 0) { return 0 - 1; }
    var val = 0;
    var i = 0;
    while (i < len) {
        var c = load8(p + i);
        if (c < 48 || c > 57) { return 0 - 1; }
        val = val * 10 + (c - 48);
        i = i + 1;
    }
    return val;
}

# Captured param `idx` as a freshly-allocated NUL-terminated cstr (the path
# buffer the segment points into is not NUL-terminated at the boundary), or ""
# if out of range, or 0 on OOM. Mirrors the alloc-the-returned-cstr contract of
# the other `sandhi_server_*_a` accessors.
fn sandhi_route_param_a(a, params, idx): i64 {
    if (params == 0) { return ""; }
    if (idx < 0 || idx >= load64(params)) { return ""; }
    var slot = params + 8 + idx * 16;
    var p   = load64(slot);
    var len = load64(slot + 8);
    var out = alloc_via(a, len + 1);
    if (out == 0) { return 0; }
    memcpy(out, p, len);
    store8(out + len, 0);
    return out;
}

fn sandhi_route_param(params, idx): i64 {
    return sandhi_route_param_a(default_alloc(), params, idx);
}

# Case-sensitive cstr equality (request method vs route method). Match only if
# both hit NUL together.
fn _sandhi_server_cstr_eq(a, b): i64 {
    if (a == 0 || b == 0) { return 0; }
    var i = 0;
    while (load8(a + i) != 0 && load8(b + i) != 0) {
        if (load8(a + i) != load8(b + i)) { return 0; }
        i = i + 1;
    }
    return load8(a + i) == load8(b + i);
}

# Route table — fixed-cap array of {method cstr, pattern cstr, handler fp} plus
# a single user `app_ctx` forwarded to handlers. Route handler signature:
#   fn handler(app_ctx, cfd, req_buf, req_len, params) -> 0
# Read path params inside the handler via sandhi_route_param_int / _param.
enum SandhiRouterOff {
    SANDHI_ROUTER_OFF_COUNT   = 0;
    SANDHI_ROUTER_OFF_CAP     = 8;
    SANDHI_ROUTER_OFF_ROUTES  = 16;
    SANDHI_ROUTER_OFF_APP_CTX = 24;
}
var SANDHI_ROUTER_HDR_SIZE = 32;

enum SandhiRouteEntryOff {
    SANDHI_RE_OFF_METHOD  = 0;
    SANDHI_RE_OFF_PATTERN = 8;
    SANDHI_RE_OFF_FP      = 16;
}
var SANDHI_RE_SIZE = 24;
var SANDHI_ROUTER_DEFAULT_CAP = 32;

fn sandhi_router_new_a(a, cap, app_ctx): i64 {
    if (cap < 1) { cap = 1; }
    var r = alloc_via(a, SANDHI_ROUTER_HDR_SIZE);
    if (r == 0) { return 0; }
    var routes = alloc_via(a, cap * SANDHI_RE_SIZE);
    if (routes == 0) { return 0; }
    store64(r + SANDHI_ROUTER_OFF_COUNT, 0);
    store64(r + SANDHI_ROUTER_OFF_CAP, cap);
    store64(r + SANDHI_ROUTER_OFF_ROUTES, routes);
    store64(r + SANDHI_ROUTER_OFF_APP_CTX, app_ctx);
    return r;
}

fn sandhi_router_new(app_ctx): i64 {
    return sandhi_router_new_a(default_alloc(), SANDHI_ROUTER_DEFAULT_CAP, app_ctx);
}

# Register a route. method/pattern are borrowed cstrs (kept by pointer — must
# outlive the router, e.g. string literals). Returns 1 on success, 0 if the
# table is full.
fn sandhi_router_add(router, method, pattern, fp): i64 {
    if (router == 0) { return 0; }
    var c = load64(router + SANDHI_ROUTER_OFF_COUNT);
    if (c >= load64(router + SANDHI_ROUTER_OFF_CAP)) { return 0; }
    var e = load64(router + SANDHI_ROUTER_OFF_ROUTES) + c * SANDHI_RE_SIZE;
    store64(e + SANDHI_RE_OFF_METHOD, method);
    store64(e + SANDHI_RE_OFF_PATTERN, pattern);
    store64(e + SANDHI_RE_OFF_FP, fp);
    store64(router + SANDHI_ROUTER_OFF_COUNT, c + 1);
    return 1;
}

# Dispatch (buf,blen) through the route table: first route whose pattern AND
# method match wins → its handler runs as fncall5(fp, ctx, cfd, buf, blen,
# params) with the captured params. A pattern match with no method match →
# 405; no pattern match → 404. Always handles the connection (returns 1).
#
# `params` is a caller-owned scratch buffer (see sandhi_route_params_init); pass
# a per-request stack buffer so this is safe under the pooled server.
#
# NOTE: extracts method + path via the bare `sandhi_server_get_method` /
# `_get_path` / `_path_only` accessors, which allocate their small returned
# cstrs on the global bump — the same per-request allocation property the whole
# `sandhi_server_*` accessor family already has. For a long-running server,
# arena adoption (the `_a` accessor variants + a per-request reset arena) is the
# answer; that is the module-wide "arena-per-request adoption" roadmap item, not
# routing's to solve here.
fn sandhi_router_dispatch(router, ctx, cfd, buf, blen, params): i64 {
    if (router == 0) { sandhi_server_send_status(cfd, 404, "Not Found"); return 1; }
    var method = sandhi_server_get_method(buf, blen);
    var path   = sandhi_server_path_only(sandhi_server_get_path(buf, blen));
    var c      = load64(router + SANDHI_ROUTER_OFF_COUNT);
    var routes = load64(router + SANDHI_ROUTER_OFF_ROUTES);
    var path_match = 0;
    var i = 0;
    while (i < c) {
        var e = routes + i * SANDHI_RE_SIZE;
        if (sandhi_server_route_match(path, load64(e + SANDHI_RE_OFF_PATTERN), params) == 1) {
            path_match = 1;
            if (_sandhi_server_cstr_eq(method, load64(e + SANDHI_RE_OFF_METHOD)) == 1) {
                fncall5(load64(e + SANDHI_RE_OFF_FP), ctx, cfd, buf, blen, params);
                return 1;
            }
        }
        i = i + 1;
    }
    if (path_match == 1) { sandhi_server_send_status(cfd, 405, "Method Not Allowed"); return 1; }
    sandhi_server_send_status(cfd, 404, "Not Found");
    return 1;
}

# Ready-made handler matching the `fn(ctx, cfd, buf, blen)` shape that
# `sandhi_server_run` / `_run_async` / `_run_pooled` invoke — pass
# `&sandhi_server_router_handler` as the handler_fp and the router as ctx, and
# routing works under any of the three serve loops. The per-request param
# buffer is a stack local (per-invocation → pool-safe, no alloc, no leak); route
# handlers receive the router's `app_ctx` as their ctx.
fn sandhi_server_router_handler(router, cfd, buf, blen): i64 {
    var params[264];                         # = SANDHI_ROUTE_PARAMS_SIZE
    sandhi_route_params_init(&params);
    var app_ctx = 0;
    if (router != 0) { app_ctx = load64(router + SANDHI_ROUTER_OFF_APP_CTX); }
    return sandhi_router_dispatch(router, app_ctx, cfd, buf, blen, &params);
}

# ================================================================
# Thread-pool server (1.6.7) — sandhi_server_run_pooled
# ================================================================
# First (and driving) consumer: yeo-cy-test (SecureYeoman → Cyrius port), whose
# axum/Tokio backend needs real multi-core parallelism. The sync `run` is
# single-flight and `run_async` is cooperative/run-to-completion — neither uses
# more than one core, so a handler doing blocking/CPU-bound work (a DB call,
# crypto) serializes every other in-flight request behind it. This adds a fixed
# worker-thread pool: the accept loop hands each accepted fd to a bounded
# channel; `max_conns` worker threads pull from it and serve one connection each,
# so a slow/blocking handler ties up only its own worker.
#
# Pool-safety: the per-request fns take an explicit recv buffer (per-worker) and
# allocate via the thread-safe global `alloc` (process-wide CAS lock), so they
# are safe to call concurrently from N workers. The handler shape is identical
# to `run` / `run_async` — `fn(ctx, cfd, req_buf, req_len)` — so existing
# handlers (and `sandhi_server_router_handler`) drop straight in.
#
# `max_conns` (server options, default 128) is the **fixed worker-thread
# count** here (not a per-drain cap as in run_async) — size it to your workload
# (cores / expected concurrency); each worker owns a 64 KiB recv buffer + a
# 64 KiB thread stack. Per-connection `idle_ms` / SO_RCVTIMEO bounds slow peers
# (floored > 0, since a stalled peer would otherwise hold a worker forever and a
# slowloris could pin the whole pool).

# Per-worker arg (32 bytes): { chan, handler_fp, ctx, idle_ms }.
enum SandhiPoolWorkerOff {
    SANDHI_POOL_W_CHAN    = 0;
    SANDHI_POOL_W_FP      = 8;
    SANDHI_POOL_W_CTX     = 16;
    SANDHI_POOL_W_IDLE_MS = 24;
}
var SANDHI_POOL_WORKER_ARG_SIZE = 32;

# One worker thread: pull a cfd off the channel, recv (SO_RCVTIMEO-bounded),
# smuggling-reject (the same fns the sync loop uses), dispatch to the handler,
# close. The recv buffer is per-worker (allocated once, reused) — the
# no-interleave invariant under a concurrent server. A 0 from chan_recv means
# the channel was closed (an accepted fd is never 0), so the worker exits.
fn _sandhi_server_pool_worker(arg): i64 {
    var ch      = load64(arg + SANDHI_POOL_W_CHAN);
    var fp      = load64(arg + SANDHI_POOL_W_FP);
    var ctx     = load64(arg + SANDHI_POOL_W_CTX);
    var idle_ms = load64(arg + SANDHI_POOL_W_IDLE_MS);
    var reqbuf  = alloc_via(default_alloc(), HSV_REQ_BUF_SIZE);
    if (reqbuf == 0) { return 0; }           # OOM — worker exits, pool runs short
    while (1 == 1) {
        var cfd = chan_recv(ch);
        if (cfd == 0) { return 0; }          # channel closed
        if (idle_ms > 0) {
            _sandhi_conn_set_timeout_ms(cfd, idle_ms, _SANDHI_SO_RCVTIMEO);
        }
        var n = sandhi_server_recv_request(cfd, reqbuf, HSV_REQ_BUF_SIZE - 1);
        if (n > 0) {
            if (sandhi_server_request_has_cl_te_conflict(reqbuf, n) == 1) {
                sandhi_server_send_status(cfd, 400, "Bad Request");
            } elif (sandhi_server_request_has_dup_smuggling_header(reqbuf, n) == 1) {
                sandhi_server_send_status(cfd, 400, "Bad Request");
            } else {
                fncall4(fp, ctx, cfd, reqbuf, n);
            }
        }
        sock_close(cfd);
    }
    return 0;
}

# Bind addr:port, listen, spawn a fixed pool of `max_conns` worker threads, then
# accept-loop forever feeding accepted fds to the workers over a bounded channel.
# `handler_fp` signature matches `run` / `run_async`:
#   fn handler(ctx, cfd, req_buf, req_len) -> 0
# Returns 1 on bind/listen/channel failure; never returns on success.
fn sandhi_server_run_pooled(addr, port, handler_fp, ctx, opts): i64 {
    # Same security fix as the other serve loops — SIGPIPE disposition is
    # process-wide, so installing it once here covers every worker thread.
    _sandhi_server_ignore_sigpipe();

    var idle_ms = sandhi_server_options_get_idle_ms(opts);
    if (idle_ms <= 0) { idle_ms = SANDHI_SERVER_DEFAULT_IDLE_MS; }
    var workers = sandhi_server_options_get_max_conns(opts);
    if (workers < 1) { workers = 1; }
    # 1.6.8 (yeo-cy-test 🔵 handoff-depth fix): the handoff channel depth + the
    # kernel listen backlog are sized by `backlog` (default 128), DECOUPLED from
    # the worker count. A burst beyond `workers` now queues up to `backlog`
    # accepted conns instead of falling straight onto the kernel backlog at
    # `chan_new(workers)`. backlog is floored to workers so the channel can
    # always hold at least one item per worker.
    var backlog = sandhi_server_options_get_backlog(opts);
    if (backlog < workers) { backlog = workers; }

    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) { return 1; }
    var sfd = payload(sfd_r);
    sock_reuse(sfd);
    if (is_err_result(sock_bind(sfd, addr, port)) == 1) { sock_close(sfd); return 1; }
    if (is_err_result(sock_listen(sfd, backlog)) == 1) { sock_close(sfd); return 1; }

    # Bounded handoff channel sized to `backlog`: when `backlog` connections are
    # already queued the accept loop blocks (backpressure / load-shed) until a
    # worker frees a slot. cfd values are always > 0, so they never collide with
    # chan's 0-on-close.
    var ch = chan_new(backlog);
    if (ch == 0) { sock_close(sfd); return 1; }

    var w = 0;
    while (w < workers) {
        var warg = alloc_via(default_alloc(), SANDHI_POOL_WORKER_ARG_SIZE);
        if (warg == 0) { sock_close(sfd); return 1; }
        store64(warg + SANDHI_POOL_W_CHAN, ch);
        store64(warg + SANDHI_POOL_W_FP, handler_fp);
        store64(warg + SANDHI_POOL_W_CTX, ctx);
        store64(warg + SANDHI_POOL_W_IDLE_MS, idle_ms);
        thread_create(&_sandhi_server_pool_worker, warg);
        w = w + 1;
    }

    while (1 == 1) {
        var cr = sock_accept(sfd);
        if (is_err_result(cr) == 0) {
            chan_send(ch, payload(cr));      # blocks if the pool is saturated
        }
    }
    return 0;
}

# ================================================================
# Server-side TLS (1.6.8) — native HTTPS serving
# ================================================================
# First (and driving) consumer: yeo-cy-test / SecureYeoman, whose entire auth
# stack (OIDC/PKCE, WebAuthn, bearer tokens, secrets) is meaningless over
# plaintext. Before 1.6.8 sandhi had NO server-side TLS: the serve loops took
# only {idle_ms, max_conns} and every send path wrote plaintext via sock_send,
# so the probe had to bypass the serve loops and hand-roll an
# accept→tls_native_accept→read→dispatch→write→close loop. This closes that gap.
#
# It ships on the NATIVE TLS stack (the default + future; libssl-server never
# existed and the libssl backend retires at 2.0). All I/O rides the
# backend-agnostic lib/tls.cyr contract — tls_write / tls_read / tls_close. As of
# 1.6.10 the server HANDSHAKE rides it too: cyrius 6.2.37 shipped the symmetric
# `tls_accept_alloc_in` / `tls_accept_complete` (the server mirror of the client
# tls_connect_alloc/_complete), so the bootstrap below composes that contract
# instead of reaching into the native server primitives — exactly as 1.6.1/1.6.2
# migrated conn.cyr's raw socket syscalls onto net.cyr helpers once they landed.
# No native-server symbol is reached anymore; ALPN rides the SAME backend-agnostic
# `_sandhi_alpn_hook` + `tls_set_alpn` the client uses. No FFI, no dlopen: pure
# contract composition.
#
# RSS is flat as of 1.6.10: `tls_accept_alloc_in` takes a per-connection arena
# (`tls_native_new_server_in` backs the native ctx + the whole handshake/record
# footprint + the shim from it), so each serve loop / worker resets ONE arena per
# connection (reset_via) and nothing accumulates. The 1.6.8 limitation —
# per-connection RSS growth, no per-connection free — is closed; the upstream
# arena-aware server ctx it was filed against landed at cyrius 6.2.37.
#
# ALPN: native server-side ALPN *selection* landed at cyrius 6.2.22, so the
# http/1.1 ALPN we offer below is genuinely negotiated (not forward-compat). h2
# over TLS is still not served — not for an ALPN reason, but because sandhi has
# no HTTP/2 *server* (its h2 is client-side only) and we offer only http/1.1; an
# h2 server is a separate, larger feature, not a cyrius gap.

# ── Transport seam: SandhiConn ──
# A tiny tagged handle so one handler set serves both transports. kind 0 =
# plaintext (handle = raw cfd), 1 = TLS (handle = lib/tls.cyr ctx shim). `fd`
# is always the raw socket (for the final sock_close). Conn-aware send/recv/
# router functions (the `_c` family) dispatch on `kind`.
# NOTE: these offsets are namespaced SANDHI_SRVCONN_OFF_* to avoid a
# symbol collision with the CLIENT conn struct's SandhiConnOff
# (src/http/conn.cyr), which defines SANDHI_CONN_OFF_FD = 8 (vs 16 here).
# Under cyrius single-pass "last definition wins", the shared name made the
# client read/write its fd at offset 16, colliding with its own
# SANDHI_CONN_OFF_TLS_CTX (16) and silently zeroing the socket fd. See
# docs/development/issues/2026-06-24-server-conn-off-fd-collision.md.
enum SandhiServerConnOff {
    SANDHI_SRVCONN_OFF_KIND   = 0;
    SANDHI_SRVCONN_OFF_HANDLE = 8;
    SANDHI_SRVCONN_OFF_FD     = 16;
}
var SANDHI_CONN_SIZE  = 24;
var SANDHI_CONN_PLAIN = 0;
var SANDHI_CONN_TLS   = 1;

# 1.6.10 — per-connection TLS arena cap. One arena per serve loop / worker,
# reset_via'd per connection so RSS stays flat (the native server ctx + the whole
# per-handshake footprint + the shim + the SandhiConn all draw from it). Sized to
# the lib/tls.cyr contract's worst-single-handshake guidance (mTLS-1.3 ≈ 128 KiB);
# sandhi serves plain server TLS 1.3 (no client-cert verify), so this is a safe
# upper bound — an undersized cap would only drop a connection (a handshake alloc
# returns 0), never corrupt. Allocated ONCE per loop/worker, never per connection
# (arena_free doesn't munmap).
var SANDHI_SERVER_TLS_ARENA_CAP = 131072;

# Wrap a raw plaintext fd as a SandhiConn (for the plaintext-adapter path so
# conn-based handlers run over the plaintext serve loops too). Returns 0 on OOM.
fn sandhi_server_conn_plain_a(a, fd): i64 {
    var c = alloc_via(a, SANDHI_CONN_SIZE);
    if (c == 0) { return 0; }
    store64(c + SANDHI_SRVCONN_OFF_KIND, SANDHI_CONN_PLAIN);
    store64(c + SANDHI_SRVCONN_OFF_HANDLE, fd);
    store64(c + SANDHI_SRVCONN_OFF_FD, fd);
    return c;
}

fn sandhi_server_conn_plain(fd): i64 {
    return sandhi_server_conn_plain_a(default_alloc(), fd);
}

# Internal: wrap a handshaken TLS ctx shim (+ its raw fd) as a SandhiConn.
fn _sandhi_server_conn_tls_a(a, shim, fd): i64 {
    var c = alloc_via(a, SANDHI_CONN_SIZE);
    if (c == 0) { return 0; }
    store64(c + SANDHI_SRVCONN_OFF_KIND, SANDHI_CONN_TLS);
    store64(c + SANDHI_SRVCONN_OFF_HANDLE, shim);
    store64(c + SANDHI_SRVCONN_OFF_FD, fd);
    return c;
}

# 1 if this conn is TLS (e.g. to set Strict-Transport-Security only over TLS).
fn sandhi_server_conn_is_tls(conn): i64 {
    if (conn == 0) { return 0; }
    return load64(conn + SANDHI_SRVCONN_OFF_KIND) == SANDHI_CONN_TLS;
}

# The underlying raw socket fd (handy for logging / peer info). -1 if conn == 0.
fn sandhi_server_conn_fd(conn): i64 {
    if (conn == 0) { return 0 - 1; }
    return load64(conn + SANDHI_SRVCONN_OFF_FD);
}

# Write all `len` bytes to a plaintext fd, looping over partial sys_writes.
fn _sandhi_server_plain_write_all(fd, buf, len): i64 {
    var off = 0;
    while (off < len) {
        var r = sock_send(fd, buf + off, len - off);
        if (is_err_result(r) == 1) { return 0 - 1; }
        var w = payload(r);
        if (w <= 0) { return 0 - 1; }
        off = off + w;
    }
    return off;
}

# The transport seam: write `len` bytes over the conn. Plaintext → looped
# sock_send; TLS → tls_write (the lib/tls.cyr contract, which fragments to
# the record cap internally). Returns >=0 on success, <0 on error.
fn sandhi_server_conn_write(conn, buf, len): i64 {
    if (conn == 0) { return 0 - 1; }
    if (load64(conn + SANDHI_SRVCONN_OFF_KIND) == SANDHI_CONN_TLS) {
        return tls_write(load64(conn + SANDHI_SRVCONN_OFF_HANDLE), buf, len);
    }
    return _sandhi_server_plain_write_all(load64(conn + SANDHI_SRVCONN_OFF_HANDLE), buf, len);
}

# Conn-aware request read. Plaintext → the existing sock_recv loop; TLS → loop
# tls_read (one record per call) until the header terminator, then until the
# Content-Length body has arrived (the plaintext recv's framing logic, over the
# TLS contract — sandhi_server_recv_request is sock_recv-welded). Returns total
# bytes (>=0); always NUL-terminates at the returned length.
fn sandhi_server_recv_request_c(conn, buf, max): i64 {
    if (conn == 0) { return 0 - 1; }
    if (load64(conn + SANDHI_SRVCONN_OFF_KIND) != SANDHI_CONN_TLS) {
        return sandhi_server_recv_request(load64(conn + SANDHI_SRVCONN_OFF_HANDLE), buf, max);
    }
    var ctx = load64(conn + SANDHI_SRVCONN_OFF_HANDLE);
    var have = 0;
    var need_body = 0 - 1;
    while (have < max) {
        var n = tls_read(ctx, buf + have, max - have);
        if (n <= 0) { store8(buf + have, 0); return have; }   # 0 = close_notify, <0 = error
        have = have + n;
        store8(buf + have, 0);
        if (need_body == 0 - 1) {
            var bo = sandhi_server_body_offset(buf, have);
            if (bo >= 0) { need_body = bo + sandhi_server_content_length(buf, have); }
        }
        if (need_body != 0 - 1 && have >= need_body) { store8(buf + have, 0); return have; }
    }
    store8(buf + have, 0);
    return have;
}

# ── Conn-aware response framing (parallels the fd-based send_* — those stay
# byte-identical for the plaintext path; these write through the seam) ──

fn sandhi_server_send_response_c_a(a, conn, code, msg, content_type, body, body_len, extra_headers): i64 {
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0 - 1; }
    str_builder_add_cstr_a(a, sb, "HTTP/1.1 ");
    str_builder_add_int_a(a, sb, code);
    str_builder_add_cstr_a(a, sb, " ");
    str_builder_add_cstr_a(a, sb, msg);
    str_builder_add_cstr_a(a, sb, "\r\nContent-Type: ");
    str_builder_add_cstr_a(a, sb, content_type);
    str_builder_add_cstr_a(a, sb, "\r\nContent-Length: ");
    str_builder_add_int_a(a, sb, body_len);
    str_builder_add_cstr_a(a, sb, "\r\n");
    if (extra_headers != 0) { str_builder_add_cstr_a(a, sb, extra_headers); }
    str_builder_add_cstr_a(a, sb, "Connection: close\r\n\r\n");
    var head = str_data(str_builder_build_a(a, sb));
    if (sandhi_server_conn_write(conn, head, strlen(head)) < 0) { return 0 - 1; }
    if (body_len > 0) {
        if (sandhi_server_conn_write(conn, body, body_len) < 0) { return 0 - 1; }
    }
    return 0;
}

fn sandhi_server_send_response_c(conn, code, msg, content_type, body, body_len, extra_headers): i64 {
    return sandhi_server_send_response_c_a(default_alloc(), conn, code, msg,
    content_type, body, body_len, extra_headers);
}

fn sandhi_server_send_status_c_a(a, conn, code, msg): i64 {
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0 - 1; }
    str_builder_add_cstr_a(a, sb, "HTTP/1.1 ");
    str_builder_add_int_a(a, sb, code);
    str_builder_add_cstr_a(a, sb, " ");
    str_builder_add_cstr_a(a, sb, msg);
    str_builder_add_cstr_a(a, sb, "\r\nContent-Length: 0\r\nConnection: close\r\n\r\n");
    var s = str_data(str_builder_build_a(a, sb));
    if (sandhi_server_conn_write(conn, s, strlen(s)) < 0) { return 0 - 1; }
    return 0;
}

fn sandhi_server_send_status_c(conn, code, msg): i64 {
    return sandhi_server_send_status_c_a(default_alloc(), conn, code, msg);
}

# ── Conn-aware routing — shares the SAME router table as the fd path ──
# Conn route handlers: fn(app_ctx, conn, req_buf, req_len, params) -> 0
# (write via sandhi_server_send_*_c; path params via sandhi_route_param_int).
fn sandhi_router_dispatch_c(router, ctx, conn, buf, blen, params): i64 {
    if (router == 0) { sandhi_server_send_status_c(conn, 404, "Not Found"); return 1; }
    var method = sandhi_server_get_method(buf, blen);
    var path   = sandhi_server_path_only(sandhi_server_get_path(buf, blen));
    var c      = load64(router + SANDHI_ROUTER_OFF_COUNT);
    var routes = load64(router + SANDHI_ROUTER_OFF_ROUTES);
    var path_match = 0;
    var i = 0;
    while (i < c) {
        var e = routes + i * SANDHI_RE_SIZE;
        if (sandhi_server_route_match(path, load64(e + SANDHI_RE_OFF_PATTERN), params) == 1) {
            path_match = 1;
            if (_sandhi_server_cstr_eq(method, load64(e + SANDHI_RE_OFF_METHOD)) == 1) {
                fncall5(load64(e + SANDHI_RE_OFF_FP), ctx, conn, buf, blen, params);
                return 1;
            }
        }
        i = i + 1;
    }
    if (path_match == 1) { sandhi_server_send_status_c(conn, 405, "Method Not Allowed"); return 1; }
    sandhi_server_send_status_c(conn, 404, "Not Found");
    return 1;
}

# Ready-made conn handler for the `_tls` serve loops (which invoke
# fn(ctx, conn, buf, blen) with a SandhiConn). Pass &sandhi_server_router_handler_c
# as handler_fp + the router as ctx.
fn sandhi_server_router_handler_c(router, conn, buf, blen): i64 {
    var params[264];                         # = SANDHI_ROUTE_PARAMS_SIZE
    sandhi_route_params_init(&params);
    var app_ctx = 0;
    if (router != 0) { app_ctx = load64(router + SANDHI_ROUTER_OFF_APP_CTX); }
    return sandhi_router_dispatch_c(router, app_ctx, conn, buf, blen, &params);
}

# Plaintext adapter matching the fn(ctx, cfd, buf, blen) shape the plaintext
# serve loops (run / run_opts / run_pooled) invoke: wraps the raw cfd in a
# plaintext SandhiConn and routes through the conn-aware dispatch. So ONE
# conn-based route-handler set (using sandhi_server_send_*_c) serves BOTH the
# plaintext loops (via this adapter) and the `_tls` loops (via _handler_c).
# Pass &sandhi_server_router_handler_cp as handler_fp + the router as ctx.
fn sandhi_server_router_handler_cp(router, cfd, buf, blen): i64 {
    var conn = sandhi_server_conn_plain(cfd);
    if (conn == 0) { sandhi_server_send_status(cfd, 500, "Internal Server Error"); return 1; }
    return sandhi_server_router_handler_c(router, conn, buf, blen);
}

# ── Server handshake bootstrap (1.6.10: composes the lib/tls.cyr contract) ──
# Per-connection: pack the borrowed DER cert/key into the 4-slot creds struct,
# offer http/1.1 ALPN via the SAME backend-agnostic `_sandhi_alpn_hook` +
# `_sandhi_alpn_h11_wire` the client uses (the hook calls `tls_set_alpn`, which
# dispatches the backend), and drive the handshake over `fd` through cyrius
# 6.2.37's arena-aware `tls_accept_alloc_in` + `tls_accept_complete` — the
# symmetric mirror of the client tls_connect_alloc/_complete. Returns the
# lib-canonical ctx shim (a usable TLS ctx for tls_write/_read/_close) or 0 on
# any failure. `a` backs the native ctx + the whole per-connection handshake /
# record footprint + the shim, so the serve loop reset_via(a)s it all per
# connection → flat RSS. No native-server symbol is reached anymore. The creds
# struct + hook ctx are read DURING the alloc call (the cert/key buffers it
# points at are the caller's borrowed option buffers, which outlive the server),
# so stack buffers suffice. Does NOT close `fd` on failure — the caller always
# sock_close's it.
fn _sandhi_server_tls_handshake_a(a, fd, cert, cert_len, key, key_len): i64 {
    _sandhi_alpn_init_wire();
    var hook_ctx[16];                        # [protos_ptr@0, protos_len@8]
    store64(&hook_ctx,     _sandhi_alpn_h11_wire);
    store64(&hook_ctx + 8, _sandhi_alpn_h11_wire_len);
    var creds[32];                           # [cert@0, cert_len@8, key@16, key_len@24]
    store64(&creds,      cert);
    store64(&creds + 8,  cert_len);
    store64(&creds + 16, key);
    store64(&creds + 24, key_len);
    var shim = tls_accept_alloc_in(a, fd, &creds, &_sandhi_alpn_hook, &hook_ctx);
    if (shim == 0) { return 0; }
    if (tls_accept_complete(shim) != 1) { tls_close(shim); return 0; }
    return shim;
}

# Serve one handshaken TLS conn: recv (conn-aware), smuggling-reject (the same
# fns the plaintext loops use), dispatch to the handler. `reqbuf` is the
# caller's recv buffer. Closes nothing — the caller owns shim + fd teardown.
# 1.6.10: the SandhiConn rides the caller's per-connection arena `a` (reclaimed
# by the loop's reset_via with the rest of the connection footprint).
fn _sandhi_server_tls_serve_one(a, handler_fp, ctx, shim, fd, reqbuf): i64 {
    var conn = _sandhi_server_conn_tls_a(a, shim, fd);
    if (conn == 0) { return 0; }
    var n = sandhi_server_recv_request_c(conn, reqbuf, HSV_REQ_BUF_SIZE - 1);
    if (n > 0) {
        if (sandhi_server_request_has_cl_te_conflict(reqbuf, n) == 1) {
            sandhi_server_send_status_c(conn, 400, "Bad Request");
        } elif (sandhi_server_request_has_dup_smuggling_header(reqbuf, n) == 1) {
            sandhi_server_send_status_c(conn, 400, "Bad Request");
        } else {
            fncall4(handler_fp, ctx, conn, reqbuf, n);
        }
    }
    return 0;
}

# Single-flight HTTPS serve loop — the TLS mirror of sandhi_server_run_opts.
# Requires sandhi_server_options_tls() to have set cert/key on `opts` (returns
# 1 otherwise). handler_fp signature: fn(ctx, conn, buf, blen) -> 0 (a
# SandhiConn, not a raw fd — write via sandhi_server_send_*_c). For real
# concurrency use sandhi_server_run_pooled_tls. Returns 1 on
# config/bind/listen failure; never returns on success.
fn sandhi_server_run_tls(addr, port, handler_fp, ctx, opts): i64 {
    _sandhi_server_ignore_sigpipe();
    if (sandhi_server_options_get_tls(opts) == 0) { return 1; }
    var cert     = load64(opts + SANDHI_SERVER_OPT_OFF_TLS_CERT);
    var cert_len = load64(opts + SANDHI_SERVER_OPT_OFF_TLS_CERT_LEN);
    var key      = load64(opts + SANDHI_SERVER_OPT_OFF_TLS_KEY);
    var key_len  = load64(opts + SANDHI_SERVER_OPT_OFF_TLS_KEY_LEN);
    if (cert == 0 || key == 0) { return 1; }
    var idle_ms  = sandhi_server_options_get_idle_ms(opts);
    var backlog  = sandhi_server_options_get_backlog(opts);

    if (_hsv_req_buf == 0) { _hsv_req_buf = alloc_via(default_alloc(), HSV_REQ_BUF_SIZE); }
    if (_hsv_req_buf == 0) { return 1; }

    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) { return 1; }
    var sfd = payload(sfd_r);
    sock_reuse(sfd);
    if (is_err_result(sock_bind(sfd, addr, port)) == 1) { sock_close(sfd); return 1; }
    if (is_err_result(sock_listen(sfd, backlog)) == 1) { sock_close(sfd); return 1; }

    # 1.6.10 — ONE arena for the loop, reset_via per connection: the native
    # server ctx + per-handshake footprint + shim + SandhiConn all draw from it,
    # so RSS stays flat instead of growing per accepted connection (the 1.6.8
    # limitation, now closed via cyrius 6.2.37's arena-aware tls_accept_alloc_in).
    var tarena = arena_allocator(SANDHI_SERVER_TLS_ARENA_CAP);
    if (tarena == 0) { sock_close(sfd); return 1; }

    while (1 == 1) {
        var cr = sock_accept(sfd);
        if (is_err_result(cr) == 0) {
            var cfd = payload(cr);
            if (idle_ms > 0) { _sandhi_conn_set_timeout_ms(cfd, idle_ms, _SANDHI_SO_RCVTIMEO); }
            var shim = _sandhi_server_tls_handshake_a(tarena, cfd, cert, cert_len, key, key_len);
            if (shim != 0) {
                _sandhi_server_tls_serve_one(tarena, handler_fp, ctx, shim, cfd, _hsv_req_buf);
                tls_close(shim);
            }
            sock_close(cfd);
            reset_via(tarena);              # rewind this connection's footprint → flat RSS
        }
    }
    return 0;
}

# ── Thread-pool HTTPS serve loop — the TLS mirror of sandhi_server_run_pooled.
# Each worker does its OWN per-connection handshake. `max_conns` = worker count;
# `backlog` (option, default 128, DECOUPLED from workers per the 1.6.8
# handoff-depth fix) sizes the kernel listen backlog + the handoff channel.
#
# CONCURRENT TLS HANDSHAKES ARE SAFE as of sandhi 1.8.0 / cyrius 6.4.49 —
# `max_conns > 1` is supported for HTTPS. Worker ctxs and their per-connection
# arenas are independent, and the TLS handshake's sigil crypto primitives now
# draw from a PER-THREAD crypto-scratch lane: sigil (since 3.9.7; vendored 3.11.1)
# auto-banks a private lane per thread in `cbank()`, so two workers handshaking at
# the same instant no longer race the (formerly process-global) HKDF/ed25519/
# AES-NI/bignum scratch. This closes the 2026-06-28 sigil scratch race — no
# per-worker `crypto_bank_set` call is needed (the lane is assigned automatically
# on first crypto use). `_server_tls_probe.cyr`'s [4] gate drives 16 genuinely
# -simultaneous handshakes against a 4-worker pool and requires all 16 to survive
# with a 200 response (was 0/16 through 1.7.0 / cyrius 6.3.5; now 16/16). The
# plaintext pool `sandhi_server_run_pooled` never touched sigil scratch and was
# always safe at any `max_conns`.

# Per-TLS-worker arg (64 bytes): { chan, fp, ctx, idle_ms, cert, cert_len, key, key_len }.
enum SandhiPoolTlsWorkerOff {
    SANDHI_POOL_TW_CHAN     = 0;
    SANDHI_POOL_TW_FP       = 8;
    SANDHI_POOL_TW_CTX      = 16;
    SANDHI_POOL_TW_IDLE_MS  = 24;
    SANDHI_POOL_TW_CERT     = 32;
    SANDHI_POOL_TW_CERT_LEN = 40;
    SANDHI_POOL_TW_KEY      = 48;
    SANDHI_POOL_TW_KEY_LEN  = 56;
}
var SANDHI_POOL_TLS_WORKER_ARG_SIZE = 64;

fn _sandhi_server_pool_tls_worker(arg): i64 {
    var ch       = load64(arg + SANDHI_POOL_TW_CHAN);
    var fp       = load64(arg + SANDHI_POOL_TW_FP);
    var ctx      = load64(arg + SANDHI_POOL_TW_CTX);
    var idle_ms  = load64(arg + SANDHI_POOL_TW_IDLE_MS);
    var cert     = load64(arg + SANDHI_POOL_TW_CERT);
    var cert_len = load64(arg + SANDHI_POOL_TW_CERT_LEN);
    var key      = load64(arg + SANDHI_POOL_TW_KEY);
    var key_len  = load64(arg + SANDHI_POOL_TW_KEY_LEN);
    var reqbuf   = alloc_via(default_alloc(), HSV_REQ_BUF_SIZE);
    if (reqbuf == 0) { return 0; }           # OOM — worker exits, pool runs short
    # 1.6.10 — per-worker arena, reset_via per connection. Worker ctxs are fully
    # independent, so each owns its own arena → no cross-worker reset race; RSS
    # stays flat per worker.
    var tarena = arena_allocator(SANDHI_SERVER_TLS_ARENA_CAP);
    if (tarena == 0) { return 0; }
    while (1 == 1) {
        var cfd = chan_recv(ch);
        if (cfd == 0) { return 0; }          # channel closed
        if (idle_ms > 0) { _sandhi_conn_set_timeout_ms(cfd, idle_ms, _SANDHI_SO_RCVTIMEO); }
        var shim = _sandhi_server_tls_handshake_a(tarena, cfd, cert, cert_len, key, key_len);
        if (shim != 0) {
            _sandhi_server_tls_serve_one(tarena, fp, ctx, shim, cfd, reqbuf);
            tls_close(shim);
        }
        sock_close(cfd);
        reset_via(tarena);                   # rewind → flat per-worker RSS
    }
    return 0;
}

fn sandhi_server_run_pooled_tls(addr, port, handler_fp, ctx, opts): i64 {
    _sandhi_server_ignore_sigpipe();
    if (sandhi_server_options_get_tls(opts) == 0) { return 1; }
    var cert     = load64(opts + SANDHI_SERVER_OPT_OFF_TLS_CERT);
    var cert_len = load64(opts + SANDHI_SERVER_OPT_OFF_TLS_CERT_LEN);
    var key      = load64(opts + SANDHI_SERVER_OPT_OFF_TLS_KEY);
    var key_len  = load64(opts + SANDHI_SERVER_OPT_OFF_TLS_KEY_LEN);
    if (cert == 0 || key == 0) { return 1; }
    var idle_ms = sandhi_server_options_get_idle_ms(opts);
    if (idle_ms <= 0) { idle_ms = SANDHI_SERVER_DEFAULT_IDLE_MS; }
    var workers = sandhi_server_options_get_max_conns(opts);
    if (workers < 1) { workers = 1; }
    var backlog = sandhi_server_options_get_backlog(opts);
    if (backlog < workers) { backlog = workers; }

    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) { return 1; }
    var sfd = payload(sfd_r);
    sock_reuse(sfd);
    if (is_err_result(sock_bind(sfd, addr, port)) == 1) { sock_close(sfd); return 1; }
    if (is_err_result(sock_listen(sfd, backlog)) == 1) { sock_close(sfd); return 1; }

    var ch = chan_new(backlog);
    if (ch == 0) { sock_close(sfd); return 1; }

    var w = 0;
    while (w < workers) {
        var warg = alloc_via(default_alloc(), SANDHI_POOL_TLS_WORKER_ARG_SIZE);
        if (warg == 0) { sock_close(sfd); return 1; }
        store64(warg + SANDHI_POOL_TW_CHAN, ch);
        store64(warg + SANDHI_POOL_TW_FP, handler_fp);
        store64(warg + SANDHI_POOL_TW_CTX, ctx);
        store64(warg + SANDHI_POOL_TW_IDLE_MS, idle_ms);
        store64(warg + SANDHI_POOL_TW_CERT, cert);
        store64(warg + SANDHI_POOL_TW_CERT_LEN, cert_len);
        store64(warg + SANDHI_POOL_TW_KEY, key);
        store64(warg + SANDHI_POOL_TW_KEY_LEN, key_len);
        thread_create(&_sandhi_server_pool_tls_worker, warg);
        w = w + 1;
    }

    while (1 == 1) {
        var cr = sock_accept(sfd);
        if (is_err_result(cr) == 0) {
            chan_send(ch, payload(cr));      # blocks if the pool is saturated
        }
    }
    return 0;
}

# ================================================================
# sandhi-scoped identity
# ================================================================
# Kept so downstream can probe the migrated-module version. Retires
# when fold-into-stdlib lands; consumers should prefer sandhi_version().
