# sandhi/rpc/appium — Appium dialect on top of W3C WebDriver.
#
# Reference: https://appium.io/docs/en/commands/
#
# Appium extends the WebDriver wire protocol with mobile-platform
# commands (UiAutomator2 on Android, XCUITest on iOS). The base
# session / navigation / element-interaction verbs from webdriver.cyr
# apply directly; this file adds the mobile-only extensions that
# yantra's Android + iOS backends need.
#
# Kept small per CLAUDE.md "one dialect per file" guidance. When a
# consumer needs more surface, add verbs here rather than splitting.

# ================================================================
# Mobile session setup
# ================================================================

# Start a new Appium session. `platform_name` is "Android" or "iOS".
# `automation_name` is "UiAutomator2" / "XCUITest" / etc. Extra caps
# may be passed via `extra_caps_json` (a pre-built JSON object fragment
# including its braces, or 0 for none).
#
# The body shape is the W3C-compatible one Appium 2.x expects:
#   {"capabilities":{"alwaysMatch":{"platformName":"Android",
#    "appium:automationName":"UiAutomator2", ...}}}
# 1.2.4 Batch F: each verb gains an `_a` variant; bare versions
# stay as back-compat wrappers passing `default_alloc()`. Each
# `_a` threads `a` through URL build, JSON envelope build, and
# `sandhi_rpc_call_a` (paired since 1.1.0).
fn sandhi_ap_new_session_a(a, base_url, platform_name, automation_name, extra_caps_json) {
    var always = sandhi_json_obj_new_a(a);
    if (always == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    sandhi_json_add_string_a(a, always, "platformName", platform_name);
    sandhi_json_add_string_a(a, always, "appium:automationName", automation_name);
    if (extra_caps_json != 0) {
        sandhi_json_add_raw_a(a, always, "appium:extras", extra_caps_json);
    }
    var caps = sandhi_json_obj_new_a(a);
    if (caps == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    sandhi_json_add_object_a(a, caps, "alwaysMatch", always);
    var root = sandhi_json_obj_new_a(a);
    if (root == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    sandhi_json_add_object_a(a, root, "capabilities", caps);
    return sandhi_wd_new_session_a(a, base_url, sandhi_json_build_a(a, root));
}

fn sandhi_ap_new_session(base_url, platform_name, automation_name, extra_caps_json) {
    return sandhi_ap_new_session_a(default_alloc(), base_url, platform_name, automation_name, extra_caps_json);
}

# ================================================================
# Context switching — native vs webview
# ================================================================

# GET /session/{id}/contexts — list available contexts.
fn sandhi_ap_get_contexts_a(a, base_url, session_id) {
    var url = _sandhi_wd_session_url_a(a, base_url, session_id, "/contexts");
    return sandhi_rpc_call_a(a, url, "GET", 0, SANDHI_RPC_DIALECT_WEBDRIVER);
}

fn sandhi_ap_get_contexts(base_url, session_id) {
    return sandhi_ap_get_contexts_a(default_alloc(), base_url, session_id);
}

# POST /session/{id}/context — switch to `context_name` (e.g.
# "NATIVE_APP" or "WEBVIEW_com.example.app").
fn sandhi_ap_set_context_a(a, base_url, session_id, context_name) {
    var url = _sandhi_wd_session_url_a(a, base_url, session_id, "/context");
    var body_obj = sandhi_json_obj_new_a(a);
    if (body_obj == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    sandhi_json_add_string_a(a, body_obj, "name", context_name);
    return sandhi_rpc_call_a(a, url, "POST", sandhi_json_build_a(a, body_obj), SANDHI_RPC_DIALECT_WEBDRIVER);
}

fn sandhi_ap_set_context(base_url, session_id, context_name) {
    return sandhi_ap_set_context_a(default_alloc(), base_url, session_id, context_name);
}

# GET /session/{id}/context — current context name.
fn sandhi_ap_current_context_a(a, base_url, session_id) {
    var url = _sandhi_wd_session_url_a(a, base_url, session_id, "/context");
    return sandhi_rpc_call_a(a, url, "GET", 0, SANDHI_RPC_DIALECT_WEBDRIVER);
}

fn sandhi_ap_current_context(base_url, session_id) {
    return sandhi_ap_current_context_a(default_alloc(), base_url, session_id);
}

# ================================================================
# App lifecycle
# ================================================================

# POST /session/{id}/appium/device/install_app — install an APK / IPA.
# `app_path` is a filesystem path the Appium server can read.
fn sandhi_ap_install_app_a(a, base_url, session_id, app_path) {
    var url = _sandhi_wd_session_url_a(a, base_url, session_id, "/appium/device/install_app");
    var body_obj = sandhi_json_obj_new_a(a);
    if (body_obj == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    sandhi_json_add_string_a(a, body_obj, "appPath", app_path);
    return sandhi_rpc_call_a(a, url, "POST", sandhi_json_build_a(a, body_obj), SANDHI_RPC_DIALECT_WEBDRIVER);
}

fn sandhi_ap_install_app(base_url, session_id, app_path) {
    return sandhi_ap_install_app_a(default_alloc(), base_url, session_id, app_path);
}

# POST /session/{id}/appium/device/remove_app — uninstall a package/bundle.
fn sandhi_ap_remove_app_a(a, base_url, session_id, bundle_id) {
    var url = _sandhi_wd_session_url_a(a, base_url, session_id, "/appium/device/remove_app");
