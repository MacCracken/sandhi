    if (body_obj == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    sandhi_json_add_string_a(a, body_obj, "appId", bundle_id);
    return sandhi_rpc_call_a(a, url, "POST", sandhi_json_build_a(a, body_obj), SANDHI_RPC_DIALECT_WEBDRIVER);
}

fn sandhi_ap_activate_app(base_url, session_id, bundle_id) {
    return sandhi_ap_activate_app_a(default_alloc(), base_url, session_id, bundle_id);
}

# POST /session/{id}/appium/device/terminate_app — stop an app.
fn sandhi_ap_terminate_app_a(a, base_url, session_id, bundle_id) {
    var url = _sandhi_wd_session_url_a(a, base_url, session_id, "/appium/device/terminate_app");
