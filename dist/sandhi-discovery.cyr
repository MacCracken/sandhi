# --- error.cyr ---

# sandhi/error — unified error kinds across sandhi's submodules.
#
# Convention: every public sandhi function that can fail returns a
# `sandhi_result*` with status_code + body ptr (http-response-shaped
# at the library boundary). Internal call chains can use sakshi
# structured error logging plus the codes below.

enum SandhiErrorKind {
    SANDHI_OK              = 0;
    SANDHI_ERR_PARSE       = 1;
    SANDHI_ERR_CONNECT     = 2;
    SANDHI_ERR_TLS         = 3;
    SANDHI_ERR_TIMEOUT     = 4;
    SANDHI_ERR_REMOTE      = 5;
    SANDHI_ERR_PROTOCOL    = 6;
    SANDHI_ERR_AUTH        = 7;
    SANDHI_ERR_DISCOVERY   = 8;
    SANDHI_ERR_INTERNAL    = 99;
}

fn sandhi_err_kind_name(kind): i64 {
    if (kind == SANDHI_OK)             { return "OK";         }
    if (kind == SANDHI_ERR_PARSE)      { return "PARSE";      }
    if (kind == SANDHI_ERR_CONNECT)    { return "CONNECT";    }
    if (kind == SANDHI_ERR_TLS)        { return "TLS";        }
    if (kind == SANDHI_ERR_TIMEOUT)    { return "TIMEOUT";    }
    if (kind == SANDHI_ERR_REMOTE)     { return "REMOTE";     }
    if (kind == SANDHI_ERR_PROTOCOL)   { return "PROTOCOL";   }
    if (kind == SANDHI_ERR_AUTH)       { return "AUTH";       }
    if (kind == SANDHI_ERR_DISCOVERY)  { return "DISCOVERY";  }
    if (kind == SANDHI_ERR_INTERNAL)   { return "INTERNAL";   }
    return "UNKNOWN";
}

# --- trace.cyr ---

# sandhi/obs/trace — thin wrapper around stdlib sakshi's span API.
#
# sandhi wraps `sakshi_span_enter` / `_exit` so that all sandhi-emitted
# spans share a naming convention ("sandhi.<subsystem>.<verb>") and
# so that the call-site code reads at the sandhi layer, not as stdlib
# internals. Keeps the fold-into-stdlib public surface clean of direct
# sakshi coupling beyond the one `lib/sakshi.cyr` include.
#
# Span model:
#   sandhi_trace_begin(name) — pushes a span onto sakshi's stack
#   sandhi_trace_end()       — pops + emits elapsed-ns on exit
#
# Stack max-depth = 16 (per sakshi). sandhi's nesting is shallow
# (HTTP call → DNS resolve + RPC dispatch → HTTP call), so the 16-
# slot budget is comfortable.
#
# Span-name-only by design — sakshi's public API has no key/value
# attribute surface (no `sakshi_span_attr` ships). Span names carry
# the context callers need (e.g. `sandhi.http.GET.example.com`).
# This is an upstream API shape, not a sandhi stub.

# Opt-in flag. Default 0 = every span call is a no-op; sandhi stays
# silent. Consumers that want spans call sandhi_trace_enable(1) once
# at process start (typically right after configuring sakshi's output
# target). We default off rather than inherit from sakshi so an
# application that uses sakshi for its own app-level events isn't
# flooded with sandhi-internal ENTER/EXIT noise it didn't ask for.
var _sandhi_trace_enabled = 0;

fn sandhi_trace_enable(on): i64 {
    _sandhi_trace_enabled = on;
    return 0;
}

fn sandhi_trace_enabled(): i64 {
    return _sandhi_trace_enabled;
}

fn sandhi_trace_begin(name): i64 {
    if (_sandhi_trace_enabled == 0) { return 0; }
    sakshi_span_enter(name, strlen(name));
    return 0;
}

fn sandhi_trace_end(): i64 {
    if (_sandhi_trace_enabled == 0) { return 0; }
    sakshi_span_exit();
    return 0;
}

fn sandhi_trace_depth(): i64 {
    return sakshi_span_depth();
}

# --- prof.cyr ---

# sandhi/obs/prof — runtime per-request profile instrumentation.
#
# Mirrors the cyrius v5.10.0 `_prof_*_end` capture pattern but
# adapted for runtime (sandhi is called many times per process, so
# captures reset per request rather than printing once at exit).
#
# Off by default — every capture is a single global-load comparison
# against `_sandhi_prof_enabled` and an early return; production
# overhead is one branch per phase boundary. Consumers that want
# numbers call `sandhi_prof_enable(1)` once at process start (or
# selectively around requests they care about) and then read back
# the per-phase elapsed-ns via `sandhi_prof_get(SANDHI_PROF_PHASE_*)`
# after the request completes.
#
# Phase model — captures during `_sandhi_http_do_impl_a`:
#   PHASE_REQUEST_START   = 0  (reset at request entry)
#   PHASE_URL_PARSE_END   = 1  (after sandhi_url_parse_a)
#   PHASE_DNS_END         = 2  (after _sandhi_client_resolve(_v6)?_a)
#   PHASE_CONN_OPEN_END   = 3  (after pool take or open_fully_timed_a)
#   PHASE_REQ_BUILD_END   = 4  (after _sandhi_client_build_request_va)
#   PHASE_EXCHANGE_END    = 5  (after _sandhi_http_exchange*_a)
#
# Each capture records a ns timestamp; `sandhi_prof_get(phase)`
# returns elapsed ns from PHASE_REQUEST_START to that phase. The
# pool-take fast path doesn't reach the connect step, so
# PHASE_CONN_OPEN_END equals the prior phase's timestamp on a pool
# hit (zero elapsed). Same for IPv6 fallback inside DNS — the v6
# resolution is captured under the unified DNS phase.
#
# Plus recv-buffer waste tracking: `sandhi_prof_recv_cap()` is the
# bytes allocated for the recv buffer; `sandhi_prof_recv_used()` is
# the bytes actually received. The ratio is the over-allocation
# factor, useful for tuning the default 256 KB cap.
#
# This module is the first slot of a future optimization arc — the
# captures stay constant across slots, but the analysis driving the
# next optimization picks lands as separate work using these numbers.

enum SandhiProfPhase {
    SANDHI_PROF_PHASE_REQUEST_START   = 0;
    SANDHI_PROF_PHASE_URL_PARSE_END   = 1;
    SANDHI_PROF_PHASE_DNS_END         = 2;
    SANDHI_PROF_PHASE_CONN_OPEN_END   = 3;
    SANDHI_PROF_PHASE_REQ_BUILD_END   = 4;
    SANDHI_PROF_PHASE_EXCHANGE_END    = 5;
}

var SANDHI_PROF_PHASE_COUNT = 6;

# Module-level state. Six slot per-phase timestamps + the cap/used
# pair. All zero at process start; reset at every request entry
# when profiling is enabled.
var _sandhi_prof_enabled = 0;
var _sandhi_prof_ts_0 = 0;
var _sandhi_prof_ts_1 = 0;
var _sandhi_prof_ts_2 = 0;
var _sandhi_prof_ts_3 = 0;
var _sandhi_prof_ts_4 = 0;
var _sandhi_prof_ts_5 = 0;
var _sandhi_prof_recv_cap_v = 0;
var _sandhi_prof_recv_used_v = 0;

# ================================================================
# Public surface
# ================================================================

# Toggle profiling on/off. Default 0 = every capture is a no-op.
fn sandhi_prof_enable(on): i64 {
    _sandhi_prof_enabled = on;
    return 0;
}

fn sandhi_prof_enabled(): i64 {
    return _sandhi_prof_enabled;
}

# Reset per-request state at request entry. Records PHASE_REQUEST_START.
# No-op when profiling is disabled.
fn sandhi_prof_reset(): i64 {
    if (_sandhi_prof_enabled == 0) { return 0; }
    var now = clock_now_ns();
    _sandhi_prof_ts_0 = now;
    _sandhi_prof_ts_1 = now;
    _sandhi_prof_ts_2 = now;
    _sandhi_prof_ts_3 = now;
    _sandhi_prof_ts_4 = now;
    _sandhi_prof_ts_5 = now;
    _sandhi_prof_recv_cap_v = 0;
    _sandhi_prof_recv_used_v = 0;
    return 0;
}

# Capture timestamp for `phase`. No-op when profiling is disabled.
# Phase ordering matters — capture in the order phases complete.
fn sandhi_prof_capture(phase): i64 {
    if (_sandhi_prof_enabled == 0) { return 0; }
    var now = clock_now_ns();
    if (phase == SANDHI_PROF_PHASE_URL_PARSE_END) { _sandhi_prof_ts_1 = now; }
    if (phase == SANDHI_PROF_PHASE_DNS_END)       { _sandhi_prof_ts_2 = now; }
    if (phase == SANDHI_PROF_PHASE_CONN_OPEN_END) { _sandhi_prof_ts_3 = now; }
    if (phase == SANDHI_PROF_PHASE_REQ_BUILD_END) { _sandhi_prof_ts_4 = now; }
    if (phase == SANDHI_PROF_PHASE_EXCHANGE_END)  { _sandhi_prof_ts_5 = now; }
    return 0;
}

# Record the recv-buffer cap (allocated) and used (actually received).
# Called once per exchange, just before `sandhi_conn_close`. No-op
# when profiling is disabled.
fn sandhi_prof_record_recv(cap, used): i64 {
    if (_sandhi_prof_enabled == 0) { return 0; }
    _sandhi_prof_recv_cap_v = cap;
    _sandhi_prof_recv_used_v = used;
    return 0;
}

# Read elapsed ns from PHASE_REQUEST_START to `phase`. Returns 0
# when profiling is disabled or for PHASE_REQUEST_START itself.
fn sandhi_prof_get(phase): i64 {
    if (_sandhi_prof_enabled == 0) { return 0; }
    if (phase == SANDHI_PROF_PHASE_REQUEST_START) { return 0; }
    var start = _sandhi_prof_ts_0;
    if (phase == SANDHI_PROF_PHASE_URL_PARSE_END) { return _sandhi_prof_ts_1 - start; }
    if (phase == SANDHI_PROF_PHASE_DNS_END)       { return _sandhi_prof_ts_2 - start; }
    if (phase == SANDHI_PROF_PHASE_CONN_OPEN_END) { return _sandhi_prof_ts_3 - start; }
    if (phase == SANDHI_PROF_PHASE_REQ_BUILD_END) { return _sandhi_prof_ts_4 - start; }
    if (phase == SANDHI_PROF_PHASE_EXCHANGE_END)  { return _sandhi_prof_ts_5 - start; }
    return 0;
}

# Bytes allocated for the recv buffer in the most-recent exchange.
fn sandhi_prof_recv_cap(): i64 {
    return _sandhi_prof_recv_cap_v;
}

# Bytes actually received in the most-recent exchange. The ratio
# `recv_used / recv_cap` is the over-allocation factor — values
# near 1.0 mean the cap is well-tuned, near 0 means we allocated
# 100KB+ for a 200-byte response.
fn sandhi_prof_recv_used(): i64 {
    return _sandhi_prof_recv_used_v;
}

# --- headers.cyr ---

# sandhi/http/headers — HTTP request/response header management.
#
# Wraps stdlib str/vec/alloc with a proper key-value store:
# case-insensitive lookup, multi-valued fields (Set-Cookie etc.),
# CRLF-terminated wire-format serialize + parse. Order is preserved
# across set/add so downstream tests don't race on iteration shape.
#
# Storage model — a vec of entry pointers. Each entry is a 16-byte
# alloc: { name_cstr, value_cstr }. Header blocks are small (< 30
# entries in practice); linear scan beats a hashmap here on both
# code size and constant factor, and matters for serialization
# ordering (multi-value fields render in the order they were added).

# ================================================================
# Entry layout + helpers
# ================================================================

# Internal entry constructor — `_a` variant takes the Allocator first.
# Returns 0 on OOM. Callers MUST null-check (existing call sites in
# sandhi_headers_add_a do).
fn _sandhi_hdr_entry_new_a(a, name, value): i64 {
    var e = alloc_via(a, 16);
    if (e == 0) { return 0; }
    store64(e, name);
    store64(e + 8, value);
    return e;
}

fn _sandhi_hdr_entry_new(name, value): i64 {
    return _sandhi_hdr_entry_new_a(default_alloc(), name, value);
}

fn _sandhi_hdr_entry_name(e): i64 {
    return load64(e);
}

fn _sandhi_hdr_entry_value(e): i64 {
    return load64(e + 8);
}

# ASCII lowercase — header names are ASCII-only per RFC 7230.
fn _sandhi_hdr_to_lower(c): i64 {
    if (c >= 65) { if (c <= 90) { return c + 32; } }
    return c;
}

# Case-insensitive cstr equality. Returns 1 if equal, 0 otherwise.
fn _sandhi_hdr_ieq(a, b): i64 {
    var i = 0;
    while (1 == 1) {
        var ca = _sandhi_hdr_to_lower(load8(a + i));
        var cb = _sandhi_hdr_to_lower(load8(b + i));
        if (ca != cb) { return 0; }
        if (ca == 0) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Trim ASCII SP / HTAB from both ends of a cstr range and copy into
# `a`. Returns 0 on OOM.
fn _sandhi_hdr_trim_copy_a(a, ptr, start, end): i64 {
    var s = start;
    var e = end;
    while (s < e && (load8(ptr + s) == 32 || load8(ptr + s) == 9)) { s = s + 1; }
    while (e > s && (load8(ptr + e - 1) == 32 || load8(ptr + e - 1) == 9)) { e = e - 1; }
    var n = e - s;
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, ptr + s, n);
    store8(out + n, 0);
    return out;
}

fn _sandhi_hdr_trim_copy(ptr, start, end): i64 {
    return _sandhi_hdr_trim_copy_a(default_alloc(), ptr, start, end);
}

# Duplicate a cstr into a fresh null-terminated alloc owned by `a`.
# Returns 0 on null input OR on OOM (caller distinguishes via the
# input-null pre-check that lives in the public verbs).
fn _sandhi_hdr_cstr_dup_a(a, s): i64 {
    if (s == 0) { return 0; }
    var n = strlen(s);
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, s, n);
    store8(out + n, 0);
    return out;
}

fn _sandhi_hdr_cstr_dup(s): i64 {
    return _sandhi_hdr_cstr_dup_a(default_alloc(), s);
}

# ================================================================
# Public API — block creation + mutation
# ================================================================

# Allocate an empty header block from `a`. Returns a vec of entry
# pointers; 0 on OOM.
fn sandhi_headers_new_a(a): i64 {
    return vec_new_a(a);
}

fn sandhi_headers_new(): i64 {
    return sandhi_headers_new_a(default_alloc());
}

# Total entry count (includes duplicate-name entries).
fn sandhi_headers_count(h): i64 {
    return vec_len(h);
}

# 0.9.1 P1 — 1 if `s` contains any of CR (0x0D), LF (0x0A), or NUL
# embedded mid-string (NUL is the cstr terminator, so embedded NUL
# is the only failure mode; CR/LF are header smuggling vectors).
# Returns 1 = unsafe, 0 = safe. Used by add / set to refuse caller-
# injected smuggled-header bytes.
fn _sandhi_hdr_has_unsafe_byte(s): i64 {
    if (s == 0) { return 0; }
    var i = 0;
    while (load8(s + i) != 0) {
        var c = load8(s + i);
        if (c == 13 || c == 10) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Append an entry into `a`. Multi-value-friendly — `add` never
# replaces; use `set` when you want single-value semantics.
#
# 0.9.1 P1 — refuses caller-supplied name/value containing CR / LF.
# Returns 0 on success, `0 - 1` on byte-rejection, `0 - 2` on OOM.
fn sandhi_headers_add_a(a, h, name, value): i64 {
    if (_sandhi_hdr_has_unsafe_byte(name) == 1)  { return 0 - 1; }
    if (_sandhi_hdr_has_unsafe_byte(value) == 1) { return 0 - 1; }
    var name_dup = _sandhi_hdr_cstr_dup_a(a, name);
    if (name_dup == 0) { return 0 - 2; }
    var value_dup = _sandhi_hdr_cstr_dup_a(a, value);
    if (value_dup == 0) { return 0 - 2; }
    var e = _sandhi_hdr_entry_new_a(a, name_dup, value_dup);
    if (e == 0) { return 0 - 2; }
    vec_push_a(a, h, e);
    return 0;
}

fn sandhi_headers_add(h, name, value): i64 {
    return sandhi_headers_add_a(default_alloc(), h, name, value);
}

# Replace all entries with the given name, then append one new entry,
# allocating any new storage in `a`. Use for single-value headers.
fn sandhi_headers_set_a(a, h, name, value): i64 {
    if (_sandhi_hdr_has_unsafe_byte(name) == 1)  { return 0 - 1; }
    if (_sandhi_hdr_has_unsafe_byte(value) == 1) { return 0 - 1; }
    sandhi_headers_remove(h, name);
    return sandhi_headers_add_a(a, h, name, value);
}

fn sandhi_headers_set(h, name, value): i64 {
    return sandhi_headers_set_a(default_alloc(), h, name, value);
}

# Remove all entries with the given name. Returns number removed.
# Order-preserving for surviving entries.
fn sandhi_headers_remove(h, name): i64 {
    var i = 0;
    var w = 0;
    var removed = 0;
    var n = vec_len(h);
    while (i < n) {
        var e = vec_get(h, i);
        if (_sandhi_hdr_ieq(_sandhi_hdr_entry_name(e), name) == 1) {
            removed = removed + 1;
        } else {
            vec_set(h, w, e);
            w = w + 1;
        }
        i = i + 1;
    }
    # Shrink the vec — store64 the new length into the len slot (vec
    # layout: {data, len, cap} per lib/vec.cyr). No public vec_truncate,
    # so we reach in. Safe because w <= old_len.
    store64(h + 8, w);
    return removed;
}

# First value for the given name, case-insensitive. Returns 0 if absent.
# For multi-value headers (Set-Cookie), iterate via the _at() verbs.
fn sandhi_headers_get(h, name): i64 {
    var i = 0;
    var n = vec_len(h);
    while (i < n) {
        var e = vec_get(h, i);
        if (_sandhi_hdr_ieq(_sandhi_hdr_entry_name(e), name) == 1) {
            return _sandhi_hdr_entry_value(e);
        }
        i = i + 1;
    }
    return 0;
}

# Indexed name access (iteration). Returns 0 if out of range.
fn sandhi_headers_name_at(h, idx): i64 {
    if (idx < 0) { return 0; }
    if (idx >= vec_len(h)) { return 0; }
    return _sandhi_hdr_entry_name(vec_get(h, idx));
}

# Indexed value access (iteration). Returns 0 if out of range.
fn sandhi_headers_value_at(h, idx): i64 {
    if (idx < 0) { return 0; }
    if (idx >= vec_len(h)) { return 0; }
    return _sandhi_hdr_entry_value(vec_get(h, idx));
}

# 1 if any entry matches the given name (case-insensitive).
fn sandhi_headers_has(h, name): i64 {
    if (sandhi_headers_get(h, name) == 0) { return 0; }
    return 1;
}

# ================================================================
# Serialization
# ================================================================

# Append each entry to the str_builder as "Name: Value\r\n".
# Does NOT append the terminating blank line — caller emits that
# after any request-line / status-line framing so the builder can
# be shared with method-specific prefixes.
fn sandhi_headers_serialize(h, sb): i64 {
    var i = 0;
    var n = vec_len(h);
    while (i < n) {
        var e = vec_get(h, i);
        str_builder_add_cstr(sb, _sandhi_hdr_entry_name(e));
        str_builder_add_cstr(sb, ": ");
        str_builder_add_cstr(sb, _sandhi_hdr_entry_value(e));
        str_builder_add_cstr(sb, "\r\n");
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Parsing
# ================================================================

# Parse a raw HTTP header block into a new sandhi_headers block.
# Expects the request-line OR status-line to already be stripped —
# start the buffer at the first header line. Stops at the first
# empty (CRLF-only) line or at blen, whichever comes first.
#
# Parse a raw HTTP header block into a fresh block allocated from `a`.
# Returns 0 on OOM (block allocation failure); otherwise returns a
# block that may be empty if every line was malformed. Per-line
# allocation failures bail out of the loop with the partial block —
# arena callers reset on failure anyway, default-alloc callers get a
# best-effort partial parse (matches pre-migration behavior where
# alloc-fail aborted, since the global bump can't fail in practice
# until the heap is exhausted).
fn sandhi_headers_parse_a(a, buf, blen): i64 {
    var h = sandhi_headers_new_a(a);
    if (h == 0) { return 0; }
    var i = 0;
    while (i < blen) {
        # End-of-headers marker — empty line.
        if (i + 1 < blen && load8(buf + i) == 13 && load8(buf + i + 1) == 10) {
            return h;
        }
        if (load8(buf + i) == 10) { return h; }

        # Find end of line (next LF).
        var line_start = i;
        var line_end = i;
        while (line_end < blen && load8(buf + line_end) != 10) {
            line_end = line_end + 1;
        }
        # Strip trailing CR.
        var trim_end = line_end;
        if (trim_end > line_start && load8(buf + trim_end - 1) == 13) {
            trim_end = trim_end - 1;
        }

        # Find colon. If absent, skip the line.
        var colon = line_start;
        while (colon < trim_end && load8(buf + colon) != 58) {
            colon = colon + 1;
        }
        if (colon < trim_end) {
            # Name: [line_start, colon) — trim trailing whitespace.
            var name_end = colon;
            while (name_end > line_start && (load8(buf + name_end - 1) == 32 || load8(buf + name_end - 1) == 9)) {
                name_end = name_end - 1;
            }
            var name_len = name_end - line_start;
            if (name_len > 0) {
                var name = alloc_via(a, name_len + 1);
                if (name == 0) { return h; }
                memcpy(name, buf + line_start, name_len);
                store8(name + name_len, 0);

                # Value: [colon+1, trim_end) — trim leading + trailing whitespace.
                var val = _sandhi_hdr_trim_copy_a(a, buf, colon + 1, trim_end);
                if (val == 0) { return h; }
                sandhi_headers_add_a(a, h, name, val);
            }
        }

        i = line_end + 1;
    }
    return h;
}

fn sandhi_headers_parse(buf, blen): i64 {
    return sandhi_headers_parse_a(default_alloc(), buf, blen);
}

# ================================================================
# Smuggling-vector dup detection (0.9.1 P1)
# ================================================================
#
# Per RFC 7230 §3.3.2 and §5.4, multiple `Content-Length` / multiple
# `Host` / multiple `Transfer-Encoding` headers in a single message
# is a malformed-message condition. Different intermediaries pick
# different ones to honor — the classic CL.CL / Host.Host
# disagreement vectors. We can't repair these; the only safe move
# is to refuse the message entirely.
#
# `sandhi_headers_smuggle_dup` returns 1 if any of those three
# header names appears more than once (case-insensitive). The
# response parser + server-side accept loop call it after parse
# and reject on truthy.

fn _sandhi_hdr_count_ci(h, name): i64 {
    var count = 0;
    var n = sandhi_headers_count(h);
    var i = 0;
    while (i < n) {
        var entry = vec_get(h, i);
        if (_sandhi_hdr_ieq(_sandhi_hdr_entry_name(entry), name) == 1) {
            count = count + 1;
        }
        i = i + 1;
    }
    return count;
}

fn sandhi_headers_smuggle_dup(h): i64 {
    if (h == 0) { return 0; }
    if (_sandhi_hdr_count_ci(h, "Host") > 1)              { return 1; }
    if (_sandhi_hdr_count_ci(h, "Content-Length") > 1)    { return 1; }
    if (_sandhi_hdr_count_ci(h, "Transfer-Encoding") > 1) { return 1; }
    return 0;
}

# ================================================================
# Identity
# ================================================================

# --- url.cyr ---

# sandhi/http/url — URL parser (http:// + https://).
#
# Returns a 40-byte struct on success, 0 on malformed input. Caller
# is responsible for null-checking before dereferencing fields.
#
# Struct layout:
#   +0   scheme      (int: SANDHI_URL_HTTP | SANDHI_URL_HTTPS)
#   +8   host        (cstr — null-terminated, alloc-owned)
#   +16  port        (int: 1..65535)
#   +24  path        (cstr — includes leading '/'; always non-empty)
#   +32  query       (cstr — after '?', or 0 if none)
#
# CRLF-injection hardening: reject any URL containing control bytes
# (CR / LF / TAB / SPACE) before we allocate anything. Same posture
# as stdlib http.cyr::_http_parse_url — these bytes can smuggle extra
# request-line / header content if the URL is reflected into a wire
# request. Rejecting at the boundary (returning 0) keeps caller-side
# code simple: null-check once, dereference fields freely thereafter.

enum SandhiUrlScheme {
    SANDHI_URL_HTTP  = 0;
    SANDHI_URL_HTTPS = 1;
}

# Field offsets within the parsed URL struct.
enum SandhiUrlOff {
    SANDHI_URL_OFF_SCHEME = 0;
    SANDHI_URL_OFF_HOST   = 8;
    SANDHI_URL_OFF_PORT   = 16;
    SANDHI_URL_OFF_PATH   = 24;
    SANDHI_URL_OFF_QUERY  = 32;
}

var SANDHI_URL_STRUCT_SIZE = 40;

# Accessors. Inline-friendly — callers can load64 directly, but going
# through accessors reads better and lets us reshape the struct later.
fn sandhi_url_scheme(u): i64 { return load64(u + SANDHI_URL_OFF_SCHEME); }
fn sandhi_url_host(u): i64 { return load64(u + SANDHI_URL_OFF_HOST); }
fn sandhi_url_port(u): i64 { return load64(u + SANDHI_URL_OFF_PORT); }
fn sandhi_url_path(u): i64 { return load64(u + SANDHI_URL_OFF_PATH); }
fn sandhi_url_query(u): i64 { return load64(u + SANDHI_URL_OFF_QUERY); }

# Validate that no byte in the URL can escape the request line / header
# block. Returns 1 if safe, 0 if any disallowed byte is present.
fn _sandhi_url_safe(url): i64 {
    var i = 0;
    while (load8(url + i) != 0) {
        var c = load8(url + i);
        if (c == 13) { return 0; }  # CR
        if (c == 10) { return 0; }  # LF
        if (c == 9)  { return 0; }  # TAB
        if (c == 32) { return 0; }  # SPACE
        i = i + 1;
    }
    return 1;
}

# Lowercase-equal comparison for scheme detection ("HTTP" == "http").
# Compares up to `n` bytes; returns 1 if equal ignoring case, 0 otherwise.
fn _sandhi_url_sceq(a, b, n): i64 {
    var i = 0;
    while (i < n) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ca >= 65 && ca <= 90) { ca = ca + 32; }
        if (cb >= 65 && cb <= 90) { cb = cb + 32; }
        if (ca != cb) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Parse a URL into the given Allocator. Returns the struct on success,
# 0 on malformed input or OOM. Every alloc on the parsed-URL hot path
# (host / path / query / struct) lands in `a`; reset_via(a) reclaims
# all of it in one shot — the per-request-arena pattern.
fn sandhi_url_parse_a(a, url): i64 {
    if (url == 0) { return 0; }
    if (_sandhi_url_safe(url) == 0) { return 0; }

    # Scheme detection. Default port follows the scheme.
    var scheme = 0;
    var default_port = 80;
    var p = 0;
    if (_sandhi_url_sceq(url, "https://", 8) == 1) {
        scheme = SANDHI_URL_HTTPS;
        default_port = 443;
        p = 8;
    } elif (_sandhi_url_sceq(url, "http://", 7) == 1) {
        scheme = SANDHI_URL_HTTP;
        default_port = 80;
        p = 7;
    } else {
        return 0;  # unsupported scheme
    }

    # Host — two flavors:
    #   1) Bracketed IPv6: `[2001:db8::1]` or `[::1]` per RFC 3986 §3.2.2.
    #      Brackets contain the literal; ':' inside brackets is part of
    #      the address, not the port separator. Brackets are stripped
    #      from the stored host (callers see "::1", not "[::1]").
    #   2) Bare hostname / IPv4: runs until ':' / '/' / '?' / end.
    if (load8(url + p) == 91) {  # '['
        var v6_start = p + 1;
        var v6_end = v6_start;
        var v6_scan = 1;
        while (v6_scan == 1) {
            var bc = load8(url + v6_end);
            if (bc == 0)  { return 0; }     # unterminated bracket
            if (bc == 93) { v6_scan = 0; }  # ']'
            else          { v6_end = v6_end + 1; }
        }
        if (v6_end == v6_start) { return 0; }  # empty []
        # finish_at() takes content-range + post-host-tail-cursor
        # separately so the v6 path can skip the trailing ']'.
        return _sandhi_url_finish_at_a(a, url, scheme, default_port, v6_start, v6_end, v6_end + 1);
    }

    var host_start = p;
    var scanning = 1;
    while (scanning == 1) {
        var c = load8(url + p);
        if (c == 0)  { scanning = 0; }
        elif (c == 58) { scanning = 0; }
        elif (c == 47) { scanning = 0; }
        elif (c == 63) { scanning = 0; }
        else { p = p + 1; }
    }
    return _sandhi_url_finish_at_a(a, url, scheme, default_port, host_start, p, p);
}

# Back-compat: parse using the process-wide default Allocator.
fn sandhi_url_parse(url): i64 {
    return sandhi_url_parse_a(default_alloc(), url);
}

# Continue parsing after the host boundary, allocating into `a`.
# host_start..host_end_excl bounds the host content; tail_start is
# where post-host parsing (port / path / query) picks up. Bare hosts
# pass host_end_excl == tail_start; bracketed-v6 passes
# tail_start == host_end_excl + 1 to skip the closing ']'. Returns
# 0 on bad input OR on allocator failure (OOM).
fn _sandhi_url_finish_at_a(a, url, scheme, default_port, host_start, host_end_excl, tail_start): i64 {
    var host_len = host_end_excl - host_start;
    if (host_len == 0) { return 0; }

    var port = default_port;
    var p = tail_start;
    if (load8(url + p) == 58) {
        p = p + 1;
        port = 0;
        var got = 0;
        # 0.9.1 P1 — explicit digit count cap. Existing post-multiply
        # check already aborts before the i64 multiply could wrap
        # (port > 65535 fires by the 5th non-leading-zero digit), but
        # bounding the input scan at 5 digits is safer and rejects
        # pathological inputs like "00000000000000080" early. Also
        # blocks attempts to use leading zeros to mask a multi-digit
        # port that any other parser might handle differently.
        var port_digits = 0;
        while (load8(url + p) >= 48 && load8(url + p) <= 57) {
            if (port_digits >= 5) { return 0; }
            port = port * 10 + (load8(url + p) - 48);
            got = 1;
            port_digits = port_digits + 1;
            p = p + 1;
            if (port > 65535) { return 0; }
        }
        if (got == 0) { return 0; }
        if (port == 0) { return 0; }
    }

    # Path + query. If delimiter is '/' → path runs to '?' or NUL. If '?' →
    # path defaults to "/" and query follows. If NUL → path "/" and no query.
    var path = "/";
    var query = 0;

    if (load8(url + p) == 47) {
        var path_start = p;
        var qmark = 0 - 1;
        var scan = 1;
        while (scan == 1) {
            var c = load8(url + p);
            if (c == 0)  { scan = 0; }
            elif (c == 63) { qmark = p; scan = 0; }
            else { p = p + 1; }
        }
        var path_end = p;
        if (qmark >= 0) { path_end = qmark; }
        var plen = path_end - path_start;
        var path_out = alloc_via(a, plen + 1);
        if (path_out == 0) { return 0; }
        memcpy(path_out, url + path_start, plen);
        store8(path_out + plen, 0);
        path = path_out;

        if (qmark >= 0) {
            var q_start = qmark + 1;
            var q_end = q_start;
            while (load8(url + q_end) != 0) { q_end = q_end + 1; }
            var qlen = q_end - q_start;
            var query_out = alloc_via(a, qlen + 1);
            if (query_out == 0) { return 0; }
            memcpy(query_out, url + q_start, qlen);
            store8(query_out + qlen, 0);
            query = query_out;
        }
    } elif (load8(url + p) == 63) {
        var qs = p + 1;
        var qe = qs;
        while (load8(url + qe) != 0) { qe = qe + 1; }
        var qlen2 = qe - qs;
        var query_out2 = alloc_via(a, qlen2 + 1);
        if (query_out2 == 0) { return 0; }
        memcpy(query_out2, url + qs, qlen2);
        store8(query_out2 + qlen2, 0);
        query = query_out2;
    }

    var host = alloc_via(a, host_len + 1);
    if (host == 0) { return 0; }
    memcpy(host, url + host_start, host_len);
    store8(host + host_len, 0);

    var result = alloc_via(a, SANDHI_URL_STRUCT_SIZE);
    if (result == 0) { return 0; }
    store64(result + SANDHI_URL_OFF_SCHEME, scheme);
    store64(result + SANDHI_URL_OFF_HOST, host);
    store64(result + SANDHI_URL_OFF_PORT, port);
    store64(result + SANDHI_URL_OFF_PATH, path);
    store64(result + SANDHI_URL_OFF_QUERY, query);
    return result;
}

# --- session_cache.cyr ---

# sandhi/tls_policy/session_cache — TLS 1.3 session-ticket / TLS 1.2
# session-ID cache, keyed by (sni_host, hook_fp, cred_digest).
#
# 1.3.1: composes cyrius v5.10.21's session primitives + v5.10.27's
# staged-connect API (`tls_connect_alloc` + `tls_connect_complete`)
# to enable client-side resumption. The full flow:
#
#   var ctx = tls_connect_alloc(fd, sni, hook_fp, hook_ctx);
#   var sess = sandhi_session_cache_lookup(sni, hook_fp, cred_digest);
#   if (sess != 0) { tls_set_session(ctx, sess); }
#   if (tls_connect_complete(ctx) == 1) {
#       var fresh = tls_get_session(ctx);
#       sandhi_session_cache_store(sni, hook_fp, cred_digest, fresh);
#   }
#
# Cache shape:
#   - Process-wide singleton (init on first use)
#   - Map<key_cstr → entry_ptr>; the map's value pointer is an entry
#     struct (16 bytes, allocated in default_alloc) holding:
#         offset  0  session_ptr   (SSL_SESSION* — refcount-bumped)
#         offset  8  last_used_ms  (monotonic clock_now_ms())
#     The entry struct gives 1.4.0 a place to track per-entry state
#     (TTL + LRU) without forking the map shape.
#   - Key: `<sni_host>|<hook_fp_hex>|<cred_digest_hex>` — hook
#     distinguishes default-ALPN connections from policy-bound
#     connections (different hook = different SSL_CTX config =
#     incompatible session); cred digest (1.3.3) distinguishes
#     different auth contexts (Authorization / Cookie /
#     Proxy-Authorization rotation).
#   - SSL_SESSION* entries are owned by the cache (refcount-bumped
#     by `tls_get_session`); released via `tls_session_free` on
#     replacement / eviction.
#   - Allocator: `default_alloc()` — sessions + entry structs are
#     process-wide singletons that outlive any per-request arena
#     (same shape as the pool's `_hsv_req_buf` and the HPACK static
#     table). Entry structs are `free_via`'d on eviction.
#
# Opt-in: default-OFF. Consumers call `sandhi_session_cache_enable(1)`
# once at process start. When disabled, lookup always returns 0 and
# store is a no-op — zero overhead beyond one global-load + early-
# return per call.
#
# Stats: `_hit_count` / `_miss_count` increment on lookup;
# `_evict_count` / `_age_evict_count` (1.4.0) track LRU + age
# evictions. Consumers sample to evaluate cache effectiveness.
#
# Capability query: `sandhi_session_cache_supported()` returns
# `tls_supports_session_resumption()` — whether the underlying
# TLS layer can actually install / capture sessions. Pre-1.4.0
# this was conflated with `enable()` (which returned 0 when
# capability was missing). 1.4.0 separates the concerns: the
# cache initializes regardless (it's a hashmap with no TLS
# dependency itself), and `enable(1)` always succeeds. Callers
# who want to skip wiring up the cache when the TLS layer
# can't use it should check `_supported()` separately. The
# practical impact: when capability is missing,
# `tls_get_session(ctx)` returns 0 and `store(..., 0)` bails
# out — the cache stays empty in production. The contract
# change was a coverage win for testing (1.3.1 / 1.3.3 round-
# trip tests now exercise the cache for real instead of skip-
# cleaning when libssl symbols don't all resolve).
#
# 1.3.2: 0-RTT (early data) wired through the staged-connect
# finalize. Cache is the substrate; 0-RTT writes the request as
# early data on resumed handshakes when the caller opts in.
#
# 1.3.3: cred-strip-aware keying. Cache key includes a 64-bit
# FNV-1a digest over the request's cred-bearing headers
# (Authorization / Cookie / Proxy-Authorization). When the
# digest changes (auth context rotates), the key changes →
# fresh handshake. Caller passes 0 for the digest when the
# request carries no cred-bearing headers — same key shape as
# 1.3.1 / 1.3.2 in that majority path.
#
# 1.4.0: TTL + max-size eviction. Cache no longer grows
# unbounded — `set_max_size(n)` bounds the entry count (default
# 256), `set_max_age_ms(ms)` ages entries out (default 24h —
# TLS session-ticket lifetime is typically hours; 24h is the
# safe upper bound). Eviction-on-insert when at max
# (oldest `last_used_ms` evicted); age-check-on-lookup
# (`now - last_used_ms > max_age_ms` → evict + miss). Touch
# updates `last_used_ms` on every hit so LRU semantics ride
# the natural access pattern. The 1.3.1 entry-struct slot
# documented as reserved for this is now wired up.
#
# 1.4.0 also fixes a silent-prereq bug carried since 1.3.1:
# the cache was calling `hashmap_*` (which is not stdlib's
# name — stdlib exports `map_*`). cyrius warned + NOPed the
# call sites, so every lookup returned miss + every store
# was a no-op. The 1.3.1 round-trip test passed only because
# its capability gate skipped cleanly when `enable(1) != 1`.
# All call sites renamed to `map_*` in this slot — same patch
# that wires the eviction logic. See 1.4.0 CHANGELOG entry.

# Defaults — 24h ≈ 86_400_000 ms; 256 is generous for typical
# AGNOS service-to-service fan-out (each consumer talks to a
# small handful of upstream authorities).
var _sandhi_session_cache_max_size       = 256;
var _sandhi_session_cache_max_age_ms     = 86400000;

# Cache state (singletons)
var _sandhi_session_cache_enabled         = 0;
var _sandhi_session_cache_initialized     = 0;
var _sandhi_session_cache_map             = 0;   # map<cstr → entry_ptr>
var _sandhi_session_cache_hit_count       = 0;
var _sandhi_session_cache_miss_count      = 0;
var _sandhi_session_cache_evict_count     = 0;   # 1.4.0 — LRU evictions
var _sandhi_session_cache_age_evict_count = 0;   # 1.4.0 — age evictions

# Entry struct layout — 16 bytes
fn _sandhi_session_entry_session(entry): i64 { return load64(entry); }
fn _sandhi_session_entry_last_used_ms(entry): i64 { return load64(entry + 8); }

fn _sandhi_session_entry_new(session, now_ms): i64 {
    var entry = alloc_via(default_alloc(), 16);
    if (entry == 0) { return 0; }
    store64(entry, session);
    store64(entry + 8, now_ms);
    return entry;
}

fn _sandhi_session_entry_touch(entry, now_ms): i64 {
    store64(entry + 8, now_ms);
    return 0;
}

fn _sandhi_session_cache_init(): i64 {
    if (_sandhi_session_cache_initialized == 1) { return 0; }
    # 1.4.0: always allocate. The cache is just a hashmap; it has no
    # TLS dependency at the data-structure level. Capability is
    # queried separately via `sandhi_session_cache_supported()`.
    _sandhi_session_cache_map = map_new_a(default_alloc());
    _sandhi_session_cache_initialized = 1;
    return 0;
}

# Toggle the cache's enabled flag. Returns 1 on success, 0 only
# if the underlying map allocation failed (OOM at init). Idempotent.
#
# 1.4.0: contract change — `enable(1)` no longer returns 0 when
# the TLS layer lacks session-resumption symbols. The cache
# initializes regardless; production callers who want to short-
# circuit on capability-missing should check
# `sandhi_session_cache_supported()` separately. The pre-1.4.0
# behavior conflated two concerns and made the 1.3.1 / 1.3.3
# round-trip tests skip-clean in any env where libssl didn't
# resolve all four resumption symbols.
fn sandhi_session_cache_enable(on): i64 {
    _sandhi_session_cache_init();
    if (_sandhi_session_cache_map == 0) {
        # Init OOM — can't enable.
        _sandhi_session_cache_enabled = 0;
        return 0;
    }
    _sandhi_session_cache_enabled = on;
    return 1;
}

fn sandhi_session_cache_enabled(): i64 {
    return _sandhi_session_cache_enabled;
}

# 1.4.0 — capability probe. Returns 1 if the TLS layer can
# actually install / capture sessions (libssl symbols resolved),
# 0 otherwise. Independent of `enable()` state.
fn sandhi_session_cache_supported(): i64 {
    return tls_supports_session_resumption();
}

# 1.4.0 — configure max entry count. Default 256. Returns 0.
# Takes effect immediately for future inserts; doesn't shrink the
# cache below the new max on the spot (next insert will evict
# until size <= max_size).
fn sandhi_session_cache_set_max_size(n): i64 {
    if (n < 1) { n = 1; }
    _sandhi_session_cache_max_size = n;
    return 0;
}

fn sandhi_session_cache_max_size(): i64 {
    return _sandhi_session_cache_max_size;
}

# 1.4.0 — configure entry max age in ms. Default 86_400_000 (24h).
# Returns 0. Pass a very large value (e.g. (1 << 62)) to effectively
# disable age-based eviction.
fn sandhi_session_cache_set_max_age_ms(ms): i64 {
    if (ms < 1) { ms = 1; }
    _sandhi_session_cache_max_age_ms = ms;
    return 0;
}

fn sandhi_session_cache_max_age_ms(): i64 {
    return _sandhi_session_cache_max_age_ms;
}

# 1.4.0 — LRU eviction counter. Increments each time
# `store` displaces an entry to make room under `max_size`.
fn sandhi_session_cache_evict_count(): i64 {
    return _sandhi_session_cache_evict_count;
}

# 1.4.0 — age-eviction counter. Increments each time `lookup`
# discards a stale entry (age > `max_age_ms`).
fn sandhi_session_cache_age_evict_count(): i64 {
    return _sandhi_session_cache_age_evict_count;
}

# Build a cache key from (sni_host, hook_fp, cred_digest) into `a`.
# The hook fp is rendered as a 16-hex-digit suffix so different hook
# surfaces (default ALPN hook vs. policy hook) don't share cache
# slots — their SSL_CTX configurations may differ, which would
# invalidate session reuse. The cred digest (1.3.3) is rendered as
# a second 16-hex-digit suffix so requests with different auth
# contexts don't share a session. Pass 0 for cred_digest when no
# cred-bearing headers are present; rendered as `|0000000000000000`,
# the common case for service-to-service traffic.
fn _sandhi_session_cache_key_a(a, sni_host, hook_fp, cred_digest): i64 {
    if (sni_host == 0) { return 0; }
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0; }
    str_builder_add_cstr_a(a, sb, sni_host);
    str_builder_add_byte(sb, 124);   # '|'
    var hex = "0123456789abcdef";
    var i = 15;
    while (i >= 0) {
        var nibble = (hook_fp >> (i * 4)) & 15;
        str_builder_add_byte(sb, load8(hex + nibble));
        i = i - 1;
    }
    str_builder_add_byte(sb, 124);   # '|'
    i = 15;
    while (i >= 0) {
        var nibble2 = (cred_digest >> (i * 4)) & 15;
        str_builder_add_byte(sb, load8(hex + nibble2));
        i = i - 1;
    }
    return str_data(str_builder_build_a(a, sb));
}

# 1.4.0 — walk all entries, find the key whose entry has the
# smallest `last_used_ms`, and evict it. Releases the SSL_SESSION*
# (via tls_session_free), deletes the key from the map, and frees
# the entry struct. Used by `store` when the cache is at
# `max_size`. No-op if the map is empty.
fn _sandhi_session_cache_evict_oldest(): i64 {
    if (_sandhi_session_cache_map == 0) { return 0; }
    var keys = map_keys(_sandhi_session_cache_map);
    var n = vec_len(keys);
    if (n == 0) { return 0; }
    var oldest_key = 0;
    var oldest_ms = 0;
    var first = 1;
    var i = 0;
    while (i < n) {
        var k = vec_get(keys, i);
        var entry = map_get(_sandhi_session_cache_map, k);
        if (entry != 0) {
            var lu = _sandhi_session_entry_last_used_ms(entry);
            if (first == 1 || lu < oldest_ms) {
                oldest_ms = lu;
                oldest_key = k;
                first = 0;
            }
        }
        i = i + 1;
    }
    if (oldest_key == 0) { return 0; }
    var victim = map_get(_sandhi_session_cache_map, oldest_key);
    if (victim != 0) {
        var sess = _sandhi_session_entry_session(victim);
        if (sess != 0) { tls_session_free(sess); }
        map_delete(_sandhi_session_cache_map, oldest_key);
        free_via(default_alloc(), victim);
        _sandhi_session_cache_evict_count = _sandhi_session_cache_evict_count + 1;
    }
    return 0;
}

# Lookup a cached session for (sni_host, hook_fp, cred_digest).
# Returns 0 on miss / disabled / cache uninitialized / age-expired.
# The returned SSL_SESSION* is OWNED BY THE CACHE — caller must
# NOT call `tls_session_free` on it. Caller passes it to
# `tls_set_session(ctx, sess)` which does NOT take ownership
# (TLS layer bumps the refcount internally).
#
# 1.4.0: age-check on hit. If `now - last_used_ms > max_age_ms`,
# the entry is evicted and the lookup returns miss. On a valid
# hit, `last_used_ms` is touched to `now` — this gives LRU
# semantics for the `_evict_oldest` walk.
#
# 1.3.3: `cred_digest` is the FNV-1a 64-bit digest over the
# cred-bearing header values from this request (computed via
# `_sandhi_compute_cred_digest` in client.cyr). Pass 0 when no
# cred-bearing headers are present.
fn sandhi_session_cache_lookup(sni_host, hook_fp, cred_digest): i64 {
    if (_sandhi_session_cache_enabled == 0) { return 0; }
    if (_sandhi_session_cache_map == 0) { return 0; }
    if (sni_host == 0) { return 0; }
    var key = _sandhi_session_cache_key_a(default_alloc(), sni_host, hook_fp, cred_digest);
    if (key == 0) { return 0; }
    var entry = map_get(_sandhi_session_cache_map, key);
    if (entry == 0) {
        _sandhi_session_cache_miss_count = _sandhi_session_cache_miss_count + 1;
        return 0;
    }
    var now = clock_now_ms();
    var last_used = _sandhi_session_entry_last_used_ms(entry);
    if (now - last_used > _sandhi_session_cache_max_age_ms) {
        # Stale entry — server has likely rotated session-ticket
        # keys. Evict + return miss.
        var sess = _sandhi_session_entry_session(entry);
        if (sess != 0) { tls_session_free(sess); }
        map_delete(_sandhi_session_cache_map, key);
        free_via(default_alloc(), entry);
        _sandhi_session_cache_age_evict_count = _sandhi_session_cache_age_evict_count + 1;
        _sandhi_session_cache_miss_count = _sandhi_session_cache_miss_count + 1;
        return 0;
    }
    _sandhi_session_entry_touch(entry, now);
    _sandhi_session_cache_hit_count = _sandhi_session_cache_hit_count + 1;
    return _sandhi_session_entry_session(entry);
}

# Store a freshly-captured session for (sni_host, hook_fp,
# cred_digest). The session pointer must come from
# `tls_get_session(ctx)` (refcount-bumped). Cache takes
# ownership — replaces any prior entry for the same key,
# freeing the prior session.
#
# 1.4.0: eviction-on-insert. If the cache is at `max_size` and
# this is a NEW key (no prior entry to replace), evict the
# entry with the oldest `last_used_ms` to make room.
#
# No-op when disabled / cache uninitialized / session is 0.
fn sandhi_session_cache_store(sni_host, hook_fp, cred_digest, session): i64 {
    if (_sandhi_session_cache_enabled == 0) { return 0; }
    if (_sandhi_session_cache_map == 0) { return 0; }
    if (sni_host == 0 || session == 0) { return 0; }
    var key = _sandhi_session_cache_key_a(default_alloc(), sni_host, hook_fp, cred_digest);
    if (key == 0) { return 0; }
    var now = clock_now_ms();
    var prior = map_get(_sandhi_session_cache_map, key);
    if (prior != 0) {
        # Replace in place — reuse the entry struct; release the
        # old session pointer. Doesn't count against eviction
        # since the slot count is unchanged.
        var old_sess = _sandhi_session_entry_session(prior);
        if (old_sess != 0 && old_sess != session) {
            tls_session_free(old_sess);
        }
        store64(prior, session);
        store64(prior + 8, now);
        return 0;
    }
    # New key — check if we need to evict to stay within bounds.
    if (map_size(_sandhi_session_cache_map) >= _sandhi_session_cache_max_size) {
        _sandhi_session_cache_evict_oldest();
    }
    var entry = _sandhi_session_entry_new(session, now);
    if (entry == 0) {
        # OOM allocating the entry struct. Release the caller's
        # session (we promised ownership transfer); return.
        tls_session_free(session);
        return 0;
    }
    map_set_a(default_alloc(), _sandhi_session_cache_map, key, entry);
    return 0;
}

# Number of cache slots currently occupied. Useful for tests +
# observability sampling.
fn sandhi_session_cache_size(): i64 {
    if (_sandhi_session_cache_map == 0) { return 0; }
    return map_size(_sandhi_session_cache_map);
}

fn sandhi_session_cache_hit_count(): i64 {
    return _sandhi_session_cache_hit_count;
}

fn sandhi_session_cache_miss_count(): i64 {
    return _sandhi_session_cache_miss_count;
}

# 1.4.0 — drop every cached session and free entry structs.
# Releases each `SSL_SESSION*` via `tls_session_free` and frees
# the entry struct via `free_via(default_alloc(), ...)`. Useful
# on logout / context-rotation / shutdown. Counters are NOT
# reset — call `_reset_stats()` for that.
fn sandhi_session_cache_clear(): i64 {
    if (_sandhi_session_cache_map == 0) { return 0; }
    var keys = map_keys(_sandhi_session_cache_map);
    var n = vec_len(keys);
    var i = 0;
    while (i < n) {
        var k = vec_get(keys, i);
        var entry = map_get(_sandhi_session_cache_map, k);
        if (entry != 0) {
            var sess = _sandhi_session_entry_session(entry);
            if (sess != 0) { tls_session_free(sess); }
            free_via(default_alloc(), entry);
        }
        i = i + 1;
    }
    map_clear(_sandhi_session_cache_map);
    return 0;
}

# Reset hit/miss + eviction counters. Doesn't clear the cache
# itself — entries persist for the next round of measurements.
# Use `sandhi_session_cache_clear()` to drop entries.
fn sandhi_session_cache_reset_stats(): i64 {
    _sandhi_session_cache_hit_count = 0;
    _sandhi_session_cache_miss_count = 0;
    _sandhi_session_cache_evict_count = 0;
    _sandhi_session_cache_age_evict_count = 0;
    return 0;
}

# --- conn.cyr ---

# sandhi/http/conn — unified plain-TCP + TLS connection abstraction.
#
# Tagged struct so client code can treat plain http:// and https://
# uniformly. Opens a socket via stdlib net.cyr, optionally wraps it
# in a TLS session via stdlib tls.cyr. Send/recv dispatch on the
# connection kind.
#
# Struct layout (24 bytes):
#   +0   kind     (int: SANDHI_CONN_PLAIN | SANDHI_CONN_TLS)
#   +8   fd       (int: raw socket fd)
#   +16  tls_ctx  (ptr: tls_connect ctx if kind == TLS, else 0)
#
# Ownership: sandhi_conn_open allocates the struct; sandhi_conn_close
# frees the TLS context and closes the fd. Caller does not free the
# struct itself — v1 is alloc-once, no explicit free (Cyrius mem model).

enum SandhiConnKind {
    SANDHI_CONN_PLAIN = 0;
    SANDHI_CONN_TLS   = 1;
}

enum SandhiConnOff {
    SANDHI_CONN_OFF_KIND        = 0;
    SANDHI_CONN_OFF_FD          = 8;
    SANDHI_CONN_OFF_TLS_CTX     = 16;
    # Cstr ptr to the ALPN protocol the server picked (e.g. "h2",
    # "http/1.1"), or 0 when ALPN didn't fire / handshake was plain.
    # Populated post-handshake from SSL_get0_alpn_selected; copy is
    # owned by the conn and lives until process exit (alloc-once).
    SANDHI_CONN_OFF_ALPN_DATA   = 24;
    # 1.3.2 — TLS 1.3 0-RTT acceptance status from
    # `tls_get_early_data_status`. Default 0 (TLS_EARLY_DATA_NOT_SENT)
    # for non-0-RTT conns. Exchange path reads this to decide
    # whether to skip the send step (ACCEPTED) or resend over the
    # normal stream (REJECTED / NOT_SENT).
    SANDHI_CONN_OFF_0RTT_STATUS = 32;
}

var SANDHI_CONN_STRUCT_SIZE = 40;

# ---------------------------------------------------------------
# ALPN runtime — wires the v5.6.40 stdlib hook
# (tls_connect_with_ctx_hook + tls_dlsym).
#
# Advertise list is tied to what the caller can actually speak. The
# default conn-open path is the HTTP/1.1 client, so it advertises
# `http/1.1` only — that way the server can't pick h2 and force a
# protocol mismatch. The (future) h2-aware auto-dispatcher will
# flip _sandhi_alpn_advertise_h2 to 1 around its open call so the
# advertise becomes `h2,http/1.1` when the caller is prepared to
# handle either.
#
# Whatever the server picks lands at SANDHI_CONN_OFF_ALPN_DATA on
# the conn struct. Consumers read it via
# sandhi_conn_alpn_selected / _is_h2 (defined in
# tls_policy/alpn.cyr — registered after this module so those
# accessors can refer to the offset constant defined here).
# ---------------------------------------------------------------

# RFC 7301 §3.1 wire-format ProtocolNameList:
#   "http/1.1"      → 08 'h' 't' 't' 'p' '/' '1' '.' '1'           (9 bytes)
#   "h2,http/1.1"   → 02 'h' '2' 08 'h' 't' 't' 'p' '/' '1' '.' '1' (12 bytes)
# Allocated lazily on first HTTPS connection rather than at module
# init, so plain-HTTP-only consumers don't pay the cost.
var _sandhi_alpn_h11_wire     = 0;
var _sandhi_alpn_h11_wire_len = 9;
var _sandhi_alpn_h2h11_wire   = 0;
var _sandhi_alpn_h2h11_wire_len = 12;

# Toggle: 0 = advertise http/1.1 only (safe default for the 1.1
# client path), 1 = advertise h2,http/1.1 (set by the auto-h2
# dispatcher before opening; cleared after). Single-threaded
# client model, so a module-level flag is sufficient.
var _sandhi_alpn_advertise_h2 = 0;

# 1.3.2 — TLS 1.3 0-RTT opt-in flag. Mirrors the alpn-advertise
# pattern: set to opts.allow_0rtt by the dispatch entry-points
# before any conn-open in the request flow; cleared after the
# request completes. `_sandhi_http_do_impl_a` reads this in its
# eligibility check (along with method-safety, capability,
# session-cache hit). 1.6.9: now the ctx==0 FALLBACK — the buffered
# dispatch threads this value per-call via `_sandhi_reqctx_allow_0rtt`;
# this global is read only by the h2-auto / bare-wrapper paths (which
# stay single-threaded). Same justification as `_sandhi_alpn_advertise_h2`.
var _sandhi_allow_0rtt = 0;

# 1.3.3 — cred-digest threaded through to the session-cache key.
# Set by dispatch entry-points to FNV-1a 64-bit over the request's
# Authorization / Cookie / Proxy-Authorization values (via
# `_sandhi_cred_digest_a` in client.cyr); 0 when no cred-bearing
# headers. Read inside `_sandhi_conn_finalize_with_early_data_a`
# when calling `sandhi_session_cache_lookup` / `_store`. Same
# module-level-flag rationale as `_sandhi_allow_0rtt`. 1.6.9: now the
# ctx==0 FALLBACK — the buffered dispatch threads the cred-digest
# per-call via `_sandhi_reqctx_cred` so concurrent dispatches don't
# cross-wire each other's session-cache keys; only the h2-auto / bare
# paths still read this global (single-threaded).
var _sandhi_cred_digest = 0;

# Hook override mechanism. When non-zero, sandhi_conn_open_fully_timed
# uses these in place of the default ALPN hook. Set by tls_policy/
# apply.cyr around its policy-aware open so the policy hook can
# do trust-store / mTLS layering on top of the SSL_CTX. Cleared by
# the same code immediately after open returns. Single-threaded
# client model — same justification as _sandhi_alpn_advertise_h2.
var _sandhi_tls_hook_override     = 0;  # fn ptr (hook signature) or 0
var _sandhi_tls_hook_override_ctx = 0;  # opaque hook_ctx ptr or 0

# 1.4.6 — pending TLS policy for the in-flight request. Set by the
# dispatch entry-points (client.cyr) to opts.tls_policy; read by
# `_sandhi_http_do_impl_a` at its open site, where it brackets the
# v4/v6 timed open with `_sandhi_policy_pre_open_a` /
# `_sandhi_policy_post_open_a` (tls_policy/apply.cyr — ordered ahead
# of client.cyr / stream.cyr in cyrius.cyml so the helpers are
# reachable; those helpers arm/clear the `_sandhi_tls_hook_override`
# above + run the post-handshake SPKI check). Same module-level-flag
# rationale as `_sandhi_allow_0rtt` / `_sandhi_cred_digest` —
# transient per-request state. 1.6.9: now the ctx==0 FALLBACK — the
# buffered dispatch threads the policy per-call via
# `_sandhi_reqctx_tls_policy`; this global is unused by the dispatch
# path now (the streaming / download paths read the policy straight off
# `opts` and never set this global).
var _sandhi_tls_policy_pending = 0;

# 1.4.2: the ALPN-read libssl binding (SSL_get0_alpn_selected via tls_dlsym +
# the raw SSL* at ctx+8) is GONE — replaced by the stdlib's typed, backend-
# agnostic `tls_get_alpn_selected` verb (cyrius 6.0.82). See
# `_sandhi_alpn_read_selected_a` below.

# Build the per-process ALPN wire buffers. Always allocates from
# `default_alloc()` — these are process-wide singletons read on every
# TLS handshake, so they must outlive any per-request arena.
fn _sandhi_alpn_init_wire(): i64 {
    if (_sandhi_alpn_h11_wire != 0) { return 0; }
    var ga = default_alloc();
    # http/1.1 only:  08 h t t p / 1 . 1
    var h11 = alloc_via(ga, 9);
    store8(h11 + 0, 8);
    store8(h11 + 1, 104);  # 'h'
    store8(h11 + 2, 116);  # 't'
    store8(h11 + 3, 116);  # 't'
    store8(h11 + 4, 112);  # 'p'
    store8(h11 + 5, 47);   # '/'
    store8(h11 + 6, 49);   # '1'
    store8(h11 + 7, 46);   # '.'
    store8(h11 + 8, 49);   # '1'
    _sandhi_alpn_h11_wire = h11;
    # h2,http/1.1:  02 h 2  08 h t t p / 1 . 1
    var both = alloc_via(ga, 12);
    store8(both + 0,  2);
    store8(both + 1,  104);  # 'h'
    store8(both + 2,  50);   # '2'
    store8(both + 3,  8);
    store8(both + 4,  104);  # 'h'
    store8(both + 5,  116);  # 't'
    store8(both + 6,  116);  # 't'
    store8(both + 7,  112);  # 'p'
    store8(both + 8,  47);   # '/'
    store8(both + 9,  49);   # '1'
    store8(both + 10, 46);   # '.'
    store8(both + 11, 49);   # '1'
    _sandhi_alpn_h2h11_wire = both;
    return 0;
}

# Hook fired by stdlib tls_connect_with_ctx_hook on the bare SSL_CTX
# before SSL_new / SSL_connect. hook_ctx points to a pair
# { protos_ptr, protos_len } (16 bytes); ssl_ctx is the SSL_CTX*.
# Returning 0 keeps the connection going; non-zero aborts the
# handshake (stdlib frees the ctx and returns 0 from the wrapper).
#
# 1.3.0: switched from `tls_dlsym("SSL_CTX_set_alpn_protos") +
# fncall3` to stdlib's typed `tls_set_alpn` wrapper (cyrius v5.10.13).
# Removes the libssl-symbol-name binding; if the underlying TLS
# transport ever swaps, sandhi rides the contract not the symbol.
# We tolerate `tls_set_alpn` failure (returns non-zero) — connection
# without ALPN is still useful, same shape as a plain-text fallback.
fn _sandhi_alpn_hook(hook_ctx, ssl_ctx): i64 {
    var protos = load64(hook_ctx);
    var plen   = load64(hook_ctx + 8);
    tls_set_alpn(ssl_ctx, protos, plen);
    return 0;
}

# Post-handshake: extract the negotiated ALPN protocol (if any) and
# return a freshly-alloc'd NUL-terminated cstr. 0 if ALPN didn't
# select anything or the get0 symbol isn't available.
#
# `tls_ctx` is the stdlib tls_connect ctx (24-byte struct: ssl_ctx /
# ssl / sock at offsets 0/8/16). We pull the SSL handle from offset
# 8 and call SSL_get0_alpn_selected(ssl, &out, &outlen). The bytes
# at *out are owned by libssl and freed when SSL is freed, so we
# copy into our own buffer.
# Read the negotiated ALPN protocol into `a`. The two scratch cells
# (out_p / out_l) are short-lived; the returned cstr lives on the
# conn struct, so it inherits the conn's lifetime — when the conn was
# allocated from an arena, the ALPN slot lives in the same arena.
fn _sandhi_alpn_read_selected_a(a, tls_ctx): i64 {
    if (tls_ctx == 0) { return 0; }
    # .82: typed, backend-agnostic ALPN read via the stdlib wrapper verb
    # `tls_get_alpn_selected` — no raw libssl SSL* (load64(ctx+8)) and no
    # tls_dlsym binding. Works on the native TLS backend too.
    var buf = alloc_via(a, 64);
    if (buf == 0) { return 0; }
    var dlen = tls_get_alpn_selected(tls_ctx, buf, 64);
    if (dlen <= 0) { return 0; }
    var copy = alloc_via(a, dlen + 1);
    if (copy == 0) { return 0; }
    var i = 0;
    while (i < dlen) {
        store8(copy + i, load8(buf + i));
        i = i + 1;
    }
    store8(copy + dlen, 0);
    return copy;
}

fn _sandhi_alpn_read_selected(tls_ctx): i64 {
    return _sandhi_alpn_read_selected_a(default_alloc(), tls_ctx);
}

# SO_*TIMEO selector tags. As of 1.6.1 these are NOT wire values — the per-op
# timeout helper composes the stdlib `sock_set_recv_timeout` /
# `sock_set_send_timeout` (which own the per-target SO_*TIMEO opt value +
# struct-timeval layout), so the helper only uses these to pick recv vs send.
# The numeric values happen to be the Linux opt numbers; server/mod.cyr +
# discovery/local.cyr still pass `_SANDHI_SO_RCVTIMEO` as the selector.
var _SANDHI_SO_RCVTIMEO = 20;
var _SANDHI_SO_SNDTIMEO = 21;

# Linux errno for "would block / timed out on socket with SO_RCVTIMEO".
var _SANDHI_EAGAIN = 11;

# 1.6.2: the raw fcntl/poll/getsockopt socket constants
# (`_SANDHI_O_NONBLOCK` / `_SANDHI_EINPROGRESS` / `_SANDHI_SO_ERROR` /
# `_SANDHI_SYS_POLL` / `_SANDHI_SYS_GETSOCKOPT` / `_SANDHI_F_GETFL` /
# `_SANDHI_F_SETFL` / `_SANDHI_POLLOUT`) are GONE. Their last consumers — the
# IPv6 sockaddr nb-connect and the server accept-loop listen socket — now compose
# stdlib's Darwin-correct `net_connect_sa_nb` / `sock_set_nonblocking` (cyrius
# 6.2.10), so no sandhi code hand-rolls the dance against Linux-only flag values
# anymore. This closed the v6/server follow-on to the 1.6.1 macOS connect fix
# (upstream issue 2026-06-15-cyrius-net-v6-darwin.md). Linux-only constants in
# sandhi were a per-target-correctness hazard; deleting them removes the hazard.

# Return sentinels for the nb-connect helpers (and read by the
# open path to classify failures).
var _SANDHI_CONN_NB_OK      = 0;
var _SANDHI_CONN_NB_ERR     = 0 - 1;
var _SANDHI_CONN_NB_TIMEOUT = 0 - 2;

# Classification of the last sandhi_conn_open_* attempt. Module-level
# because Cyrius doesn't expose tagged-union returns and restructuring
# the conn-struct shape would break every caller. As of 1.6.9 this
# global is the ctx==0 FALLBACK only: the buffered dispatch path
# threads a per-call context (the _sandhi_reqctx_* helpers below) so
# concurrent opens on separate OS threads classify their own errors.
# The public conn-open verbs + sandhi_conn_last_open_err() + the
# streaming / download / h2-auto paths still write/read this global
# (single-threaded-correct). See the thoth thread-safety issue.
var _sandhi_conn_last_err = 0;

enum SandhiConnOpenErr {
    SANDHI_CONN_OPEN_OK        = 0;
    SANDHI_CONN_OPEN_CONNECT   = 1;
    SANDHI_CONN_OPEN_TIMEOUT   = 2;
    SANDHI_CONN_OPEN_TLS       = 3;
}

fn sandhi_conn_last_open_err(): i64 {
    return _sandhi_conn_last_err;
}

# ================================================================
# 1.6.9 — per-dispatch request context (client thread-safety)
# ================================================================
# Four module globals above (_sandhi_allow_0rtt / _sandhi_cred_digest
# / _sandhi_tls_policy_pending / _sandhi_conn_last_err) hold transient
# per-request state the buffered client dispatch sets on entry and
# reads deep in the connect path. With one process-wide word each, two
# dispatches on separate OS threads race them — the thoth concurrency
# bite (N parallel `sandhi_http_post_a` workers over `lib/thread.cyr`).
# The buffered dispatch path (`_sandhi_http_dispatch_a`) now allocates
# a small per-call context from the request arena and threads a
# pointer to it through do/follow -> do_impl -> conn-open -> finalize
# (+ the policy pre/post-open helpers in tls_policy/apply.cyr), so that
# path is structurally safe under concurrent dispatch with distinct
# arenas + fresh connections. A `ctx == 0` argument anywhere below
# means "no per-call context" — the single-threaded callers that don't
# thread one (the public conn-open verbs + `sandhi_conn_last_open_err`,
# the streaming / download / h2-auto paths, `sandhi_conn_open_with_policy`)
# fall back to the module globals, which stay correct for any
# single-threaded caller. The hook-override + alpn-advertise globals
# are NOT lifted here — they are only armed on the policy / h2-auto
# paths, which thoth does not drive concurrently (a documented
# follow-on, not part of this bite).
enum SandhiReqCtxOff {
    SANDHI_REQCTX_OFF_ALLOW_0RTT  = 0;
    SANDHI_REQCTX_OFF_CRED_DIGEST = 8;
    SANDHI_REQCTX_OFF_TLS_POLICY  = 16;
    SANDHI_REQCTX_OFF_LAST_ERR    = 24;
}

var SANDHI_REQCTX_SIZE = 32;

# 0-RTT opt-in for this dispatch (ctx==0 -> module global).
fn _sandhi_reqctx_allow_0rtt(ctx): i64 {
    if (ctx == 0) { return _sandhi_allow_0rtt; }
    return load64(ctx + SANDHI_REQCTX_OFF_ALLOW_0RTT);
}

# Credential digest for the session-cache key (ctx==0 -> module global).
fn _sandhi_reqctx_cred(ctx): i64 {
    if (ctx == 0) { return _sandhi_cred_digest; }
    return load64(ctx + SANDHI_REQCTX_OFF_CRED_DIGEST);
}

# Pending TLS policy for this dispatch (ctx==0 -> module global).
fn _sandhi_reqctx_tls_policy(ctx): i64 {
    if (ctx == 0) { return _sandhi_tls_policy_pending; }
    return load64(ctx + SANDHI_REQCTX_OFF_TLS_POLICY);
}

# Read the open-error classification for this dispatch (ctx==0 ->
# module global, i.e. identical to sandhi_conn_last_open_err()).
fn _sandhi_reqctx_err(ctx): i64 {
    if (ctx == 0) { return _sandhi_conn_last_err; }
    return load64(ctx + SANDHI_REQCTX_OFF_LAST_ERR);
}

# Write the open-error classification (ctx==0 -> module global, so the
# public conn verbs + sandhi_conn_last_open_err() keep working).
fn _sandhi_reqctx_set_err(ctx, e): i64 {
    if (ctx == 0) { _sandhi_conn_last_err = e; return 0; }
    store64(ctx + SANDHI_REQCTX_OFF_LAST_ERR, e);
    return 0;
}

fn sandhi_conn_kind(c): i64 { return load64(c + SANDHI_CONN_OFF_KIND); }
fn sandhi_conn_fd(c): i64 { return load64(c + SANDHI_CONN_OFF_FD); }
fn sandhi_conn_tls_ctx(c): i64 { return load64(c + SANDHI_CONN_OFF_TLS_CTX); }

# 1.3.2 — 0-RTT acceptance status. Returns one of:
#   TLS_EARLY_DATA_NOT_SENT (0) — no 0-RTT attempted, OR conn is
#                                 plain HTTP, OR pool reuse
#   TLS_EARLY_DATA_REJECTED (1) — server rejected; exchange path
#                                 must resend via `tls_write`
#   TLS_EARLY_DATA_ACCEPTED (2) — server accepted; exchange path
#                                 skips send, jumps to recv
fn sandhi_conn_0rtt_status(c): i64 {
    if (c == 0) { return 0; }
    return load64(c + SANDHI_CONN_OFF_0RTT_STATUS);
}

# Set SO_RCVTIMEO (opt == _SANDHI_SO_RCVTIMEO) or SO_SNDTIMEO
# (_SANDHI_SO_SNDTIMEO) to `ms` milliseconds. ms<=0 is a no-op.
#
# 1.6.1: composes the stdlib `sock_set_recv_timeout` / `sock_set_send_timeout`
# instead of building the `struct timeval` + `setsockopt` by hand. stdlib owns
# the per-target detail this code got wrong on Darwin — the SO_*TIMEO opt value
# (Linux 20/21 vs Darwin 0x1006/0x1005) and the Darwin `tv_usec` being 32-bit
# (a 64-bit write spilled past the field) — plus the agnos no-op. sandhi only
# splits ms into secs/usecs and picks recv vs send (ADR 0001 — compose, don't
# reimplement). `opt` is now an opaque recv/send selector, not a wire value, so
# `a` is unused (kept for caller-signature stability). Closes the SO_RCVTIMEO
# half of docs/issues/2026-06-06-macos-nonblocking-connect.md.
fn _sandhi_conn_set_timeout_ms_a(a, fd, ms, opt): i64 {
    if (ms <= 0) { return 0; }
    var sec = ms / 1000;
    var usec = (ms - sec * 1000) * 1000;
    if (opt == _SANDHI_SO_SNDTIMEO) {
        return sock_set_send_timeout(fd, sec, usec);
    }
    return sock_set_recv_timeout(fd, sec, usec);
}

fn _sandhi_conn_set_timeout_ms(fd, ms, opt): i64 {
    return _sandhi_conn_set_timeout_ms_a(default_alloc(), fd, ms, opt);
}

# Open a connection to the given IPv4 address (network-byte-order
# uint32 from sandhi_resolve_ipv4 or a hand-built literal) and port.
# If use_tls == 1, wrap the socket via tls_connect using sni_host for
# SNI + peer verification. Returns the conn struct on success, 0 on
# any failure path (socket create, connect, TLS handshake).
#
# `addr` is the same shape net.cyr expects: a 32-bit big-endian IPv4
# address packed as an int (e.g. 127.0.0.1 → 0x0100007F on little-
# endian hosts per INADDR_LOOPBACK).
# Non-blocking connect with poll-based timeout: puts the fd in
# O_NONBLOCK, fires connect (expects EINPROGRESS), polls for POLLOUT
# up to timeout_ms, reads SO_ERROR to distinguish connected from
# refused, then restores blocking mode. Leaves the fd in blocking
# mode on every exit path so subsequent recv/send behave normally.
#
# Factoring (1.4.4 → reversed at 1.6.1): this nb-connect dance was kept
# duplicated rather than sharing cyrius's `net_connect_nb` on the
# rationale that connect runs once per conn-open so a shared primitive
# "would not measure". That traded a non-benefit for a real correctness
# bug — the sandhi copy hardcoded Linux constants and broke on macOS
# (Mach-O). 1.6.1 composes `net_connect_nb` (Darwin-correct + agnos-
# guarded); the duplicate is gone (ADR 0001 — compose, don't reimplement).
#
# Returns (the stdlib `_NET_CONN_NB_*` sentinels, which alias these
# one-for-one):
#   _SANDHI_CONN_NB_OK      (0)  — connected
#   _SANDHI_CONN_NB_TIMEOUT (-2) — poll timed out waiting for completion
#   _SANDHI_CONN_NB_ERR     (-1) — any other failure (fcntl, immediate
#                                  connect err, SO_ERROR non-zero)
fn _sandhi_conn_connect_nb_a(a, fd, addr, port, timeout_ms): i64 {
    # 1.6.1: compose the stdlib `net_connect_nb` rather than re-running the
    # fcntl/poll/getsockopt dance against sandhi's Linux-only constants. stdlib
    # carries the platform-branched O_NONBLOCK / EINPROGRESS / SOL_SOCKET /
    # SO_ERROR (`_NET_O_NONBLOCK` / `_NET_EINPROGRESS` / `SockOpt`) and the agnos
    # blocking-connect fallback, so this path is now correct on macOS (Mach-O),
    # where the old `_SANDHI_O_NONBLOCK=0x800` / `_SANDHI_EINPROGRESS=115` set
    # the wrong flag and misread the connect-in-progress errno as a hard failure
    # → spurious SANDHI_ERR_CONNECT. The stdlib sentinels
    # (_NET_CONN_NB_OK/_TIMEOUT/_ERR = 0/-2/-1) match sandhi's _SANDHI_CONN_NB_*
    # one-for-one, so the open path's classification is unchanged. This retires
    # sandhi's duplicate of the nb-connect machinery (ADR 0001 — compose, don't
    # reimplement); `a` is now unused (net_connect_nb builds its sockaddr on the
    # stack). Closes the v4 half of docs/issues/2026-06-06-macos-nonblocking-connect.md.
    return net_connect_nb(fd, addr, port, timeout_ms);
}

fn _sandhi_conn_connect_nb(fd, addr, port, timeout_ms): i64 {
    return _sandhi_conn_connect_nb_a(default_alloc(), fd, addr, port, timeout_ms);
}

fn sandhi_conn_open_a(a, addr, port, use_tls, sni_host): i64 {
    return sandhi_conn_open_timed_a(a, addr, port, use_tls, sni_host, 0, 0);
}

fn sandhi_conn_open(addr, port, use_tls, sni_host): i64 {
    return sandhi_conn_open_a(default_alloc(), addr, port, use_tls, sni_host);
}

# Open a connection with per-operation timeouts. read_ms and write_ms
# apply to subsequent recv/send via SO_RCVTIMEO/SO_SNDTIMEO; 0 means
# blocking (kernel default). connect() itself is blocking (kernel
# default; can take up to ~75 s on a dropped-SYN blackhole). For a
# bounded connect, use sandhi_conn_open_fully_timed with connect_ms.
#
# On a timeout during recv/send, the underlying syscall returns
# EAGAIN (-11). sandhi_conn_recv/send convert that to -_SANDHI_EAGAIN
# so callers can distinguish "connection broke" from "deadline fired".
fn sandhi_conn_open_timed_a(a, addr, port, use_tls, sni_host, read_ms, write_ms): i64 {
    return sandhi_conn_open_fully_timed_a(a, addr, port, use_tls, sni_host, 0, read_ms, write_ms);
}

fn sandhi_conn_open_timed(addr, port, use_tls, sni_host, read_ms, write_ms): i64 {
    return sandhi_conn_open_timed_a(default_alloc(), addr, port, use_tls, sni_host, read_ms, write_ms);
}

# Open with connect + r/w timeouts (0.7.3). connect_ms=0 means blocking
# connect (pre-0.7.3 behavior). connect_ms>0 uses _sandhi_conn_connect_nb.
# On failure, `sandhi_conn_last_open_err()` returns the classification
# (SANDHI_CONN_OPEN_CONNECT / _TIMEOUT / _TLS) so callers can raise
# the right SANDHI_ERR_*.
# 1.6.2: sandhi's hand-rolled IPv6 sockaddr builder + generic sockaddr
# nb-connect were RETIRED here — the v6 open paths now compose stdlib's
# Darwin-correct `sockaddr_in6` + `net_connect_sa_nb` directly (cyrius 6.2.10,
# which shipped the v6-on-Darwin surface that blocked this — see the upstream
# issue 2026-06-15-cyrius-net-v6-darwin.md). This is the v6 half of the macOS
# port whose v4 half landed at 1.6.1; ADR 0001 (compose, don't reimplement).

# Post-connect plumbing: SO_RCVTIMEO/SO_SNDTIMEO, TLS handshake with
# the policy/ALPN hook, ALPN slot population, conn struct alloc.
# Shared between the v4 and v6 open paths.
# Finalize a connected fd into a sandhi_conn struct allocated from `a`.
# The conn struct's lifetime matches `a` — long-lived pool conns want
# default_alloc; per-request one-shots can use an arena. The hook ctx
# (16 bytes for the ALPN hook) and the ALPN-selected cstr also live
# in `a`. The wire literals themselves are process-wide singletons
# (see _sandhi_alpn_init_wire).
#
# 1.6.9: `ctx` is the per-call request context (or 0 for the legacy
# module-global path) — the cred-digest for the session-cache key and
# the open-error classification ride it via the _sandhi_reqctx_*
# helpers, so concurrent dispatches don't share those words.
fn _sandhi_conn_finalize_with_early_data_a(a, fd, use_tls, sni_host,
read_ms, write_ms, early_data, early_data_len, ctx): i64 {
    if (read_ms > 0)  { _sandhi_conn_set_timeout_ms_a(a, fd, read_ms,  _SANDHI_SO_RCVTIMEO); }
    if (write_ms > 0) { _sandhi_conn_set_timeout_ms_a(a, fd, write_ms, _SANDHI_SO_SNDTIMEO); }

    var tls_ctx = 0;
    var kind = SANDHI_CONN_PLAIN;
    var alpn_data = 0;
    var early_data_status = 0;  # TLS_EARLY_DATA_NOT_SENT
    if (use_tls == 1) {
        if (tls_available() == 0) {
            sock_close(fd);
            _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TLS);
            return 0;
        }
        var hook_fp = 0;
        var hook_ctx = 0;
        if (_sandhi_tls_hook_override != 0) {
            hook_fp  = _sandhi_tls_hook_override;
            hook_ctx = _sandhi_tls_hook_override_ctx;
        } else {
            _sandhi_alpn_init_wire();
            hook_ctx = alloc_via(a, 16);
            if (hook_ctx == 0) {
                sock_close(fd);
                _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TLS);
                return 0;
            }
            if (_sandhi_alpn_advertise_h2 == 1) {
                store64(hook_ctx,     _sandhi_alpn_h2h11_wire);
                store64(hook_ctx + 8, _sandhi_alpn_h2h11_wire_len);
            } else {
                store64(hook_ctx,     _sandhi_alpn_h11_wire);
                store64(hook_ctx + 8, _sandhi_alpn_h11_wire_len);
            }
            hook_fp = &_sandhi_alpn_hook;
        }
        # 1.3.1 staged-connect with session-resumption hook.
        # When `sandhi_session_cache_enable(1)` is set AND the
        # cache has a session for (sni_host, hook_fp), we install
        # it pre-`SSL_connect` via `tls_set_session` to attempt
        # resumption. Post-handshake we capture a fresh session
        # via `tls_get_session` for the next request.
        # When the cache is disabled, lookup returns 0 and store
        # is a no-op — the path collapses to one-shot connect
        # with one extra global-load per call.
        tls_ctx = tls_connect_alloc(fd, sni_host, hook_fp, hook_ctx);
        if (tls_ctx == 0) {
            sock_close(fd);
            _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TLS);
            return 0;
        }
        var cached_sess = sandhi_session_cache_lookup(sni_host, hook_fp, _sandhi_reqctx_cred(ctx));
        if (cached_sess != 0) {
            tls_set_session(tls_ctx, cached_sess);
        }
        # 1.3.2 — 0-RTT write between session-set and handshake-
        # complete. Caller already gated `early_data` non-zero
        # on capability + method-safety + session-presence; here
        # we only need the per-session-size check
        # (`tls_session_get_max_early_data` against actual req
        # length). Skip 0-RTT silently if the session doesn't
        # advertise enough budget. tls_write_early_data return
        # value is informational — definitive accepted/rejected
        # signal comes post-handshake from
        # `tls_get_early_data_status`.
        if (early_data != 0 && early_data_len > 0 && cached_sess != 0) {
            var max_early = tls_session_get_max_early_data(cached_sess);
            if (max_early >= early_data_len) {
                tls_write_early_data(tls_ctx, early_data, early_data_len);
            }
        }
        if (tls_connect_complete(tls_ctx) != 1) {
            tls_close(tls_ctx);
            sock_close(fd);
            _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TLS);
            return 0;
        }
        # Post-handshake early-data status — drives the
        # exchange path's send-or-skip decision.
        early_data_status = tls_get_early_data_status(tls_ctx);
        # Capture session for next time — ONLY when the cache is enabled.
        # tls_get_session bumps the SSL_SESSION refcount and hands us an
        # owned ref; the cache takes ownership via _store. When the cache
        # is OFF (the default), _store is a no-op that never frees, so an
        # unconditional capture here leaks one SSL_SESSION per connection
        # on the libssl backend. Gate the whole capture on enabled. [1.4.5]
        if (sandhi_session_cache_enabled() == 1) {
            var fresh_sess = tls_get_session(tls_ctx);
            if (fresh_sess != 0) {
                sandhi_session_cache_store(sni_host, hook_fp, _sandhi_reqctx_cred(ctx), fresh_sess);
            }
        }
        alpn_data = _sandhi_alpn_read_selected_a(a, tls_ctx);
        kind = SANDHI_CONN_TLS;
    }

    var conn = alloc_via(a, SANDHI_CONN_STRUCT_SIZE);
    if (conn == 0) {
        if (tls_ctx != 0) { tls_close(tls_ctx); }
        sock_close(fd);
        _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TLS);
        return 0;
    }
    store64(conn + SANDHI_CONN_OFF_KIND, kind);
    store64(conn + SANDHI_CONN_OFF_FD, fd);
    store64(conn + SANDHI_CONN_OFF_TLS_CTX, tls_ctx);
    store64(conn + SANDHI_CONN_OFF_ALPN_DATA, alpn_data);
    store64(conn + SANDHI_CONN_OFF_0RTT_STATUS, early_data_status);
    return conn;
}

# Back-compat wrapper — pre-1.3.2 callers don't pass early-data; ctx=0
# routes cred-digest + open-error through the module globals.
fn _sandhi_conn_finalize_a(a, fd, use_tls, sni_host, read_ms, write_ms): i64 {
    return _sandhi_conn_finalize_with_early_data_a(a, fd, use_tls, sni_host,
    read_ms, write_ms, 0, 0, 0);
}

fn _sandhi_conn_finalize(fd, use_tls, sni_host, read_ms, write_ms): i64 {
    return _sandhi_conn_finalize_a(default_alloc(), fd, use_tls, sni_host, read_ms, write_ms);
}

# Open an IPv6 connection. Internal-only — sandhi's public surface
# (frozen at 0.9.2 per ADR 0005) stays IPv4-named but the http
# client tries v6 fallback through this path. `addr16` is a
# 16-byte network-byte-order AAAA address buffer (e.g. from
# sandhi_resolve_ipv6).
fn _sandhi_conn_open_v6_fully_timed_a(a, addr16, port, use_tls, sni_host, connect_ms, read_ms, write_ms, ctx): i64 {
    #ifdef CYRIUS_TARGET_AGNOS
    # AGNOS is IPv4-only today (no AF_INET6 socket surface; SYS_SOCKET /
    # SYS_CONNECT undefined on the agnos target). Fail the v6 path cleanly so
    # the client falls back to the v4 path. Revisit when agnos gains AF_INET6.
    _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
    return 0;
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_OK);
    if (addr16 == 0) {
        _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
        return 0;
    }
    var fd = syscall(SYS_SOCKET, AF_INET6, 1, 0);  # per-target AF_INET6 (Linux 10 / Darwin 30), SOCK_STREAM
    if (fd < 0) {
        _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
        return 0;
    }
    # 1.6.2: compose stdlib's Darwin-correct sockaddr_in6 builder + generic
    # sockaddr nb-connect (cyrius 6.2.10) instead of sandhi's retired hand-rolled
    # versions, which hardcoded the Linux AF_INET6 (=10, vs Darwin 30), omitted the
    # BSD sin6_len byte, and ran the fcntl/poll dance against Linux-only flag/opt
    # values. `net_connect_sa_nb` returns the `_NET_CONN_NB_*` sentinels, which
    # alias `_SANDHI_CONN_NB_*` one-for-one.
    var sa = sockaddr_in6(addr16, port);
    if (sa == 0) {
        sock_close(fd); _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT); return 0;
    }
    if (connect_ms > 0) {
        var nbr = net_connect_sa_nb(fd, sa, 28, connect_ms);
        if (nbr == _SANDHI_CONN_NB_TIMEOUT) {
            sock_close(fd); _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TIMEOUT); return 0;
        }
        if (nbr != _SANDHI_CONN_NB_OK) {
            sock_close(fd); _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT); return 0;
        }
    } else {
        var rc = syscall(SYS_CONNECT, fd, sa, 28);
        if (rc < 0) {
            sock_close(fd); _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT); return 0;
        }
    }
    return _sandhi_conn_finalize_with_early_data_a(a, fd, use_tls, sni_host, read_ms, write_ms, 0, 0, ctx);
    #endif
}

fn _sandhi_conn_open_v6_fully_timed(addr16, port, use_tls, sni_host, connect_ms, read_ms, write_ms): i64 {
    return _sandhi_conn_open_v6_fully_timed_a(
    default_alloc(), addr16, port, use_tls, sni_host,
    connect_ms, read_ms, write_ms, 0);
}

# 1.3.2 — v6 variant of the early-data-aware open path.
fn _sandhi_conn_open_v6_fully_timed_with_early_data_a(a, addr16, port,
use_tls, sni_host, connect_ms, read_ms, write_ms, early_data, early_data_len, ctx): i64 {
    #ifdef CYRIUS_TARGET_AGNOS
    # AGNOS is IPv4-only today (no AF_INET6; SYS_SOCKET / SYS_CONNECT undefined).
    # Fail the v6 early-data path cleanly; the client falls back to v4.
    _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
    return 0;
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_OK);
    if (addr16 == 0) {
        _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
        return 0;
    }
    var fd = syscall(SYS_SOCKET, AF_INET6, 1, 0);  # per-target AF_INET6 (Linux 10 / Darwin 30), SOCK_STREAM
    if (fd < 0) {
        _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
        return 0;
    }
    # 1.6.2: compose stdlib's Darwin-correct sockaddr_in6 builder + generic
    # sockaddr nb-connect (cyrius 6.2.10) instead of sandhi's retired hand-rolled
    # versions, which hardcoded the Linux AF_INET6 (=10, vs Darwin 30), omitted the
    # BSD sin6_len byte, and ran the fcntl/poll dance against Linux-only flag/opt
    # values. `net_connect_sa_nb` returns the `_NET_CONN_NB_*` sentinels, which
    # alias `_SANDHI_CONN_NB_*` one-for-one.
    var sa = sockaddr_in6(addr16, port);
    if (sa == 0) {
        sock_close(fd); _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT); return 0;
    }
    if (connect_ms > 0) {
        var nbr = net_connect_sa_nb(fd, sa, 28, connect_ms);
        if (nbr == _SANDHI_CONN_NB_TIMEOUT) {
            sock_close(fd); _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TIMEOUT); return 0;
        }
        if (nbr != _SANDHI_CONN_NB_OK) {
            sock_close(fd); _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT); return 0;
        }
    } else {
        var rc = syscall(SYS_CONNECT, fd, sa, 28);
        if (rc < 0) {
            sock_close(fd); _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT); return 0;
        }
    }
    return _sandhi_conn_finalize_with_early_data_a(a, fd, use_tls, sni_host,
    read_ms, write_ms, early_data, early_data_len, ctx);
    #endif
}

# Public v4 timed open — back-compat wrapper. ctx=0 routes the
# open-error classification through the module global, so external
# callers (stream / download / h2-auto + sandhi_conn_last_open_err)
# are byte-identical to pre-1.6.9.
fn sandhi_conn_open_fully_timed_a(a, addr, port, use_tls, sni_host, connect_ms, read_ms, write_ms): i64 {
    return _sandhi_conn_open_fully_timed_ctx_a(a, addr, port, use_tls, sni_host,
    connect_ms, read_ms, write_ms, 0);
}

# 1.6.9 — ctx-threading v4 timed open. Internal: the buffered dispatch
# (`_sandhi_http_do_impl_a`) calls this directly with its per-call
# context so concurrent opens classify their own errors; the public
# wrapper above passes ctx=0 (module-global classification).
fn _sandhi_conn_open_fully_timed_ctx_a(a, addr, port, use_tls, sni_host, connect_ms, read_ms, write_ms, ctx): i64 {
    _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_OK);

    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) {
        _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
        return 0;
    }
    var fd = payload(sfd_r);

    if (connect_ms > 0) {
        var nbr = _sandhi_conn_connect_nb_a(a, fd, addr, port, connect_ms);
        if (nbr == _SANDHI_CONN_NB_TIMEOUT) {
            sock_close(fd);
            _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TIMEOUT);
            return 0;
        }
        if (nbr != _SANDHI_CONN_NB_OK) {
            sock_close(fd);
            _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
            return 0;
        }
    } else {
        var cr = sock_connect(fd, addr, port);
        if (is_err_result(cr) == 1) {
            sock_close(fd);
            _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
            return 0;
        }
    }

    return _sandhi_conn_finalize_with_early_data_a(a, fd, use_tls, sni_host, read_ms, write_ms, 0, 0, ctx);
}

fn sandhi_conn_open_fully_timed(addr, port, use_tls, sni_host, connect_ms, read_ms, write_ms): i64 {
    return sandhi_conn_open_fully_timed_a(
    default_alloc(), addr, port, use_tls, sni_host,
    connect_ms, read_ms, write_ms);
}

# 1.3.2 — open with early-data attached. Internal-only; the public
# `sandhi_conn_open_fully_timed_a` stays unchanged. Caller
# (`_sandhi_http_do_impl_a`) pre-checks 0-RTT eligibility
# (allow_0rtt opt + method safety + capability + session present);
# this fn just plumbs early_data + early_data_len through to
# `_sandhi_conn_finalize_with_early_data_a`. The actual size-fit
# check (`tls_session_get_max_early_data >= len`) happens inside
# finalize against the cached session.
fn _sandhi_conn_open_fully_timed_with_early_data_a(a, addr, port, use_tls,
sni_host, connect_ms, read_ms, write_ms, early_data, early_data_len, ctx): i64 {
    _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_OK);

    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) {
        _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
        return 0;
    }
    var fd = payload(sfd_r);

    if (connect_ms > 0) {
        var nbr = _sandhi_conn_connect_nb_a(a, fd, addr, port, connect_ms);
        if (nbr == _SANDHI_CONN_NB_TIMEOUT) {
            sock_close(fd);
            _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TIMEOUT);
            return 0;
        }
        if (nbr != _SANDHI_CONN_NB_OK) {
            sock_close(fd);
            _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
            return 0;
        }
    } else {
        var cr = sock_connect(fd, addr, port);
        if (is_err_result(cr) == 1) {
            sock_close(fd);
            _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_CONNECT);
            return 0;
        }
    }

    return _sandhi_conn_finalize_with_early_data_a(a, fd, use_tls, sni_host,
    read_ms, write_ms, early_data, early_data_len, ctx);
}

# Send `len` bytes through the connection. Returns bytes sent, 0 on
# peer-close, or a negative errno on error. Specifically returns
# `0 - _SANDHI_EAGAIN` when SO_SNDTIMEO fires — callers map to
# SANDHI_ERR_TIMEOUT. Any other negative is a CONNECT-class error.
# Full write not guaranteed — caller loops on partial.
fn sandhi_conn_send(conn, buf, len): i64 {
    if (conn == 0) { return 0 - 1; }
    if (sandhi_conn_kind(conn) == SANDHI_CONN_TLS) {
        # tls_write returns negative on error (pre-libssl-pthread-fix
        # we can't reach here anyway); passthrough keeps contract.
        return tls_write(sandhi_conn_tls_ctx(conn), buf, len);
    }
    var r = sock_send(sandhi_conn_fd(conn), buf, len);
    if (is_err_result(r) == 1) { return 0 - payload(r); }
    return payload(r);
}

# Send a full cstr. Loops on partial writes. Returns 0 on success,
# `0 - _SANDHI_EAGAIN` on send-timeout, -1 on any other failure.
fn sandhi_conn_send_all(conn, buf, len): i64 {
    var sent = 0;
    while (sent < len) {
        var n = sandhi_conn_send(conn, buf + sent, len - sent);
        if (n == 0 - _SANDHI_EAGAIN) { return 0 - _SANDHI_EAGAIN; }
        if (n <= 0) { return 0 - 1; }
        sent = sent + n;
    }
    return 0;
}

# Receive up to `max` bytes. Returns bytes read, 0 at EOF, or a
# negative errno on error. `0 - _SANDHI_EAGAIN` signals a read
# timeout (SO_RCVTIMEO fired); callers treat other negatives as
# CONNECT-class.
fn sandhi_conn_recv(conn, buf, max): i64 {
    if (conn == 0) { return 0 - 1; }
    if (sandhi_conn_kind(conn) == SANDHI_CONN_TLS) {
        var tr = tls_read(sandhi_conn_tls_ctx(conn), buf, max);
        if (tr < 0) { return 0 - 1; }
        return tr;
    }
    var r = sock_recv(sandhi_conn_fd(conn), buf, max);
    if (is_err_result(r) == 1) { return 0 - payload(r); }
    return payload(r);
}

# Drain the connection into `buf` up to `max` bytes. Reads until EOF or
# max reached. Returns total bytes read on success; `0 - _SANDHI_EAGAIN`
# if read-timeout fires; `0 - 1` for any other error. Always null-
# terminates buf at the returned length (buf must have room for max+1).
fn sandhi_conn_recv_all(conn, buf, max): i64 {
    return sandhi_conn_recv_all_deadline(conn, buf, max, 0);
}

# Same as sandhi_conn_recv_all but bounded by a monotonic deadline
# (clock_now_ms() value; 0 = no deadline). Added 0.7.3 for total_ms
# enforcement — each iteration of the read loop checks the deadline
# before the next recv and returns -_SANDHI_EAGAIN if it's passed.
# SO_RCVTIMEO still bounds individual recv calls; the deadline is
# the outer ceiling.
fn sandhi_conn_recv_all_deadline(conn, buf, max, deadline_ms): i64 {
    var have = 0;
    var going = 1;
    while (going == 1 && have < max) {
        if (deadline_ms > 0) {
            if (clock_now_ms() >= deadline_ms) {
                store8(buf + have, 0);
                return 0 - _SANDHI_EAGAIN;
            }
        }
        var n = sandhi_conn_recv(conn, buf + have, max - have);
        if (n == 0 - _SANDHI_EAGAIN) { return 0 - _SANDHI_EAGAIN; }
        if (n < 0) { return 0 - 1; }
        if (n == 0) { going = 0; }
        else { have = have + n; }
    }
    store8(buf + have, 0);
    return have;
}

# Close the connection. Shuts TLS cleanly, closes the fd. No-op on 0.
fn sandhi_conn_close(conn): i64 {
    if (conn == 0) { return 0; }
    if (sandhi_conn_kind(conn) == SANDHI_CONN_TLS) {
        tls_close(sandhi_conn_tls_ctx(conn));
    }
    sock_close(sandhi_conn_fd(conn));
    return 0;
}

# --- policy.cyr ---

# sandhi/tls_policy/policy — policy struct + constructors.
#
# A TLS policy carries declarative intent that the connection layer
# applies at handshake time: pin to a specific SPKI hash, present an
# mTLS client certificate, override the system trust store.
#
# Policies are additive — `sandhi_tls_policy_combine(a, b)` merges
# two policies so callers can compose pinning + mTLS + custom CA
# without a combinatorial explosion of constructors.
#
# Struct layout (48 bytes):
#   +0   flags              (bitmask: PINNED | MTLS | CUSTOM_TRUST)
#   +8   pinned_spki_hex    (cstr — SHA-256 hex of Subject Public Key Info, or 0)
#   +16  mtls_cert_path     (cstr — PEM cert path, or 0)
#   +24  mtls_key_path      (cstr — PEM key path, or 0)
#   +32  trust_store_path   (cstr — CA bundle file, or 0 for system default)
#   +40  reserved           (future: verify callback fn ptr or flags)

enum SandhiTlsPolicyFlag {
    SANDHI_TLS_POLICY_DEFAULT      = 0;
    SANDHI_TLS_POLICY_PINNED       = 1;
    SANDHI_TLS_POLICY_MTLS         = 2;
    SANDHI_TLS_POLICY_CUSTOM_TRUST = 4;
}

enum SandhiTlsPolicyOff {
    SANDHI_TLS_POLICY_OFF_FLAGS       = 0;
    SANDHI_TLS_POLICY_OFF_PINNED      = 8;
    SANDHI_TLS_POLICY_OFF_MTLS_CERT   = 16;
    SANDHI_TLS_POLICY_OFF_MTLS_KEY    = 24;
    SANDHI_TLS_POLICY_OFF_TRUST_STORE = 32;
    SANDHI_TLS_POLICY_OFF_RESERVED    = 40;
}

var SANDHI_TLS_POLICY_STRUCT_SIZE = 48;

fn _sandhi_tls_policy_dup_a(a, s): i64 {
    if (s == 0) { return 0; }
    var n = strlen(s);
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, s, n);
    store8(out + n, 0);
    return out;
}

fn _sandhi_tls_policy_dup(s): i64 {
    return _sandhi_tls_policy_dup_a(default_alloc(), s);
}

fn _sandhi_tls_policy_empty_a(a): i64 {
    var p = alloc_via(a, SANDHI_TLS_POLICY_STRUCT_SIZE);
    if (p == 0) { return 0; }
    store64(p + SANDHI_TLS_POLICY_OFF_FLAGS, 0);
    store64(p + SANDHI_TLS_POLICY_OFF_PINNED, 0);
    store64(p + SANDHI_TLS_POLICY_OFF_MTLS_CERT, 0);
    store64(p + SANDHI_TLS_POLICY_OFF_MTLS_KEY, 0);
    store64(p + SANDHI_TLS_POLICY_OFF_TRUST_STORE, 0);
    store64(p + SANDHI_TLS_POLICY_OFF_RESERVED, 0);
    return p;
}

fn _sandhi_tls_policy_empty(): i64 {
    return _sandhi_tls_policy_empty_a(default_alloc());
}

# ================================================================
# Constructors
# ================================================================

# Default policy allocated from `a`. Returns 0 on OOM.
fn sandhi_tls_policy_new_default_a(a): i64 {
    return _sandhi_tls_policy_empty_a(a);
}

fn sandhi_tls_policy_new_default(): i64 {
    return sandhi_tls_policy_new_default_a(default_alloc());
}

# Pinned policy allocated from `a`. The caller-supplied hex is dup'd
# into `a` so the policy is self-contained against arena reset.
fn sandhi_tls_policy_new_pinned_a(a, spki_hex): i64 {
    var p = _sandhi_tls_policy_empty_a(a);
    if (p == 0) { return 0; }
    store64(p + SANDHI_TLS_POLICY_OFF_FLAGS, SANDHI_TLS_POLICY_PINNED);
    store64(p + SANDHI_TLS_POLICY_OFF_PINNED, _sandhi_tls_policy_dup_a(a, spki_hex));
    return p;
}

fn sandhi_tls_policy_new_pinned(spki_hex): i64 {
    return sandhi_tls_policy_new_pinned_a(default_alloc(), spki_hex);
}

# mTLS policy allocated from `a`. Cert + key paths are dup'd into `a`.
fn sandhi_tls_policy_new_mtls_a(a, cert_path, key_path): i64 {
    var p = _sandhi_tls_policy_empty_a(a);
    if (p == 0) { return 0; }
    store64(p + SANDHI_TLS_POLICY_OFF_FLAGS, SANDHI_TLS_POLICY_MTLS);
    store64(p + SANDHI_TLS_POLICY_OFF_MTLS_CERT, _sandhi_tls_policy_dup_a(a, cert_path));
    store64(p + SANDHI_TLS_POLICY_OFF_MTLS_KEY, _sandhi_tls_policy_dup_a(a, key_path));
    return p;
}

fn sandhi_tls_policy_new_mtls(cert_path, key_path): i64 {
    return sandhi_tls_policy_new_mtls_a(default_alloc(), cert_path, key_path);
}

# Trust-store-override policy allocated from `a`.
fn sandhi_tls_policy_new_trust_store_a(a, bundle_path): i64 {
    var p = _sandhi_tls_policy_empty_a(a);
    if (p == 0) { return 0; }
    store64(p + SANDHI_TLS_POLICY_OFF_FLAGS, SANDHI_TLS_POLICY_CUSTOM_TRUST);
    store64(p + SANDHI_TLS_POLICY_OFF_TRUST_STORE, _sandhi_tls_policy_dup_a(a, bundle_path));
    return p;
}

fn sandhi_tls_policy_new_trust_store(bundle_path): i64 {
    return sandhi_tls_policy_new_trust_store_a(default_alloc(), bundle_path);
}

# ================================================================
# Combine — merge two policies into one.
# ================================================================
#
# Right-hand fields win where present; falls back to left-hand
# otherwise. Flags OR together. Lets callers build up:
#   var p = sandhi_tls_policy_combine(
#               sandhi_tls_policy_new_pinned(fp),
#               sandhi_tls_policy_new_mtls(cert, key));

# Combine two policies into a fresh struct allocated from `alloc`.
# Right-hand fields win; left-hand fills the gaps. Field cstrs are
# NOT re-dup'd — the resulting struct shares string ownership with
# its inputs (caller must keep them alive). Returns 0 on OOM.
fn sandhi_tls_policy_combine_a(alloc, a, b): i64 {
    if (a == 0) { return b; }
    if (b == 0) { return a; }
    var out = _sandhi_tls_policy_empty_a(alloc);
    if (out == 0) { return 0; }
    var fa = load64(a + SANDHI_TLS_POLICY_OFF_FLAGS);
    var fb = load64(b + SANDHI_TLS_POLICY_OFF_FLAGS);
    store64(out + SANDHI_TLS_POLICY_OFF_FLAGS, fa | fb);

    var pin_a = load64(a + SANDHI_TLS_POLICY_OFF_PINNED);
    var pin_b = load64(b + SANDHI_TLS_POLICY_OFF_PINNED);
    if (pin_b != 0) { store64(out + SANDHI_TLS_POLICY_OFF_PINNED, pin_b); }
    else            { store64(out + SANDHI_TLS_POLICY_OFF_PINNED, pin_a); }

    var cert_a = load64(a + SANDHI_TLS_POLICY_OFF_MTLS_CERT);
    var cert_b = load64(b + SANDHI_TLS_POLICY_OFF_MTLS_CERT);
    if (cert_b != 0) { store64(out + SANDHI_TLS_POLICY_OFF_MTLS_CERT, cert_b); }
    else             { store64(out + SANDHI_TLS_POLICY_OFF_MTLS_CERT, cert_a); }

    var key_a = load64(a + SANDHI_TLS_POLICY_OFF_MTLS_KEY);
    var key_b = load64(b + SANDHI_TLS_POLICY_OFF_MTLS_KEY);
    if (key_b != 0) { store64(out + SANDHI_TLS_POLICY_OFF_MTLS_KEY, key_b); }
    else            { store64(out + SANDHI_TLS_POLICY_OFF_MTLS_KEY, key_a); }

    var trust_a = load64(a + SANDHI_TLS_POLICY_OFF_TRUST_STORE);
    var trust_b = load64(b + SANDHI_TLS_POLICY_OFF_TRUST_STORE);
    if (trust_b != 0) { store64(out + SANDHI_TLS_POLICY_OFF_TRUST_STORE, trust_b); }
    else              { store64(out + SANDHI_TLS_POLICY_OFF_TRUST_STORE, trust_a); }

    return out;
}

fn sandhi_tls_policy_combine(a, b): i64 {
    return sandhi_tls_policy_combine_a(default_alloc(), a, b);
}

# ================================================================
# Accessors
# ================================================================

fn sandhi_tls_policy_flags(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_TLS_POLICY_OFF_FLAGS);
}

fn sandhi_tls_policy_pinned_hash(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_TLS_POLICY_OFF_PINNED);
}

fn sandhi_tls_policy_mtls_cert(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_TLS_POLICY_OFF_MTLS_CERT);
}

fn sandhi_tls_policy_mtls_key(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_TLS_POLICY_OFF_MTLS_KEY);
}

fn sandhi_tls_policy_trust_store(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_TLS_POLICY_OFF_TRUST_STORE);
}

fn sandhi_tls_policy_has_flag(p, flag): i64 {
    if (p == 0) { return 0; }
    var f = load64(p + SANDHI_TLS_POLICY_OFF_FLAGS);
    if ((f & flag) == flag) { return 1; }
    return 0;
}

# --- fingerprint.cyr ---

# sandhi/tls_policy/fingerprint — SPKI hash format helpers.
#
# SPKI pinning compares a SHA-256 hash of the server's Subject Public
# Key Info (DER bytes) against a caller-supplied hex string. This
# module handles format normalization + comparison; the actual DER
# extraction from server certs lives in apply.cyr's
# `_sandhi_check_spki` (X509_get_pubkey + i2d_PUBKEY → SHA-256, all
# resolved via stdlib `tls_dlsym`). Wired since 0.9.3 via stdlib's
# v5.6.40 hook.
#
# Accepted caller formats — all of these compare equal:
#
#   "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
#   "E3B0C44298FC1C149AFBF4C8996FB92427AE41E4649B934CA495991B7852B855"
#   "e3:b0:c4:42:98:fc:1c:14:9a:fb:f4:c8:99:6f:b9:24:27:ae:41:e4:64:9b:93:4c:a4:95:99:1b:78:52:b8:55"
#   "e3 b0 c4 42 98 fc 1c 14 9a fb f4 c8 99 6f b9 24 27 ae 41 e4 64 9b 93 4c a4 95 99 1b 78 52 b8 55"
#
# Normalization strips ':' / ' ' / '\t' and lowercases the hex.
# Length is not enforced here — callers pinning non-SHA-256 hashes
# (e.g. SHA-1 legacy — discouraged) get their length back.

# Lowercase an ASCII byte. Non-alpha bytes pass through.
fn _sandhi_fp_to_lower(c): i64 {
    if (c >= 65) { if (c <= 90) { return c + 32; } }
    return c;
}

# 1 if the byte is a hex digit (0-9 / a-f / A-F), 0 otherwise.
fn _sandhi_fp_is_hex(c): i64 {
    if (c >= 48 && c <= 57) { return 1; }
    if (c >= 65 && c <= 70) { return 1; }
    if (c >= 97 && c <= 102) { return 1; }
    return 0;
}

# Normalize an SPKI hex string into `a`: strip delimiters (: space tab),
# lowercase. Returns a fresh cstr or 0 on null input / invalid byte / OOM.
fn sandhi_fp_normalize_a(a, hex): i64 {
    if (hex == 0) { return 0; }
    var slen = strlen(hex);
    var out = alloc_via(a, slen + 1);
    if (out == 0) { return 0; }
    var oi = 0;
    var i = 0;
    while (i < slen) {
        var c = load8(hex + i);
        if (c == 58 || c == 32 || c == 9) {
            # Delimiter — skip.
            i = i + 1;
        } elif (_sandhi_fp_is_hex(c) == 1) {
            store8(out + oi, _sandhi_fp_to_lower(c));
            oi = oi + 1;
            i = i + 1;
        } else {
            # Invalid byte — reject.
            return 0;
        }
    }
    store8(out + oi, 0);
    return out;
}

fn sandhi_fp_normalize(hex): i64 {
    return sandhi_fp_normalize_a(default_alloc(), hex);
}

# Case- and delimiter-insensitive equality. Returns 1 if the two
# strings represent the same hex fingerprint, 0 otherwise. Either
# operand being 0 returns 0 (null-safe; absent pin never matches).
#
# 0.9.1 P1 — constant-time compare. Cert-pinning is auth-adjacent
# (a MITM trying to craft a cert that matches a pin can use timing
# leaks to brute-force one byte at a time when the cost-of-attempt
# is sub-millisecond). For SHA-256 pins the search space is large
# enough that timing-side-channel doesn't matter in absolute terms,
# but the pattern matters — defensive compares should always be
# constant-time, full stop.
# Constant-time equality with normalization done in `alloc`. The two
# scratch normalized buffers don't escape, so an arena allocator with
# reset_via(a) afterwards is the natural fit.
fn sandhi_fp_eq_a(alloc, a, b): i64 {
    if (a == 0 || b == 0) { return 0; }
    var na = sandhi_fp_normalize_a(alloc, a);
    var nb = sandhi_fp_normalize_a(alloc, b);
    if (na == 0 || nb == 0) { return 0; }
    var la = strlen(na);
    var lb = strlen(nb);
    if (la != lb) { return 0; }
    var diff = 0;
    var i = 0;
    while (i < la) {
        diff = diff | (load8(na + i) ^ load8(nb + i));
        i = i + 1;
    }
    if (diff == 0) { return 1; }
    return 0;
}

fn sandhi_fp_eq(a, b): i64 {
    if (a == 0 || b == 0) { return 0; }
    var na = sandhi_fp_normalize(a);
    var nb = sandhi_fp_normalize(b);
    if (na == 0 || nb == 0) { return 0; }
    var la = strlen(na);
    var lb = strlen(nb);
    # Length mismatch is fatal (different fingerprint widths can't
    # match anyway). Surface this directly — leaks no per-byte info.
    if (la != lb) { return 0; }
    # Walk the full length regardless of mismatch position. OR every
    # XOR into a running accumulator; only inspect the accumulator
    # at the end. No early-exit on mismatch.
    var diff = 0;
    var i = 0;
    while (i < la) {
        diff = diff | (load8(na + i) ^ load8(nb + i));
        i = i + 1;
    }
    if (diff == 0) { return 1; }
    return 0;
}

# Byte length of the normalized fingerprint (2 hex chars per byte).
# Returns 0 on malformed input, 32 for SHA-256, 20 for SHA-1 (legacy).
fn sandhi_fp_byte_length(hex): i64 {
    var n = sandhi_fp_normalize(hex);
    if (n == 0) { return 0; }
    var len = strlen(n);
    if ((len & 1) != 0) { return 0; }  # odd number of nibbles — malformed
    return len / 2;
}

# Encode raw SHA-256 bytes (or any digest buffer) as lowercase hex
# allocated from `a`. Returns 0 on OOM.
fn sandhi_fp_encode_bytes_a(a, bytes, nbytes): i64 {
    var out = alloc_via(a, nbytes * 2 + 1);
    if (out == 0) { return 0; }
    var i = 0;
    while (i < nbytes) {
        var b = load8(bytes + i);
        var hi = (b >> 4) & 0xF;
        var lo = b & 0xF;
        var c1 = 48 + hi;
        if (hi >= 10) { c1 = 87 + hi; }
        var c2 = 48 + lo;
        if (lo >= 10) { c2 = 87 + lo; }
        store8(out + i * 2, c1);
        store8(out + i * 2 + 1, c2);
        i = i + 1;
    }
    store8(out + nbytes * 2, 0);
    return out;
}

fn sandhi_fp_encode_bytes(bytes, nbytes): i64 {
    return sandhi_fp_encode_bytes_a(default_alloc(), bytes, nbytes);
}

# --- apply.cyr ---

# sandhi/tls_policy/apply — wire policy into the connection layer.
#
# Public API: `sandhi_conn_open_with_policy(addr, port, use_tls,
# sni_host, policy)` — parallel to `sandhi_conn_open` but honors a
# caller-supplied TLS policy.
#
# STATUS (2026-06-15, 1.6.0 / cyrius 6.2.8): trust-store override, mTLS
# cert/key load, and SPKI pinning are all live and **enforce on the native
# backend** (the no-flag default). 6.2.8 shipped the typed, backend-aware
# pre-handshake config verbs (`tls_ctx_load_verify_locations` /
# `_use_certificate_file` / `_use_private_key_file`) — the last libssl
# coupling for policy enforcement — so trust/mTLS no longer fails closed on
# native. (Resolves Batch A1; see docs/architecture/004-native-tls-default.md.)
#
# How it fits together:
#
#   - `_sandhi_apply_hook` is a `tls_connect_with_ctx_hook` callback that runs
#     against the bare ctx (native ctx under native, `SSL_CTX*` under libssl).
#     It applies ALPN advertise (mirroring the conn-level default), trust-store
#     override, and mTLS cert/key load via the typed verbs, which dispatch to
#     the native trust-store / client-auth machinery or to libssl `SSL_CTX_*`
#     internally. All run before the handshake completes.
#
#   - `_sandhi_check_spki` runs post-handshake. Reads the peer SPKI DER via the
#     backend-agnostic stdlib verb `tls_get_peer_spki_der` (1.4.2), hashes with
#     SHA-256, and compares to the policy's pinned hex via the constant-time
#     `sandhi_fp_eq`. Mismatch closes the conn and fails the open with err=TLS,
#     per ADR 0004.
#
# Config constants
# ================

# 1.6.0 / cyrius 6.2.8: trust-store + mTLS config goes through the stdlib's
# typed, backend-aware verbs (`tls_ctx_load_verify_locations` /
# `_use_certificate_file` / `_use_private_key_file`) — no `tls_dlsym`
# fn-pointer cache here any more. (ALPN already moved to typed `tls_set_alpn`
# at 1.3.0; the SPKI read to `tls_get_peer_spki_der` at 1.4.2.) The typed verbs
# resolve the backend internally, so the old `_sandhi_apply_resolve_fns`
# lazy-resolve step is retired.

# SSL_FILETYPE_PEM(1) / SSL_FILETYPE_ASN1(2 = DER) for the cert/key verbs.
var _SANDHI_SSL_FILETYPE_PEM = 1;

# Trust-store / mTLS enforcement availability. 1.6.0 / cyrius 6.2.8: the typed
# config verbs (`tls_ctx_load_verify_locations` / `_use_certificate_file` /
# `_use_private_key_file`) are backend-aware — native ENFORCES via the
# tls_native trust-store + client-auth machinery (`_tls_native_alloc` defaults
# verify-peer + system CA; `tls_native_connect` is fail-closed: it verifies the
# chain to a trusted root AND the hostname before returning TLS_OK), and libssl
# routes to the core `SSL_CTX_*` symbols. So enforcement is available on BOTH
# backends whenever TLS is usable — the 1.4.7 "0 on native" fail-closed is
# retired (it was the last libssl coupling for policy enforcement; Batch A1,
# see docs/architecture/004-native-tls-default.md). SPKI-pin availability is
# separate — `sandhi_tls_policy_pin_available` below.
fn sandhi_tls_policy_enforcement_available(): i64 {
    return tls_available();
}

# SPKI-pin enforcement availability. Pinning reads the peer SPKI
# post-handshake via the stdlib, backend-agnostic `tls_get_peer_spki_der`
# (1.4.2) + SHA-256 compare — no libssl SSL_CTX config — so it does NOT
# need the trust-store/mTLS symbols above. On the native backend it is
# always available when TLS is usable (this is what lets high-level
# pinning work on a native box with no libssl present). On the
# **deprecated libssl backend**, cyrius's libssl SPKI extraction currently
# SIGSEGVs (a cyrius regression — a single libssl pinned open faults in
# `tls_get_peer_spki_der`; localized in the issue), so 1.4.7 reports
# pinning UNAVAILABLE there and the caller fails closed rather than crash.
# Drop the libssl exclusion once the cyrius libssl-SPKI fix lands.
fn sandhi_tls_policy_pin_available(): i64 {
    if (tls_available() == 0)                    { return 0; }
    if (tls_get_backend() == TLS_BACKEND_LIBSSL) { return 0; }
    return 1;
}

# ================================================================
# Hook context layout (24 bytes):
#   +0   protos_ptr     (cstr — ALPN advertise wire bytes)
#   +8   protos_len     (int  — length of the wire bytes)
#   +16  policy_ptr     (sandhi_tls_policy* — for trust/mTLS lookup)
# ================================================================

fn _sandhi_apply_hook(hook_ctx, ssl_ctx): i64 {
    if (hook_ctx == 0 || ssl_ctx == 0) { return 0; }

    # ALPN advertise — non-fatal if missing, same shape as the
    # plain ALPN hook in conn.cyr. 1.3.0: switched from the
    # `_sandhi_apply_set_alpn_fp` cache to stdlib's typed
    # `tls_set_alpn` wrapper (cyrius v5.10.13). The wrapper itself
    # null-checks the underlying symbol resolution.
    var protos = load64(hook_ctx);
    var plen   = load64(hook_ctx + 8);
    if (protos != 0 && plen > 0) {
        tls_set_alpn(ssl_ctx, protos, plen);
    }

    var policy = load64(hook_ctx + 16);
    if (policy == 0) { return 0; }

    # Custom trust store: tls_ctx_load_verify_locations(ctx, file, dir).
    # We always pass file=path, dir=0 — sandhi's policy is per-file, not
    # per-directory. Typed verb → native CA-bundle install or libssl
    # SSL_CTX_load_verify_locations; returns 1 on success.
    var trust = sandhi_tls_policy_trust_store(policy);
    if (trust != 0) {
        if (tls_ctx_load_verify_locations(ssl_ctx, trust, 0) != 1) { return 1; }
    }

    # mTLS: present the client cert + key. Both PEM (filetype 1). Order
    # matters — load the cert before the key so the backend can pair them.
    # Typed verbs → native client-auth install or libssl SSL_CTX_use_*.
    var cert = sandhi_tls_policy_mtls_cert(policy);
    var key  = sandhi_tls_policy_mtls_key(policy);
    if (cert != 0) {
        if (tls_ctx_use_certificate_file(ssl_ctx, cert, _SANDHI_SSL_FILETYPE_PEM) != 1) { return 1; }
    }
    if (key != 0) {
        if (tls_ctx_use_private_key_file(ssl_ctx, key, _SANDHI_SSL_FILETYPE_PEM) != 1) { return 1; }
    }

    return 0;
}

# Post-handshake SPKI check, allocating all scratch (DER buffer,
# pointer cell, digest, hex string) from `a`. Returns 1 on match,
# 0 on any failure (cert missing, pubkey extraction failure, hash
# mismatch, OOM). Frees the X509 + EVP_PKEY it pulls. None of the
# allocs escape; an arena reset after this call reclaims everything.
fn _sandhi_check_spki_a(a, tls_ctx, expected_hex): i64 {
    if (tls_ctx == 0 || expected_hex == 0) { return 0; }
    # .82: typed, backend-agnostic SPKI read via the stdlib wrapper verb
    # `tls_get_peer_spki_der` — no raw libssl SSL* (load64(ctx+8)) and no
    # tls_dlsym binding (SSL_get1_peer_certificate / X509_get_pubkey /
    # i2d_PUBKEY now live in lib/tls.cyr). Works on the native TLS backend too.
    # 1024 holds any SubjectPublicKeyInfo (P-256 91 / P-384 120 / RSA-4096 ~550).
    var der = alloc_via(a, 1024);
    if (der == 0) { return 0; }
    var written = tls_get_peer_spki_der(tls_ctx, der, 1024);
    if (written <= 0) { return 0; }

    # SHA-256 the SPKI DER, hex-encode, constant-time compare. The hex
    # encoding + compare-time normalize buffers all flow through `a`.
    var digest = alloc_via(a, 32);
    if (digest == 0) { return 0; }
    sha256(der, written, digest);
    var actual_hex = sandhi_fp_encode_bytes_a(a, digest, 32);
    if (actual_hex == 0) { return 0; }
    if (sandhi_fp_eq_a(a, actual_hex, expected_hex) == 1) { return 1; }
    return 0;
}

fn _sandhi_check_spki(tls_ctx, expected_hex): i64 {
    return _sandhi_check_spki_a(default_alloc(), tls_ctx, expected_hex);
}

# --- Pre/post open helpers (1.4.6) ------------------------------
# Policy enforcement splits cleanly into a PRE step (install the
# SSL_CTX hook override that layers trust-store / mTLS) and a POST
# step (clear the override + run the post-handshake SPKI pin check).
# Splitting them lets the high-level request paths bracket THEIR OWN
# v4/v6 timed opener with policy enforcement — `_sandhi_http_do_impl_a`
# (client.cyr) and `sandhi_http_stream_opts_a` (stream.cyr) call these
# helpers directly. That reachability is why `tls_policy/policy` +
# `fingerprint` + `apply` are ordered ahead of `http/client` +
# `http/stream` in cyrius.cyml (single-pass; see the manifest comment).
# `sandhi_conn_open_with_policy_a` below is itself now just pre → open
# → post, so there's one enforcement implementation.
#
# 0.9.0 P0 #5 (fail-closed) lives in `_sandhi_policy_pre_open_a`: if a
# policy demands enforcement (`_pinned()` / `_mtls()` / `_trust_store()`)
# AND `enforcement_available()` is 0, we refuse rather than silently
# downgrade. A NULL / default policy carries no enforcement requirement.

# Install the policy hook override for `policy`. Returns 0 to proceed
# (override installed when the policy demands enforcement; left clear
# for a NULL / default policy), or -1 fail-closed when the policy
# demands enforcement we can't deliver (enforcement unavailable, or
# OOM building the hook ctx). The caller MUST pair every 0 return with
# a later `_sandhi_policy_post_open_a` (even if the open fails) so the
# override is cleared. Sets the open-error classification to TLS on -1
# (1.6.9: through `ctx`, or the module global when ctx==0).
fn _sandhi_policy_pre_open_a(a, policy, ctx): i64 {
    if (policy == 0) { return 0; }

    var pinned      = sandhi_tls_policy_pinned_hash(policy);
    var mtls_cert   = sandhi_tls_policy_mtls_cert(policy);
    var trust_store = sandhi_tls_policy_trust_store(policy);

    # Two enforcement modes:
    #   - trust-store / mTLS → typed backend-aware ctx config (1.6.0: enforces
    #     on native + libssl; `enforcement_available()` is 1 whenever TLS is up)
    #   - SPKI pinning       → backend-agnostic peer-SPKI read (post-open);
    #     `pin_available()` (libssl-excluded pending the cyrius libssl-SPKI fix)
    # Fail closed on whichever mode the policy demands but the active backend
    # can't deliver, BEFORE arming the hook.
    var needs_ctx = 0;
    if (mtls_cert != 0)   { needs_ctx = 1; }
    if (trust_store != 0) { needs_ctx = 1; }
    var needs_pin = 0;
    if (pinned != 0)      { needs_pin = 1; }

    if (needs_ctx == 0 && needs_pin == 0) { return 0; }

    if (needs_ctx == 1 && sandhi_tls_policy_enforcement_available() == 0) {
        _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TLS);
        return 0 - 1;
    }
    if (needs_pin == 1 && sandhi_tls_policy_pin_available() == 0) {
        _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TLS);
        return 0 - 1;
    }

    # Build the policy hook ctx and arm conn.cyr's override mechanism.
    _sandhi_alpn_init_wire();
    var protos = _sandhi_alpn_h11_wire;
    var plen   = _sandhi_alpn_h11_wire_len;
    if (_sandhi_alpn_advertise_h2 == 1) {
        protos = _sandhi_alpn_h2h11_wire;
        plen   = _sandhi_alpn_h2h11_wire_len;
    }
    var hook_ctx = alloc_via(a, 24);
    if (hook_ctx == 0) {
        _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TLS);
        return 0 - 1;
    }
    store64(hook_ctx,      protos);
    store64(hook_ctx + 8,  plen);
    store64(hook_ctx + 16, policy);

    _sandhi_tls_hook_override     = &_sandhi_apply_hook;
    _sandhi_tls_hook_override_ctx = hook_ctx;
    return 0;
}

# Clear the hook override and run the post-handshake SPKI pin check.
# `conn` may be 0 (the open failed) — we still clear the override.
# Returns `conn` on success, or 0 on SPKI mismatch (conn closed,
# open-err = TLS — 1.6.9: through `ctx`, or the module global when
# ctx==0). A NULL / un-pinned policy passes `conn` through.
fn _sandhi_policy_post_open_a(a, conn, policy, ctx): i64 {
    _sandhi_tls_hook_override     = 0;
    _sandhi_tls_hook_override_ctx = 0;
    if (conn == 0)   { return 0; }
    if (policy == 0) { return conn; }

    var pinned = sandhi_tls_policy_pinned_hash(policy);
    if (pinned != 0) {
        var tls_ctx = sandhi_conn_tls_ctx(conn);
        if (_sandhi_check_spki_a(a, tls_ctx, pinned) == 0) {
            sandhi_conn_close(conn);
            _sandhi_reqctx_set_err(ctx, SANDHI_CONN_OPEN_TLS);
            return 0;
        }
    }
    return conn;
}

fn sandhi_conn_open_with_policy_a(a, addr, port, use_tls, sni_host, policy): i64 {
    if (use_tls == 0) {
        return sandhi_conn_open(addr, port, 0, sni_host);
    }
    # NULL / default policy → plain open (no enforcement requirements).
    if (policy == 0) {
        return sandhi_conn_open(addr, port, 1, sni_host);
    }

    if (_sandhi_policy_pre_open_a(a, policy, 0) != 0) {
        # _sandhi_conn_last_err already set to TLS (fail-closed / OOM)
        # via the ctx==0 global path.
        return 0;
    }
    var conn = sandhi_conn_open(addr, port, 1, sni_host);
    return _sandhi_policy_post_open_a(a, conn, policy, 0);
}

fn sandhi_conn_open_with_policy(addr, port, use_tls, sni_host, policy): i64 {
    return sandhi_conn_open_with_policy_a(default_alloc(), addr, port, use_tls, sni_host, policy);
}

# --- response.cyr ---

# sandhi/http/response — response parser (status line + headers + body).
#
# Handles the three HTTP/1.1 body framings:
#   - Content-Length: N  — N bytes of body
#   - Transfer-Encoding: chunked  — decoded chunk-by-chunk
#   - Neither  — read-to-close (Connection: close semantics)
#
# The parser works on a complete response buffer. Drainage (reading
# bytes until the buffer is complete) is the caller's concern — the
# client does that via sandhi_conn_recv_all.
#
# Struct layout (48 bytes):
#   +0   status      (int: 100..599, or 0 if unparseable)
#   +8   body_ptr    (ptr: alloc-owned; null-terminated for convenience)
#   +16  body_len    (int: decoded body length)
#   +24  headers     (ptr: sandhi_headers block, never 0 after parse)
#   +32  err_kind    (int: SandhiErrorKind — 0 on parseable status)
#   +40  err_message (cstr: optional context; 0 if none. Added in 0.7.1
#                    to mirror rpc-response shape. Callers today receive
#                    0 for every err_kind the parser raises; the slot
#                    is reserved so the 0.8.x security pass — which
#                    needs to surface "CL+TE both present" / "chunked
#                    truncated" / "redirect strip" reasons — doesn't
#                    break ABI.)
#
# NOTE (2026-04-24): the body-framing logic is split into
# `_sandhi_resp_frame` because under a heavier local count in
# `sandhi_http_response_parse`, `var headers` appeared to get zeroed
# after a downstream `sandhi_headers_get` call. At the time (sandhi
# M2 on cyrius 5.6.22) this was tracked as a compiler quirk — but
# the post-mortem at `docs/issues/archive/2026-04-24-fdlopen-getaddrinfo-blocked.md`
# (closed v5.6.29-1) identified the HTTPS-loop sibling symptom as
# "undef-fn call-sites silently patched with a placeholder disp32
# that re-enters _cyrius_init" — almost certainly the same mechanism
# underlying this one. sandhi's `[deps.stdlib]` was missing
# `dynlib`/`mmap`/`fdlopen`/`bigint`/`freelist` at the time, which
# would produce the same class of silent-stomp symptoms on calls
# transitively resolving through the missing libs. Keeping the
# split regardless — the smaller function is the better shape even
# on correctly-linked binaries.

enum SandhiRespOff {
    SANDHI_RESP_OFF_STATUS    = 0;
    SANDHI_RESP_OFF_BODY_PTR  = 8;
    SANDHI_RESP_OFF_BODY_LEN  = 16;
    SANDHI_RESP_OFF_HEADERS   = 24;
    SANDHI_RESP_OFF_ERR_KIND  = 32;
    SANDHI_RESP_OFF_ERR_MSG   = 40;
}

var SANDHI_RESP_STRUCT_SIZE = 48;

# Public accessors. Same rationale as URL accessors — lets us reshape
# the struct without churning call sites.
fn sandhi_http_status(r): i64 { return load64(r + SANDHI_RESP_OFF_STATUS); }
fn sandhi_http_body(r): i64 { return load64(r + SANDHI_RESP_OFF_BODY_PTR); }
fn sandhi_http_body_len(r): i64 { return load64(r + SANDHI_RESP_OFF_BODY_LEN); }
fn sandhi_http_headers(r): i64 { return load64(r + SANDHI_RESP_OFF_HEADERS); }
fn sandhi_http_err_kind(r): i64 { return load64(r + SANDHI_RESP_OFF_ERR_KIND); }
fn sandhi_http_err_message(r): i64 { return load64(r + SANDHI_RESP_OFF_ERR_MSG); }

# Build a response struct in one shot, allocated from `a`. Returns 0
# on OOM. This is THE central constructor — every public client verb
# eventually returns a struct built here, so threading the Allocator
# through is the foundation of the per-request-arena pattern: a
# handler can build everything (headers, body, struct) into one arena
# and reset between requests.
fn _sandhi_resp_new_a(a, status, body_ptr, body_len, headers, err_kind): i64 {
    var r = alloc_via(a, SANDHI_RESP_STRUCT_SIZE);
    if (r == 0) { return 0; }
    store64(r + SANDHI_RESP_OFF_STATUS, status);
    store64(r + SANDHI_RESP_OFF_BODY_PTR, body_ptr);
    store64(r + SANDHI_RESP_OFF_BODY_LEN, body_len);
    store64(r + SANDHI_RESP_OFF_HEADERS, headers);
    store64(r + SANDHI_RESP_OFF_ERR_KIND, err_kind);
    store64(r + SANDHI_RESP_OFF_ERR_MSG, 0);
    return r;
}

fn _sandhi_resp_new(status, body_ptr, body_len, headers, err_kind): i64 {
    return _sandhi_resp_new_a(default_alloc(), status, body_ptr, body_len, headers, err_kind);
}

# Error-response shortcut from `a`. Headers is always an empty block
# (never 0) so downstream code can iterate without null-checking.
fn _sandhi_resp_err_a(a, err_kind): i64 {
    return _sandhi_resp_new_a(a, 0, 0, 0, sandhi_headers_new_a(a), err_kind);
}

fn _sandhi_resp_err(err_kind): i64 {
    return _sandhi_resp_err_a(default_alloc(), err_kind);
}

# Error-response with a caller-supplied context message. The parser
# still uses `_sandhi_resp_err_a` for today's failure modes — this is
# the escape hatch for the 0.8.x security pass diagnostics.
fn _sandhi_resp_err_msg_a(a, err_kind, msg): i64 {
    var r = _sandhi_resp_err_a(a, err_kind);
    if (r == 0) { return 0; }
    store64(r + SANDHI_RESP_OFF_ERR_MSG, msg);
    return r;
}

fn _sandhi_resp_err_msg(err_kind, msg): i64 {
    return _sandhi_resp_err_msg_a(default_alloc(), err_kind, msg);
}

# Parse status line. Returns the int status code, or 0 on malformed.
fn _sandhi_resp_status(buf, blen): i64 {
    if (blen < 12) { return 0; }
    # "HTTP/1.x NNN ..."
    if (load8(buf) != 72)  { return 0; }  # H
    if (load8(buf + 1) != 84) { return 0; }  # T
    if (load8(buf + 2) != 84) { return 0; }  # T
    if (load8(buf + 3) != 80) { return 0; }  # P
    if (load8(buf + 4) != 47) { return 0; }  # /
    if (load8(buf + 8) != 32) { return 0; }  # SP after minor version
    var d0 = load8(buf + 9);
    var d1 = load8(buf + 10);
    var d2 = load8(buf + 11);
    if (d0 < 48 || d0 > 57) { return 0; }
    if (d1 < 48 || d1 > 57) { return 0; }
    if (d2 < 48 || d2 > 57) { return 0; }
    return (d0 - 48) * 100 + (d1 - 48) * 10 + (d2 - 48);
}

# Find the offset of the end-of-headers marker (\r\n\r\n). Returns
# (0 - 1) if not present — the buffer is incomplete.
fn _sandhi_resp_headers_end(buf, blen): i64 {
    var i = 0;
    while (i + 3 < blen) {
        if (load8(buf + i) == 13
        && load8(buf + i + 1) == 10
        && load8(buf + i + 2) == 13
        && load8(buf + i + 3) == 10) {
            return i;
        }
        i = i + 1;
    }
    # Also accept LF-only terminators (permissive parser).
    i = 0;
    while (i + 1 < blen) {
        if (load8(buf + i) == 10 && load8(buf + i + 1) == 10) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

# Offset of the first CR or LF from `start`, bounded by `end`.
fn _sandhi_resp_eol(buf, start, end): i64 {
    var i = start;
    while (i < end) {
        var c = load8(buf + i);
        if (c == 13 || c == 10) { return i; }
        i = i + 1;
    }
    return end;
}

# Parse chunk-size line (hex digits, CRLF-terminated). Returns the
# decoded size. Ignores chunk extensions (";name=value" after the hex).
# Walks `*offset_ptr` past the CRLF.
#
# 0.9.0 P0 #1 + #3 — hardened in two ways:
#   - Requires at least one hex digit (no-digit input returns the
#     `_SANDHI_RESP_CHUNK_BAD` sentinel rather than silently
#     succeeding with size=0). The streaming variant in stream.cyr
#     had this guard; the buffered variant did not, allowing a
#     malformed chunk to be misread as the terminal 0-chunk.
#   - Rejects sizes > 2^31. RFC 7230 doesn't cap chunk-size, but
#     anything that large overflows the signed-64-bit accumulator
#     long before it lands in a real response. Capping at i31 keeps
#     `off + size > blen` comparisons always-positive even if blen
#     itself approached i63.
var _SANDHI_RESP_CHUNK_BAD     = 0 - 1;
var _SANDHI_RESP_CHUNK_MAX     = 0x7FFFFFFF;
fn _sandhi_resp_chunk_size(buf, blen, offset_ptr): i64 {
    var p = load64(offset_ptr);
    var size = 0;
    var seen_digit = 0;
    var scan = 1;
    while (scan == 1 && p < blen) {
        var c = load8(buf + p);
        if (c >= 48 && c <= 57)      { size = size * 16 + (c - 48); seen_digit = 1; p = p + 1; }
        elif (c >= 97 && c <= 102)   { size = size * 16 + (c - 87); seen_digit = 1; p = p + 1; }
        elif (c >= 65 && c <= 70)    { size = size * 16 + (c - 55); seen_digit = 1; p = p + 1; }
        else { scan = 0; }
        if (size > _SANDHI_RESP_CHUNK_MAX) { return _SANDHI_RESP_CHUNK_BAD; }
    }
    if (seen_digit == 0) { return _SANDHI_RESP_CHUNK_BAD; }
    # Skip chunk extensions ";..." up to CRLF.
    while (p < blen && load8(buf + p) != 13 && load8(buf + p) != 10) {
        p = p + 1;
    }
    if (p < blen && load8(buf + p) == 13) { p = p + 1; }
    if (p < blen && load8(buf + p) == 10) { p = p + 1; }
    store64(offset_ptr, p);
    return size;
}

# Decode a chunked body starting at `start` within `buf`. Returns 0
# on success (writing body via out-params) or `0 - 1` on malformed
# input (bad chunk-size, truncated mid-chunk, or stream ending
# without the terminal 0-chunk). Out-params are also written on
# error to keep them initialized for the caller.
#
# 0.9.0 P0 #1 — previously the decoder treated ANY size==0 (including
# the no-hex-digit malformed case from chunk_size + early-stop on
# truncation) as success. This silently truncated bodies. Now we
# track `saw_terminal` and propagate `_BAD` from chunk_size, so a
# clean stream end is the only way to claim success.
fn _sandhi_resp_decode_chunked_a(a, buf, blen, start, body_out_ptr, body_len_ptr, headers): i64 {
    var cap = blen - start;
    if (cap < 1) { cap = 1; }
    var out = alloc_via(a, cap + 1);
    if (out == 0) { return 0 - 1; }
    var out_len = 0;
    var off_cell = alloc_via(a, 8);
    if (off_cell == 0) { return 0 - 1; }
    store64(off_cell, start);
    var going = 1;
    var saw_terminal = 0;
    var malformed = 0;
    while (going == 1) {
        var size = _sandhi_resp_chunk_size(buf, blen, off_cell);
        var off = load64(off_cell);
        if (size == _SANDHI_RESP_CHUNK_BAD) {
            malformed = 1;
            going = 0;
        } elif (size == 0) {
            saw_terminal = 1;
            going = 0;
        } else {
            if (off + size > blen) {
                malformed = 1;
                going = 0;
            } else {
                memcpy(out + out_len, buf + off, size);
                out_len = out_len + size;
                off = off + size;
                if (off < blen && load8(buf + off) == 13) { off = off + 1; }
                if (off < blen && load8(buf + off) == 10) { off = off + 1; }
                store64(off_cell, off);
            }
        }
    }
    store8(out + out_len, 0);
    store64(body_out_ptr, out);
    store64(body_len_ptr, out_len);
    if (malformed == 1) { return 0 - 1; }
    if (saw_terminal == 0) { return 0 - 1; }
    # RFC 7230 §4.1.2 trailer-part. The terminal 0-chunk is followed
    # by zero or more trailer header-fields and then a final empty
    # CRLF. Parse + merge allowed trailers into `headers` so they
    # surface via sandhi_http_headers; drain forbidden ones silently
    # (filtering matches the smuggling-protection list).
    if (headers != 0) {
        _sandhi_resp_merge_trailers_a(a, buf, blen, load64(off_cell), headers);
    }
    return 0;
}

fn _sandhi_resp_decode_chunked(buf, blen, start, body_out_ptr, body_len_ptr, headers): i64 {
    return _sandhi_resp_decode_chunked_a(default_alloc(), buf, blen, start, body_out_ptr, body_len_ptr, headers);
}

# Case-insensitive cstr equality. Local to response.cyr because
# client.cyr's identical helper sits later in the build order.
fn _sandhi_resp_streq_ci(a, b): i64 {
    if (a == 0 || b == 0) { return 0; }
    var i = 0;
    while (1 == 1) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ca >= 65 && ca <= 90) { ca = ca + 32; }
        if (cb >= 65 && cb <= 90) { cb = cb + 32; }
        if (ca != cb) { return 0; }
        if (ca == 0)  { return 1; }
        i = i + 1;
    }
    return 0;
}

# RFC 7230 §4.1.2 forbids these field names in trailers because
# either (a) they affect framing/routing/auth (would defeat the
# fact that the recipient already committed to a body framing) or
# (b) they modify the trailer parsing itself. Returns 1 if `name`
# (case-insensitive) is on the forbidden list, 0 otherwise.
fn _sandhi_resp_trailer_forbidden(name): i64 {
    if (_sandhi_resp_streq_ci(name, "Transfer-Encoding") == 1) { return 1; }
    if (_sandhi_resp_streq_ci(name, "Content-Length") == 1)    { return 1; }
    if (_sandhi_resp_streq_ci(name, "Host") == 1)              { return 1; }
    if (_sandhi_resp_streq_ci(name, "Cache-Control") == 1)     { return 1; }
    if (_sandhi_resp_streq_ci(name, "Expect") == 1)            { return 1; }
    if (_sandhi_resp_streq_ci(name, "Max-Forwards") == 1)      { return 1; }
    if (_sandhi_resp_streq_ci(name, "Pragma") == 1)            { return 1; }
    if (_sandhi_resp_streq_ci(name, "Range") == 1)             { return 1; }
    if (_sandhi_resp_streq_ci(name, "TE") == 1)                { return 1; }
    if (_sandhi_resp_streq_ci(name, "Trailer") == 1)           { return 1; }
    if (_sandhi_resp_streq_ci(name, "Authorization") == 1)     { return 1; }
    if (_sandhi_resp_streq_ci(name, "Set-Cookie") == 1)        { return 1; }
    # 0.9.9 audit additions:
    # `Connection` is connection-management metadata per RFC 7230 §6.1
    # and MUST NOT appear in trailers — letting it through would let a
    # malicious server inject `Connection: close` post-body and
    # destabilize the keep-alive state machine that the pool layer
    # relies on for put-back decisions.
    # `Cookie` and `Proxy-Authorization` are auth-bearing request
    # headers; treating them symmetrically with `Authorization` /
    # `Set-Cookie` closes the trailer-side equivalent of the redirect
    # cred-strip filter (`_sandhi_strip_sensitive_headers`).
    # `Proxy-Authenticate` rounds out the proxy-auth pair (1.1.1).
    # Originally held back from 0.9.9 on per-program-fixup-cap grounds
    # (architecture/001); the cap re-baselined post-fold once consumers
    # stopped re-concatenating sandhi's `src/`. Shipped 1.1.1 (CHANGELOG
    # [1.1.1]).
    if (_sandhi_resp_streq_ci(name, "Connection") == 1)          { return 1; }
    if (_sandhi_resp_streq_ci(name, "Cookie") == 1)              { return 1; }
    if (_sandhi_resp_streq_ci(name, "Proxy-Authorization") == 1) { return 1; }
    if (_sandhi_resp_streq_ci(name, "Proxy-Authenticate") == 1)  { return 1; }
    return 0;
}

# Walk forward from `start` parsing trailer header-fields ("Name:
# value\r\n") until an empty line (CRLF on its own). Adds allowed
# fields to `headers` via sandhi_headers_add (preserves order; lets
# multi-value trailers like Server-Timing show up multiple times).
# Tolerant: returns silently on malformed bytes — trailer parsing
# is best-effort. The body has already been delivered correctly;
# trailer drops only affect metadata visibility.
fn _sandhi_resp_merge_trailers_a(a, buf, blen, start, headers): i64 {
    var off = start;
    var safety = 0;
    while (off < blen && safety < 256) {
        # Empty line (CRLF or LF alone) terminates the trailer block.
        if (off < blen && load8(buf + off) == 13) {
            if (off + 1 < blen && load8(buf + off + 1) == 10) { return 0; }
        }
        if (off < blen && load8(buf + off) == 10) { return 0; }
        # Find ':' separating name from value.
        var colon = off;
        while (colon < blen && load8(buf + colon) != 58
        && load8(buf + colon) != 13
        && load8(buf + colon) != 10) {
            colon = colon + 1;
        }
        if (colon >= blen || load8(buf + colon) != 58) { return 0; }
        var name_len = colon - off;
        if (name_len <= 0) { return 0; }
        var name = alloc_via(a, name_len + 1);
        if (name == 0) { return 0; }
        memcpy(name, buf + off, name_len);
        store8(name + name_len, 0);
        # Skip ':' + leading OWS on value.
        var vstart = colon + 1;
        while (vstart < blen && (load8(buf + vstart) == 32 || load8(buf + vstart) == 9)) {
            vstart = vstart + 1;
        }
        # Value runs to CR/LF.
        var vend = vstart;
        while (vend < blen && load8(buf + vend) != 13 && load8(buf + vend) != 10) {
            vend = vend + 1;
        }
        # Trim trailing OWS.
        while (vend > vstart && (load8(buf + vend - 1) == 32 || load8(buf + vend - 1) == 9)) {
            vend = vend - 1;
        }
        var val_len = vend - vstart;
        var value = alloc_via(a, val_len + 1);
        if (value == 0) { return 0; }
        if (val_len > 0) { memcpy(value, buf + vstart, val_len); }
        store8(value + val_len, 0);
        # Filter forbidden names; merge the rest.
        if (_sandhi_resp_trailer_forbidden(name) == 0) {
            sandhi_headers_add_a(a, headers, name, value);
        }
        # Consume CR/LF and advance past line terminator.
        off = vend;
        if (off < blen && load8(buf + off) == 13) { off = off + 1; }
        if (off < blen && load8(buf + off) == 10) { off = off + 1; }
        safety = safety + 1;
    }
    return 0;
}

fn _sandhi_resp_merge_trailers(buf, blen, start, headers): i64 {
    return _sandhi_resp_merge_trailers_a(default_alloc(), buf, blen, start, headers);
}

# 1 if the headers block declares Transfer-Encoding: chunked.
fn _sandhi_resp_is_chunked(headers): i64 {
    var te = sandhi_headers_get(headers, "Transfer-Encoding");
    if (te == 0) { return 0; }
    var i = 0;
    while (load8(te + i) != 0) {
        if (load8(te + i) == 99
        && load8(te + i + 1) == 104
        && load8(te + i + 2) == 117
        && load8(te + i + 3) == 110
        && load8(te + i + 4) == 107
        && load8(te + i + 5) == 101
        && load8(te + i + 6) == 100) {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

# Parse the decimal Content-Length value from a cstr. Returns 0 on
# empty, `0 - 1` on malformed.
#
# 0.9.1 P1 — strict per RFC 7230 §3.3.2: pure decimal digits only,
# leading/trailing space tolerated. Previously non-digit bytes
# (including `+`, `,`, `-`, `0x`) were silently skipped, so values
# like `"10, 20"` would parse as 1020 — different from any sane
# parser's reading. That kind of disagreement is the CL.CL leg of
# the smuggling triad (CL.TE handled in 0.9.0 P0 #2).
fn _sandhi_resp_parse_clen(v): i64 {
    if (v == 0) { return 0; }
    var i = 0;
    # Skip leading whitespace.
    while (load8(v + i) == 32 || load8(v + i) == 9) { i = i + 1; }
    if (load8(v + i) == 0) { return 0; }
    var n = 0;
    var seen_digit = 0;
    while (load8(v + i) >= 48 && load8(v + i) <= 57) {
        n = n * 10 + (load8(v + i) - 48);
        seen_digit = 1;
        i = i + 1;
    }
    if (seen_digit == 0) { return 0 - 1; }
    # Skip trailing whitespace.
    while (load8(v + i) == 32 || load8(v + i) == 9) { i = i + 1; }
    # Anything else after digits + whitespace is malformed.
    if (load8(v + i) != 0) { return 0 - 1; }
    return n;
}

# Copy `len` bytes starting at `buf+start` into a fresh null-terminated
# cstr allocated from `a`. Returns 0 on OOM.
fn _sandhi_resp_body_copy_a(a, buf, start, len): i64 {
    if (len < 0) { len = 0; }
    var out = alloc_via(a, len + 1);
    if (out == 0) { return 0; }
    if (len > 0) { memcpy(out, buf + start, len); }
    store8(out + len, 0);
    return out;
}

fn _sandhi_resp_body_copy(buf, start, len): i64 {
    return _sandhi_resp_body_copy_a(default_alloc(), buf, start, len);
}

# Figure out body framing and return the struct. Kept small because
# the original split was prompted by a silent-local-zeroing symptom
# that's since been re-attributed to sandhi's missing stdlib deps
# (see top-of-file NOTE). The small-function shape stays regardless.
#
# 0.9.0 P0 #2 — reject responses that carry both `Content-Length`
# AND `Transfer-Encoding: chunked` per RFC 7230 §3.3.3 ("the message
# is malformed and the recipient MUST treat it as such"). Two
# upstream parsers picking different framings is the classic
# CL.TE / TE.CL request/response smuggling vector. We return
# SANDHI_ERR_PROTOCOL on the response struct so callers see the
# refusal rather than a silently-truncated or silently-extended body.
# Frame the body using `a` for every per-response allocation: chunked
# scratch cells, body-copy buffers, and the response struct itself.
fn _sandhi_resp_frame_a(a, buf, blen, status, headers, body_start): i64 {
    var body_ptr = 0;
    var body_len = 0;
    var chunked = _sandhi_resp_is_chunked(headers);
    var has_clen = 0;
    if (sandhi_headers_get(headers, "Content-Length") != 0) { has_clen = 1; }

    if (chunked == 1 && has_clen == 1) {
        return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
    }

    # 0.9.1 P1 — duplicate Host / Content-Length / Transfer-Encoding
    # is a malformed-message condition per RFC 7230. CL.CL / Host.Host
    # disagreement is the smuggling vector.
    if (sandhi_headers_smuggle_dup(headers) == 1) {
        return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
    }

    if (chunked == 1) {
        var outp_cell = alloc_via(a, 8);
        var outl_cell = alloc_via(a, 8);
        if (outp_cell == 0 || outl_cell == 0) {
            return _sandhi_resp_err_a(a, SANDHI_ERR_INTERNAL);
        }
        var dr = _sandhi_resp_decode_chunked_a(a, buf, blen, body_start, outp_cell, outl_cell, headers);
        if (dr < 0) {
            return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
        }
        body_ptr = load64(outp_cell);
        body_len = load64(outl_cell);
    } else {
        var clen_v = sandhi_headers_get(headers, "Content-Length");
        if (clen_v != 0) {
            var n = _sandhi_resp_parse_clen(clen_v);
            if (n < 0) {
                return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
            }
            if (body_start + n > blen) { n = blen - body_start; }
            body_len = n;
            body_ptr = _sandhi_resp_body_copy_a(a, buf, body_start, body_len);
        } else {
            body_len = blen - body_start;
            body_ptr = _sandhi_resp_body_copy_a(a, buf, body_start, body_len);
        }
    }

    return _sandhi_resp_new_a(a, status, body_ptr, body_len, headers, SANDHI_OK);
}

fn _sandhi_resp_frame(buf, blen, status, headers, body_start): i64 {
    return _sandhi_resp_frame_a(default_alloc(), buf, blen, status, headers, body_start);
}

# Parse a complete response buffer into `a`. Headers / body / struct
# all flow through `a`; an arena reset reclaims the entire response
# in one shot. Returns a response struct (never 0 — even on parse
# failure the err-response is allocated from `a`); the caller can
# detect parse failure via sandhi_http_err_kind.
fn sandhi_http_response_parse_a(a, buf, blen): i64 {
    if (buf == 0 || blen <= 0) {
        return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
    }

    var status = _sandhi_resp_status(buf, blen);
    if (status == 0) {
        return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
    }

    var sline_end = _sandhi_resp_eol(buf, 0, blen);
    var header_start = sline_end;
    if (header_start < blen && load8(buf + header_start) == 13) { header_start = header_start + 1; }
    if (header_start < blen && load8(buf + header_start) == 10) { header_start = header_start + 1; }

    var hend = _sandhi_resp_headers_end(buf, blen);
    if (hend < 0) {
        return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
    }

    var hblock_len = hend - header_start;
    if (hblock_len < 0) { hblock_len = 0; }
    var headers = sandhi_headers_parse_a(a, buf + header_start, hblock_len);

    var body_start = hend + 4;
    if (load8(buf + hend) == 10) { body_start = hend + 2; }
    if (body_start > blen) { body_start = blen; }

    return _sandhi_resp_frame_a(a, buf, blen, status, headers, body_start);
}

fn sandhi_http_response_parse(buf, blen): i64 {
    return sandhi_http_response_parse_a(default_alloc(), buf, blen);
}

# --- resolve.cyr ---

# sandhi/net/resolve — native DNS resolver (UDP, RFC 1035).
#
# Linux-first, A-records only, single-nameserver fallback from
# /etc/resolv.conf. Written because fdlopen_getaddrinfo is blocked
# at the 5.6.22 toolchain pin (docs/issues/2026-04-24-fdlopen...).
# Retires opportunistically when fdlopen orchestration lands and
# sandhi can drop back to a thin stdlib-compose wrapper.
#
# Scope: what service consumers actually hit.
#   - UDP only (no TCP fallback for >512B responses — rare for A-only)
#   - A + AAAA records (sandhi_resolve_ipv4 / _ipv6); HTTP client
#     tries v4 first, falls back to v6 in `_sandhi_http_do_impl`
#   - First nameserver from /etc/resolv.conf (no per-query retry across
#     multiple nameservers yet — add when we see timeouts in practice)
#   - No /etc/hosts consultation; resolve_ipv4 defers to the client's
#     IP-literal path for numeric inputs before reaching here.
#
# All RFC 1035 packet building + parsing is inline — it's tight, and
# pulling in a generic DNS library would inflate the fold-into-stdlib
# surface area ADR 0002 is trying to keep small.

var _SANDHI_RESOLVE_BUF_SIZE = 512;   # RFC 1035 UDP limit
var _SANDHI_RESOLVE_TIMEOUT_MS = 2000;  # reserved; net.cyr lacks timeouts today

# Maximum compression-pointer hops when walking a wire-format name.
# RFC 1035 §4.1.4 bans forward / cyclic pointers, but malformed or
# hostile responses can have both. Bound the traversal to 32 hops —
# well above any legitimate DNS message (names are ≤255 bytes = ≤128
# labels, and compression can only point backward).
var _SANDHI_RESOLVE_MAX_PTR_HOPS = 32;

# ================================================================
# Cryptographic randomness for DNS TXID + future needs
# ================================================================

# Read 2 random bytes from the kernel CSPRNG and return as a u16
# (0..65535). Composes the stdlib `sys_getrandom` syscall-selector
# primitive (from the `syscalls` dep) rather than hand-rolling
# `/dev/urandom` open/read/close: getrandom is portable across every
# Cyrius target — Linux `getrandom(2)`, AGNOS #45 (landed agnos 1.45.0),
# the macOS / Windows peers (all routed through the per-target syscall
# selector) — needs no fs access (works under chroot / landlock / early
# boot), and is a strict upgrade over the old Linux-ABI-pinned
# `/dev/urandom` path, whose raw syscall numbers (open=2/read=0/close=3)
# meant something else on AGNOS and broke the TXID there. The 1.5.2 /
# Batch C2 fix. For a 2-byte read getrandom never short-reads (that only
# happens > 256 bytes), so a single call returns 2 on success; flags=0
# blocks until the CSPRNG is seeded (ms at boot, immediate after).
# Falls back to a deterministic-but-poor source (monotonic-clock-ns low
# bits, also portable) if the read fails — better than a fixed constant
# for anti-spoofing, worse than real entropy. Exists specifically to
# close the Kaminsky-class cache-poisoning window.
fn _sandhi_resolve_random_u16(): i64 {
    var buf[2];
    store8(&buf + 0, 0);
    store8(&buf + 1, 0);
    var n = sys_getrandom(&buf, 2, 0);
    if (n == 2) {
        return (load8(&buf + 0) << 8) | load8(&buf + 1);
    }
    # Fallback: clock-nanos low bits. Poor but non-constant.
    var ns = clock_now_ns();
    return (ns ^ (ns >> 16)) & 0xFFFF;
}

# ================================================================
# IPv4-literal parser — also used by the HTTP client for numeric URLs.
# ================================================================

# Parse "127.0.0.1" / "1.2.3.4" into a network-byte-order uint32.
# Returns (0 - 1) on malformed input. sock_connect expects this shape.
fn sandhi_net_parse_ipv4(host): i64 {
    if (host == 0) { return 0 - 1; }
    var octets[4];
    store8(&octets + 0, 0);
    store8(&octets + 1, 0);
    store8(&octets + 2, 0);
    store8(&octets + 3, 0);
    var oi = 0;
    var got = 0;
    var cur = 0;
    var i = 0;
    while (load8(host + i) != 0) {
        var c = load8(host + i);
        if (c == 46) {
            if (got == 0) { return 0 - 1; }
            if (oi >= 3) { return 0 - 1; }
            if (cur > 255) { return 0 - 1; }
            store8(&octets + oi, cur);
            oi = oi + 1;
            cur = 0;
            got = 0;
        } elif (c >= 48 && c <= 57) {
            cur = cur * 10 + (c - 48);
            got = 1;
            if (cur > 255) { return 0 - 1; }
        } else {
            return 0 - 1;
        }
        i = i + 1;
    }
    if (got == 0) { return 0 - 1; }
    if (oi != 3) { return 0 - 1; }
    store8(&octets + 3, cur);
    var a0 = load8(&octets + 0);
    var a1 = load8(&octets + 1);
    var a2 = load8(&octets + 2);
    var a3 = load8(&octets + 3);
    return a0 | (a1 << 8) | (a2 << 16) | (a3 << 24);
}

# ================================================================
# /etc/resolv.conf parser
# ================================================================

# Return the first `nameserver A.B.C.D` entry in /etc/resolv.conf as
# an IPv4 uint32 (network-byte-order, shape matches INADDR_LOOPBACK).
# Returns (0 - 1) on any failure — caller falls back to 8.8.8.8.
# Read the first nameserver entry from /etc/resolv.conf into `a`. The
# 4 KB scratch + the parsed cstr both live in `a`; both are short-
# lived (caller only needs the returned int). Returns (0 - 1) on any
# failure so the caller can fall back to a public DNS default.
fn _sandhi_resolve_read_resolv_conf_a(a): i64 {
    var buf = alloc_via(a, 4096);
    if (buf == 0) { return 0 - 1; }
    var n = file_read_all("/etc/resolv.conf", buf, 4095);
    if (n <= 0) { return 0 - 1; }
    store8(buf + n, 0);
    var i = 0;
    while (i < n) {
        # Skip leading whitespace.
        while (i < n && (load8(buf + i) == 32 || load8(buf + i) == 9)) { i = i + 1; }
        # Comment line? Skip to newline.
        if (i < n && load8(buf + i) == 35) {
            while (i < n && load8(buf + i) != 10) { i = i + 1; }
            i = i + 1;
        } elif (i + 10 < n && memeq(buf + i, "nameserver", 10) == 1
        && (load8(buf + i + 10) == 32 || load8(buf + i + 10) == 9)) {
            # Found "nameserver" — advance past whitespace, read up to ws/EOL.
            i = i + 10;
            while (i < n && (load8(buf + i) == 32 || load8(buf + i) == 9)) { i = i + 1; }
            var ns_start = i;
            while (i < n && load8(buf + i) != 32 && load8(buf + i) != 9
            && load8(buf + i) != 13 && load8(buf + i) != 10) {
                i = i + 1;
            }
            var nlen = i - ns_start;
            var ns = alloc_via(a, nlen + 1);
            if (ns == 0) { return 0 - 1; }
            memcpy(ns, buf + ns_start, nlen);
            store8(ns + nlen, 0);
            return sandhi_net_parse_ipv4(ns);
        } else {
            # Skip to newline.
            while (i < n && load8(buf + i) != 10) { i = i + 1; }
            i = i + 1;
        }
    }
    return 0 - 1;
}

fn _sandhi_resolve_read_resolv_conf(): i64 {
    return _sandhi_resolve_read_resolv_conf_a(default_alloc());
}

# ================================================================
# DNS wire-format: query build
# ================================================================

# Encode a hostname as DNS labels: "example.com" → 07 example 03 com 00.
# Writes to `out` starting at offset 0, returns bytes written. Returns
# (0 - 1) if any label exceeds 63 bytes or total exceeds 255.
fn _sandhi_resolve_encode_labels(host, out): i64 {
    var total = 0;
    var label_start = 0;
    var p = 0;
    var wi = 1;  # +1: leaves room for the length byte of label 0
    while (load8(host + p) != 0) {
        var c = load8(host + p);
        if (c == 46) {
            var llen = p - label_start;
            if (llen == 0) { return 0 - 1; }
            if (llen > 63) { return 0 - 1; }
            store8(out + (wi - llen - 1), llen);
            label_start = p + 1;
            wi = wi + 1;
        } else {
            store8(out + wi, c);
            wi = wi + 1;
        }
        p = p + 1;
        total = wi;
    }
    # Emit last label.
    var last_len = p - label_start;
    if (last_len == 0) { return 0 - 1; }
    if (last_len > 63) { return 0 - 1; }
    store8(out + (wi - last_len - 1), last_len);
    store8(out + wi, 0);  # root terminator
    wi = wi + 1;
    if (wi > 255) { return 0 - 1; }
    return wi;
}

# Build the full DNS query packet. Writes into `out` (must hold at
# least 12 + 255 + 4 bytes). Returns packet length.
fn _sandhi_resolve_build_query(id, host, out): i64 {
    # Header
    store8(out + 0, (id >> 8) & 0xFF);
    store8(out + 1, id & 0xFF);
    store8(out + 2, 0x01);  # Flags MSB: QR=0, Opcode=0, AA=0, TC=0, RD=1
    store8(out + 3, 0x00);  # Flags LSB: all zero
    store8(out + 4, 0x00); store8(out + 5, 0x01);  # QDCOUNT = 1
    store8(out + 6, 0x00); store8(out + 7, 0x00);  # ANCOUNT
    store8(out + 8, 0x00); store8(out + 9, 0x00);  # NSCOUNT
    store8(out + 10, 0x00); store8(out + 11, 0x00);  # ARCOUNT

    # Question
    var qname_len = _sandhi_resolve_encode_labels(host, out + 12);
    if (qname_len < 0) { return 0 - 1; }
    var qi = 12 + qname_len;
    store8(out + qi + 0, 0x00); store8(out + qi + 1, 0x01);  # QTYPE = A
    store8(out + qi + 2, 0x00); store8(out + qi + 3, 0x01);  # QCLASS = IN
    return qi + 4;
}

# ================================================================
# DNS wire-format: response parse
# ================================================================

# Skip a name at offset `off` in the response. Handles both plain
# length-labeled names and pointer compression (0xC0xx). Returns
# the offset just past the name. Returns (0 - 1) on malformed.
#
# Note: this function only skips — it doesn't follow the pointer
# target. That's safe for iteration (the caller only needs the offset
# past the pointer byte), but DOES NOT validate that the pointer
# target is well-formed. Consumers that need the actual name bytes
# must use `_sandhi_resolve_name_eq` which does follow pointers with
# an explicit hop-budget guard.
fn _sandhi_resolve_skip_name(buf, blen, off): i64 {
    var p = off;
    var safety = 0;
    while (safety < 256) {
        if (p >= blen) { return 0 - 1; }
        var c = load8(buf + p);
        if (c == 0) { return p + 1; }
        if ((c & 0xC0) == 0xC0) {
            # Two-byte compression pointer — name continues elsewhere.
            if (p + 1 >= blen) { return 0 - 1; }
            return p + 2;
        }
        # Otherwise c is the label length (max 63).
        if (c > 63) { return 0 - 1; }
        p = p + 1 + c;
        safety = safety + 1;
    }
    return 0 - 1;
}

# Read one label from a wire-format name, following compression
# pointers. Returns the label length (0 at terminator) via out-param
# `label_len_cell`, and writes the label bytes into `label_buf` (must
# hold ≥63 bytes). Advances the offset via `off_cell`. Returns 0 on
# success, (0 - 1) on malformed input (bad length / out-of-bounds /
# pointer loop). `hops_cell` tracks pointer-hops across calls — pass
# the same cell to successive reads of one name so the budget is
# shared.
fn _sandhi_resolve_read_label(buf, blen, off_cell, label_buf, label_len_cell, hops_cell): i64 {
    var p = load64(off_cell);
    while (1 == 1) {
        if (p >= blen) { return 0 - 1; }
        var c = load8(buf + p);
        if (c == 0) {
            store64(label_len_cell, 0);
            store64(off_cell, p + 1);
            return 0;
        }
        if ((c & 0xC0) == 0xC0) {
            # Pointer. RFC 1035 §4.1.4: target offset = (c & 0x3F) << 8 | next byte.
            if (p + 1 >= blen) { return 0 - 1; }
            var hops = load64(hops_cell);
            if (hops >= _SANDHI_RESOLVE_MAX_PTR_HOPS) { return 0 - 1; }
            store64(hops_cell, hops + 1);
            var target = ((c & 0x3F) << 8) | load8(buf + p + 1);
            if (target >= p) { return 0 - 1; }  # RFC 1035: pointers must go backward
            if (target >= blen) { return 0 - 1; }
            p = target;
        } else {
            if (c > 63) { return 0 - 1; }
            if (p + 1 + c > blen) { return 0 - 1; }
            var i = 0;
            while (i < c) {
                store8(label_buf + i, load8(buf + p + 1 + i));
                i = i + 1;
            }
            store64(label_len_cell, c);
            store64(off_cell, p + 1 + c);
            return 0;
        }
    }
    return 0 - 1;
}

# 1 if the wire-format name at offset `off_a` matches the one at
# offset `off_b`. Both names may use compression. Case-insensitive
# ASCII comparison (DNS names are case-insensitive per RFC 1035 §2.3.3).
# Compare two compressed names byte-for-byte (case-insensitive),
# allocating the 8 transient cells + 2 64-byte label buffers from `a`.
# Heaviest alloc site in the resolver — the cells are touched per
# label per name, so they really want to live in an arena that the
# resolver caller resets after the query completes.
fn _sandhi_resolve_name_eq_a(a, buf, blen, off_a, off_b): i64 {
    var pa_cell = alloc_via(a, 8);
    var pb_cell = alloc_via(a, 8);
    var ha_cell = alloc_via(a, 8);
    var hb_cell = alloc_via(a, 8);
    var la_buf  = alloc_via(a, 64);
    var lb_buf  = alloc_via(a, 64);
    var la_cell = alloc_via(a, 8);
    var lb_cell = alloc_via(a, 8);
    if (pa_cell == 0 || pb_cell == 0 || ha_cell == 0 || hb_cell == 0
    || la_buf  == 0 || lb_buf  == 0 || la_cell == 0 || lb_cell == 0) { return 0; }
    store64(pa_cell, off_a);
    store64(pb_cell, off_b);
    store64(ha_cell, 0);
    store64(hb_cell, 0);
    while (1 == 1) {
        if (_sandhi_resolve_read_label(buf, blen, pa_cell, la_buf, la_cell, ha_cell) < 0) { return 0; }
        if (_sandhi_resolve_read_label(buf, blen, pb_cell, lb_buf, lb_cell, hb_cell) < 0) { return 0; }
        var la = load64(la_cell);
        var lb = load64(lb_cell);
        if (la != lb) { return 0; }
        if (la == 0) { return 1; }
        var i = 0;
        while (i < la) {
            var ca = load8(la_buf + i);
            var cb = load8(lb_buf + i);
            if (ca >= 65 && ca <= 90) { ca = ca + 32; }
            if (cb >= 65 && cb <= 90) { cb = cb + 32; }
            if (ca != cb) { return 0; }
            i = i + 1;
        }
    }
    return 0;
}

fn _sandhi_resolve_name_eq(buf, blen, off_a, off_b): i64 {
    return _sandhi_resolve_name_eq_a(default_alloc(), buf, blen, off_a, off_b);
}

# Parse the first A record from a DNS response packet. Returns the
# IPv4 as a network-byte-order uint32 (same shape as
# _sandhi_client_parse_ipv4), or (0 - 1) on any parse failure.
#
# `expected_id` must match the TXID we sent — guards against off-path
# cache-poisoning (Kaminsky class). Answer names are checked against
# the question name (echoed at offset 12) — guards against answer
# substitution where a crafted packet resolves a different host.
# Parse an A-record response, allocating the name-eq scratch from `a`.
fn _sandhi_resolve_parse_response_a(a, buf, blen, expected_id): i64 {
    if (blen < 12) { return 0 - 1; }
    # TXID echo check.
    var got_id = (load8(buf + 0) << 8) | load8(buf + 1);
    if (got_id != expected_id) { return 0 - 1; }
    # Answer count.
    var ancount = (load8(buf + 6) << 8) | load8(buf + 7);
    if (ancount == 0) { return 0 - 1; }
    # Response code (low 4 bits of byte 3).
    var rcode = load8(buf + 3) & 0x0F;
    if (rcode != 0) { return 0 - 1; }
    # QDCOUNT — skip the question. Also remember where qname starts
    # so we can compare answer names against it.
    var qdcount = (load8(buf + 4) << 8) | load8(buf + 5);
    if (qdcount != 1) { return 0 - 1; }  # we only ever send 1 question
    var qname_off = 12;
    var off = _sandhi_resolve_skip_name(buf, blen, qname_off);
    if (off < 0) { return 0 - 1; }
    off = off + 4;  # QTYPE + QCLASS
    # Scan answers. Loop counter is `a_idx` because `a` is the
    # Allocator parameter — the v1.1.0 migration renamed the inner
    # var to dodge the shadow.
    var a_idx = 0;
    while (a_idx < ancount) {
        var name_off = off;
        off = _sandhi_resolve_skip_name(buf, blen, off);
        if (off < 0) { return 0 - 1; }
        if (off + 10 > blen) { return 0 - 1; }
        var rtype = (load8(buf + off + 0) << 8) | load8(buf + off + 1);
        var rdlength = (load8(buf + off + 8) << 8) | load8(buf + off + 9);
        off = off + 10;
        if (rtype == 1) {
            # A record — rdlength must be 4, and the owner name must
            # match the question. (CNAME chains land here too, but
            # stdlib net.cyr's sock_connect doesn't do CNAME following
            # for us — so we only return the A record that answers
            # the question directly. CNAME support is post-v1 unless
            # a consumer needs it.)
            if (rdlength != 4) { return 0 - 1; }
            if (off + 4 > blen) { return 0 - 1; }
            if (_sandhi_resolve_name_eq_a(a, buf, blen, name_off, qname_off) == 0) {
                # Not the name we asked about — skip this RR rather than
                # trust it.
                off = off + 4;
                a_idx = a_idx + 1;
            } else {
                var a0 = load8(buf + off + 0);
                var a1 = load8(buf + off + 1);
                var a2 = load8(buf + off + 2);
                var a3 = load8(buf + off + 3);
                return a0 | (a1 << 8) | (a2 << 16) | (a3 << 24);
            }
        } else {
            off = off + rdlength;
            a_idx = a_idx + 1;
        }
    }
    return 0 - 1;
}

fn _sandhi_resolve_parse_response(buf, blen, expected_id): i64 {
    return _sandhi_resolve_parse_response_a(default_alloc(), buf, blen, expected_id);
}

# ================================================================
# Public resolver
# ================================================================

# Resolve `host` to an IPv4 address (net-byte-order uint32). Returns
# (0 - 1) on any failure. For IP-literal inputs, caller should use
# _sandhi_client_parse_ipv4 directly — this function always performs
# a DNS query.
# Build a DNS query for AAAA records (QTYPE=28, not 1). Everything else
# identical to the A-record build. Kept separate so the hot path of
# IPv4 resolution doesn't pay a branch.
fn _sandhi_resolve_build_query_aaaa(id, host, out): i64 {
    store8(out + 0, (id >> 8) & 0xFF);
    store8(out + 1, id & 0xFF);
    store8(out + 2, 0x01);
    store8(out + 3, 0x00);
    store8(out + 4, 0x00); store8(out + 5, 0x01);
    store8(out + 6, 0x00); store8(out + 7, 0x00);
    store8(out + 8, 0x00); store8(out + 9, 0x00);
    store8(out + 10, 0x00); store8(out + 11, 0x00);
    var qname_len = _sandhi_resolve_encode_labels(host, out + 12);
    if (qname_len < 0) { return 0 - 1; }
    var qi = 12 + qname_len;
    store8(out + qi + 0, 0x00); store8(out + qi + 1, 0x1C);  # QTYPE = AAAA (28)
    store8(out + qi + 2, 0x00); store8(out + qi + 3, 0x01);  # QCLASS = IN
    return qi + 4;
}

# Parse the first AAAA record from a DNS response. Returns a freshly-
# alloc'd 16-byte buffer containing the IPv6 address in network order,
# or 0 on any parse failure / missing RR. Same hardening as the A-
# record parser: TXID echo + answer-name match + compression-loop guard.
# Parse an AAAA-record response into `a`. The 16-byte AAAA buffer
# returned to the caller (and the name-eq scratch) flow through `a`.
fn _sandhi_resolve_parse_response_aaaa_a(a, buf, blen, expected_id): i64 {
    if (blen < 12) { return 0; }
    var got_id = (load8(buf + 0) << 8) | load8(buf + 1);
    if (got_id != expected_id) { return 0; }
    var ancount = (load8(buf + 6) << 8) | load8(buf + 7);
    if (ancount == 0) { return 0; }
    var rcode = load8(buf + 3) & 0x0F;
    if (rcode != 0) { return 0; }
    var qdcount = (load8(buf + 4) << 8) | load8(buf + 5);
    if (qdcount != 1) { return 0; }
    var qname_off = 12;
    var off = _sandhi_resolve_skip_name(buf, blen, qname_off);
    if (off < 0) { return 0; }
    off = off + 4;
    var a_idx = 0;
    while (a_idx < ancount) {
        var name_off = off;
        off = _sandhi_resolve_skip_name(buf, blen, off);
        if (off < 0) { return 0; }
        if (off + 10 > blen) { return 0; }
        var rtype = (load8(buf + off + 0) << 8) | load8(buf + off + 1);
        var rdlength = (load8(buf + off + 8) << 8) | load8(buf + off + 9);
        off = off + 10;
        if (rtype == 28) {
            # AAAA — rdlength must be 16.
            if (rdlength != 16) { return 0; }
            if (off + 16 > blen) { return 0; }
            if (_sandhi_resolve_name_eq_a(a, buf, blen, name_off, qname_off) == 0) {
                off = off + 16;
                a_idx = a_idx + 1;
            } else {
                var out = alloc_via(a, 16);
                if (out == 0) { return 0; }
                var i = 0;
                while (i < 16) { store8(out + i, load8(buf + off + i)); i = i + 1; }
                return out;
            }
        } else {
            off = off + rdlength;
            a_idx = a_idx + 1;
        }
    }
    return 0;
}

fn _sandhi_resolve_parse_response_aaaa(buf, blen, expected_id): i64 {
    return _sandhi_resolve_parse_response_aaaa_a(default_alloc(), buf, blen, expected_id);
}

# Resolve `host` to an IPv6 address. Returns a freshly-allocated 16-byte
# buffer (network-byte-order AAAA record bytes), or 0 on failure. Caller
# owns the alloc. Intentionally does NOT share a resolver handle with
# sandhi_resolve_ipv4 — both issue their own UDP query.
#
# Client-side integration: wired since 0.9.3.
# `_sandhi_http_do_impl` calls v4 first; on miss falls back to
# `_sandhi_client_resolve_v6` and routes through
# `_sandhi_conn_open_v6_fully_timed` (raw socket(AF_INET6) +
# connect(sockaddr_in6)). v4 + v6 are tried sequentially, not in
# parallel — Happy Eyeballs (RFC 8305) would need the connect-path
# refactor to drive two concurrent attempts; not in 0.9.x scope.
fn sandhi_resolve_ipv6_a(a, host): i64 {
    sandhi_trace_begin("sandhi.dns.v6");
    var r = _sandhi_resolve_ipv6_impl_a(a, host);
    sandhi_trace_end();
    return r;
}

fn sandhi_resolve_ipv6(host): i64 {
    return sandhi_resolve_ipv6_a(default_alloc(), host);
}

fn _sandhi_resolve_ipv6_impl_a(a, host): i64 {
    if (host == 0) { return 0; }
    var ns = _sandhi_resolve_read_resolv_conf_a(a);
    if (ns == 0 - 1) {
        ns = 8 | (8 << 8) | (8 << 16) | (8 << 24);
    }
    var txid = _sandhi_resolve_random_u16();
    var qbuf = alloc_via(a, 512);
    if (qbuf == 0) { return 0; }
    var qlen = _sandhi_resolve_build_query_aaaa(txid, host, qbuf);
    if (qlen < 0) { return 0; }

    var fd_r = udp_socket();
    if (is_err_result(fd_r) == 1) { return 0; }
    var fd = payload(fd_r);
    var cr = sock_connect(fd, ns, 53);
    if (is_err_result(cr) == 1) { sock_close(fd); return 0; }
    var sr = sock_send(fd, qbuf, qlen);
    if (is_err_result(sr) == 1) { sock_close(fd); return 0; }
    var rbuf = alloc_via(a, _SANDHI_RESOLVE_BUF_SIZE);
    if (rbuf == 0) { sock_close(fd); return 0; }
    var rr = sock_recv(fd, rbuf, _SANDHI_RESOLVE_BUF_SIZE);
    sock_close(fd);
    if (is_err_result(rr) == 1) { return 0; }
    var rlen = payload(rr);
    if (rlen <= 0) { return 0; }
    return _sandhi_resolve_parse_response_aaaa_a(a, rbuf, rlen, txid);
}

fn _sandhi_resolve_ipv6_impl(host): i64 {
    return _sandhi_resolve_ipv6_impl_a(default_alloc(), host);
}

fn sandhi_resolve_ipv4_a(a, host): i64 {
    sandhi_trace_begin("sandhi.dns.v4");
    var r = _sandhi_resolve_ipv4_impl_a(a, host);
    sandhi_trace_end();
    return r;
}

fn sandhi_resolve_ipv4(host): i64 {
    return sandhi_resolve_ipv4_a(default_alloc(), host);
}

fn _sandhi_resolve_ipv4_impl_a(a, host): i64 {
    if (host == 0) { return 0 - 1; }
    var ns = _sandhi_resolve_read_resolv_conf_a(a);
    if (ns == 0 - 1) {
        # Fall back to public DNS (Google's 8.8.8.8 = 0x08080808 LE).
        ns = 8 | (8 << 8) | (8 << 16) | (8 << 24);
    }

    # Fresh random TXID per query — closes the Kaminsky window.
    # Kernel-assigned ephemeral source port (via connect(2) on UDP
    # without explicit bind) is already random-per-socket on Linux
    # ≥ 2.6.16 and provides the source-port-randomization leg.
    var txid = _sandhi_resolve_random_u16();

    var qbuf = alloc_via(a, 512);
    if (qbuf == 0) { return 0 - 1; }
    var qlen = _sandhi_resolve_build_query(txid, host, qbuf);
    if (qlen < 0) { return 0 - 1; }

    var fd_r = udp_socket();
    if (is_err_result(fd_r) == 1) { return 0 - 1; }
    var fd = payload(fd_r);

    var cr = sock_connect(fd, ns, 53);
    if (is_err_result(cr) == 1) { sock_close(fd); return 0 - 1; }

    var sr = sock_send(fd, qbuf, qlen);
    if (is_err_result(sr) == 1) { sock_close(fd); return 0 - 1; }

    var rbuf = alloc_via(a, _SANDHI_RESOLVE_BUF_SIZE);
    if (rbuf == 0) { sock_close(fd); return 0 - 1; }
    var rr = sock_recv(fd, rbuf, _SANDHI_RESOLVE_BUF_SIZE);
    sock_close(fd);
    if (is_err_result(rr) == 1) { return 0 - 1; }
    var rlen = payload(rr);
    if (rlen <= 0) { return 0 - 1; }

    return _sandhi_resolve_parse_response_a(a, rbuf, rlen, txid);
}

fn _sandhi_resolve_ipv4_impl(host): i64 {
    return _sandhi_resolve_ipv4_impl_a(default_alloc(), host);
}

# --- client.cyr ---

# sandhi/http/client — full HTTP client.
#
# Verbs: sandhi_http_get / post / put / delete / patch / head. Each is
# a thin wrapper around `_sandhi_http_do(method, url, headers, body, body_len)`.
#
# Composes: url.cyr (parse) → resolve (IPv4 literal in v0.3.0, native DNS
# in src/net/resolve.cyr at P7) → conn.cyr (plain or TLS) → wire-format
# request build → response.cyr (parse).
#
# Layering note: this module stays small — originally prompted by a
# suspected cyrius 5.6.22 stack-slot issue, later re-attributed to
# sandhi's missing `[deps.stdlib]` entries (see
# `docs/issues/archive/2026-04-24-fdlopen-getaddrinfo-blocked.md`
# post-mortem, closed v5.6.29-1). The small-function shape stays
# because it reads better; no compiler quirk was at fault.

var _SANDHI_HTTP_RESP_BUF_SIZE = 262144;  # 256 KB — enough for most API responses

# ================================================================
# Host resolution
# ================================================================
#
# Try the numeric-literal fast path first (sandhi_net_parse_ipv4 in
# src/net/resolve.cyr); on miss, fall through to sandhi_resolve_ipv4
# which does a real UDP DNS query. Returns the address (net-byte-
# order uint32), or (0 - 1) on any failure.
# Resolve `host` via IPv4 literal then DNS, allocating any DNS scratch
# from `a`. Returns the address on hit, (0 - 1) on miss.
fn _sandhi_client_resolve_a(a, host): i64 {
    var lit = sandhi_net_parse_ipv4(host);
    if (lit != 0 - 1) { return lit; }
    return sandhi_resolve_ipv4_a(a, host);
}

fn _sandhi_client_resolve(host): i64 {
    return _sandhi_client_resolve_a(default_alloc(), host);
}

# IPv6 fallback into `a`. Returns a 16-byte AAAA buffer or 0.
fn _sandhi_client_resolve_v6_a(a, host): i64 {
    if (host == 0) { return 0; }
    return sandhi_resolve_ipv6_a(a, host);
}

fn _sandhi_client_resolve_v6(host): i64 {
    return _sandhi_client_resolve_v6_a(default_alloc(), host);
}

# ================================================================
# Request build
# ================================================================

# Combine path + query into a single cstr "path?query" (or just path).
# Caller owns the returned alloc.
fn _sandhi_client_full_path_a(a, url_struct): i64 {
    var path = sandhi_url_path(url_struct);
    var query = sandhi_url_query(url_struct);
    if (query == 0) {
        var plen = strlen(path);
        var out = alloc_via(a, plen + 1);
        if (out == 0) { return 0; }
        memcpy(out, path, plen);
        store8(out + plen, 0);
        return out;
    }
    var plen2 = strlen(path);
    var qlen = strlen(query);
    var total = plen2 + 1 + qlen;
    var out2 = alloc_via(a, total + 1);
    if (out2 == 0) { return 0; }
    memcpy(out2, path, plen2);
    store8(out2 + plen2, 63);  # '?'
    memcpy(out2 + plen2 + 1, query, qlen);
    store8(out2 + total, 0);
    return out2;
}

fn _sandhi_client_full_path(url_struct): i64 {
    return _sandhi_client_full_path_a(default_alloc(), url_struct);
}

# Build the Host header value into `a`. The str_builder used in the
# port-bearing variant is on the global bump; only the final cstr
# (dup'd into `a`) is tied to the caller's lifetime.
fn _sandhi_client_host_header_a(a, url_struct): i64 {
    var host = sandhi_url_host(url_struct);
    var port = sandhi_url_port(url_struct);
    var scheme = sandhi_url_scheme(url_struct);
    var default_port = 80;
    if (scheme == SANDHI_URL_HTTPS) { default_port = 443; }
    var hlen = strlen(host);
    if (port == default_port) {
        var out = alloc_via(a, hlen + 1);
        if (out == 0) { return 0; }
        memcpy(out, host, hlen);
        store8(out + hlen, 0);
        return out;
    }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, host);
    str_builder_add_cstr(sb, ":");
    str_builder_add_int(sb, port);
    return _sandhi_json_dup_a(a, str_data(str_builder_build(sb)));
}

fn _sandhi_client_host_header(url_struct): i64 {
    return _sandhi_client_host_header_a(default_alloc(), url_struct);
}

# 1.1.1 dup-prevention filter: caller-supplied `Host` / `Content-
# Length` / `Transfer-Encoding` / `Connection` in user_headers would
# emit alongside the auto-injected versions and create a dup-header
# smuggling vector on the wire (TE.CL / CL.TE / dup-Host / Connection-
# override). Symmetric to the server-side detector
# `sandhi_headers_smuggle_dup` (0.9.1). Returns 1 for any reserved
# name (case-insensitive), 0 otherwise. Uses `_sandhi_resp_streq_ci`
# from response.cyr (bundled before client.cyr); client.cyr's own
# `_sandhi_streq_ci` sits later in the file and isn't reachable from
# here under single-pass compilation.
fn _sandhi_client_user_header_is_reserved(name): i64 {
    if (_sandhi_resp_streq_ci(name, "Host") == 1)              { return 1; }
    if (_sandhi_resp_streq_ci(name, "Content-Length") == 1)    { return 1; }
    if (_sandhi_resp_streq_ci(name, "Transfer-Encoding") == 1) { return 1; }
    if (_sandhi_resp_streq_ci(name, "Connection") == 1)        { return 1; }
    return 0;
}

# Construct the wire-format request as a Str. user_headers may be 0.
# Body is sent separately — the builder emits headers + blank line only.
# `keep_alive` controls the trailing Connection header — 1 omits it
# (HTTP/1.1 default is keep-alive); 0 emits "Connection: close" so the
# peer drops the conn after the response.
#
# 1.2.0 audit: the prior `_a` wrapper called the bare `_v` impl, which
# routed every str_builder op through `default_alloc()` — `a` was
# accepted and silently dropped. The arena variant now lives in `_va`
# and threads `a` through `str_builder_new_a` / `_add_cstr_a` /
# `_add_int_a` / `_build_a`. The four-fn family (`_a` / bare / `_v` /
# `_va`) preserves every existing call shape; only the under-the-hood
# allocator changes when `a` is supplied.
fn _sandhi_client_build_request_a(a, method, full_path, host_header, user_headers, body_len): i64 {
    return _sandhi_client_build_request_va(a, method, full_path, host_header, user_headers, body_len, 0);
}

fn _sandhi_client_build_request(method, full_path, host_header, user_headers, body_len): i64 {
    return _sandhi_client_build_request_va(default_alloc(), method, full_path, host_header, user_headers, body_len, 0);
}

fn _sandhi_client_build_request_v(method, full_path, host_header, user_headers, body_len, keep_alive): i64 {
    return _sandhi_client_build_request_va(default_alloc(), method, full_path,
    host_header, user_headers, body_len, keep_alive);
}

fn _sandhi_client_build_request_va(a, method, full_path, host_header, user_headers, body_len, keep_alive): i64 {
    var sb = str_builder_new_a(a);
    # OOM on the builder header alloc → return 0 cleanly. Without
    # this guard, downstream str_builder_add_cstr_a's dereference 0
    # via _sb_grow_a (load64(sb + 8) → SIGSEGV). Matches the
    # graceful-0 OOM pattern from 1.1.0 (sandhi_url_parse_a etc.).
    if (sb == 0) { return 0; }
    str_builder_add_cstr_a(a, sb, method);
    str_builder_add_cstr_a(a, sb, " ");
    str_builder_add_cstr_a(a, sb, full_path);
    str_builder_add_cstr_a(a, sb, " HTTP/1.1\r\nHost: ");
    str_builder_add_cstr_a(a, sb, host_header);
    str_builder_add_cstr_a(a, sb, "\r\n");

    # Content-Length: present whenever a body will follow. 0 for POST
    # with no body (HTTP/1.1 convention; some servers require it).
    var add_clen = 0;
    if (body_len > 0) { add_clen = 1; }
    if (streq(method, "POST") == 1) { add_clen = 1; }
    if (streq(method, "PUT") == 1)  { add_clen = 1; }
    if (streq(method, "PATCH") == 1){ add_clen = 1; }
    if (add_clen == 1) {
        str_builder_add_cstr_a(a, sb, "Content-Length: ");
        str_builder_add_int_a(a, sb, body_len);
        str_builder_add_cstr_a(a, sb, "\r\n");
    }

    # Default User-Agent + Accept-Encoding + TE — only if caller didn't
    # set them. Some servers 403 on missing UA; explicit `identity`
    # guards against `Content-Encoding: gzip` we can't decode. `TE:
    # trailers` lets spec-compliant servers emit response trailers
    # (RFC 7230 §4.4 — "a server SHOULD NOT generate trailer fields
    # ... unless the request includes a TE header field indicating
    # 'trailers' is acceptable"); the response-side trailer parser
    # landed at 0.9.4, this signal landed at 0.9.7.
    var have_ua = 0;
    var have_ae = 0;
    var have_te = 0;
    if (user_headers != 0) {
        if (sandhi_headers_has(user_headers, "User-Agent") == 1)      { have_ua = 1; }
        if (sandhi_headers_has(user_headers, "Accept-Encoding") == 1) { have_ae = 1; }
        if (sandhi_headers_has(user_headers, "TE") == 1)              { have_te = 1; }
    }
    if (have_ua == 0) {
        str_builder_add_cstr_a(a, sb, "User-Agent: sandhi/");
        str_builder_add_cstr_a(a, sb, sandhi_version());
        str_builder_add_cstr_a(a, sb, "\r\n");
    }
    if (have_ae == 0) {
        str_builder_add_cstr_a(a, sb, "Accept-Encoding: identity\r\n");
    }
    if (have_te == 0) {
        str_builder_add_cstr_a(a, sb, "TE: trailers\r\n");
    }

    # User headers (after auto headers). Caller-supplied
    # `Host` / `Content-Length` / `Transfer-Encoding` /
    # `Connection` are filtered out via
    # `_sandhi_client_user_header_is_reserved` (1.1.2): each of
    # those is auto-injected above, so a caller-supplied second
    # copy would create a dup-header smuggling vector on the
    # wire. Symmetric to the server-side dup detector
    # `sandhi_headers_smuggle_dup` (0.9.1). All other user
    # headers pass through unchanged.
    if (user_headers != 0) {
        var ui = 0;
        var un = sandhi_headers_count(user_headers);
        while (ui < un) {
            var nm = sandhi_headers_name_at(user_headers, ui);
            if (_sandhi_client_user_header_is_reserved(nm) == 0) {
                str_builder_add_cstr_a(a, sb, nm);
                str_builder_add_cstr_a(a, sb, ": ");
                str_builder_add_cstr_a(a, sb, sandhi_headers_value_at(user_headers, ui));
                str_builder_add_cstr_a(a, sb, "\r\n");
            }
            ui = ui + 1;
        }
    }

    if (keep_alive == 1) {
        # HTTP/1.1 default — omit Connection altogether. Some old
        # proxies infer keep-alive only when "Keep-Alive" is explicit;
        # the tradeoff is wire bytes. Default behavior: omit.
        str_builder_add_cstr_a(a, sb, "\r\n");
    } else {
        str_builder_add_cstr_a(a, sb, "Connection: close\r\n\r\n");
    }
    return str_builder_build_a(a, sb);
}

# ================================================================
# Core request/response round-trip
# ================================================================

# Outer trace wrapper — opt-in span via sandhi_trace_enable(1). Span
# no-op by default; the inner does all the work either way.
fn _sandhi_http_do_a(a, method, url, user_headers, body, body_len, max_bytes,
connect_ms, read_ms, write_ms, total_ms, pool, ctx): i64 {
    sandhi_trace_begin("sandhi.http");
    var r = _sandhi_http_do_impl_a(a, method, url, user_headers, body, body_len,
    max_bytes, connect_ms, read_ms, write_ms, total_ms, pool, ctx);
    sandhi_trace_end();
    return r;
}

# Bare wrapper — ctx=0 routes the per-request state (0-RTT / cred /
# policy / open-err) through the module globals (single-threaded).
fn _sandhi_http_do(method, url, user_headers, body, body_len, max_bytes,
connect_ms, read_ms, write_ms, total_ms, pool): i64 {
    return _sandhi_http_do_a(default_alloc(), method, url, user_headers, body, body_len,
    max_bytes, connect_ms, read_ms, write_ms, total_ms, pool, 0);
}

# 1.3.2 — request-method safety check for TLS 1.3 0-RTT. Per
# RFC 8446 §8, only requests that are safe to replay should be sent
# as 0-RTT (replay-attack mitigation). Safe methods per RFC 7231:
# GET, HEAD, OPTIONS, TRACE — sandhi exposes the first three. PUT
# is idempotent but not safe (changes server state), so it stays
# out per OpenSSL's recommended posture.
fn _sandhi_method_is_replay_safe(method): i64 {
    if (streq(method, "GET") == 1) { return 1; }
    if (streq(method, "HEAD") == 1) { return 1; }
    if (streq(method, "OPTIONS") == 1) { return 1; }
    return 0;
}

# 1.3.3 — FNV-1a 64-bit byte-mixer. Continues from a running hash
# `h` so the cred digest can chain multiple header values together
# in one accumulator without losing entropy across them. Same
# offset basis / prime as stdlib `hash_str` (lib/hashmap.cyr).
fn _sandhi_fnv1a_mix(h, s): i64 {
    if (s == 0) { return h; }
    var i = 0;
    while (load8(s + i) != 0) {
        h = h ^ load8(s + i);
        h = h * 0x100000001B3;
        i = i + 1;
    }
    return h;
}

# 1.3.3 — cred-strip-aware session-cache keying digest. Hashes the
# values of Authorization / Cookie / Proxy-Authorization headers
# (case-insensitive lookup via `sandhi_headers_get`) into a 64-bit
# digest. When at least one cred-bearing header is present, the
# digest folds in a per-header marker prefix ("A:" / "C:" / "P:")
# before the value bytes so a value reused across header names
# (e.g. same token in Authorization vs. Cookie) doesn't collide.
# Returns 0 when no cred-bearing headers — preserves the pre-1.3.3
# cache-key shape for the common service-to-service path.
#
# Used by `_sandhi_http_dispatch_a` / `sandhi_http_request_auto_a`
# to set the module-level `_sandhi_cred_digest` flag (defined in
# conn.cyr alongside `_sandhi_allow_0rtt`); the conn finalize reads
# the flag when calling `sandhi_session_cache_lookup` / `_store`.
# Named `_compute_` rather than just `_cred_digest` to avoid
# collision with the module-level variable of the same root.
fn _sandhi_compute_cred_digest(headers): i64 {
    if (headers == 0) { return 0; }
    var found = 0;
    var h = 0xCBF29CE484222325;  # FNV offset basis
    var v = sandhi_headers_get(headers, "Authorization");
    if (v != 0) {
        h = _sandhi_fnv1a_mix(h, "A:");
        h = _sandhi_fnv1a_mix(h, v);
        found = 1;
    }
    v = sandhi_headers_get(headers, "Cookie");
    if (v != 0) {
        h = _sandhi_fnv1a_mix(h, "C:");
        h = _sandhi_fnv1a_mix(h, v);
        found = 1;
    }
    v = sandhi_headers_get(headers, "Proxy-Authorization");
    if (v != 0) {
        h = _sandhi_fnv1a_mix(h, "P:");
        h = _sandhi_fnv1a_mix(h, v);
        found = 1;
    }
    if (found == 0) { return 0; }
    return h;
}

# Compute the effective connect_ms given a monotonic deadline.
# Returns connect_ms unchanged when deadline is disabled; otherwise
# clamps to `deadline - now`. Returns 0 if the deadline has already
# elapsed (caller treats as TIMEOUT).
fn _sandhi_http_clamp_ms(raw_ms, deadline_ms): i64 {
    if (deadline_ms <= 0) { return raw_ms; }
    var remaining = deadline_ms - clock_now_ms();
    if (remaining <= 0) { return 0 - 1; }  # sentinel: already elapsed
    if (raw_ms <= 0 || raw_ms > remaining) { return remaining; }
    return raw_ms;
}

# Keep this function compact — Cyrius 5.6.22 aliases locals on crowded
# frames. Everything meaningful lives in helpers. 1.2.0 added the `_a`
# variant that threads `a` through every per-request alloc:
# url-parse, DNS resolve (v4 + v6), conn-open (the `_a` paths exist as
# back-compat-clean leaves), request-builder, and the exchange recv
# buffer. Pool ops keep using the pool's own allocator (per
# `_sandhi_pool_alloc`) — pool entries outlive any per-request arena.
fn _sandhi_http_do_impl_a(a, method, url, user_headers, body, body_len, max_bytes,
connect_ms, read_ms, write_ms, total_ms, pool, ctx): i64 {
    sandhi_prof_reset();
    var u = sandhi_url_parse_a(a, url);
    sandhi_prof_capture(SANDHI_PROF_PHASE_URL_PARSE_END);
    if (u == 0) { return _sandhi_resp_err_a(a, SANDHI_ERR_PARSE); }

    # v4-first, v6-fallback. Most production hosts have v4 (often
    # alongside v6), so a v4 hit is the common path. v6-only hosts
    # are reached via _sandhi_client_resolve_v6 + the v6 connect
    # path in conn.cyr.
    var addr = _sandhi_client_resolve_a(a, sandhi_url_host(u));
    var addr6 = 0;
    if (addr == 0 - 1) {
        addr6 = _sandhi_client_resolve_v6_a(a, sandhi_url_host(u));
        if (addr6 == 0) {
            sandhi_prof_capture(SANDHI_PROF_PHASE_DNS_END);
            return _sandhi_resp_err_a(a, SANDHI_ERR_DISCOVERY);
        }
    }
    sandhi_prof_capture(SANDHI_PROF_PHASE_DNS_END);

    # Compute monotonic deadline if total_ms is set. Passed through to
    # exchange so the recv loop can break early. A fresh deadline
    # applies per _sandhi_http_do call; the redirect follower re-enters
    # here for each hop, so each hop gets its own `total_ms` budget.
    var deadline_ms = 0;
    if (total_ms > 0) { deadline_ms = clock_now_ms() + total_ms; }

    var use_tls = 0;
    if (sandhi_url_scheme(u) == SANDHI_URL_HTTPS) { use_tls = 1; }
    var port = sandhi_url_port(u);
    var host = sandhi_url_host(u);

    # Try the pool first when attached. A taken conn skips the connect
    # phase entirely (and its timeout). Failure on a pooled conn falls
    # back to opening a fresh one — peer may have closed since put-back.
    # 1.4.6 — a TLS policy on an HTTPS request bypasses the pool
    # (a pooled conn was opened under whatever policy created it;
    # policy-bound conns are single-use) and bypasses 0-RTT.
    var has_policy = 0;
    if (_sandhi_reqctx_tls_policy(ctx) != 0 && use_tls == 1) { has_policy = 1; }

    var keep_alive = 0;
    var conn = 0;
    if (pool != 0 && has_policy == 0) {
        keep_alive = 1;
        conn = _sandhi_pool_take(pool, host, port, use_tls);
    }

    # 1.3.2 — request build moved BEFORE conn-open so the bytes are
    # available to pass as early-data when 0-RTT eligible. For the
    # non-0-RTT path this is byte-identical to the pre-1.3.2 ordering
    # (the request bytes don't depend on the connection's properties,
    # only on the URL + headers + body + keep_alive).
    var full_path = _sandhi_client_full_path_a(a, u);
    var host_hdr = _sandhi_client_host_header_a(a, u);
    var req = _sandhi_client_build_request_va(a, method, full_path, host_hdr,
    user_headers, body_len, keep_alive);
    sandhi_prof_capture(SANDHI_PROF_PHASE_REQ_BUILD_END);

    if (conn == 0) {
        var eff_connect = _sandhi_http_clamp_ms(connect_ms, deadline_ms);
        if (eff_connect == 0 - 1) { return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT); }
        # 1.4.6 — install the TLS policy hook before opening. _pre arms
        # the _sandhi_tls_hook_override (consumed by finalize) when the
        # policy demands enforcement; returns -1 fail-closed when
        # enforcement is unavailable. The matching _post (after open)
        # clears the override + runs the SPKI pin check. Both helpers
        # live in tls_policy/apply.cyr, ordered ahead of client.cyr in
        # cyrius.cyml so they're reachable here.
        if (has_policy == 1) {
            if (_sandhi_policy_pre_open_a(a, _sandhi_reqctx_tls_policy(ctx), ctx) != 0) {
                return _sandhi_resp_err_a(a, SANDHI_ERR_TLS);
            }
        }
        # 1.3.2 — 0-RTT eligibility: opt-in flag set + TLS + method
        # is replay-safe + libssl exposes the full 0-RTT surface +
        # session-cache enabled (no session means no resumption).
        # The session-presence check itself happens inside
        # `_sandhi_conn_finalize_with_early_data_a` (per-cache-key
        # lookup); we just need the early_data bytes to be non-zero
        # for finalize to consider 0-RTT.
        var use_0rtt = 0;
        if (has_policy == 0
        && _sandhi_reqctx_allow_0rtt(ctx) == 1
        && use_tls == 1
        && _sandhi_method_is_replay_safe(method) == 1
        && tls_supports_early_data() == 1
        && sandhi_session_cache_enabled() == 1) {
            use_0rtt = 1;
        }
        var ed_ptr = 0;
        var ed_len = 0;
        if (use_0rtt == 1) {
            ed_ptr = str_data(req);
            ed_len = strlen(ed_ptr);
        }
        if (addr6 != 0) {
            if (use_0rtt == 1) {
                conn = _sandhi_conn_open_v6_fully_timed_with_early_data_a(a, addr6,
                port, use_tls, host, eff_connect, read_ms, write_ms, ed_ptr, ed_len, ctx);
            } else {
                conn = _sandhi_conn_open_v6_fully_timed_a(a, addr6, port, use_tls, host,
                eff_connect, read_ms, write_ms, ctx);
            }
        } else {
            if (use_0rtt == 1) {
                conn = _sandhi_conn_open_fully_timed_with_early_data_a(a, addr,
                port, use_tls, host, eff_connect, read_ms, write_ms, ed_ptr, ed_len, ctx);
            } else {
                conn = _sandhi_conn_open_fully_timed_ctx_a(a, addr, port, use_tls, host,
                eff_connect, read_ms, write_ms, ctx);
            }
        }
        # 1.4.6 — clear the policy hook override + run the post-handshake
        # SPKI pin check. _post always clears the override (even on a 0
        # conn from a failed open) and, on an SPKI mismatch, closes the
        # conn + sets last-err to TLS → the block below maps it to
        # SANDHI_ERR_TLS. Pass-through (no policy) leaves conn untouched.
        if (has_policy == 1) {
            conn = _sandhi_policy_post_open_a(a, conn, _sandhi_reqctx_tls_policy(ctx), ctx);
        }
        if (conn == 0) {
            sandhi_prof_capture(SANDHI_PROF_PHASE_CONN_OPEN_END);
            var oe = _sandhi_reqctx_err(ctx);
            if (oe == SANDHI_CONN_OPEN_TIMEOUT) { return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT); }
            if (oe == SANDHI_CONN_OPEN_TLS)     { return _sandhi_resp_err_a(a, SANDHI_ERR_TLS); }
            return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
        }
    }
    sandhi_prof_capture(SANDHI_PROF_PHASE_CONN_OPEN_END);

    var resp = 0;
    if (keep_alive == 1) {
        resp = _sandhi_http_exchange_keepalive_a(a, conn, req, body, body_len, max_bytes,
        deadline_ms, pool, host, port, use_tls);
    } else {
        resp = _sandhi_http_exchange_a(a, conn, req, body, body_len, max_bytes, deadline_ms);
    }
    sandhi_prof_capture(SANDHI_PROF_PHASE_EXCHANGE_END);
    return resp;
}

fn _sandhi_http_do_impl(method, url, user_headers, body, body_len, max_bytes,
connect_ms, read_ms, write_ms, total_ms, pool): i64 {
    return _sandhi_http_do_impl_a(default_alloc(), method, url, user_headers, body, body_len,
    max_bytes, connect_ms, read_ms, write_ms, total_ms, pool, 0);
}

# Send request, receive response, close connection. Extracted so the
# local count in _sandhi_http_do stays small. Returns SANDHI_ERR_TIMEOUT
# on SO_RCVTIMEO/SO_SNDTIMEO or deadline-exceeded; SANDHI_ERR_CONNECT
# for any other I/O fail. 1.2.0: `_a` threads `a` through the recv
# buffer alloc + response parse + every error-path resp construction;
# the bare version calls `_a` with default_alloc() for back-compat.
fn _sandhi_http_exchange_a(a, conn, req, body, body_len, max_bytes, deadline_ms): i64 {
    if (deadline_ms > 0 && clock_now_ms() >= deadline_ms) {
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
    }
    var req_data = str_data(req);
    var req_len = strlen(req_data);
    # 1.3.2 — TLS 1.3 0-RTT branch. When `conn` was opened with the
    # request bytes also written as early data (eligibility gated to
    # session-resumed TLS + replay-safe methods at conn-open time),
    # the 0-RTT status decides whether to re-send the request on the
    # normal stream:
    #   ACCEPTED (2)  — server processed the early data; skip resend.
    #   REJECTED (1)  — server discarded the early data; must resend.
    #   NOT_SENT (0)  — no early data was attempted; normal path.
    # NOT_SENT also covers every plaintext / non-resumed TLS exchange,
    # so the default path stays identical to pre-1.3.2 behavior.
    var ed_status = sandhi_conn_0rtt_status(conn);
    var skip_req_send = 0;
    if (ed_status == TLS_EARLY_DATA_ACCEPTED) { skip_req_send = 1; }
    if (skip_req_send == 0) {
        var sw = sandhi_conn_send_all(conn, req_data, req_len);
        if (sw == 0 - _SANDHI_EAGAIN) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
        }
        if (sw < 0) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
        }
    }
    if (body_len > 0 && body != 0) {
        var sb = sandhi_conn_send_all(conn, body, body_len);
        if (sb == 0 - _SANDHI_EAGAIN) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
        }
        if (sb < 0) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
        }
    }
    var cap = max_bytes;
    if (cap <= 0) { cap = _SANDHI_HTTP_RESP_BUF_SIZE; }
    var rbuf = alloc_via(a, cap + 1);
    # 1.2.6 OOM guard: if the recv buffer can't be allocated, close
    # the conn and surface INTERNAL — without this, recv_all_deadline
    # would write to address 0 and SIGSEGV.
    if (rbuf == 0) {
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_INTERNAL);
    }
    # 1.4.1 — frame the response by Content-Length / chunked (the same
    # `_sandhi_http_recv_framed` the keep-alive path uses) instead of draining
    # until EOF. A server that sends a complete, Content-Length-framed response
    # with `Connection: close` but does NOT promptly close the socket
    # (chromedriver, Chromium's DevTools — see
    # docs/issues/2026-06-03-http-close-path-drains-until-eof.md) otherwise
    # stalls this read until the deadline and we return TIMEOUT despite having
    # the whole response buffered. We close the conn right after regardless, so
    # the must-close sentinel (0 - 2) simply means "full response received" —
    # treat it as success. EOF-delimited (HTTP/1.0, no CL/chunked) still works:
    # recv_framed returns the bytes read at EOF.
    var nread = _sandhi_http_recv_framed(conn, rbuf, cap, deadline_ms);
    sandhi_conn_close(conn);
    if (nread == 0 - _SANDHI_EAGAIN) { return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT); }
    var actual_n = nread;
    if (nread == 0 - 2) {
        actual_n = strlen(rbuf);
    } elif (nread < 0) {
        return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
    }
    sandhi_prof_record_recv(cap, actual_n);
    return sandhi_http_response_parse_a(a, rbuf, actual_n);
}

fn _sandhi_http_exchange(conn, req, body, body_len, max_bytes, deadline_ms): i64 {
    return _sandhi_http_exchange_a(default_alloc(), conn, req, body, body_len, max_bytes, deadline_ms);
}

# Keep-alive variant — does framed recv (Content-Length or chunked
# detected from response headers) so the conn stays alive past the
# response. On success (2xx/3xx, no server-Connection-close) the conn
# is returned to the pool; otherwise it's closed. Bite 1 of 0.8.0.
# 1.2.0: `_a` threads `a` through the recv buffer + response parse +
# error-path resp construction. Pool put-back uses the pool's own
# allocator (`_sandhi_pool_alloc`) — pool entries outlive any per-
# request arena, so the put-back path is intentionally arena-skipping.
fn _sandhi_http_exchange_keepalive_a(a, conn, req, body, body_len, max_bytes,
deadline_ms, pool, host, port, use_tls): i64 {
    if (deadline_ms > 0 && clock_now_ms() >= deadline_ms) {
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
    }
    var req_data = str_data(req);
    var req_len = strlen(req_data);
    # 1.3.2 — same 0-RTT skip-resend gate as the non-keepalive exchange.
    # See `_sandhi_http_exchange_a` for the status-value rationale.
    var ed_status = sandhi_conn_0rtt_status(conn);
    var skip_req_send = 0;
    if (ed_status == TLS_EARLY_DATA_ACCEPTED) { skip_req_send = 1; }
    if (skip_req_send == 0) {
        var sw = sandhi_conn_send_all(conn, req_data, req_len);
        if (sw == 0 - _SANDHI_EAGAIN) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
        }
        if (sw < 0) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
        }
    }
    if (body_len > 0 && body != 0) {
        var sb = sandhi_conn_send_all(conn, body, body_len);
        if (sb == 0 - _SANDHI_EAGAIN) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
        }
        if (sb < 0) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
        }
    }
    var cap = max_bytes;
    if (cap <= 0) { cap = _SANDHI_HTTP_RESP_BUF_SIZE; }
    var rbuf = alloc_via(a, cap + 1);
    # 1.2.6 OOM guard: request + body have already been sent by
    # this point, so the conn is mid-exchange. Close (don't pool-
    # put) so the next request gets a fresh handshake; the peer
    # sees an abrupt close mid-response, which is the same shape
    # as a network drop and well within the keep-alive contract.
    if (rbuf == 0) {
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_INTERNAL);
    }
    var nread = _sandhi_http_recv_framed(conn, rbuf, cap, deadline_ms);
    sandhi_prof_record_recv(cap, nread);
    if (nread == 0 - _SANDHI_EAGAIN) {
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
    }
    if (nread < 0 && nread != 0 - 2) {
        # 0 - 2 is the must-close sentinel — we still got the response.
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
    }
    var server_sent_close = 0;
    var actual_n = nread;
    if (nread == 0 - 2) {
        # Server told us close; read whatever we have, then close.
        # _sandhi_http_recv_framed null-terminates buf at the bytes
        # actually read; recompute via strlen-style scan up to cap.
        actual_n = strlen(rbuf);
        server_sent_close = 1;
    }
    var resp = sandhi_http_response_parse_a(a, rbuf, actual_n);
    var status = sandhi_http_status(resp);
    var ek = sandhi_http_err_kind(resp);
    var put_back = 0;
    if (ek == SANDHI_OK && server_sent_close == 0
    && status >= 200 && status < 400) {
        put_back = 1;
    }
    if (put_back == 1) {
        _sandhi_pool_put(pool, host, port, use_tls, conn);
    } else {
        sandhi_conn_close(conn);
    }
    return resp;
}

fn _sandhi_http_exchange_keepalive(conn, req, body, body_len, max_bytes,
deadline_ms, pool, host, port, use_tls): i64 {
    return _sandhi_http_exchange_keepalive_a(default_alloc(), conn, req, body, body_len,
    max_bytes, deadline_ms, pool, host, port, use_tls);
}

# ================================================================
# Redirect following (opt-in, bounded)
# ================================================================
#
# RFC 7231 §6.4 method rewrite semantics:
#   303 See Other            — rewrite to GET, drop body
#   301/302/307/308         — preserve method + body
#
# Location may be absolute ("https://other.example.com/x") or relative
# ("/x" — resolve against the current URL's scheme+authority).

# Options struct (64 bytes):
#   +0   follow_redirects   (int: 0 default, 1 to enable)
#   +8   max_hops           (int: default 5)
#   +16  max_response_bytes (int: default 262144 = 256 KB; applies to
#                            the buffered client's scratch buffer and
#                            to streaming's per-buffer cap)
#   +24  read_ms            (int: SO_RCVTIMEO in ms; 0 = blocking).
#                            Added 0.7.2.
#   +32  write_ms           (int: SO_SNDTIMEO in ms; 0 = blocking).
#                            Added 0.7.2.
#   +40  connect_ms         (int: non-blocking connect + poll timeout
#                            in ms; 0 = blocking connect). Added 0.7.3.
#   +48  total_ms           (int: monotonic deadline for entire
#                            request-response cycle; 0 = no deadline).
#                            Bounds connect_ms + recv loop but not
#                            redirect-follow chain (each hop gets a
#                            fresh deadline). Added 0.7.3.
#   +56  pool               (ptr: sandhi_http_pool* or 0). When
#                            attached: emit Connection: keep-alive,
#                            try-take from pool before opening new,
#                            put-back on 2xx/3xx with no
#                            server-Connection-close. Added 0.8.0
#                            (Bite 1).
enum SandhiHttpOptOff {
    SANDHI_HTTP_OPT_OFF_FOLLOW       = 0;
    SANDHI_HTTP_OPT_OFF_MAX_HOPS     = 8;
    SANDHI_HTTP_OPT_OFF_MAX_BYTES    = 16;
    SANDHI_HTTP_OPT_OFF_READ_MS      = 24;
    SANDHI_HTTP_OPT_OFF_WRITE_MS     = 32;
    SANDHI_HTTP_OPT_OFF_CONNECT_MS   = 40;
    SANDHI_HTTP_OPT_OFF_TOTAL_MS     = 48;
    SANDHI_HTTP_OPT_OFF_POOL         = 56;
    SANDHI_HTTP_OPT_OFF_ALLOW_0RTT   = 64;   # 1.3.2 — opt-in TLS 1.3 0-RTT
    SANDHI_HTTP_OPT_OFF_TLS_POLICY   = 72;   # 1.4.6 — opt-in TLS policy (pin/mTLS/trust)
}

var SANDHI_HTTP_OPT_STRUCT_SIZE = 80;
var SANDHI_HTTP_DEFAULT_MAX_HOPS = 5;
var SANDHI_HTTP_DEFAULT_MAX_BYTES = 262144;

fn sandhi_http_options_new_a(a): i64 {
    var o = alloc_via(a, SANDHI_HTTP_OPT_STRUCT_SIZE);
    if (o == 0) { return 0; }
    store64(o + SANDHI_HTTP_OPT_OFF_FOLLOW, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_MAX_HOPS, SANDHI_HTTP_DEFAULT_MAX_HOPS);
    store64(o + SANDHI_HTTP_OPT_OFF_MAX_BYTES, SANDHI_HTTP_DEFAULT_MAX_BYTES);
    store64(o + SANDHI_HTTP_OPT_OFF_READ_MS, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_WRITE_MS, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_CONNECT_MS, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_TOTAL_MS, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_POOL, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_ALLOW_0RTT, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_TLS_POLICY, 0);
    return o;
}

fn sandhi_http_options_new(): i64 {
    return sandhi_http_options_new_a(default_alloc());
}

fn sandhi_http_options_follow_redirects(opts, on): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_FOLLOW, on);
    return 0;
}

fn sandhi_http_options_max_hops(opts, n): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_MAX_HOPS, n);
    return 0;
}

fn sandhi_http_options_max_response_bytes(opts, n): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_MAX_BYTES, n);
    return 0;
}

fn sandhi_http_options_read_ms(opts, ms): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_READ_MS, ms);
    return 0;
}

fn sandhi_http_options_write_ms(opts, ms): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_WRITE_MS, ms);
    return 0;
}

fn sandhi_http_options_connect_ms(opts, ms): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_CONNECT_MS, ms);
    return 0;
}

fn sandhi_http_options_total_ms(opts, ms): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_TOTAL_MS, ms);
    return 0;
}

fn sandhi_http_options_pool(opts, pool): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_POOL, pool);
    return 0;
}

# 1.3.2: opt-in TLS 1.3 0-RTT (early data). Default 0 = off.
# Replay-attack surface means this MUST stay default-off; consumers
# opt in per-request when they're sending replay-safe payloads
# (GET / HEAD / OPTIONS). Sandhi enforces method-safety internally
# even when this flag is set — POST / PUT / PATCH / DELETE silently
# skip 0-RTT regardless. Also gated on
# `tls_supports_early_data()` (libssl capability) + session-cache
# hit + cached session advertising 0-RTT support
# (`tls_session_get_max_early_data >= req_len`).
fn sandhi_http_options_allow_0rtt(opts, on): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_ALLOW_0RTT, on);
    return 0;
}

# 1.4.6 — attach a TLS policy (pin / mTLS / trust-store, built via
# `sandhi_tls_policy_new_pinned` / `_new_mtls` / `_new_trust_store` /
# `_combine`) to a high-level request. Default 0 = no enforcement
# (today's behavior). When set on an HTTPS request, `_sandhi_http_do_impl_a`
# (and `sandhi_http_stream_opts_a`) open through the policy opener:
# fail-closed if enforcement is unavailable, post-handshake SPKI pin
# check, and the connection is NOT pooled (policy-bound conns are
# single-use). A policy on a plain-HTTP request is ignored (no TLS to
# enforce). See docs/issues/2026-06-09-https-client-tls-policy-threading.md.
fn sandhi_http_options_tls_policy(opts, policy): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_TLS_POLICY, policy);
    return 0;
}

fn sandhi_http_options_get_tls_policy(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_TLS_POLICY);
}

fn sandhi_http_options_get_allow_0rtt(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_ALLOW_0RTT);
}

fn sandhi_http_options_follow(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_FOLLOW);
}

fn sandhi_http_options_hops(opts): i64 {
    if (opts == 0) { return SANDHI_HTTP_DEFAULT_MAX_HOPS; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_MAX_HOPS);
}

fn sandhi_http_options_bytes(opts): i64 {
    if (opts == 0) { return SANDHI_HTTP_DEFAULT_MAX_BYTES; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_MAX_BYTES);
}

fn sandhi_http_options_get_read_ms(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_READ_MS);
}

fn sandhi_http_options_get_write_ms(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_WRITE_MS);
}

fn sandhi_http_options_get_connect_ms(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_CONNECT_MS);
}

fn sandhi_http_options_get_total_ms(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_TOTAL_MS);
}

fn sandhi_http_options_get_pool(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_POOL);
}

# 1 if the status code indicates a redirect we follow.
fn _sandhi_is_redirect(status): i64 {
    if (status == 301) { return 1; }
    if (status == 302) { return 1; }
    if (status == 303) { return 1; }
    if (status == 307) { return 1; }
    if (status == 308) { return 1; }
    return 0;
}

# Resolve a Location header value against a base URL. Returns an alloc'd
# cstr with a fully-qualified URL, or 0 if resolution fails.
fn _sandhi_resolve_location_a(a, base_url, location): i64 {
    if (location == 0) { return 0; }
    if (_sandhi_url_sceq(location, "http://", 7) == 1
    || _sandhi_url_sceq(location, "https://", 8) == 1) {
        var llen = strlen(location);
        var out = alloc_via(a, llen + 1);
        if (out == 0) { return 0; }
        memcpy(out, location, llen);
        store8(out + llen, 0);
        return out;
    }
    if (load8(location) != 47) { return 0; }
    var u = sandhi_url_parse_a(a, base_url);
    if (u == 0) { return 0; }
    # 1.2.8: was `str_builder_new()` (default_alloc) — partial-
    # arena leak found during the OOM audit. The fn is `_a` and
    # callers expect every alloc on `a`; the str_builder scratch
    # was bypassing that. Threaded through `_a` variants now;
    # OOM null-guard added on `str_builder_new_a`.
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0; }
    if (sandhi_url_scheme(u) == SANDHI_URL_HTTPS) {
        str_builder_add_cstr_a(a, sb, "https://");
    } else {
        str_builder_add_cstr_a(a, sb, "http://");
    }
    str_builder_add_cstr_a(a, sb, sandhi_url_host(u));
    var scheme = sandhi_url_scheme(u);
    var default_port = 80;
    if (scheme == SANDHI_URL_HTTPS) { default_port = 443; }
    if (sandhi_url_port(u) != default_port) {
        str_builder_add_cstr_a(a, sb, ":");
        str_builder_add_int_a(a, sb, sandhi_url_port(u));
    }
    str_builder_add_cstr_a(a, sb, location);
    return _sandhi_json_dup_a(a, str_data(str_builder_build_a(a, sb)));
}

fn _sandhi_resolve_location(base_url, location): i64 {
    return _sandhi_resolve_location_a(default_alloc(), base_url, location);
}

# 0.9.0 P0 #4 — case-insensitive cstr compare. Used by the redirect
# follower for header-name filtering. Inlined here rather than in
# headers.cyr because the only consumer is right below.
fn _sandhi_streq_ci(a, b): i64 {
    if (a == 0 || b == 0) { return 0; }
    var i = 0;
    while (1 == 1) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ca >= 65 && ca <= 90) { ca = ca + 32; }
        if (cb >= 65 && cb <= 90) { cb = cb + 32; }
        if (ca != cb) { return 0; }
        if (ca == 0)  { return 1; }
        i = i + 1;
    }
    return 0;
}

# 1 if `next_url` has the same scheme+host+port as `prev_url`. Used
# to decide whether to forward sensitive headers across a redirect.
fn _sandhi_url_same_authority(prev_url, next_url): i64 {
    var pu = sandhi_url_parse(prev_url);
    var nu = sandhi_url_parse(next_url);
    if (pu == 0 || nu == 0) { return 0; }
    if (sandhi_url_scheme(pu) != sandhi_url_scheme(nu)) { return 0; }
    if (sandhi_url_port(pu) != sandhi_url_port(nu)) { return 0; }
    if (streq(sandhi_url_host(pu), sandhi_url_host(nu)) != 1) { return 0; }
    return 1;
}

# 1 if `prev_url` was HTTPS and `next_url` is HTTP — a security
# downgrade we refuse to follow per the curl CVE-2025-0167 /
# 14524 cluster lessons.
fn _sandhi_url_is_https_downgrade(prev_url, next_url): i64 {
    var pu = sandhi_url_parse(prev_url);
    var nu = sandhi_url_parse(next_url);
    if (pu == 0 || nu == 0) { return 0; }
    if (sandhi_url_scheme(pu) == SANDHI_URL_HTTPS
    && sandhi_url_scheme(nu) == SANDHI_URL_HTTP) { return 1; }
    return 0;
}

# Return a fresh sandhi_headers struct that's a copy of `src` with
# `Authorization`, `Cookie`, and `Proxy-Authorization` stripped.
# Used when a redirect crosses authorities — the caller's secret
# wasn't intended for the new origin.
fn _sandhi_strip_sensitive_headers_a(a, src): i64 {
    if (src == 0) { return 0; }
    var out = sandhi_headers_new_a(a);
    if (out == 0) { return 0; }
    var n = sandhi_headers_count(src);
    var i = 0;
    while (i < n) {
        var name = sandhi_headers_name_at(src, i);
        var value = sandhi_headers_value_at(src, i);
        var keep = 1;
        if (_sandhi_streq_ci(name, "authorization") == 1)        { keep = 0; }
        if (_sandhi_streq_ci(name, "cookie") == 1)               { keep = 0; }
        if (_sandhi_streq_ci(name, "proxy-authorization") == 1)  { keep = 0; }
        if (keep == 1) { sandhi_headers_add_a(a, out, name, value); }
        i = i + 1;
    }
    return out;
}

fn _sandhi_strip_sensitive_headers(src): i64 {
    return _sandhi_strip_sensitive_headers_a(default_alloc(), src);
}

# Redirect-following driver. Keep compact — each iteration reassigns
# locals rather than allocating new ones, so the function stays under
# the Cyrius local-count threshold. total_ms resets per hop (each
# destination gets its own request budget); if a tighter end-to-end
# bound is needed, the caller should lower max_hops or pre-compute.
#
# 0.9.0 P0 #4 — security-aware redirect handling:
#   - Refuse https→http downgrades (return the prior response with
#     `SANDHI_ERR_TLS` rather than silently leaking creds in
#     plaintext to an attacker-controlled `Location:`).
#   - Strip `Authorization` / `Cookie` / `Proxy-Authorization` from
#     headers when the redirect crosses authorities (different
#     scheme / host / port). The caller's secret was bound to the
#     original origin; the redirect target may be hostile.
#   - Both apply per-hop, so a chain that bounces back to the
#     original authority gets the full headers again. (curl does
#     the same; matches RFC 7235 §2.2 spirit even though the spec
#     doesn't mandate.)
fn _sandhi_http_follow_a(a, method, url, headers, body, body_len, max_hops,
max_bytes, connect_ms, read_ms, write_ms, total_ms, pool, ctx): i64 {
    var m = method;
    var u = url;
    var b = body;
    var bl = body_len;
    var h = headers;
    var hops = 0;
    var r = _sandhi_http_do_a(a, m, u, h, b, bl, max_bytes,
    connect_ms, read_ms, write_ms, total_ms, pool, ctx);
    while (hops < max_hops) {
        if (_sandhi_is_redirect(sandhi_http_status(r)) == 0) { return r; }
        var loc = sandhi_headers_get(sandhi_http_headers(r), "Location");
        if (loc == 0) { return r; }
        var next = _sandhi_resolve_location_a(a, u, loc);
        if (next == 0) { return r; }

        # Refuse https→http downgrade — surface the redirect response
        # with err_kind=TLS so the caller sees the refusal rather
        # than transparently following.
        if (_sandhi_url_is_https_downgrade(u, next) == 1) {
            store64(r + SANDHI_RESP_OFF_ERR_KIND, SANDHI_ERR_TLS);
            return r;
        }

        # Strip sensitive headers if crossing authorities.
        if (_sandhi_url_same_authority(u, next) == 0) {
            h = _sandhi_strip_sensitive_headers_a(a, h);
        }

        if (sandhi_http_status(r) == 303) { m = "GET"; b = 0; bl = 0; }
        u = next;
        hops = hops + 1;
        r = _sandhi_http_do_a(a, m, u, h, b, bl, max_bytes,
        connect_ms, read_ms, write_ms, total_ms, pool, ctx);
    }
    return r;
}

fn _sandhi_http_follow(method, url, headers, body, body_len, max_hops,
max_bytes, connect_ms, read_ms, write_ms, total_ms, pool): i64 {
    return _sandhi_http_follow_a(default_alloc(), method, url, headers, body, body_len,
    max_hops, max_bytes, connect_ms, read_ms, write_ms, total_ms, pool, 0);
}

# ================================================================
# Public verbs
# ================================================================

# Core dispatch. Opts == 0 means single request; opts with follow == 1
# engages the redirect-following driver up to max_hops. 1.2.1: both
# the no-follow and follow paths thread `a` end-to-end (the 1.2.0
# partial-arena leak on follow=1 is closed).
fn _sandhi_http_dispatch_a(a, method, url, headers, body, body_len, opts): i64 {
    var max_bytes = sandhi_http_options_bytes(opts);
    var read_ms = sandhi_http_options_get_read_ms(opts);
    var write_ms = sandhi_http_options_get_write_ms(opts);
    var connect_ms = sandhi_http_options_get_connect_ms(opts);
    var total_ms = sandhi_http_options_get_total_ms(opts);
    var pool = sandhi_http_options_get_pool(opts);
    # 1.6.9 — per-call request context. Replaces the former module-global
    # save/restore of the 0-RTT opt-in / cred-digest / pending TLS policy
    # (and the open-error classification): each rode one process-wide word,
    # so two dispatches on separate OS threads raced them (thoth's parallel
    # `sandhi_http_post_a` workers). The context is arena-allocated, so
    # distinct-arena concurrent dispatches each get their own, and it
    # threads through do/follow -> do_impl -> conn-open -> finalize (+ the
    # TLS-policy pre/post-open helpers). The three values are computed
    # per-call exactly as before; the connect path now writes its open-error
    # classification into the same context (read back below the open in
    # do_impl) instead of `_sandhi_conn_last_err`. ONE context is reused for
    # the whole redirect-follow hop chain, so the cred-digest is still
    # computed once per top-level dispatch — same semantics as the prior
    # save/restore (the "per-hop cred-digest recompute on cross-authority
    # redirect-follow" wait-for-consumer item is unchanged). A 32-byte OOM
    # is a fatal per-request failure -> INTERNAL.
    var ctx = alloc_via(a, SANDHI_REQCTX_SIZE);
    if (ctx == 0) { return _sandhi_resp_err_a(a, SANDHI_ERR_INTERNAL); }
    store64(ctx + SANDHI_REQCTX_OFF_ALLOW_0RTT, sandhi_http_options_get_allow_0rtt(opts));
    store64(ctx + SANDHI_REQCTX_OFF_CRED_DIGEST, _sandhi_compute_cred_digest(headers));
    store64(ctx + SANDHI_REQCTX_OFF_TLS_POLICY, sandhi_http_options_get_tls_policy(opts));
    store64(ctx + SANDHI_REQCTX_OFF_LAST_ERR, SANDHI_CONN_OPEN_OK);
    var r = 0;
    if (sandhi_http_options_follow(opts) == 1) {
        var hops = sandhi_http_options_hops(opts);
        r = _sandhi_http_follow_a(a, method, url, headers, body, body_len, hops,
        max_bytes, connect_ms, read_ms, write_ms, total_ms, pool, ctx);
    } else {
        r = _sandhi_http_do_a(a, method, url, headers, body, body_len,
        max_bytes, connect_ms, read_ms, write_ms, total_ms, pool, ctx);
    }
    return r;
}

fn _sandhi_http_dispatch(method, url, headers, body, body_len, opts): i64 {
    return _sandhi_http_dispatch_a(default_alloc(), method, url, headers, body, body_len, opts);
}

# Simple verbs — no redirect following. Pass user_headers = 0 for none.
# 1.2.2 Batch D: every verb gains an `_a` variant that takes the
# allocator as the first arg. Internal cascade has been fully
# `_a`-threaded since 1.2.1, so the wrappers are thin — `_a` calls
# `_sandhi_http_dispatch_a(a, ...)`; bare versions stay as
# back-compat wrappers passing `default_alloc()`. Consumers wiring
# a per-request arena now have an end-to-end path:
# `sandhi_http_get_a(arena, url, headers)` allocates response +
# body + parsed headers entirely in the arena.
fn sandhi_http_get_a(a, url, user_headers): i64 {
    return _sandhi_http_dispatch_a(a, "GET", url, user_headers, 0, 0, 0);
}

fn sandhi_http_get(url, user_headers): i64 {
    return sandhi_http_get_a(default_alloc(), url, user_headers);
}

fn sandhi_http_post_a(a, url, user_headers, body, body_len): i64 {
    return _sandhi_http_dispatch_a(a, "POST", url, user_headers, body, body_len, 0);
}

fn sandhi_http_post(url, user_headers, body, body_len): i64 {
    return sandhi_http_post_a(default_alloc(), url, user_headers, body, body_len);
}

fn sandhi_http_put_a(a, url, user_headers, body, body_len): i64 {
    return _sandhi_http_dispatch_a(a, "PUT", url, user_headers, body, body_len, 0);
}

fn sandhi_http_put(url, user_headers, body, body_len): i64 {
    return sandhi_http_put_a(default_alloc(), url, user_headers, body, body_len);
}

fn sandhi_http_patch_a(a, url, user_headers, body, body_len): i64 {
    return _sandhi_http_dispatch_a(a, "PATCH", url, user_headers, body, body_len, 0);
}

fn sandhi_http_patch(url, user_headers, body, body_len): i64 {
    return sandhi_http_patch_a(default_alloc(), url, user_headers, body, body_len);
}

fn sandhi_http_delete_a(a, url, user_headers): i64 {
    return _sandhi_http_dispatch_a(a, "DELETE", url, user_headers, 0, 0, 0);
}

fn sandhi_http_delete(url, user_headers): i64 {
    return sandhi_http_delete_a(default_alloc(), url, user_headers);
}

fn sandhi_http_head_a(a, url, user_headers): i64 {
    return _sandhi_http_dispatch_a(a, "HEAD", url, user_headers, 0, 0, 0);
}

fn sandhi_http_head(url, user_headers): i64 {
    return sandhi_http_head_a(default_alloc(), url, user_headers);
}

# _opts variants — pass a sandhi_http_options_new() with
# follow_redirects enabled to opt into redirect chasing.
# 1.2.3 Batch E: each gains an `_a` variant; bare versions stay
# as back-compat wrappers passing `default_alloc()`. Underlying
# `_sandhi_http_dispatch_a` has been `_a`-threaded since 1.2.0.
fn sandhi_http_get_opts_a(a, url, user_headers, opts): i64 {
    return _sandhi_http_dispatch_a(a, "GET", url, user_headers, 0, 0, opts);
}

fn sandhi_http_get_opts(url, user_headers, opts): i64 {
    return sandhi_http_get_opts_a(default_alloc(), url, user_headers, opts);
}

fn sandhi_http_post_opts_a(a, url, user_headers, body, body_len, opts): i64 {
    return _sandhi_http_dispatch_a(a, "POST", url, user_headers, body, body_len, opts);
}

fn sandhi_http_post_opts(url, user_headers, body, body_len, opts): i64 {
    return sandhi_http_post_opts_a(default_alloc(), url, user_headers, body, body_len, opts);
}

# --- pool.cyr ---

# sandhi/http/pool — connection pool for HTTP/1.1 keep-alive (and h2
# stream-multiplex once Bite 6 lands).
#
# Why this exists: every request through `sandhi_http_get` etc.
# without a pool pays a full TCP handshake + TLS handshake. For a
# yantra/daimon RPC loop hitting the same host 100×/sec, that's
# 100× the round-trip cost it needs to be. A small pool with a
# generous idle timeout amortizes those handshakes across many
# requests at trivial memory cost.
#
# Pool struct (32 bytes):
#   +0   map               (host:port:tls cstr → vec<idle_conn>)
#   +8   max_per_host      (int: cap on idle conns per route)
#   +16  idle_timeout_ms   (int: stale-conn evict threshold)
#   +24  total_idle        (int: sum of all vec lens; observability)
#
# idle_conn struct (16 bytes):
#   +0   conn              (ptr to sandhi_conn struct)
#   +8   last_used_ms      (clock_now_ms() at put time)
#
# Lifecycle: take / put / close.
#   - take(host, port, tls) returns the freshest idle conn for the
#     route, or 0 if none. Stale conns (now - last_used >
#     idle_timeout_ms) are closed and discarded; take recurses.
#   - put(host, port, tls, conn) stores the conn for reuse. If the
#     vec is at max_per_host, the OLDEST entry is evicted (FIFO
#     across the cap; LIFO take order keeps the freshest hot).
#   - close drops every idle conn (calls sock_close + tls_close).
#
# Single-threaded today. Multi-threaded clients would need a
# per-pool mutex; tracked as a wait-for-consumer-ask roadmap item
# (no consumer needs concurrent request dispatch today).

enum SandhiPoolOff {
    SANDHI_POOL_OFF_MAP             = 0;
    SANDHI_POOL_OFF_MAX_PER_HOST    = 8;
    SANDHI_POOL_OFF_IDLE_TIMEOUT    = 16;
    SANDHI_POOL_OFF_TOTAL_IDLE      = 24;
    SANDHI_POOL_OFF_H2_MAP          = 32;   # added 0.8.0 Bite 6
    SANDHI_POOL_OFF_ALLOC           = 40;   # added 1.1.0 — Allocator handle
}

enum SandhiIdleConnOff {
    SANDHI_IDLE_OFF_CONN     = 0;
    SANDHI_IDLE_OFF_LAST_MS  = 8;
}

var SANDHI_POOL_STRUCT_SIZE      = 48;
var SANDHI_IDLE_CONN_STRUCT_SIZE = 16;
var SANDHI_POOL_DEFAULT_MAX_PER_HOST     = 8;
var SANDHI_POOL_DEFAULT_IDLE_TIMEOUT_MS  = 90000;  # 90 s — Go default

# ================================================================
# Public API
# ================================================================

# Build a connection pool whose internal allocations all flow through
# `a`. The Allocator handle lives on the pool struct so subsequent
# `_sandhi_pool_put` calls allocate idle-conn wrappers from the same
# place — important when consumers want pool churn isolated from the
# global bump (e.g., a long-lived service backed by an arena it
# periodically reset). Returns 0 on OOM.
fn sandhi_http_pool_new_a(a, max_per_host, idle_timeout_ms): i64 {
    var p = alloc_via(a, SANDHI_POOL_STRUCT_SIZE);
    if (p == 0) { return 0; }
    store64(p + SANDHI_POOL_OFF_MAP, map_new_a(a));
    var mph = max_per_host;
    if (mph <= 0) { mph = SANDHI_POOL_DEFAULT_MAX_PER_HOST; }
    var ito = idle_timeout_ms;
    if (ito <= 0) { ito = SANDHI_POOL_DEFAULT_IDLE_TIMEOUT_MS; }
    store64(p + SANDHI_POOL_OFF_MAX_PER_HOST, mph);
    store64(p + SANDHI_POOL_OFF_IDLE_TIMEOUT, ito);
    store64(p + SANDHI_POOL_OFF_TOTAL_IDLE, 0);
    # h2 multiplex (Bite 6): one h2 conn per route. h2_map keys are
    # the same "host:port:tls" cstrs the 1.1 map uses; values are
    # sandhi_h2_conn ptrs (not idle_conn wrappers — h2 is always
    # active so last_used_ms isn't meaningful).
    store64(p + SANDHI_POOL_OFF_H2_MAP, map_new_a(a));
    store64(p + SANDHI_POOL_OFF_ALLOC, a);
    return p;
}

fn sandhi_http_pool_new(max_per_host, idle_timeout_ms): i64 {
    return sandhi_http_pool_new_a(default_alloc(), max_per_host, idle_timeout_ms);
}

# Read back the Allocator stored at construction time. Returns
# default_alloc() if the pool was built before 1.1.0 (legacy callers
# can't reach this path; the slot is always written by `_new_a`).
fn _sandhi_pool_alloc(p): i64 {
    if (p == 0) { return default_alloc(); }
    var a = load64(p + SANDHI_POOL_OFF_ALLOC);
    if (a == 0) { return default_alloc(); }
    return a;
}

fn sandhi_http_pool_max_per_host(p): i64 {
    if (p == 0) { return SANDHI_POOL_DEFAULT_MAX_PER_HOST; }
    return load64(p + SANDHI_POOL_OFF_MAX_PER_HOST);
}

fn sandhi_http_pool_idle_timeout_ms(p): i64 {
    if (p == 0) { return SANDHI_POOL_DEFAULT_IDLE_TIMEOUT_MS; }
    return load64(p + SANDHI_POOL_OFF_IDLE_TIMEOUT);
}

fn sandhi_http_pool_idle_count(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_POOL_OFF_TOTAL_IDLE);
}

# Drop every idle conn (closes fds + TLS contexts). Pool struct stays
# allocated and reusable; map is cleared.
fn sandhi_http_pool_close(p): i64 {
    if (p == 0) { return 0; }
    var m = load64(p + SANDHI_POOL_OFF_MAP);
    var keys = map_keys(m);
    var i = 0;
    var n = vec_len(keys);
    while (i < n) {
        var key = vec_get(keys, i);
        var v = map_get(m, key);
        if (v != 0) {
            var j = 0;
            var jn = vec_len(v);
            while (j < jn) {
                var ic = vec_get(v, j);
                if (ic != 0) {
                    var c = load64(ic + SANDHI_IDLE_OFF_CONN);
                    if (c != 0) { sandhi_conn_close(c); }
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    map_clear(m);
    store64(p + SANDHI_POOL_OFF_TOTAL_IDLE, 0);
    # The h2_map is cleared but its h2-conn values are NOT walked
    # here — pool.cyr can't reference sandhi_h2_conn_underlying
    # without violating the build order (Bite 6 added the h2_map
    # field; tear-down lives in src/http/h2/pool_glue.cyr's
    # `sandhi_http_pool_close_h2_conns` so consumers that opted into
    # h2 explicitly tear those down before this generic close).
    var h2m = load64(p + SANDHI_POOL_OFF_H2_MAP);
    if (h2m != 0) { map_clear(h2m); }
    return 0;
}

# ================================================================
# Internal: route key + idle_conn helpers
# ================================================================

# Build a route key "host:port:tls" as a NUL-terminated cstr that
# map_get/map_set can use directly. tls is "0" or "1".
fn _sandhi_pool_route_key(host, port, tls): i64 {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, host);
    str_builder_add_cstr(sb, ":");
    str_builder_add_int(sb, port);
    str_builder_add_cstr(sb, ":");
    if (tls == 1) { str_builder_add_cstr(sb, "1"); }
    else          { str_builder_add_cstr(sb, "0"); }
    return str_data(str_builder_build(sb));
}

fn _sandhi_pool_idle_conn_new_a(a, conn, now_ms): i64 {
    var ic = alloc_via(a, SANDHI_IDLE_CONN_STRUCT_SIZE);
    if (ic == 0) { return 0; }
    store64(ic + SANDHI_IDLE_OFF_CONN, conn);
    store64(ic + SANDHI_IDLE_OFF_LAST_MS, now_ms);
    return ic;
}

fn _sandhi_pool_idle_conn_new(conn, now_ms): i64 {
    return _sandhi_pool_idle_conn_new_a(default_alloc(), conn, now_ms);
}

# Non-consuming peek: 1 if the route has at least one 1.1 idle conn
# that is NOT past idle_timeout_ms. Used by the h2 auto-promoter
# (`_sandhi_http_try_h2_promote`) to decide whether to attempt ALPN
# promotion or just take the existing 1.1 conn.
#
# 0.9.10 hardening: previously this peek returned 1 whenever the
# per-route vec had any entry, regardless of staleness. Two
# consequences for routes whose only entries had aged past
# idle_timeout_ms:
#   - ALPN promotion was incorrectly skipped, so h2 was never
#     attempted on a route that previously got 1.1 — even after
#     all those 1.1 conns went stale and would be discarded by
#     `_sandhi_pool_take` on the very next request.
#   - The fall-through `_sandhi_http_do` then opened a fresh
#     TLS+1.1 conn (correct), but the chance to negotiate h2 was
#     gone until something else reaped the stale entries.
# The walk is non-destructive — `_sandhi_pool_take` already does
# stale-skip on the take path, so reaping happens naturally.
fn _sandhi_pool_has_idle(pool, host, port, tls): i64 {
    if (pool == 0) { return 0; }
    var key = _sandhi_pool_route_key(host, port, tls);
    var m = load64(pool + SANDHI_POOL_OFF_MAP);
    var v = map_get(m, key);
    if (v == 0) { return 0; }
    var n = vec_len(v);
    if (n == 0) { return 0; }
    var idle_to = load64(pool + SANDHI_POOL_OFF_IDLE_TIMEOUT);
    var now = clock_now_ms();
    var i = 0;
    while (i < n) {
        var ic = vec_get(v, i);
        if (ic != 0) {
            var last = load64(ic + SANDHI_IDLE_OFF_LAST_MS);
            if (now - last <= idle_to) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Take / put — the hot path
# ================================================================

# Fish a conn out of the pool for the given route. Returns 0 if the
# pool is empty for that route. Stale conns (idle > idle_timeout_ms)
# are closed and skipped before returning a fresh one. take is LIFO
# over the per-route vec (freshest first) — keeps the most-recently-
# used conn hot in the kernel buffer cache.
fn _sandhi_pool_take(pool, host, port, tls): i64 {
    if (pool == 0) { return 0; }
    var key = _sandhi_pool_route_key(host, port, tls);
    var m = load64(pool + SANDHI_POOL_OFF_MAP);
    var v = map_get(m, key);
    if (v == 0) { return 0; }
    var idle_to = load64(pool + SANDHI_POOL_OFF_IDLE_TIMEOUT);
    var now = clock_now_ms();
    var picked = 0;
    while (picked == 0 && vec_len(v) > 0) {
        var ic = vec_pop(v);
        if (ic == 0) { return 0; }  # defensive; vec_pop shouldn't yield 0
        var conn = load64(ic + SANDHI_IDLE_OFF_CONN);
        var last = load64(ic + SANDHI_IDLE_OFF_LAST_MS);
        store64(pool + SANDHI_POOL_OFF_TOTAL_IDLE,
        load64(pool + SANDHI_POOL_OFF_TOTAL_IDLE) - 1);
        if (now - last > idle_to) {
            # Stale — peer may have closed it. Close + try next.
            if (conn != 0) { sandhi_conn_close(conn); }
        } else {
            return conn;
        }
    }
    return 0;
}

# Return a conn to the pool. If the per-route vec is at max_per_host,
# the oldest (front of vec) is evicted to make room — bounded memory.
# Caller guarantees the conn is still usable (2xx/3xx response, no
# server-sent Connection: close).
fn _sandhi_pool_put(pool, host, port, tls, conn): i64 {
    if (pool == 0 || conn == 0) {
        if (conn != 0) { sandhi_conn_close(conn); }
        return 0;
    }
    var key = _sandhi_pool_route_key(host, port, tls);
    var m = load64(pool + SANDHI_POOL_OFF_MAP);
    var v = map_get(m, key);
    if (v == 0) {
        v = vec_new();
        map_set(m, key, v);
    }
    var cap = load64(pool + SANDHI_POOL_OFF_MAX_PER_HOST);
    if (vec_len(v) >= cap) {
        # Evict oldest (index 0). vec_remove shifts the rest.
        var oldest = vec_get(v, 0);
        if (oldest != 0) {
            var oc = load64(oldest + SANDHI_IDLE_OFF_CONN);
            if (oc != 0) { sandhi_conn_close(oc); }
        }
        vec_remove(v, 0);
        store64(pool + SANDHI_POOL_OFF_TOTAL_IDLE,
        load64(pool + SANDHI_POOL_OFF_TOTAL_IDLE) - 1);
    }
    var ic = _sandhi_pool_idle_conn_new_a(_sandhi_pool_alloc(pool), conn, clock_now_ms());
    if (ic == 0) {
        # Allocator failure on the put path — drop the conn on the floor
        # rather than leaking it. Caller treats put as fire-and-forget,
        # so there's nothing to surface; the conn close mirrors the
        # max_per_host eviction path's free-it-here semantics.
        sandhi_conn_close(conn);
        return 0;
    }
    vec_push(v, ic);
    store64(pool + SANDHI_POOL_OFF_TOTAL_IDLE,
    load64(pool + SANDHI_POOL_OFF_TOTAL_IDLE) + 1);
    return 0;
}

# ================================================================
# Framing-aware response read for keep-alive
# ================================================================
#
# When the connection is going back to the pool we cannot read-to-EOF
# (the peer is keeping the socket open for the next request). Read
# incrementally until we have a complete response per its declared
# framing — Content-Length or chunked. HTTP/1.0 / no-framing
# responses always close the connection per RFC 7230 §3.3.3 ("connection
# closed by server"); the caller treats that as no-keep-alive.
#
# Returns:
#   - bytes-read on success (≥ 0)
#   - 0 - _SANDHI_EAGAIN on read deadline
#   - 0 - 1 on protocol error or buffer exhaustion
#   - 0 - 2 if the response declares Connection: close (caller must
#         not put back into the pool; we read what we can and stop)
#
# Status: this function is the keep-alive correctness boundary.
# Trailer parsing landed at 0.9.4 in `_sandhi_resp_decode_chunked`
# (response.cyr) — RFC 7230 §4.1.2 trailers are merged into the
# response's headers map, with the §4.1.2 forbidden-name list
# filtered. The pool-side completeness check below still treats
# `0\r\n\r\n` as the simple terminator without parsing the trailer
# block; that's safe because the body itself is complete at that
# point — completeness is what gates pool put-back. Actual trailer
# bytes that follow are consumed by the response parser when the
# scratch buffer is handed to `sandhi_http_response_parse`.

fn _sandhi_pool_chunked_complete(buf, body_start, blen): i64 {
    # Walk the chunked body looking for terminal 0-chunk. Returns 1
    # if a complete chunked stream is present in [body_start, blen),
    # 0 if more bytes are needed, (0 - 1) on malformed chunk-size.
    var off = body_start;
    var going = 1;
    while (going == 1) {
        if (off >= blen) { return 0; }
        # Parse chunk-size hex digits.
        var size = 0;
        var seen = 0;
        var scan = 1;
        while (scan == 1 && off < blen) {
            var c = load8(buf + off);
            if (c >= 48 && c <= 57)      { size = size * 16 + (c - 48); seen = 1; off = off + 1; }
            elif (c >= 97 && c <= 102)   { size = size * 16 + (c - 87); seen = 1; off = off + 1; }
            elif (c >= 65 && c <= 70)    { size = size * 16 + (c - 55); seen = 1; off = off + 1; }
            else { scan = 0; }
        }
        if (seen == 0 && off >= blen) { return 0; }
        if (seen == 0) { return 0 - 1; }
        # Skip chunk-extension up to CR or LF.
        while (off < blen && load8(buf + off) != 13 && load8(buf + off) != 10) {
            off = off + 1;
        }
        if (off >= blen) { return 0; }
        # Eat CRLF.
        if (load8(buf + off) == 13) {
            if (off + 1 >= blen) { return 0; }
            off = off + 2;
        } else {
            off = off + 1;
        }
        if (size == 0) {
            # Terminal — need trailing CRLF (skipping any trailers).
            # We accept 0\r\n\r\n as "done" without parsing trailers.
            if (off + 1 >= blen) { return 0; }
            return 1;
        }
        # Skip data + trailing CRLF.
        if (off + size + 2 > blen) { return 0; }
        off = off + size + 2;
    }
    return 0;
}

# Receive a framed response into a scratch buffer that the caller
# allocated (`buf`, capacity `cap`). Returns total bytes read, or
# negative sentinel per top-of-section. `deadline_ms` (0 = none)
# bounds the total recv loop. Reads in 4 KB chunks for sane progress.
fn _sandhi_http_recv_framed(conn, buf, cap, deadline_ms): i64 {
    var have = 0;
    var headers_end = 0 - 1;
    var body_start = 0;
    var content_length = 0 - 1;  # -1 = unparsed sentinel
    var is_chunked = 0;
    var must_close = 0;

    # Read in whole-TLS-record steps (16384 = TLS_RECORD_MAX_PLAINTEXT) rather than
    # a small sub-record chunk. This is an EFFICIENCY choice, not a correctness
    # one: the native `tls_read` delivers partial records and holds any remainder
    # (as libssl always has), so a smaller ask is still correct — the `ask =
    # min(step, room)` clamp below can pass a sub-record ask near buffer-full and
    # that is fine. But a record-sized ask lets each tls_read return a full record
    # in one call instead of several hold-buffer slices, cutting recv/decrypt
    # round-trips on large responses. (A prior 4096 step exposed a native-backend
    # bug where a whole record could not be delivered into a sub-record ask; that
    # bug is fixed in the TLS layer, and this step keeps the common path cheap.)
    var step = 16384;
    var scratch_done = 0;

    var going = 1;
    while (going == 1) {
        if (have >= cap) { return 0 - 1; }
        if (deadline_ms > 0 && clock_now_ms() >= deadline_ms) {
            return 0 - _SANDHI_EAGAIN;
        }
        var room = cap - have;
        var ask = step;
        if (ask > room) { ask = room; }
        var n = sandhi_conn_recv(conn, buf + have, ask);
        if (n == 0 - _SANDHI_EAGAIN) { return 0 - _SANDHI_EAGAIN; }
        if (n < 0) { return 0 - 1; }
        if (n == 0) {
            # EOF before framing satisfied — could be HTTP/1.0 close-
            # delimited OR a broken connection. Caller decides.
            store8(buf + have, 0);
            return have;
        }
        have = have + n;
        store8(buf + have, 0);

        if (headers_end < 0) {
            headers_end = _sandhi_resp_headers_end(buf, have);
            if (headers_end >= 0) {
                body_start = headers_end + 4;
                if (load8(buf + headers_end) == 10) { body_start = headers_end + 2; }
                if (body_start > have) { body_start = have; }
                # Parse headers to figure out framing.
                var sline_end = _sandhi_resp_eol(buf, 0, headers_end);
                var hstart = sline_end;
                if (hstart < headers_end && load8(buf + hstart) == 13) { hstart = hstart + 1; }
                if (hstart < headers_end && load8(buf + hstart) == 10) { hstart = hstart + 1; }
                var hblock_len = headers_end - hstart;
                if (hblock_len < 0) { hblock_len = 0; }
                var headers = sandhi_headers_parse(buf + hstart, hblock_len);
                if (_sandhi_resp_is_chunked(headers) == 1) {
                    is_chunked = 1;
                } else {
                    var clv = sandhi_headers_get(headers, "Content-Length");
                    if (clv != 0) {
                        content_length = _sandhi_resp_parse_clen(clv);
                    }
                }
                # Detect server-sent Connection: close.
                var conn_hdr = sandhi_headers_get(headers, "Connection");
                if (conn_hdr != 0) {
                    var i = 0;
                    var matches = 1;
                    while (i < 5 && matches == 1) {
                        var ch = load8(conn_hdr + i);
                        # case-insensitive compare to "close"
                        if (ch >= 65 && ch <= 90) { ch = ch + 32; }
                        var want = load8("close" + i);
                        if (ch != want) { matches = 0; }
                        i = i + 1;
                    }
                    if (matches == 1) { must_close = 1; }
                }
                scratch_done = 1;
            }
        }

        if (scratch_done == 1) {
            if (is_chunked == 1) {
                var done = _sandhi_pool_chunked_complete(buf, body_start, have);
                if (done == 0 - 1) { return 0 - 1; }
                if (done == 1) { going = 0; }
            } elif (content_length >= 0) {
                if (have - body_start >= content_length) { going = 0; }
            } else {
                # No framing declared — HTTP/1.0 close-delimited. Read
                # until EOF (handled by the n==0 branch above).
                must_close = 1;
            }
        }
    }
    if (must_close == 1) { return 0 - 2; }
    return have;
}

# --- json.cyr ---

# sandhi/rpc/json — minimal nested JSON build + extract for RPC use.
#
# Stdlib `lib/json.cyr` is flat-only and always quotes values, which
# doesn't fit real WebDriver / MCP / Appium wire formats (nested
# objects, numeric fields, booleans). This module adds just what
# sandhi::rpc needs — builder with typed values + nested-object
# support, plus a dotted-path extractor for pulling fields out of
# responses.
#
# Deliberately small. Not a full JSON library; consumers that need
# full parsing are still free to use stdlib json.cyr or their own
# layer. Fold-into-stdlib wants the sandhi public surface tight.

# ================================================================
# Builder
# ================================================================
#
# Usage:
#   var o = sandhi_json_obj_new();
#   sandhi_json_add_string(o, "browserName", "firefox");
#   sandhi_json_add_int(o, "w3c", 1);
#   var nested = sandhi_json_obj_new();
#   sandhi_json_add_string(nested, "platform", "linux");
#   sandhi_json_add_object(o, "capabilities", nested);
#   var wire = sandhi_json_build(o);  # cstr

# Entry is {key_cstr, value_cstr, kind} — 24 bytes.
# kind: 0=string (quote+escape), 1=raw (already JSON — ints, objects, booleans, null).
enum SandhiJsonKind {
    SANDHI_JSON_STRING = 0;
    SANDHI_JSON_RAW    = 1;
}

fn _sandhi_json_entry_new_a(a, key, value, kind): i64 {
    var e = alloc_via(a, 24);
    if (e == 0) { return 0; }
    store64(e, key);
    store64(e + 8, value);
    store64(e + 16, kind);
    return e;
}

fn _sandhi_json_entry_new(key, value, kind): i64 {
    return _sandhi_json_entry_new_a(default_alloc(), key, value, kind);
}

# Build a fresh empty object backed by `a`. Returns 0 on OOM.
fn sandhi_json_obj_new_a(a): i64 {
    return vec_new_a(a);
}

fn sandhi_json_obj_new(): i64 {
    return sandhi_json_obj_new_a(default_alloc());
}

# Copy a cstr into a fresh alloc owned by `a`. Returns 0 on null
# input or OOM.
fn _sandhi_json_dup_a(a, s): i64 {
    if (s == 0) { return 0; }
    var n = strlen(s);
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, s, n);
    store8(out + n, 0);
    return out;
}

fn _sandhi_json_dup(s): i64 {
    return _sandhi_json_dup_a(default_alloc(), s);
}

# Append a string field to `o`, allocating the dup'd key + value into `a`.
fn sandhi_json_add_string_a(a, o, key, value): i64 {
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    _sandhi_json_dup_a(a, value),
    SANDHI_JSON_STRING));
    return 0;
}

fn sandhi_json_add_string(o, key, value): i64 {
    return sandhi_json_add_string_a(default_alloc(), o, key, value);
}

fn sandhi_json_add_int_a(a, o, key, value): i64 {
    var tmp[24];
    var n = fmt_int_buf(value, &tmp);
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, &tmp, n);
    store8(out + n, 0);
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    out,
    SANDHI_JSON_RAW));
    return 0;
}

fn sandhi_json_add_int(o, key, value): i64 {
    return sandhi_json_add_int_a(default_alloc(), o, key, value);
}

fn sandhi_json_add_bool_a(a, o, key, value): i64 {
    var raw = "false";
    if (value == 1) { raw = "true"; }
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    _sandhi_json_dup_a(a, raw),
    SANDHI_JSON_RAW));
    return 0;
}

fn sandhi_json_add_bool(o, key, value): i64 {
    return sandhi_json_add_bool_a(default_alloc(), o, key, value);
}

fn sandhi_json_add_null_a(a, o, key): i64 {
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    _sandhi_json_dup_a(a, "null"),
    SANDHI_JSON_RAW));
    return 0;
}

fn sandhi_json_add_null(o, key): i64 {
    return sandhi_json_add_null_a(default_alloc(), o, key);
}

# Embed a child object as a nested value, allocating into `a`. The
# child is serialized into `a` here — caller's handle on the child
# stays valid for the lifetime of `a`.
fn sandhi_json_add_object_a(a, o, key, child): i64 {
    var rendered = sandhi_json_build_a(a, child);
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    rendered,
    SANDHI_JSON_RAW));
    return 0;
}

fn sandhi_json_add_object(o, key, child): i64 {
    return sandhi_json_add_object_a(default_alloc(), o, key, child);
}

# Embed a pre-built raw JSON fragment, dup'd into `a`.
fn sandhi_json_add_raw_a(a, o, key, raw_cstr): i64 {
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    _sandhi_json_dup_a(a, raw_cstr),
    SANDHI_JSON_RAW));
    return 0;
}

fn sandhi_json_add_raw(o, key, raw_cstr): i64 {
    return sandhi_json_add_raw_a(default_alloc(), o, key, raw_cstr);
}

# Escape a string for JSON, allocating the result into `a`. The
# str_builder scratch still flows through the global bump (str_builder
# lacks `_a` variants in the pinned stdlib); only the final cstr lands
# in `a`. Returns 0 on OOM.
fn sandhi_json_escape_a(a, s): i64 {
    if (s == 0) {
        var nul = alloc_via(a, 5);
        if (nul == 0) { return 0; }
        memcpy(nul, "\"\"", 2);
        store8(nul + 2, 0);
        return nul;
    }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "\"");
    var i = 0;
    while (load8(s + i) != 0) {
        var c = load8(s + i);
        if (c == 34) { str_builder_add_cstr(sb, "\\\""); }
        elif (c == 92) { str_builder_add_cstr(sb, "\\\\"); }
        elif (c == 8)  { str_builder_add_cstr(sb, "\\b"); }
        elif (c == 9)  { str_builder_add_cstr(sb, "\\t"); }
        elif (c == 10) { str_builder_add_cstr(sb, "\\n"); }
        elif (c == 12) { str_builder_add_cstr(sb, "\\f"); }
        elif (c == 13) { str_builder_add_cstr(sb, "\\r"); }
        elif (c < 32) {
            # Generic \u00XX escape for other control bytes (RFC 8259).
            str_builder_add_cstr(sb, "\\u00");
            var hi = (c >> 4) & 0xF;
            var lo = c & 0xF;
            var h1 = 48 + hi;
            if (hi >= 10) { h1 = 87 + hi; }
            var h2 = 48 + lo;
            if (lo >= 10) { h2 = 87 + lo; }
            str_builder_add_byte(sb, h1);
            str_builder_add_byte(sb, h2);
        }
        else { str_builder_add_byte(sb, c); }
        i = i + 1;
    }
    str_builder_add_cstr(sb, "\"");
    return str_data(str_builder_build(sb));
}

fn sandhi_json_escape(s): i64 {
    return sandhi_json_escape_a(default_alloc(), s);
}

# Render the object as a cstr allocated from `a`. Per-entry escape
# scratch also flows through `a`; the str_builder used for assembly
# remains on the global bump (see comment on sandhi_json_escape_a).
fn sandhi_json_build_a(a, o): i64 {
    if (o == 0) { return _sandhi_json_dup_a(a, "{}"); }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{");
    var n = vec_len(o);
    var i = 0;
    while (i < n) {
        if (i > 0) { str_builder_add_cstr(sb, ","); }
        var e = vec_get(o, i);
        var ekey = load64(e);
        var eval = load64(e + 8);
        var ekind = load64(e + 16);
        var escaped_key = sandhi_json_escape_a(a, ekey);
        str_builder_add_cstr(sb, escaped_key);
        str_builder_add_cstr(sb, ":");
        if (ekind == SANDHI_JSON_STRING) {
            var escaped_val = sandhi_json_escape_a(a, eval);
            str_builder_add_cstr(sb, escaped_val);
        } else {
            str_builder_add_cstr(sb, eval);
        }
        i = i + 1;
    }
    str_builder_add_cstr(sb, "}");
    var built = str_data(str_builder_build(sb));
    # str_builder_build's output lives on the global bump; dup into
    # `a` so the returned cstr matches the caller's lifetime contract
    # (arena reset must reclaim it). Cheap — JSON bodies are small.
    return _sandhi_json_dup_a(a, built);
}

fn sandhi_json_build(o): i64 {
    return sandhi_json_build_a(default_alloc(), o);
}

# ================================================================
# Extract — dotted-path navigation.
# ================================================================
#
# Usage: sandhi_json_get_string(body, "value.sessionId") → cstr or 0.
#
# Supports nested object paths only — arrays and escape-sequences in
# values are handled by the caller if needed. Good enough for the
# WebDriver / MCP response shapes we actually see.

# Internal: find the next "key":"... after `start` and return offset
# of the value's opening quote or opening brace. Matches key as
# substring, relies on proper JSON lack-of-colons-in-keys. `key_len`
# is strlen(key).
fn _sandhi_json_find_key(body, blen, start, key, key_len): i64 {
    var i = start;
    while (i + key_len + 3 < blen) {
        if (load8(body + i) == 34) {
            # At a quote — check if it starts the target key.
            if (memeq(body + i + 1, key, key_len) == 1
            && load8(body + i + 1 + key_len) == 34) {
                # Skip "key"
                var p = i + 2 + key_len;
                # Skip whitespace + colon.
                while (p < blen && load8(body + p) == 32) { p = p + 1; }
                if (p < blen && load8(body + p) == 58) {
                    p = p + 1;
                    while (p < blen && load8(body + p) == 32) { p = p + 1; }
                    return p;
                }
            }
        }
        i = i + 1;
    }
    return 0 - 1;
}

# Skip past balanced braces starting at `start` (buf[start] == '{').
# Returns the offset just past the matching '}'.
fn _sandhi_json_skip_object(body, blen, start): i64 {
    if (start >= blen || load8(body + start) != 123) { return 0 - 1; }
    var depth = 1;
    var p = start + 1;
    var in_string = 0;
    var prev_backslash = 0;
    while (p < blen && depth > 0) {
        var c = load8(body + p);
        if (in_string == 1) {
            if (c == 92 && prev_backslash == 0) { prev_backslash = 1; }
            else {
                if (c == 34 && prev_backslash == 0) { in_string = 0; }
                prev_backslash = 0;
            }
        } else {
            if (c == 34) { in_string = 1; }
            elif (c == 123) { depth = depth + 1; }
            elif (c == 125) { depth = depth - 1; }
        }
        p = p + 1;
    }
    return p;
}

# Walk a dotted path, allocating per-segment scratch in `a`. The
# segments are transient — arena reset after this returns reclaims
# them. Returns (off << 32) | len encoding a value range, or 0 - 1.
fn _sandhi_json_path_range_a(a, body, blen, path): i64 {
    var scope_start = 0;
    var scope_end = blen;
    var pi = 0;
    var plen = strlen(path);
    while (pi < plen) {
        var seg_end = pi;
        while (seg_end < plen && load8(path + seg_end) != 46) { seg_end = seg_end + 1; }
        var seg_len = seg_end - pi;
        if (seg_len == 0) { return 0 - 1; }
        var seg = alloc_via(a, seg_len + 1);
        if (seg == 0) { return 0 - 1; }
        memcpy(seg, path + pi, seg_len);
        store8(seg + seg_len, 0);

        var vpos = _sandhi_json_find_key(body, scope_end, scope_start, seg, seg_len);
        if (vpos < 0) { return 0 - 1; }

        if (seg_end >= plen) {
            return _sandhi_json_value_range(body, blen, vpos);
        }
        if (load8(body + vpos) != 123) { return 0 - 1; }
        scope_start = vpos + 1;
        scope_end = _sandhi_json_skip_object(body, blen, vpos);
        if (scope_end < 0) { return 0 - 1; }
        pi = seg_end + 1;
    }
    return 0 - 1;
}

fn _sandhi_json_path_range(body, blen, path): i64 {
    return _sandhi_json_path_range_a(default_alloc(), body, blen, path);
}

# Given an offset at the start of a JSON value (quote, brace, digit,
# or literal), return (off << 32) | len covering the value bytes.
# For strings the range excludes the surrounding quotes.
fn _sandhi_json_value_range(body, blen, start): i64 {
    if (start >= blen) { return 0 - 1; }
    var c = load8(body + start);
    if (c == 34) {
        # String — scan until unescaped closing quote.
        var p = start + 1;
        var prev = 0;
        while (p < blen) {
            var cc = load8(body + p);
            if (cc == 34 && prev != 92) {
                var off = start + 1;
                var len = p - off;
                return (off << 32) | len;
            }
            if (cc == 92 && prev == 92) { prev = 0; }
            else { prev = cc; }
            p = p + 1;
        }
        return 0 - 1;
    }
    if (c == 123) {
        # Object — include the braces.
        var endp = _sandhi_json_skip_object(body, blen, start);
        if (endp < 0) { return 0 - 1; }
        var lenO = endp - start;
        return (start << 32) | lenO;
    }
    # Numeric / true / false / null — until ',' '}' ']' or whitespace.
    var ps = start;
    var pe = start;
    while (pe < blen) {
        var ce = load8(body + pe);
        if (ce == 44 || ce == 125 || ce == 93 || ce == 32 || ce == 10 || ce == 13 || ce == 9) {
            var lenN = pe - ps;
            return (ps << 32) | lenN;
        }
        pe = pe + 1;
    }
    var lenT = pe - ps;
    return (ps << 32) | lenT;
}

# Extract a string at the dotted path, allocating the returned cstr
# from `a`. Returns 0 if not found or on OOM.
fn sandhi_json_get_string_a(a, body, path): i64 {
    if (body == 0 || path == 0) { return 0; }
    var blen = strlen(body);
    var r = _sandhi_json_path_range_a(a, body, blen, path);
    if (r == 0 - 1) { return 0; }
    var off = r >> 32;
    var len = r & 0xFFFFFFFF;
    var out = alloc_via(a, len + 1);
    if (out == 0) { return 0; }
    memcpy(out, body + off, len);
    store8(out + len, 0);
    return out;
}

fn sandhi_json_get_string(body, path): i64 {
    return sandhi_json_get_string_a(default_alloc(), body, path);
}

# Extract an integer at the dotted path. Returns 0 if absent or
# non-numeric; caller should pre-check with sandhi_json_has_path
# if zero vs absent needs to be distinguished. The transient string
# the int is parsed from lives in `a`.
fn sandhi_json_get_int_a(a, body, path): i64 {
    var v = sandhi_json_get_string_a(a, body, path);
    if (v == 0) { return 0; }
    return atoi(v);
}

fn sandhi_json_get_int(body, path): i64 {
    return sandhi_json_get_int_a(default_alloc(), body, path);
}

# 1 if the path exists, 0 otherwise. Path scratch lives in `a`.
# Local len var is `body_len` rather than `blen` (which is what the
# sibling `sandhi_json_get_string_a` uses) to dodge the cyrius 5.8.36
# linter's "global var init refs N declared at line M" false-positive
# triggered when two functions in the same file have a same-named
# local `var blen = strlen(body)` at the head.
fn sandhi_json_has_path_a(a, body, path): i64 {
    if (body == 0 || path == 0) { return 0; }
    var body_len = strlen(body);
    if (_sandhi_json_path_range_a(a, body, body_len, path) == 0 - 1) { return 0; }
    return 1;
}

fn sandhi_json_has_path(body, path): i64 {
    return sandhi_json_has_path_a(default_alloc(), body, path);
}

# --- service.cyr ---

# sandhi/discovery/service — types shared across resolvers.
#
# A `service` names an endpoint inside an AGNOS deployment. Any
# resolver that claims to resolve returns one of these (or 0 on miss).
#
# Struct layout (32 bytes):
#   +0   name  (cstr — logical service name, may be 0 for unnamed)
#   +8   host  (cstr — hostname OR dotted-quad IP; non-0)
#   +16  port  (int — 1..65535)
#   +24  ipv4  (int — pre-resolved address in sock_connect format, or 0
#               if the caller should resolve the host themselves)

enum SandhiServiceOff {
    SANDHI_SERVICE_OFF_NAME = 0;
    SANDHI_SERVICE_OFF_HOST = 8;
    SANDHI_SERVICE_OFF_PORT = 16;
    SANDHI_SERVICE_OFF_IPV4 = 24;
}

var SANDHI_SERVICE_STRUCT_SIZE = 32;

# Allocate a service struct from `a`. Returns 0 on OOM.
fn sandhi_service_new_a(a, name, host, port, ipv4): i64 {
    var s = alloc_via(a, SANDHI_SERVICE_STRUCT_SIZE);
    if (s == 0) { return 0; }
    store64(s + SANDHI_SERVICE_OFF_NAME, name);
    store64(s + SANDHI_SERVICE_OFF_HOST, host);
    store64(s + SANDHI_SERVICE_OFF_PORT, port);
    store64(s + SANDHI_SERVICE_OFF_IPV4, ipv4);
    return s;
}

fn sandhi_service_new(name, host, port, ipv4): i64 {
    return sandhi_service_new_a(default_alloc(), name, host, port, ipv4);
}

fn sandhi_service_name(s): i64 { return load64(s + SANDHI_SERVICE_OFF_NAME); }
fn sandhi_service_host(s): i64 { return load64(s + SANDHI_SERVICE_OFF_HOST); }
fn sandhi_service_port(s): i64 { return load64(s + SANDHI_SERVICE_OFF_PORT); }
fn sandhi_service_ipv4(s): i64 { return load64(s + SANDHI_SERVICE_OFF_IPV4); }

# ================================================================
# Resolver — a function pointer + opaque context.
# ================================================================
#
# Contract: `lookup_fn(ctx, name)` returns an alloc'd sandhi_service or 0 on miss.
# Resolvers MUST NOT abort on network failure — return 0 so the chain
# can try the next backend.
#
# Struct layout (16 bytes):
#   +0   lookup_fn  (fn pointer, matches fncall2 signature: (ctx, name))
#   +8   ctx        (ptr, resolver-specific)

enum SandhiResolverOff {
    SANDHI_RESOLVER_OFF_FN  = 0;
    SANDHI_RESOLVER_OFF_CTX = 8;
}

var SANDHI_RESOLVER_STRUCT_SIZE = 16;

# Allocate a resolver wrapper from `a`. Returns 0 on OOM.
fn sandhi_resolver_new_a(a, lookup_fn, ctx): i64 {
    var r = alloc_via(a, SANDHI_RESOLVER_STRUCT_SIZE);
    if (r == 0) { return 0; }
    store64(r + SANDHI_RESOLVER_OFF_FN, lookup_fn);
    store64(r + SANDHI_RESOLVER_OFF_CTX, ctx);
    return r;
}

fn sandhi_resolver_new(lookup_fn, ctx): i64 {
    return sandhi_resolver_new_a(default_alloc(), lookup_fn, ctx);
}

fn sandhi_resolver_fn(r): i64 { return load64(r + SANDHI_RESOLVER_OFF_FN); }
fn sandhi_resolver_ctx(r): i64 { return load64(r + SANDHI_RESOLVER_OFF_CTX); }

# Invoke a resolver directly. Chain + consumers use this shape.
fn sandhi_resolver_lookup(r, name): i64 {
    if (r == 0) { return 0; }
    var fp = sandhi_resolver_fn(r);
    if (fp == 0) { return 0; }
    return fncall2(fp, sandhi_resolver_ctx(r), name);
}

# --- chain.cyr ---

# sandhi/discovery/chain — fallback sequence of resolvers.
#
# A chain holds an ordered list of resolvers. On resolve, it asks
# each in turn and returns the first non-null service. No resolver
# is load-bearing — if daimon is down, the chain falls through to
# the next backend (mDNS, static config, …) without the caller
# having to notice.
#
# Usage:
#   var c = sandhi_discovery_chain_new();
#   sandhi_discovery_chain_add(c, sandhi_discovery_daimon_resolver("http://127.0.0.1:9000"));
#   sandhi_discovery_chain_add(c, sandhi_discovery_local_resolver());
#   var svc = sandhi_discovery_chain_resolve(c, "yantra-worker");

# Chain is just a vec of resolver pointers. Kept as a typed alias so
# the API documents intent rather than leaking "vec".
fn sandhi_discovery_chain_new(): i64 {
    return vec_new();
}

# Append a resolver. Resolvers run in insertion order on lookup.
fn sandhi_discovery_chain_add(chain, resolver): i64 {
    if (chain == 0 || resolver == 0) { return 0; }
    vec_push(chain, resolver);
    return 0;
}

# Count of resolvers in the chain. Handy for diagnostics.
fn sandhi_discovery_chain_count(chain): i64 {
    if (chain == 0) { return 0; }
    return vec_len(chain);
}

# Resolve `name` by trying each resolver. Returns the first non-null
# service, or 0 if every resolver misses.
fn sandhi_discovery_chain_resolve(chain, name): i64 {
    if (chain == 0 || name == 0) { return 0; }
    var n = vec_len(chain);
    var i = 0;
    while (i < n) {
        var r = vec_get(chain, i);
        var svc = sandhi_resolver_lookup(r, name);
        if (svc != 0) { return svc; }
        i = i + 1;
    }
    return 0;
}

# Wrap a chain as a resolver itself, so one chain can nest another.
# The caller passes the chain as ctx; the adapter calls chain_resolve.
fn _sandhi_discovery_chain_adapter(ctx, name): i64 {
    return sandhi_discovery_chain_resolve(ctx, name);
}

# Adapt a discovery chain into a `sandhi_resolver` handle (fn-ptr +
# context), so a chain can be passed wherever a single resolver is
# expected. Resolving through the handle runs the chain's fallback order.
fn sandhi_discovery_chain_as_resolver(chain): i64 {
    return sandhi_resolver_new(&_sandhi_discovery_chain_adapter, chain);
}

# --- daimon.cyr ---

# sandhi/discovery/daimon — resolver backed by the daimon service registry.
#
# Daimon is AGNOS's local agent orchestrator; when a sandhi consumer
# runs alongside daimon, daimon knows which services are alive and
# where they live. This resolver speaks a minimal HTTP contract
# against daimon's registry endpoint; daimon implements it.
#
# Contract (this file is the reference):
#
#   GET  {base}/services/{name}
#       200 → {"host":"...","port":N}  (service found)
#       404 → miss
#       any other response → miss (safe fail-open so chain falls through)
#
#   POST {base}/services/{name}  body: {"host":"...","port":N}
#       2xx → registered
#       non-2xx → caller should surface as SANDHI_ERR_DISCOVERY
#
#   DELETE {base}/services/{name}
#       2xx → deregistered
#       non-2xx → see above
#
# Base URL is whatever daimon is listening on — typically
# "http://127.0.0.1:9000" for a local daimon. Chain-resolver users
# can make daimon one backend among many; daimon outages fall through.

# Context struct (24 bytes):
#   +0   base_url  (cstr)
#   +8   reserved  (held 0 — future: auth token, timeouts; roadmap
#                   wait-for-consumer-ask "Daimon resolver context:
#                   auth token + timeouts")
#   +16  alloc     (Allocator handed to the resolver-fn-pointer
#                   callback; the (ctx, name) shape can't take an
#                   extra arg, so the allocator rides on the ctx)
enum SandhiDaimonCtxOff {
    SANDHI_DAIMON_CTX_OFF_BASE  = 0;
    SANDHI_DAIMON_CTX_OFF_RES   = 8;
    SANDHI_DAIMON_CTX_OFF_ALLOC = 16;
}

var SANDHI_DAIMON_CTX_SIZE = 24;

# Build a daimon resolver context backed by `a`. Returns 0 on OOM.
fn _sandhi_discovery_daimon_ctx_new_a(a, base_url): i64 {
    var c = alloc_via(a, SANDHI_DAIMON_CTX_SIZE);
    if (c == 0) { return 0; }
    store64(c + SANDHI_DAIMON_CTX_OFF_BASE, base_url);
    store64(c + SANDHI_DAIMON_CTX_OFF_RES, 0);
    store64(c + SANDHI_DAIMON_CTX_OFF_ALLOC, a);
    return c;
}

fn _sandhi_discovery_daimon_ctx_new(base_url): i64 {
    return _sandhi_discovery_daimon_ctx_new_a(default_alloc(), base_url);
}

# Build "{base}/services/{name}" with trailing-slash normalization,
# allocating the trimmed copy from `a`. The str_builder used to
# concatenate the final URL still goes through the global bump
# (str_builder lacks `_a` variants in the pinned stdlib); only the
# trim-copy and the final cstr land in `a`.
fn _sandhi_daimon_url_a(a, base, name): i64 {
    var sb = str_builder_new();
    var blen = strlen(base);
    if (blen > 0 && load8(base + blen - 1) == 47) {
        # Trim trailing slash.
        var trimmed = alloc_via(a, blen);
        if (trimmed == 0) { return 0; }
        memcpy(trimmed, base, blen - 1);
        store8(trimmed + blen - 1, 0);
        str_builder_add_cstr(sb, trimmed);
    } else {
        str_builder_add_cstr(sb, base);
    }
    str_builder_add_cstr(sb, "/services/");
    str_builder_add_cstr(sb, name);
    return str_data(str_builder_build(sb));
}

fn _sandhi_daimon_url(base, name): i64 {
    return _sandhi_daimon_url_a(default_alloc(), base, name);
}

# The resolver callback. Matches fn(ctx, name) → *service. The
# allocator stored on ctx (slot +16, 0 = process default) drives
# every alloc on the resolved-service path.
fn _sandhi_daimon_lookup(ctx, name): i64 {
    if (ctx == 0 || name == 0) { return 0; }
    var base = load64(ctx + SANDHI_DAIMON_CTX_OFF_BASE);
    if (base == 0) { return 0; }
    var a = load64(ctx + SANDHI_DAIMON_CTX_OFF_ALLOC);
    if (a == 0) { a = default_alloc(); }
    var url = _sandhi_daimon_url_a(a, base, name);
    if (url == 0) { return 0; }
    var resp = sandhi_http_get(url, 0);
    # Any non-2xx or transport error → miss (fall-through for chain).
    if (sandhi_http_err_kind(resp) != SANDHI_OK) { return 0; }
    var status = sandhi_http_status(resp);
    if (status < 200 || status >= 300) { return 0; }
    var body = sandhi_http_body(resp);
    if (body == 0) { return 0; }
    return _sandhi_daimon_parse_service_a(a, body, name);
}

# Parse daimon's {"host":"...","port":N} response into a service
# allocated from `a`. Returns 0 on missing fields, malformed input,
# or OOM.
fn _sandhi_daimon_parse_service_a(a, body, name): i64 {
    var host = sandhi_json_get_string(body, "host");
    if (host == 0) { return 0; }
    var port = sandhi_json_get_int(body, "port");
    if (port <= 0) { return 0; }
    if (port > 65535) { return 0; }
    # Daimon might also include a pre-resolved "address" field.
    var ipv4 = 0;
    var addr_str = sandhi_json_get_string(body, "address");
    if (addr_str != 0) {
        var av4 = sandhi_net_parse_ipv4(addr_str);
        if (av4 != 0 - 1) { ipv4 = av4; }
    }
    # Dup the caller-passed name so the service is self-contained.
    var name_copy = 0;
    if (name != 0) {
        var nlen = strlen(name);
        name_copy = alloc_via(a, nlen + 1);
        if (name_copy == 0) { return 0; }
        memcpy(name_copy, name, nlen);
        store8(name_copy + nlen, 0);
    }
    return sandhi_service_new_a(a, name_copy, host, port, ipv4);
}

fn _sandhi_daimon_parse_service(body, name): i64 {
    return _sandhi_daimon_parse_service_a(default_alloc(), body, name);
}

# Build a resolver for the given daimon base URL, owned by `a`.
# Returns 0 on OOM.
fn sandhi_discovery_daimon_resolver_a(a, base_url): i64 {
    if (base_url == 0) { return 0; }
    var ctx = _sandhi_discovery_daimon_ctx_new_a(a, base_url);
    if (ctx == 0) { return 0; }
    return sandhi_resolver_new_a(a, &_sandhi_daimon_lookup, ctx);
}

fn sandhi_discovery_daimon_resolver(base_url): i64 {
    return sandhi_discovery_daimon_resolver_a(default_alloc(), base_url);
}

# --- local.cyr ---

# sandhi/discovery/local — mDNS / link-local resolver (RFC 6762).
#
# Resolves `<name>.local` over IPv4 mDNS (224.0.0.251:5353). Both resolver
# flavours use the TWO-SOCKET receive split (1.5.5 for the opt-in QM, 1.6.12 for
# the default QU): an UNCONNECTED, group-joined RX socket sees the answer from
# ANY source, dodging the Linux connect()-source-filter that makes a single
# connect()ed socket drop every reply (the answer arrives from the responder's
# own unicast IP, not the group — the 1.5.4 bug).
#
#   - Default (QU — `sandhi_discovery_local_resolver`): sets the QU bit (RFC 6762
#     §5.4 — request a unicast answer to our source port) and binds the TX to
#     5353, so the unicast reply lands on the RX's port (the connect()-filter on
#     the TX rejects it — source != group — so it falls to the unconnected RX);
#     the group-join means it ALSO catches a multicast answer.
#   - Opt-in (QM — `sandhi_discovery_local_mc_resolver`, 1.5.5): plain-IN query;
#     the responder multicasts its answer to the group, caught on the RX.
#
# Both bounded by SO_RCVTIMEO (500 ms) so a missing responder doesn't hang the
# chain. Query ID = 0 (RFC 6762 §18.1 — responses carry ID 0; match by name).
# QTYPE = A. IP_MULTICAST_TTL for the outgoing query is 255 (RFC 6762 §11;
# link-scope is enforced by the group address, not the TTL).
#
# Reference: RFC 6762 (Multicast DNS). RFC 6763 (DNS-SD service-by-type
# browsing) is a distinct feature class; this is a `<name>.local` name resolver
# only, not a service-by-type resolver.

# 224.0.0.251 packed as a network-byte-order uint32 in little-endian-host repr
# (bytes 224, 0, 0, 251 across the int).
var _SANDHI_MDNS_GROUP = 0;
var _SANDHI_MDNS_PORT  = 5353;
var _SANDHI_MDNS_TIMEOUT_MS = 500;
# MC_TTL: IP multicast hop limit for the outgoing query — RFC 6762 §11 sets 255
# (link-scope is enforced by the group address, not the TTL). MC_MAX_RECV: hard
# cap on the recv-loop, since a group-joined socket sees all group traffic and the
# loop filters by name; the total-time bound is the SO_RCVTIMEO deadline.
var _SANDHI_MDNS_MC_TTL = 255;
var _SANDHI_MDNS_MC_MAX_RECV = 8;

# Build a `<name>.local` cstr in `a`. If `name` already ends in
# `.local` (case-insensitive), the input is dup'd into `a`; otherwise
# the suffix is appended. Returns 0 on OOM.
fn _sandhi_local_qname_a(a, name): i64 {
    var nlen = strlen(name);
    var has_suffix = 0;
    if (nlen >= 6) {
        var s = name + nlen - 6;
        var c0 = load8(s + 0);
        var c1 = load8(s + 1);
        var c2 = load8(s + 2);
        var c3 = load8(s + 3);
        var c4 = load8(s + 4);
        var c5 = load8(s + 5);
        if (c0 == 46) {  # '.'
            if ((c1 == 108 || c1 == 76) && (c2 == 111 || c2 == 79)
            && (c3 == 99 || c3 == 67) && (c4 == 97 || c4 == 65)
            && (c5 == 108 || c5 == 76)) {
                has_suffix = 1;
            }
        }
    }
    if (has_suffix == 1) {
        var dup = alloc_via(a, nlen + 1);
        if (dup == 0) { return 0; }
        memcpy(dup, name, nlen);
        store8(dup + nlen, 0);
        return dup;
    }
    var out = alloc_via(a, nlen + 7);
    if (out == 0) { return 0; }
    memcpy(out, name, nlen);
    store8(out + nlen + 0, 46);   # '.'
    store8(out + nlen + 1, 108);  # 'l'
    store8(out + nlen + 2, 111);  # 'o'
    store8(out + nlen + 3, 99);   # 'c'
    store8(out + nlen + 4, 97);   # 'a'
    store8(out + nlen + 5, 108);  # 'l'
    store8(out + nlen + 6, 0);
    return out;
}

fn _sandhi_local_qname(name): i64 {
    return _sandhi_local_qname_a(default_alloc(), name);
}

# Build the mDNS query packet. Same wire format as the unicast DNS
# resolver in net/resolve.cyr. `qclass_hi` is the QCLASS high byte:
# 0x80 = IN | QU-bit (RFC 6762 §5.4 — request a unicast response; the
# default fast path) or 0x00 = plain IN (QM — the responder multicasts
# its answer; used by the 1.5.5 multicast-listen resolver).
fn _sandhi_local_build_query_cls(id, qname, out, qclass_hi): i64 {
    store8(out + 0, (id >> 8) & 0xFF);
    store8(out + 1, id & 0xFF);
    store8(out + 2, 0x00);  # mDNS queries: QR=0, Opcode=0, AA=0, TC=0, RD=0
    store8(out + 3, 0x00);
    store8(out + 4, 0x00); store8(out + 5, 0x01);  # QDCOUNT = 1
    store8(out + 6, 0x00); store8(out + 7, 0x00);  # ANCOUNT
    store8(out + 8, 0x00); store8(out + 9, 0x00);  # NSCOUNT
    store8(out + 10, 0x00); store8(out + 11, 0x00); # ARCOUNT

    var qname_len = _sandhi_resolve_encode_labels(qname, out + 12);
    if (qname_len < 0) { return 0 - 1; }
    var qi = 12 + qname_len;
    store8(out + qi + 0, 0x00); store8(out + qi + 1, 0x01);  # QTYPE = A
    store8(out + qi + 2, qclass_hi); store8(out + qi + 3, 0x01);  # QCLASS = IN (| QU if hi=0x80)
    return qi + 4;
}

# Back-compat / default: QU-bit query (0x8001).
fn _sandhi_local_build_query(id, qname, out): i64 {
    return _sandhi_local_build_query_cls(id, qname, out, 0x80);
}

# Local resolver context (8 bytes):
#   +0  alloc  (Allocator handle the lookup callback uses; 0 → default)
# Carried so the resolver-fn-pointer `(ctx, name)` shape can pull an
# Allocator without growing the callback signature — same approach as
# daimon's ctx struct.
var _SANDHI_LOCAL_CTX_SIZE = 8;

fn _sandhi_discovery_local_ctx_new_a(a): i64 {
    var c = alloc_via(a, _SANDHI_LOCAL_CTX_SIZE);
    if (c == 0) { return 0; }
    store64(c, a);
    return c;
}

# ================================================================
# Two-socket mDNS receive (the 1.5.4 bug fix) — shared by QU + QM
# ================================================================
# CRITICAL DESIGN NOTE (the 1.5.4 bug, fixed here): you CANNOT use one
# `connect()`ed UDP socket for both send and receive. On Linux, connect()
# installs a source-address filter, so a socket connected to the group
# drops every answer (responders send from their own unicast IP, not the
# group). The fix is a TWO-SOCKET split:
#   - RX socket: UNCONNECTED, bound to 5353 + SO_REUSEPORT + group-joined.
#     `sock_recv` (sys_read) on an unconnected bound socket delivers the
#     next datagram from ANY source — so it sees the answer.
#   - TX socket: connected to the group, used only to send the query
#     (sys_write needs a connected socket).
# 1.6.12 extends this to the default QU resolver: for a QU query the answer
# is UNICAST to the query's source port, so the TX is bound to 5353 (the RX
# port, via SO_REUSEPORT) — the reply lands on 5353 where the unconnected RX
# listens; the connected TX's source-filter rejects it (source != group), so
# it falls to RX. Loopback live tests (tests/sandhi.tcyr discovery/local/mc_qm
# + qu_unicast) exercise both RX paths end-to-end so this can't silently
# regress again.

# Open the RX (receive) socket: unconnected, SO_REUSEPORT, bound to `port`,
# joined to `group` on interface `iface` (0 = INADDR_ANY = default iface).
# Parametrized so the loopback live test can drive the exact same code on an
# isolated group/port over the loopback interface. Returns the fd, or -1 on
# any failure (incl. AGNOS, where the net multicast helpers return -1).
fn _sandhi_local_mc_rx_open(group, port, iface): i64 {
    var fd_r = udp_socket();
    if (is_err_result(fd_r) == 1) { return 0 - 1; }
    var fd = payload(fd_r);
    if (sock_reuseport(fd) < 0) { sock_close(fd); return 0 - 1; }
    if (is_err_result(sock_bind(fd, 0, port)) == 1) { sock_close(fd); return 0 - 1; }
    if (net_join_multicast(fd, group, iface) < 0) { sock_close(fd); return 0 - 1; }
    _sandhi_conn_set_timeout_ms(fd, _SANDHI_MDNS_TIMEOUT_MS, _SANDHI_SO_RCVTIMEO);
    return fd;
}

# Recv-loop on an already-open RX socket: read datagrams (unconnected → from
# any source), parse each with `expected_id`, return the first A record whose
# answer-name matches the question (the parser enforces both). Bounded by the
# SO_RCVTIMEO deadline + a hard attempt cap (a group-joined socket can see
# unrelated group traffic). Returns the IPv4 address or 0 on miss/OOM.
fn _sandhi_local_mc_recv_match(a, fd, expected_id): i64 {
    var rbuf = alloc_via(a, _SANDHI_RESOLVE_BUF_SIZE);
    if (rbuf == 0) { return 0; }
    var deadline = clock_now_ns() + _SANDHI_MDNS_TIMEOUT_MS * 1000000;
    var ip = 0;
    var done = 0;
    var attempts = 0;
    while ((done == 0) && (attempts < _SANDHI_MDNS_MC_MAX_RECV)) {
        attempts = attempts + 1;
        if (clock_now_ns() >= deadline) {
            done = 1;
        } else {
            var rr = sock_recv(fd, rbuf, _SANDHI_RESOLVE_BUF_SIZE);
            if (is_err_result(rr) == 1) {
                done = 1;
            } else {
                var rlen = payload(rr);
                if (rlen > 0) {
                    var got = _sandhi_resolve_parse_response(rbuf, rlen, expected_id);
                    if (got != (0 - 1)) { ip = got; done = 1; }
                }
            }
        }
    }
    return ip;
}

# 1.6.12 — shared two-socket mDNS query. RX is UNCONNECTED (bound 5353 +
# SO_REUSEPORT + group-joined) so it sees the answer from ANY source; TX is
# connected to the group, send-only (sock_send/sys_write needs a connected
# socket). `qclass_hi` picks QU (0x80 — request a unicast answer) or QM (0x00 —
# responder multicasts). `tx_port` binds the TX source port: 5353 (REUSEPORT,
# alongside RX) for QU so the unicast reply lands on RX's port; 0 = ephemeral for
# QM (whose reply is multicast to the group regardless). id=0 per RFC 6762 §18.1.
# Returns the IPv4 address, or 0 on miss / OOM / unsupported (AGNOS → rx_open -1).
fn _sandhi_local_query_2sock_a(a, name, qclass_hi, tx_port): i64 {
    if (name == 0) { return 0; }
    if (_SANDHI_MDNS_GROUP == 0) {
        _SANDHI_MDNS_GROUP = 224 | (0 << 8) | (0 << 16) | (251 << 24);
    }
    var qname = _sandhi_local_qname_a(a, name);
    if (qname == 0) { return 0; }
    var qbuf = alloc_via(a, _SANDHI_RESOLVE_BUF_SIZE);
    if (qbuf == 0) { return 0; }
    var qlen = _sandhi_local_build_query_cls(0, qname, qbuf, qclass_hi);
    if (qlen < 0) { return 0; }

    var rx = _sandhi_local_mc_rx_open(_SANDHI_MDNS_GROUP, _SANDHI_MDNS_PORT, 0);
    if (rx < 0) { return 0; }

    var tx_r = udp_socket();
    if (is_err_result(tx_r) == 1) {
        net_drop_multicast(rx, _SANDHI_MDNS_GROUP, 0); sock_close(rx); return 0;
    }
    var tx = payload(tx_r);
    # QU binds TX to 5353 (REUSEPORT, alongside RX) so the responder's unicast
    # reply lands on port 5353 where the unconnected RX listens. QM (tx_port=0)
    # leaves TX ephemeral — its reply is multicast to the group → RX sees it anyway.
    if (tx_port != 0) {
        if (sock_reuseport(tx) < 0) {
            sock_close(tx); net_drop_multicast(rx, _SANDHI_MDNS_GROUP, 0); sock_close(rx); return 0;
        }
        if (is_err_result(sock_bind(tx, 0, tx_port)) == 1) {
            sock_close(tx); net_drop_multicast(rx, _SANDHI_MDNS_GROUP, 0); sock_close(rx); return 0;
        }
    }
    net_set_multicast_ttl(tx, _SANDHI_MDNS_MC_TTL);
    var cr = sock_connect(tx, _SANDHI_MDNS_GROUP, _SANDHI_MDNS_PORT);
    if (is_err_result(cr) == 1) {
        sock_close(tx); net_drop_multicast(rx, _SANDHI_MDNS_GROUP, 0); sock_close(rx); return 0;
    }
    var sr = sock_send(tx, qbuf, qlen);
    sock_close(tx);
    if (is_err_result(sr) == 1) {
        net_drop_multicast(rx, _SANDHI_MDNS_GROUP, 0); sock_close(rx); return 0;
    }

    var ip = _sandhi_local_mc_recv_match(a, rx, 0);
    net_drop_multicast(rx, _SANDHI_MDNS_GROUP, 0);
    sock_close(rx);
    return ip;
}

# ================================================================
# Default (QU) resolver
# ================================================================

# Issue a QU mDNS query (request a unicast answer), allocating scratch into `a`.
# 1.6.12: was a single connect()ed socket that source-filtered out the
# responder's unicast reply (the 1.5.4 bug) AND used a random TXID that mDNS
# responses (ID=0) never matched. Now routes through the two-socket helper with
# the QU bit + TX bound to 5353, so the unicast reply lands on the unconnected
# RX; the group-join also catches a multicast answer. Returns the IPv4 address
# or 0 on any failure / OOM.
fn _sandhi_local_query_a(a, name): i64 {
    return _sandhi_local_query_2sock_a(a, name, 0x80, _SANDHI_MDNS_PORT);
}

fn _sandhi_local_query(name): i64 {
    return _sandhi_local_query_a(default_alloc(), name);
}

# Resolver callback. Reads the Allocator from ctx (0 → default) and
# threads it through the query + service-build path.
fn _sandhi_local_lookup(ctx, name): i64 {
    if (name == 0) { return 0; }
    var a = default_alloc();
    if (ctx != 0) {
        var stored = load64(ctx);
        if (stored != 0) { a = stored; }
    }
    var ip = _sandhi_local_query_a(a, name);
    if (ip == 0) { return 0; }
    var qname = _sandhi_local_qname_a(a, name);
    if (qname == 0) { return 0; }
    return sandhi_service_new_a(a, name, qname, 0, ip);
}

# Build the mDNS resolver backed by `a`. Both the resolver wrapper and
# its ctx are allocated from `a`; the lookup callback also routes its
# transient + service-struct allocations through `a`. Returns 0 on OOM.
fn sandhi_discovery_local_resolver_a(a): i64 {
    var ctx = _sandhi_discovery_local_ctx_new_a(a);
    if (ctx == 0) { return 0; }
    return sandhi_resolver_new_a(a, &_sandhi_local_lookup, ctx);
}

fn sandhi_discovery_local_resolver(): i64 {
    return sandhi_discovery_local_resolver_a(default_alloc());
}

# 1 where IPv4 multicast setsockopt is available (Linux/macOS), 0 on AGNOS.
# 1.6.12: the default resolver now joins the multicast group (two-socket
# receive — the 1.5.4 connect()-filter fix), so it shares the QM resolver's
# AGNOS limitation; report unavailable there (it would always miss). Linux/macOS
# unchanged (1, wired since 0.9.3).
fn sandhi_discovery_local_available(): i64 {
    #ifdef CYRIUS_TARGET_AGNOS
    return 0;
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    return 1;
    #endif
}

# ================================================================
# Opt-in multicast (QM) resolver (1.5.5) — for responders that ignore the QU
# bit and multicast their answer to 224.0.0.251:5353.
# ================================================================

# Multicast (QM) query: plain-IN ID=0 query (responder multicasts), TX ephemeral.
# Byte-identical to the 1.5.5 implementation — now shares the two-socket helper
# with the default QU path. Returns the IPv4 address or 0 on miss / OOM /
# unsupported (AGNOS → rx_open -1).
fn _sandhi_local_query_mc_a(a, name): i64 {
    return _sandhi_local_query_2sock_a(a, name, 0x00, 0);
}

fn _sandhi_local_query_mc(name): i64 {
    return _sandhi_local_query_mc_a(default_alloc(), name);
}

# Multicast (QM) resolver callback — mirrors `_sandhi_local_lookup` but uses
# the join-and-listen query path.
fn _sandhi_local_lookup_mc(ctx, name): i64 {
    if (name == 0) { return 0; }
    var a = default_alloc();
    if (ctx != 0) {
        var stored = load64(ctx);
        if (stored != 0) { a = stored; }
    }
    var ip = _sandhi_local_query_mc_a(a, name);
    if (ip == 0) { return 0; }
    var qname = _sandhi_local_qname_a(a, name);
    if (qname == 0) { return 0; }
    return sandhi_service_new_a(a, name, qname, 0, ip);
}

# Opt-in multicast (QM) mDNS resolver (1.5.5). Same resolver/ctx shape as
# `sandhi_discovery_local_resolver_a`, but the lookup sends a plain-IN query and
# relies on the responder multicasting its answer. Use this — or chain it after
# the default QU resolver — for responders that only multicast. Returns 0 on OOM.
fn sandhi_discovery_local_mc_resolver_a(a): i64 {
    var ctx = _sandhi_discovery_local_ctx_new_a(a);
    if (ctx == 0) { return 0; }
    return sandhi_resolver_new_a(a, &_sandhi_local_lookup_mc, ctx);
}

fn sandhi_discovery_local_mc_resolver(): i64 {
    return sandhi_discovery_local_mc_resolver_a(default_alloc());
}

# 1 where IPv4 multicast setsockopt is available (Linux/macOS), 0 on AGNOS
# (the net multicast helpers return -1; the QM resolver degrades to a clean
# miss).
fn sandhi_discovery_local_mc_available(): i64 {
    #ifdef CYRIUS_TARGET_AGNOS
    return 0;
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    return 1;
    #endif
}

# --- register.cyr ---

# sandhi/discovery/register — publish / withdraw services via daimon.
#
# Pairs with discovery/daimon.cyr. Uses the same REST contract:
#   POST   {base}/services/{name}   body: {"host":"...","port":N}
#   DELETE {base}/services/{name}
#
# mDNS publishing (a continuous-responder loop) is not in M4 scope —
# see discovery/local.cyr for the rationale. Register/deregister
# against daimon is the primary path for AGNOS services.

# Register a service with the daimon registry. `base_url` is daimon's
# listening endpoint (e.g. "http://127.0.0.1:9000"). `host` + `port`
# are the published location of the service being registered.
#
# Returns SANDHI_OK on success, or one of:
#   SANDHI_ERR_CONNECT    — daimon unreachable
#   SANDHI_ERR_REMOTE     — daimon answered but refused (non-2xx)
#   SANDHI_ERR_INTERNAL   — malformed input
fn sandhi_discovery_register(base_url, name, host, port): i64 {
    if (base_url == 0 || name == 0 || host == 0) { return SANDHI_ERR_INTERNAL; }
    if (port <= 0 || port > 65535) { return SANDHI_ERR_INTERNAL; }

    var url = _sandhi_daimon_url(base_url, name);
    var body_obj = sandhi_json_obj_new();
    sandhi_json_add_string(body_obj, "host", host);
    sandhi_json_add_int(body_obj, "port", port);
    var body = sandhi_json_build(body_obj);
    var body_len = strlen(body);

    var headers = sandhi_headers_new();
    sandhi_headers_set(headers, "Content-Type", "application/json");

    var resp = sandhi_http_post(url, headers, body, body_len);
    var ek = sandhi_http_err_kind(resp);
    if (ek != SANDHI_OK) { return ek; }
    var status = sandhi_http_status(resp);
    if (status < 200 || status >= 300) { return SANDHI_ERR_REMOTE; }
    return SANDHI_OK;
}

# Withdraw a previously-registered service.
fn sandhi_discovery_deregister(base_url, name): i64 {
    if (base_url == 0 || name == 0) { return SANDHI_ERR_INTERNAL; }
    var url = _sandhi_daimon_url(base_url, name);
    var resp = sandhi_http_delete(url, 0);
    var ek = sandhi_http_err_kind(resp);
    if (ek != SANDHI_OK) { return ek; }
    var status = sandhi_http_status(resp);
    if (status < 200 || status >= 300) { return SANDHI_ERR_REMOTE; }
    return SANDHI_OK;
}

# --- mod.cyr ---

# sandhi/discovery — service discovery index.
#
# Composes:
#   discovery/service   — service struct + resolver (fn-ptr + ctx) shape
#   discovery/chain     — fallback sequence of resolvers
#   discovery/daimon    — HTTP-backed resolver against daimon's registry
#   discovery/local     — mDNS resolver (RFC 6762 link-local query against 224.0.0.251:5353)
#   discovery/register  — publish/withdraw against daimon
#
# Typical consumer shape:
#   var c = sandhi_discovery_chain_new();
#   sandhi_discovery_chain_add(c, sandhi_discovery_daimon_resolver("http://127.0.0.1:9000"));
#   sandhi_discovery_chain_add(c, sandhi_discovery_local_resolver());
#   var svc = sandhi_discovery_chain_resolve(c, "yantra-worker");
#   if (svc != 0) {
#       # svc_host(svc) / svc_port(svc) / svc_ipv4(svc)
#   }
#
# No resolver in the chain is load-bearing — a missing daimon falls
# through to the next backend silently.

# --- main.cyr ---

# sandhi — public API / library root.
#
# This file declares the top-level surface that consumers include
# via `lib/sandhi.cyr` (once folded into Cyrius stdlib) or
# `dist/sandhi.cyr` (the distributed bundle pre-fold).
#
# No top-level `main()` / `syscall(60)` — sandhi is a LIBRARY.
# `programs/smoke.cyr` is the compile-link proof target.
#
# Per ADR 0001: sandhi composes stdlib primitives (http.cyr, ws.cyr,
# tls.cyr, json.cyr, net.cyr) into full-featured client patterns +
# service discovery. It does NOT reimplement the primitives.
# Scaffolded 2026-04-24.

# --- Public surface ---------------------------------------------------------
# Each sub-module exposes a small, documented verb set:
#   sandhi::http            — HTTP/1.1 + HTTP/2 client. Full method
#                             surface (GET/POST/PUT/DELETE/PATCH/HEAD),
#                             custom headers, HTTPS via tls, opt-in
#                             bounded redirect following, full timeout
#                             matrix (connect/read/write/total),
#                             retry-with-backoff for idempotent
#                             methods. Auto-selection between h2 and
#                             1.1 via `sandhi_http_request_auto`.
#   sandhi::http::pool      — per-route connection pool. Backs
#                             HTTP/1.1 keep-alive + HTTP/2 stream
#                             multiplex from the same struct (ADR
#                             0003). Opt-in via `sandhi_http_options_pool`.
#   sandhi::http::h2        — full HTTP/2 protocol stack: frames
#                             (RFC 7540 §6), HPACK header compression
#                             with Huffman decode (RFC 7541), per-call
#                             reentrant connection lifecycle.
#                             `sandhi_h2_request` is the manual entry
#                             point; auto-selection wires it through
#                             the pool.
#   sandhi::http::stream    — streaming HTTP + WHATWG SSE parser +
#                             incremental chunked decode + callback-per-
#                             event dispatch.
#   sandhi::http::download  — binary streaming download to an fd or
#                             byte-sink (`sandhi_http_download` /
#                             `_download_sink`). Reuses the redirect-
#                             follow + chunked/close decode of the
#                             buffered path but never buffers the whole
#                             body — resident memory is bounded
#                             regardless of artifact size. The non-SSE
#                             counterpart to stream (carries binary
#                             blobs the SSE path can't).
#   sandhi::rpc             — JSON-RPC dialects (W3C WebDriver wire,
#                             Appium extensions, MCP-over-HTTP + SSE).
#                             Transport only per ADR 0001 — protocol
#                             semantics live in bote / t-ron.
#   sandhi::discovery       — service discovery: daimon-registered
#                             lookup, chain-fallback composition,
#                             mDNS resolver (RFC 6762 link-local A
#                             query against 224.0.0.251:5353).
#   sandhi::tls_policy      — cert pinning (SPKI, constant-time
#                             compare), mTLS, custom trust store,
#                             policy composition, ALPN advertise list.
#                             Runtime enforcement wired since 0.9.3
#                             (libssl/libcrypto symbols resolved via
#                             stdlib `tls_dlsym`); fail-closed when a
#                             policy demands enforcement that isn't
#                             wired.
#   sandhi::server          — HTTP/1.1 server. Canonical names are
#                             `sandhi_server_*` (post-0.9.2 rename);
#                             `http_*` aliases retained as transitional
#                             wrappers, retire at the v5.7.0 fold.
#                             Built-in 400-on-smuggling guards (CL+TE,
#                             dup Host/CL/TE).

# `SANDHI_VERSION` is declared in `src/version_str.cyr`, which is
# auto-generated from the top-level `VERSION` file via
# `scripts/version-bump.sh` (mirrors the cyrius pattern in
# `cyrius/src/version_str.cyr`). VERSION is the only place a
# developer edits the version string; the bump script regenerates
# version_str.cyr in lockstep and CI fails the build if they drift.
fn sandhi_version(): i64 {
    return SANDHI_VERSION;
}
